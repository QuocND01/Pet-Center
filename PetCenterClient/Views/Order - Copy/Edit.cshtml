@model AddressCreateDTO

<div class="container mt-4">
    <h4>Chỉnh sửa địa chỉ</h4>
    <hr />
    <div class="row">
        <div class="col-md-6">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <input type="hidden" name="id" value="@ViewContext.RouteData.Values["id"]" />

                <div class="mb-3">
                    <label class="form-label">Địa chỉ chi tiết</label>
                    <input asp-for="AddressDetails" class="form-control" />
                    <span asp-validation-for="AddressDetails" class="text-danger"></span>
                </div>

                <div class="row mb-3">
                    <div class="col">
                        <label class="form-label">Tỉnh/Thành</label>
                        <input asp-for="Province" class="form-control" />
                    </div>
                    <div class="col">
                        <label class="form-label">Quận/Huyện</label>
                        <input asp-for="District" class="form-control" />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Phường/Xã</label>
                    <input asp-for="Ward" class="form-control" />
                </div>

                <div class="form-check mb-3">
                    <input asp-for="IsDefault" class="form-check-input" type="checkbox" />
                    <label class="form-check-label" asp-for="IsDefault">Đặt làm mặc định</label>
                    <span asp-validation-for="IsDefault" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary">Cập nhật</button>
                <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
            </form>
        </div>
    </div>
</div>