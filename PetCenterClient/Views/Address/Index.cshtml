@model IEnumerable<AddressResponseDTO>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Quản lý Địa chỉ</h2>
        <a asp-action="Create" class="btn btn-success">➕ Thêm mới</a>
    </div>

    <table class="table table-hover border">
        <thead class="table-dark">
            <tr>
                <th>Chi tiết</th>
                <th>Tỉnh/Thành</th>
                <th>Mặc định</th>
                <th class="text-center">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.AddressDetails</td>
                    <td>@item.Province</td>
                    <td>@(item.IsDefault == true ? "✅" : "❌")</td>
                    <td class="text-center">
                        <a asp-action="Edit" asp-route-id="@item.AddressId" class="btn btn-sm btn-warning">Sửa</a>
                        <a asp-action="Delete" asp-route-id="@item.AddressId" class="btn btn-sm btn-danger">Xóa</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>