@model PetCenterClient.DTOs.ReadCategoryDTOs

<style>
    .logo-preview {
        width: 140px;
        height: 140px;
        object-fit: cover;
        border-radius: 8px;
        border: 1px solid #ddd;
        cursor: pointer;
    }

    .logo-wrapper {
        position: relative;
        display: inline-block;
    }

    .remove-btn {
        position: absolute;
        top: -6px;
        right: -6px;
        border-radius: 50%;
        width: 22px;
        height: 22px;
        padding: 0;
        font-size: 12px;
    }
</style>

<form asp-action="Edit"
      asp-controller="Category"
      method="post"
      enctype="multipart/form-data">

    <input type="hidden" asp-for="CategoryId" />

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="row">

        <!-- CATEGORY NAME -->
        <div class="col-md-12 mb-3">
            <label asp-for="CategoryName"></label>
            <input asp-for="CategoryName" class="form-control" />
            <span asp-validation-for="CategoryName" class="text-danger"></span>
        </div>


        <!-- DESCRIPTION -->
        <div class="col-md-12 mb-3">
            <label asp-for="CategoryDescription"></label>

            <textarea asp-for="CategoryDescription"
                      class="form-control"
                      rows="3"
                      placeholder="Enter category description"></textarea>

            <span asp-validation-for="CategoryDescription"
                  class="text-danger"></span>
        </div>

    </div>

    <!-- CURRENT LOGO -->
    <div class="mt-3">

        <h6>Current Logo</h6>

        <div class="logo-wrapper">

            <img id="logoPreview"
                 src="@(string.IsNullOrEmpty(Model.CategoryLogo) ? "https://via.placeholder.com/140" : Model.CategoryLogo)"
                 class="logo-preview"
                 onclick="document.getElementById('logoInput').click()" />

            <button type="button"
                    class="btn btn-danger btn-sm remove-btn"
                    onclick="removeLogo()">
                ✖
            </button>

        </div>

    </div>

    <!-- NEW LOGO -->
    <div class="mt-3">

        <label>Change Logo</label>

        <input type="file"
               id="logoInput"
               name="CategoryLogo"
               accept="image/*"
               hidden
               onchange="previewLogo(this)" />

    </div>

    <!-- ATTRIBUTES -->
    <div class="mt-4">

        <label class="fw-bold">Attributes</label>

        <div id="attributeContainer">

            @if (Model.Attributes != null && Model.Attributes.Any())
            {
                var index = 0;

                foreach (var attr in Model.Attributes)
                {
                    <div class="input-group mb-2 attribute-item">

                        <input type="hidden"
                               name="Attributes[@index].CategoryAttributeId"
                               value="@attr.CategoryAttributeId" />

                        <input name="Attributes[@index].AttributeName"
                               value="@attr.AttributeName"
                               class="form-control"
                               data-val="true"
                               data-val-required="Attribute name is required" />

                        <span class="text-danger field-validation-valid"
                              data-valmsg-for="Attributes[@index].AttributeName"
                              data-valmsg-replace="true"></span>

                        <button type="button"
                                class="btn btn-danger removeAttr">
                            X
                        </button>

                    </div>

                    index++;
                }
            }

        </div>

        <button type="button"
                class="btn btn-sm btn-secondary mt-2"
                id="addAttributeBtn">
            Add Attribute
        </button>

    </div>

    <!-- BUTTON -->
    <div class="d-flex justify-content-end gap-2 mt-4">

        <button type="button"
                class="btn btn-secondary"
                data-bs-dismiss="modal">
            Cancel
        </button>

        <button type="submit"
                class="btn btn-warning">
            <i class="bi bi-pencil-square"></i>
            Update
        </button>

    </div>

</form>

<script>

    // preview file
    function previewLogo(input) {
        const file = input.files[0]
        if (!file) return

        const reader = new FileReader()
        reader.onload = function (e) {
            $("#logoPreview").attr("src", e.target.result)
        }
        reader.readAsDataURL(file)
    }

    function removeLogo() {
        $("#logoPreview").attr("src", "https://via.placeholder.com/140")
        $("#logoInput").val("")
    }

    // ===== ATTRIBUTES (giữ nguyên logic bạn, chỉ clean lại chút) =====

    let attrIndex = @((Model.Attributes?.Count ?? 0))

         $(document).off("click", "#addAttributeBtn")
               .on("click", "#addAttributeBtn", function () {

        const html = `
        <div class="input-group mb-2 attribute-item">

            <input name="Attributes[${attrIndex}].AttributeName"
                   class="form-control"
                   data-val="true"
                   data-val-required="Attribute name is required"/>

            <span class="text-danger field-validation-valid"
                  data-valmsg-for="Attributes[${attrIndex}].AttributeName"></span>

            <button type="button"
                    class="btn btn-danger removeAttr">X</button>

        </div>
        `

        const $html = $(html)

        $("#attributeContainer").append($html)
        $.validator.unobtrusive.parse($html)

        attrIndex++
    })

    $(document).on("click", ".removeAttr", function () {
        $(this).closest(".attribute-item").remove()
        reIndexAttributes()
        checkDuplicate()
    })

           $(document).off("submit", "form")
           .on("submit", "form", function (e) {

        reIndexAttributes()

        const isDuplicate = checkDuplicate()

        if (isDuplicate) {
            e.preventDefault()
            $(".is-invalid").first().focus()
        }
    })

       function reIndexAttributes() {

        $("#attributeContainer .attribute-item").each(function (index) {

            $(this).find("input[name$='.AttributeName']")
                   .attr("name", `Attributes[${index}].AttributeName`)

            $(this).find("input[name$='.CategoryAttributeId']")
                   .attr("name", `Attributes[${index}].CategoryAttributeId`)

            $(this).find("span[data-valmsg-for]")
                   .attr("data-valmsg-for", `Attributes[${index}].AttributeName`)
        })

        attrIndex = $("#attributeContainer .attribute-item").length

        checkDuplicate() // ✔ giữ lại
    }

               function checkDuplicate() {

        let map = {}
        let isDuplicate = false

        $(".duplicate-error").remove()

        $("input[name*='AttributeName']").each(function () {

            const val = $(this).val().trim().toLowerCase()

            $(this).removeClass("is-invalid")

            if (!val) return

            if (map[val]) {

                isDuplicate = true

                $(this).addClass("is-invalid")
                map[val].addClass("is-invalid")

            } else {
                map[val] = $(this)
            }
        })

        if (isDuplicate) {
            $("#attributeContainer").prepend(`
                <div class="text-danger duplicate-error mb-2">
                    Attributes must be unique
                </div>
            `)
        }

        $("button[type='submit']").prop("disabled", isDuplicate)

        return isDuplicate
    }

        $(document).on("input", "input[name*='AttributeName']", function () {
        checkDuplicate()
    })

        $(document).ready(function () {
        checkDuplicate()
    })
</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}