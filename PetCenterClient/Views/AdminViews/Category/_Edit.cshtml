@model PetCenterClient.ViewModels.Category.UpdateCategoryViewModel

<style>

    .page-card {
        background: #fff;
        border-radius: 18px;
        padding: 30px;
    }

    .section-card {
        background: #f8f9fa;
        border-radius: 16px;
        padding: 20px;
        margin-bottom: 20px;
        border: 1px solid #e9ecef;
    }

    .section-title {
        font-size: 17px;
        font-weight: 700;
        margin-bottom: 15px;
    }

    .form-control {
        border-radius: 12px;
        min-height: 46px;
    }

    .logo-preview {
        width: 140px;
        height: 140px;
        object-fit: cover;
        border-radius: 14px;
        border: 2px solid #eee;
        cursor: pointer;
    }

    .attribute-item {
        display: flex;
        gap: 10px;
        margin-bottom: 10px;
        width: 100%;
    }

        .attribute-item.is-dup input {
            border-color: #dc3545 !important;
            background: #fff5f5;
        }

    #attributeError {
        font-size: 13px;
    }

</style>

<div class="page-card">

    <form asp-action="Edit"
          asp-controller="Category"
          method="post"
          enctype="multipart/form-data">

        <input type="hidden" asp-for="CategoryId" />

        <!-- CATEGORY INFO -->
        <div class="section-card">
            <div class="section-title">Category Information</div>

            <div class="row">

                <div class="col-md-12 mb-3">
                    <label asp-for="CategoryName"></label>
                    <input asp-for="CategoryName" class="form-control" />
                </div>

                <div class="col-md-12 mb-3">
                    <label asp-for="CategoryDescription"></label>
                    <textarea asp-for="CategoryDescription"
                              class="form-control"
                              rows="3"></textarea>
                </div>

            </div>
        </div>

        <!-- LOGO -->
        <div class="section-card">
            <div class="section-title">Category Logo</div>

            <img id="logoPreview"
                 src="@(string.IsNullOrEmpty(Model.ExistingCategoryLogo)
                                         ? "https://via.placeholder.com/140"
                                         : Model.ExistingCategoryLogo)"
                 class="logo-preview"
                 onclick="document.getElementById('logoInput').click()" />

            <input type="file"
                   id="logoInput"
                   name="CategoryLogo"
                   hidden
                   accept="image/*"
                   onchange="previewLogo(this)" />
        </div>

        <!-- ATTRIBUTES -->
        <div class="section-card">
            <div class="section-title">Attributes</div>

            <div id="attributeContainer">

                @if (Model.Attributes != null)
                {
                    var index = 0;

                    foreach (var attr in Model.Attributes)
                    {
                        <div class="input-group attribute-item">

                            <input type="hidden"
                                   name="Attributes[@index].CategoryAttributeId"
                                   value="@attr.CategoryAttributeId" />

                            <input name="Attributes[@index].AttributeName"
                                   value="@attr.AttributeName"
                                   class="form-control attribute-input"
                                   autocomplete="off" />

                            <button type="button"
                                    class="btn btn-danger removeAttr">
                                X
                            </button>

                        </div>

                        index++;
                    }
                }

            </div>

            <button type="button"
                    class="btn btn-secondary btn-sm mt-2"
                    id="addAttributeBtn">
                + Add Attribute
            </button>

            <div id="attributeError" class="mt-2"></div>
        </div>

        <!-- BUTTON -->
        <div class="text-end">
            <button type="submit" class="btn btn-warning">
                Update
            </button>
        </div>

    </form>

</div>

<script>

    let attrIndex = @((Model.Attributes?.Count ?? 0));

    /* ================= LOGO ================= */

    function previewLogo(input) {
        const file = input.files[0];
        if (!file) return;

        const reader = new FileReader();
        reader.onload = e => {
            $("#logoPreview").attr("src", e.target.result);
        };
        reader.readAsDataURL(file);
    }

    /* ================= ADD ATTRIBUTE ================= */

    $(document).on("click", "#addAttributeBtn", function () {

        const html = `
        <div class="input-group attribute-item">

            <input name="Attributes[${attrIndex}].AttributeName"
                   class="form-control attribute-input"
                   autocomplete="off" />

            <button type="button"
                    class="btn btn-danger removeAttr">X</button>

        </div>`;

        $("#attributeContainer").append(html);

        attrIndex++;

        checkDuplicate();
    });

    /* ================= REMOVE ATTRIBUTE ================= */

    $(document).on("click", ".removeAttr", function () {

        $(this).closest(".attribute-item").remove();

        reindex();

        setTimeout(checkDuplicate, 0);
    });

    function reindex() {

        $("#attributeContainer .attribute-item").each(function (i) {

            $(this).find("input[name*='AttributeName']")
                   .attr("name", `Attributes[${i}].AttributeName`);

            $(this).find("input[name*='CategoryAttributeId']")
                   .attr("name", `Attributes[${i}].CategoryAttributeId`);
        });

        attrIndex = $(".attribute-item").length;
    }

    /* ================= DUPLICATE CHECK (FINAL FIX) ================= */

    let debounceTimer;

    function normalize(val) {
        return (val || "").trim().toLowerCase();
    }

    function checkDuplicate() {

        clearTimeout(debounceTimer);

        debounceTimer = setTimeout(() => {

            const map = new Map();
            let hasDup = false;

            $("#attributeError").empty();
            $(".attribute-item").removeClass("is-dup");

            $(".attribute-input").each(function () {

                const val = normalize($(this).val());

                if (!val) return;

                if (map.has(val)) {

                    hasDup = true;

                    $(this).closest(".attribute-item").addClass("is-dup");
                    map.get(val).closest(".attribute-item").addClass("is-dup");

                } else {
                    map.set(val, $(this));
                }
            });

            if (hasDup) {
                $("#attributeError").html(`
                    <div class="text-danger">
                        Attributes must be unique
                    </div>
                `);
            }

            $("button[type='submit']").prop("disabled", hasDup);

        }, 150);
    }

    /* ================= EVENTS ================= */

    $(document).on("input", ".attribute-input", checkDuplicate);

    $(document).ready(function () {
        checkDuplicate();
    });

</script>