@model PetCenterClient.DTOs.ReadCategoryViewModel

<style>

    .category-logo {
        width: 120px;
        height: 120px;
        object-fit: cover;
        border-radius: 8px;
        border: 1px solid #ddd;
    }

</style>

<form asp-action="ChangeStatusConfirmed"
      asp-controller="Category"
      method="post">

    <input type="hidden"
           name="id"
           value="@Model.CategoryId" />

    <input type="hidden"
           name="status"
           value="@ViewBag.Status" />

    <div class="text-center">

        <h5 class="text-danger mb-3">
            Are you sure you want to change this category status?
        </h5>

        <h4 class="fw-bold">
            @Model.CategoryName
        </h4>

    </div>

    <!-- Logo -->

    <div class="d-flex justify-content-center mt-3">

        @if (!string.IsNullOrEmpty(Model.CategoryLogo))
        {
            <img src="@Model.CategoryLogo"
                 class="category-logo" />
        }
        else
        {
            <img src="https://via.placeholder.com/120"
                 class="category-logo" />
        }

    </div>

    <!-- Attributes -->
    @if (Model.Attributes != null && Model.Attributes.Any())
    {
        <div class="mt-4">

            <label class="fw-bold">Attributes</label>

            <div class="mt-2">

                @foreach (var attr in Model.Attributes)
                {
                    <span class="badge bg-secondary me-1">
                        @attr.AttributeName
                    </span>
                }

            </div>

        </div>
    }

    <!-- Buttons -->

    <div class="d-flex justify-content-end gap-2 mt-3">

        <button type="button"
                class="btn btn-secondary"
                data-bs-dismiss="modal">
            Cancel
        </button>

        <button type="submit"
                class="btn btn-danger">

            <i class="bi bi-trash"></i>
            Confirm

        </button>

    </div>

</form>