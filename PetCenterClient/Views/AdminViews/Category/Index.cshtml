@using PetCenterClient.DTOs
@model OdataResponse<ReadCategoryDTOs>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Manage Categories";
}

<style>
    .pagination {
        margin-top: 20px;
        display: flex;
        gap: 6px;
    }

    .page-btn {
        padding: 6px 12px;
        background: #eee;
        border-radius: 6px;
        text-decoration: none;
    }

        .page-btn.active {
            background: #4f46e5;
            color: white;
        }

</style>

<link rel="stylesheet" href="~/css/AdminViews/BaseManageLayout.css" asp-append-version="true" />

<div class="page-wrapper">

    <!-- HEADER -->
    <div class="page-header">

        <div class="page-title-group">
            <h1>Category Management</h1>
            <p>Manage all categories in system</p>
        </div>

        <div class="header-stat">
            <span class="num">@Model?.Values?.Count()</span>
            <span class="label">Categories</span>
        </div>

    </div>


    <!-- TOOLBAR -->
    <form asp-action="Indexadmin" asp-controller="Category" method="get" class="toolbar">

        <div class="search-wrap">
            <i class="bi bi-search"></i>

            <input type="text"
                   name="search"
                   value="@Context.Request.Query["search"]"
                   class="search-input"
                   placeholder="Search category name..." />
        </div>

        <button type="submit" class="filter-btn active">
            Apply
        </button>

        <button type="button"
                class="filter-btn"
                data-bs-toggle="modal"
                data-bs-target="#categoryModal"
                data-url="@Url.Action("Create", "Category")">

            <i class="bi bi-plus"></i> Add
        </button>

    </form>


    <!-- TABLE -->
    <div class="table-card">

        <table class="data-table">

            <thead>
                <tr>
                    <th>#</th>
                    <th>Logo</th>
                    <th>Category Name</th>
                    <th>Attributes</th>
                    <th style="width:180px">Actions</th>
                </tr>
            </thead>

            <tbody>

                @if (Model?.Values != null && Model.Values.Any())
                {
                    int i = 1;

                    foreach (var c in Model.Values)
                    {
                        <tr>

                            <td class="row-num">@i</td>

                            <td>
                                <img src="@c.CategoryLogo"
                                     style="width:48px;height:48px;border-radius:8px;object-fit:cover" />
                            </td>

                            <td class="customer-name">
                                @c.CategoryName
                            </td>

                            <td>

                                @if (c.Attributes != null && c.Attributes.Any())
                                {
                                    foreach (var attr in c.Attributes)
                                    {
                                        <span class="badge bg-secondary me-1">
                                            @attr.AttributeName
                                        </span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">No attributes</span>
                                }

                            </td>

                            <td>

                                <!-- VIEW -->
                                <button class="btn-detail"
                                        data-bs-toggle="modal"
                                        data-bs-target="#categoryModal"
                                        data-url="@Url.Action("DetailsAsyncAdmin", "Category", new { id = c.CategoryId })">

                                    <i class="bi bi-eye"></i>
                                </button>

                                <!-- EDIT -->
                                <button class="btn-detail"
                                        data-bs-toggle="modal"
                                        data-bs-target="#categoryModal"
                                        data-url="@Url.Action("Edit", "Category", new { id = c.CategoryId })">

                                    <i class="bi bi-pencil"></i>
                                </button>

                                <!-- DELETE -->
                                <button class="btn-toggle-status active"
                                        data-bs-toggle="modal"
                                        data-bs-target="#categoryModal"
                                        data-url="@Url.Action("Delete", "Category", new { id = c.CategoryId })">

                                    <i class="bi bi-trash"></i>
                                </button>

                            </td>

                        </tr>

                        i++;
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5">

                            <div class="empty-state">

                                <div class="empty-icon">
                                    <i class="bi bi-grid"></i>
                                </div>

                                <h3>No categories found</h3>
                                <p>Try adding a new category</p>

                            </div>

                        </td>
                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>


<!-- CATEGORY MODAL -->

<div class="modal fade" id="categoryModal" tabindex="-1">

    <div class="modal-dialog modal-lg modal-dialog-centered">

        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Category</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body" id="categoryModalBody"></div>

        </div>

    </div>

</div>

@{
    int pageSize = 10;
    int totalItems = Model?.Count ?? 0;
    int totalPages = (int)Math.Ceiling((double)totalItems / pageSize);
    int currentPage = ViewBag.CurrentPage ?? 1;
}

@if (totalPages > 1)
{
    <div class="pagination">

        <!-- PREV -->
        @if (currentPage > 1)
        {
            <a class="page-btn"
               href="@Url.Action("Indexadmin", new { page = currentPage - 1, search = ViewBag.Search })">
                Prev
            </a>
        }

        <!-- NUMBERS -->
        @for (int i = 1; i <= totalPages; i++)
        {
            <a class="page-btn @(i == currentPage ? "active" : "")"
               href="@Url.Action("Indexadmin", new { page = i, search = ViewBag.Search })">
                @i
            </a>
        }

        <!-- NEXT -->
        @if (currentPage < totalPages)
        {
            <a class="page-btn"
               href="@Url.Action("Indexadmin", new { page = currentPage + 1, search = ViewBag.Search })">
                Next
            </a>
        }

    </div>
}


<!-- LOADING -->

<div id="pageLoadingOverlay"
     style="display:none;
            position:fixed;
            top:0;
            left:0;
            width:100%;
            height:100%;
            background: rgba(255,255,255,0.7);
            z-index:2000;
            justify-content:center;
            align-items:center;
            flex-direction:column;">

    <div class="spinner-border text-primary"
         style="width:3rem;height:3rem"></div>

    <p class="mt-2">Processing, Please wait...</p>

</div>


<!-- TOAST -->

<div class="position-fixed bottom-0 end-0 p-3" style="z-index:1100">

    <div id="liveToast"
         class="toast bg-success text-white">

        <div class="toast-body"></div>

    </div>

</div>


@section Scripts {

    <script>

        $('#categoryModal').on('show.bs.modal', function (e) {

            var button = $(e.relatedTarget);
            var url = button.data('url');

            var modalBody = $("#categoryModalBody");

            modalBody.html("Loading...");

             modalBody.load(url, function () {

            $.validator.unobtrusive.parse("#categoryModalBody");

        });

        });


        $('#categoryModal').on('submit','form',function(e){

            e.preventDefault();

            var form = $(this);

            var formData = new FormData(form[0]);

            $("#pageLoadingOverlay").css("display","flex");

            $.ajax({

                url: form.attr('action'),
                type: form.attr('method'),
                data: formData,
                contentType:false,
                processData:false,

                success:function(res){

                    $("#pageLoadingOverlay").hide();

                    if(res.success){

                        $('#categoryModal').modal('hide');

                        showToast("Success");

                        setTimeout(function(){

                            location.reload();

                        },800);
                    }
                },

                error:function(){

                    $("#pageLoadingOverlay").hide();
                    showToast("Error");

                }

            });

        });


        function showToast(message){

            $('#liveToast .toast-body').text(message);

            var toast = new bootstrap.Toast(document.getElementById('liveToast'));

            toast.show();

        }

    </script>

}