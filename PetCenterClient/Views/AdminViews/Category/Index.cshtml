@using PetCenterClient.Common
@using PetCenterClient.ViewModels.Category
@model IEnumerable<ReadCategoryViewModel>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Manage Categories";
        var role = Context.Session.GetString("Role");
    bool isAdmin = role == "Admin";
}

<style>
    .pagination {
        margin-top: 20px;
        display: flex;
        gap: 6px;
    }

    .page-btn {
        padding: 6px 12px;
        background: #eee;
        border-radius: 6px;
        text-decoration: none;
    }

        .page-btn.active {
            background: #4f46e5;
            color: white;
        }

        .btn-add-product {
    border: none;
    background: #16a34a;
    color: white;
    border-radius: 10px;
    padding: 11px 18px;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 8px;
    transition: .2s;
}

.btn-add-product:hover {
    background: #15803d;
}

.page-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.header-actions {
    display: flex;
    align-items: center;
    gap: 10px;
}
.action-grid {
    display: grid;
    grid-template-columns: repeat(2, 40px);
    gap: 8px;
    justify-content: center;
}

/* Chỉ áp dụng cho trang Category */

/* Category Name */
.data-table td .customer-name {
    display: inline-block;
    max-width: 180px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    vertical-align: middle;
}

/* Attribute badge nếu tên quá dài */
.data-table td .badge {
    max-width: 110px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    vertical-align: middle;
}

/* Cột Attributes không cho kéo giãn bảng */
.data-table td:nth-child(4) {
    max-width: 240px;
    white-space: nowrap;
    overflow: hidden;
}

.category-logo {
    width: 48px;
    height: 48px;
    border-radius: 8px;
    object-fit: contain;
    object-position: center;
    background: #fff;
}
/* Category Name */
.data-table th:nth-child(3),
.data-table td:nth-child(3) {
    width: 180px;      /* Có thể chỉnh 160px hoặc 200px tùy ý */
    max-width: 180px;
}

.data-table td:nth-child(3) {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}
</style>

<link rel="stylesheet" href="~/css/AdminViews/BaseManageLayout.css" asp-append-version="true" />

<div class="page-wrapper">

    <!-- HEADER -->
   <div class="page-header">

    <div class="page-title-group">
        <h1>Category Management</h1>
        <p>Manage all categories in system</p>
    </div>

    <div class="header-actions">

        <div class="header-stat">
            <span class="num">@ViewBag.TotalCategories</span>
            <span class="label">Categories</span>
        </div>

        @if (isAdmin)
        {
            <button type="button"
                    class="btn-add-product"
                    data-bs-toggle="modal"
                    data-bs-target="#categoryModal"
                    data-url="@Url.Action("Create", "Category")">

                <i class="bi bi-plus-lg"></i>
                Add Category
            </button>
        }

    </div>

</div>

    <!-- TOOLBAR -->
    <form asp-action="IndexAdmin" asp-controller="Category" method="get" class="toolbar">

        <div class="search-wrap">
            <i class="bi bi-search"></i>

            <input type="text"
                   name="search"
                   value="@Context.Request.Query["search"]"
                   class="search-input"
                   placeholder="Search category name..." />
        </div>

         <select name="status" class="filter-select">
        <option value="">All Status</option>

        <option value="1"
                selected="@(Context.Request.Query["status"] == "1")">
            Active
        </option>

        <option value="2"
                selected="@(Context.Request.Query["status"] == "2")">
            Inactive
        </option>
    </select>

        <button type="submit" class="filter-btn active">
            Apply
        </button>

       

    </form>


    <!-- TABLE -->
    <div class="table-card">

        <table class="data-table">

            <thead>
                <tr>
                    <th>#</th>
                    <th>Logo</th>
                    <th>Category Name</th>
                    <th>Attributes</th>
                    <th>Status</th>
                    <th style="width:180px">Actions</th>
                </tr>
            </thead>

            <tbody>

                @if (Model != null && Model.Any())
                {
                    int i = 1;

                    foreach (var c in Model)
                    {
                        <tr>

                            <td class="row-num">@i</td>

                            <td>
                               <img src="@c.CategoryLogo" class="category-logo" />
                            </td>

                            <td class="customer-name">
                                @c.CategoryName
                            </td>

                          <td>
                                    @if (c.Attributes != null && c.Attributes.Any())
                                    {
                                        @foreach (var attr in c.Attributes.Take(2))
                                        {
                                            <span class="badge bg-secondary me-1">
                                                @attr.AttributeName
                                            </span>
                                        }

                                        @if (c.Attributes.Count > 2)
                                        {
                                            <span class="badge bg-light text-dark">
                                                +@(c.Attributes.Count - 2)
                                            </span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted">No attributes</span>
                                    }
                                </td>

                            <td class="customer-name">
                                @c.Status
                            </td>

                            <td>
                                     <div class="action-grid">
                                <!-- VIEW -->
                                <button class="btn-detail"
                                        data-bs-toggle="modal"
                                        data-bs-target="#categoryModal"
                                        data-url="@Url.Action("DetailsAdmin", "Category", new { id = c.CategoryId })">

                                    <i class="bi bi-eye"></i>
                                </button>

                                <!-- EDIT -->
                                <button class="btn-detail"
                                        data-bs-toggle="modal"
                                        data-bs-target="#categoryModal"
                                        data-url="@Url.Action("Edit", "Category", new { id = c.CategoryId })">

                                    <i class="bi bi-pencil"></i>
                                </button>

                                <!-- DELETE -->
                              <!-- Active / Inactive -->
                                <button class="btn-detail @(c.Status == Status.Active ? "text-warning" : "text-success")"
                                        data-bs-toggle="modal"
                                        data-bs-target="#categoryModal"
                                        data-url="@Url.Action("ChangeStatus", "Category", new
                                        {
                                            id = c.CategoryId,
                                            status = c.Status == Status.Active ? Status.Inactive : Status.Active
                                        })">

                                    @if (c.Status == Status.Active)
                                    {
                                        <i class="bi bi-toggle-on text-success"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-toggle-off text-warning"></i>
                                    }

                                </button>

                              <!-- Delete -->
                                <button class="btn-detail text-danger"
                                        data-bs-toggle="modal"
                                        data-bs-target="#categoryModal"
                                        data-url="@Url.Action("ChangeStatus", "Category", new
                                        {
                                            id = c.CategoryId,
                                            status = Status.Deleted
                                        })">

                                    <i class="bi bi-trash"></i>
                                </button>
                                   </div>
                            </td>

                        </tr>

                        i++;
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5">

                            <div class="empty-state">

                                <div class="empty-icon">
                                    <i class="bi bi-grid"></i>
                                </div>

                                <h3>No categories found</h3>
                                <p>Try adjusting filters</p>

                            </div>

                        </td>
                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>


<!-- CATEGORY MODAL -->

<div class="modal fade" id="categoryModal" tabindex="-1">

    <div class="modal-dialog modal-lg modal-dialog-centered">

        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Category</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body" id="categoryModalBody"></div>

        </div>

    </div>

</div>

@{
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
}

@if (totalPages > 1)
{
    <div class="pagination">

        <!-- PREV -->
        @if (currentPage > 1)
        {
            <a class="page-btn"
               href="@Url.Action("IndexAdmin", new {  page = currentPage - 1,
            search = Context.Request.Query["search"],
            status = Context.Request.Query["status"] })">
                Prev
            </a>
        }

        <!-- NUMBERS -->
        @for (int i = 1; i <= totalPages; i++)
        {
            <a class="page-btn @(i == currentPage ? "active" : "")"
               href="@Url.Action("IndexAdmin", new { page = i,
            search = Context.Request.Query["search"],
            status = Context.Request.Query["status"]})">
                @i
            </a>
        }

        <!-- NEXT -->
        @if (currentPage < totalPages)
        {
            <a class="page-btn"
               href="@Url.Action("IndexAdmin", new {  page = currentPage + 1,
            search = Context.Request.Query["search"],
            status = Context.Request.Query["status"] })">
                Next
            </a>
        }

    </div>
}


<!-- LOADING -->

<div id="pageLoadingOverlay"
     style="display:none;
            position:fixed;
            top:0;
            left:0;
            width:100%;
            height:100%;
            background: rgba(255,255,255,0.7);
            z-index:2000;
            justify-content:center;
            align-items:center;
            flex-direction:column;">

    <div class="spinner-border text-primary"
         style="width:3rem;height:3rem"></div>

    <p class="mt-2">Processing, Please wait...</p>

</div>


<!-- TOAST -->

<div class="position-fixed bottom-0 end-0 p-3" style="z-index:1100">

    <div id="liveToast"
         class="toast bg-success text-white">

        <div class="toast-body"></div>

    </div>

</div>


@section Scripts {

    <script>

        $('#categoryModal').on('show.bs.modal', function (e) {

            var button = $(e.relatedTarget);
            var url = button.data('url');

            var modalBody = $("#categoryModalBody");

            modalBody.html("Loading...");

             modalBody.load(url, function () {

            $.validator.unobtrusive.parse("#categoryModalBody");

        });

        });


        $('#categoryModal').on('submit','form',function(e){

            e.preventDefault();

            var form = $(this);

            var formData = new FormData(form[0]);

            $("#pageLoadingOverlay").css("display","flex");

            $.ajax({

                url: form.attr('action'),
                type: form.attr('method'),
                data: formData,
                contentType:false,
                processData:false,

            success: function (res) {

    $("#pageLoadingOverlay").hide();

    // Thành công
    if (typeof res === "object" && res.success) {

        $('#categoryModal').modal('hide');

        showToast("Success");

        setTimeout(function () {
            location.reload();
        }, 800);

        return;
    }

    $("#categoryModalBody").html(res);

$.validator.unobtrusive.parse("#categoryModalBody");

let message = $("#categoryModalBody .text-danger:first").text().trim();

showToast(message || "Please check the form.");
},

error: function (xhr) {

    $("#pageLoadingOverlay").hide();

    let message = "An unexpected error occurred.";

    if (xhr.responseJSON?.message) {
        message = xhr.responseJSON.message;
    }

    showToast(message);
}

            });

        });


        function showToast(message){

            $('#liveToast .toast-body').text(message);

            var toast = new bootstrap.Toast(document.getElementById('liveToast'));

            toast.show();

        }

    </script>

}