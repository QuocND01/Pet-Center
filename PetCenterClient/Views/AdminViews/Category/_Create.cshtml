@model PetCenterClient.ViewModels.Category.CreateCategoryViewModel

<style>

    .page-card {
        background: #fff;
        border-radius: 18px;
        padding: 30px;
    }

    .section-card {
        background: #f8f9fa;
        border-radius: 16px;
        padding: 20px;
        margin-bottom: 25px;
        border: 1px solid #e9ecef;
    }

    .section-title {
        font-size: 18px;
        font-weight: 700;
        margin-bottom: 18px;
    }

    .form-control {
        border-radius: 12px;
        min-height: 46px;
    }

    .category-create-logo {
        width: 140px;
        height: 140px;
        object-fit: contain;
        object-position: center;
        background: #fff;
        border-radius: 14px;
        border: 2px dashed #ccc;
        cursor: pointer;
    }

    .attribute-item {
        width: 100%;
        display: flex;
        gap: 10px;
        margin-bottom: 10px;
    }

    .attribute-input {
        border-radius: 10px;
    }

    .is-invalid {
        border-color: #dc3545 !important;
    }

    #attributeContainer {
        display: flex;
        flex-direction: column;
    }

</style>

<div class="page-card">

    <form asp-action="Create"
          asp-controller="Category"
          method="post"
          enctype="multipart/form-data">

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <!-- BASIC INFO -->
        <div class="section-card">

            <div class="section-title">Category Information</div>

            <div class="row">

                <div class="col-md-12 mb-3">
                    <label class="form-label">Category Name</label>
                    <input asp-for="CategoryName" class="form-control" />
                    <span asp-validation-for="CategoryName"
                          class="text-danger"></span>
                </div>

                <div class="col-md-12 mb-3">
                    <label class="form-label">Description</label>
                    <textarea asp-for="CategoryDescription"
                              class="form-control"
                              rows="3"></textarea>
                    <span asp-validation-for="CategoryDescription"
                          class="text-danger"></span>
                </div>

            </div>
        </div>

        <!-- LOGO -->
        <div class="section-card">

            <div class="section-title">Category Logo</div>

            <input type="file"
                   id="logoInput"
                   name="CategoryLogo"
                   hidden
                   accept="image/*"
                   onchange="previewLogo(this)" />

            <img id="logoPreview"
                 src="https://via.placeholder.com/140"
                 class="category-create-logo"
                 onclick="document.getElementById('logoInput').click()" />
            <span asp-validation-for="CategoryLogo"
                  class="text-danger"></span>
        </div>

        <!-- ATTRIBUTES -->
        <div class="section-card">

            <div class="section-title">Attributes</div>

            <div id="attributeError"></div>

            <div id="attributeContainer">
                @if (Model.Attributes != null)
                {
                    for (int i = 0; i < Model.Attributes.Count; i++)
                    {
                        <div class="input-group attribute-item">

                            <input name="Attributes[@i].AttributeName"
                                   class="form-control attribute-input"
                                   value="@Model.Attributes[i].AttributeName"
                                   placeholder="Attribute name"
                                   data-val="true"
                                   data-val-required="Category Attribute name is required"
                                   data-val-maxlength="Category Attribute name cannot exceed 200 characters"
                                   data-val-maxlength-max="200"
                                   data-val-regex="Category Attribute name cannot contain special characters"
                                   data-val-regex-pattern="^[a-zA-Z0-9\s]+$" />

                            <button type="button"
                                    class="btn btn-danger removeAttr">
                                X
                            </button>

                        </div>
                    }
                }
            </div>

            <button type="button"
                    class="btn btn-secondary btn-sm mt-2"
                    id="addAttributeBtn">
                + Add Attribute
            </button>
            <span asp-validation-for="Attributes"
                  class="text-danger"></span>
        </div>

        <!-- SUBMIT -->
        <div class="text-end">
            <button type="submit" class="btn btn-primary">
                Create Category
            </button>
        </div>

    </form>

</div>
<script>
    (function () {

        function previewLogo(input) {
            const file = input.files[0];
            if (!file) return;
            const reader = new FileReader();
            reader.onload = e => $("#logoPreview").attr("src", e.target.result);
            reader.readAsDataURL(file);
        }
        // previewLogo được gọi từ onchange="previewLogo(this)" trong HTML
        // -> phải gán ra window vì HTML attribute chỉ tìm hàm ở global scope
        window.previewLogo = previewLogo;

        /* ================= ATTRIBUTES ================= */
        let attrIndex = $("#attributeContainer .attribute-item").length;

        $(document).off("click.categoryCreate", "#addAttributeBtn")
                   .on("click.categoryCreate", "#addAttributeBtn", function () {

            if ($(".attribute-item").length >= 10) {
                alert("Maximum 10 attributes are allowed.");
                return;
            }

            const html = `
        <div class="input-group attribute-item">
            <input name="Attributes[${attrIndex}].AttributeName"
                   class="form-control attribute-input"
                   placeholder="Attribute name"
                   data-val="true"
                   data-val-required="Category Attribute name is required"
                   data-val-maxlength="Category Attribute name cannot exceed 200 characters"
                   data-val-maxlength-max="200"
                   data-val-regex="Category Attribute name cannot contain special characters"
                   data-val-regex-pattern="^[a-zA-Z0-9\\s]+$" />
            <button type="button" class="btn btn-danger removeAttr">X</button>
        </div>`;

            $("#attributeContainer").append(html);
            $.validator.unobtrusive.parse("#attributeContainer");
            attrIndex++;
            checkDuplicate();
        });

        $(document).off("click.categoryCreate", ".removeAttr")
                   .on("click.categoryCreate", ".removeAttr", function () {
            $(this).closest(".attribute-item").remove();
            reIndexAttributes();
            setTimeout(checkDuplicate, 0);
        });

        function reIndexAttributes() {
            $("#attributeContainer .attribute-item").each(function (index) {
                $(this).find("input").attr("name", `Attributes[${index}].AttributeName`);
            });
            attrIndex = $("#attributeContainer .attribute-item").length;
        }

        function checkDuplicate() {
            let map = {};
            let isDuplicate = false;
            $("#attributeError").empty();

            $(".attribute-input").each(function () {
                const val = $(this).val()?.trim().toLowerCase();
                $(this).removeClass("is-invalid");
                if (!val) return;

                if (map[val]) {
                    isDuplicate = true;
                    $(this).addClass("is-invalid");
                    map[val].addClass("is-invalid");
                } else {
                    map[val] = $(this);
                }
            });

            if (isDuplicate) {
                $("#attributeError").html(`<div class="text-danger mb-2">Attributes must be unique</div>`);
            }

            $("button[type='submit']").prop("disabled", isDuplicate);
            return isDuplicate;
        }

        $(document).off("input.categoryCreate", ".attribute-input")
                   .on("input.categoryCreate", ".attribute-input", checkDuplicate);

        checkDuplicate();

    })();
</script>