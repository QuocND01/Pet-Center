@model PetCenterClient.DTOs.CreateCategoryViewModel

<style>

    .page-card {
        background: #fff;
        border-radius: 18px;
        padding: 30px;
    }

    .section-card {
        background: #f8f9fa;
        border-radius: 16px;
        padding: 20px;
        margin-bottom: 25px;
        border: 1px solid #e9ecef;
    }

    .section-title {
        font-size: 18px;
        font-weight: 700;
        margin-bottom: 18px;
    }

    .form-control {
        border-radius: 12px;
        min-height: 46px;
    }

    .logo-preview {
        width: 140px;
        height: 140px;
        object-fit: cover;
        border-radius: 14px;
        border: 2px dashed #ccc;
        cursor: pointer;
    }

    .attribute-item {
        width: 100%;
        display: flex;
        gap: 10px;
        margin-bottom: 10px;
    }

    .attribute-input {
        border-radius: 10px;
    }

    .is-invalid {
        border-color: #dc3545 !important;
    }

    #attributeContainer {
        display: flex;
        flex-direction: column;
    }

</style>

<div class="page-card">

    <form asp-action="Create"
          asp-controller="Category"
          method="post"
          enctype="multipart/form-data">

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <!-- BASIC INFO -->
        <div class="section-card">

            <div class="section-title">Category Information</div>

            <div class="row">

                <div class="col-md-12 mb-3">
                    <label class="form-label">Category Name</label>
                    <input asp-for="CategoryName" class="form-control" />
                </div>

                <div class="col-md-12 mb-3">
                    <label class="form-label">Description</label>
                    <textarea asp-for="CategoryDescription"
                              class="form-control"
                              rows="3"></textarea>
                </div>

            </div>
        </div>

        <!-- LOGO -->
        <div class="section-card">

            <div class="section-title">Category Logo</div>

            <input type="file"
                   id="logoInput"
                   name="CategoryLogo"
                   hidden
                   accept="image/*"
                   onchange="previewLogo(this)" />

            <img id="logoPreview"
                 src="https://via.placeholder.com/140"
                 class="logo-preview"
                 onclick="document.getElementById('logoInput').click()" />

        </div>

        <!-- ATTRIBUTES -->
        <div class="section-card">

            <div class="section-title">Attributes</div>

            <div id="attributeError"></div>

            <div id="attributeContainer"></div>

            <button type="button"
                    class="btn btn-secondary btn-sm mt-2"
                    id="addAttributeBtn">
                + Add Attribute
            </button>

        </div>

        <!-- SUBMIT -->
        <div class="text-end">
            <button type="submit" class="btn btn-primary">
                Create Category
            </button>
        </div>

    </form>

</div>

<script>

    function previewLogo(input) {

        const file = input.files[0];
        if (!file) return;

        const reader = new FileReader();
        reader.onload = e => {
            $("#logoPreview").attr("src", e.target.result);
        };
        reader.readAsDataURL(file);
    }

    /* ================= ATTRIBUTES ================= */

    let attrIndex = 0;

    /* ADD */
    $(document).on("click", "#addAttributeBtn", function () {

        const html = `
        <div class="input-group attribute-item">

            <input name="Attributes[${attrIndex}].AttributeName"
                   class="form-control attribute-input"
                   placeholder="Attribute name" />

            <button type="button"
                    class="btn btn-danger removeAttr">X</button>

        </div>`;

        $("#attributeContainer").append(html);

        attrIndex++;

        checkDuplicate();
    });

    /* REMOVE */
    $(document).on("click", ".removeAttr", function () {

        $(this).closest(".attribute-item").remove();

        reIndexAttributes();

        setTimeout(checkDuplicate, 0);
    });

    /* REINDEX */
    function reIndexAttributes() {

        $("#attributeContainer .attribute-item").each(function (index) {

            $(this).find("input")
                .attr("name", `Attributes[${index}].AttributeName`);
        });

        attrIndex = $("#attributeContainer .attribute-item").length;
    }

    /* ================= DUPLICATE CHECK ================= */

    function checkDuplicate() {

        let map = {};
        let isDuplicate = false;

        $("#attributeError").empty();

        $(".attribute-input").each(function () {

            const val = $(this).val()?.trim().toLowerCase();

            $(this).removeClass("is-invalid");

            if (!val) return;

            if (map[val]) {

                isDuplicate = true;

                $(this).addClass("is-invalid");
                map[val].addClass("is-invalid");

            } else {
                map[val] = $(this);
            }
        });

        if (isDuplicate) {
            $("#attributeError").html(`
                <div class="text-danger mb-2">
                    Attributes must be unique
                </div>
            `);
        }

        $("button[type='submit']").prop("disabled", isDuplicate);

        return isDuplicate;
    }

    /* realtime */
    $(document).on("input", ".attribute-input", checkDuplicate);

    /* init */
    $(document).ready(function () {
        checkDuplicate();
    });

</script>