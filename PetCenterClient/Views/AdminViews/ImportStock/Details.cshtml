@using PetCenterClient.ViewModels
@model ImportStockViewModel

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var productList = ViewBag.ProductList as SelectList;
    var staffDict = ViewBag.StaffDict as Dictionary<Guid, string>;
    string statusText = Model.Status switch
    {
        0 => "Cancel",
        1 => "Pending",
        2 => "Confirmed",
        _ => "Unknown"
    };

    string badgeClass = Model.Status switch
    {
        0 => "badge-inactive",
        1 => "badge-pending",
        2 => "badge-active",
        _ => "badge-inactive"
    };
}
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=Space+Grotesk:wght@400;500;600&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
<link rel="stylesheet" href="~/css/AdminViews/ManageImport/import_detail.css" asp-append-version="true" />
<div class="page-wrapper">
    <div class="page-header">

        <div class="page-title-group">
            <h1>Import Detail</h1>
            <p>View detailed information of this stock import</p>
        </div>

        <div class="nav-actions">
            <a asp-action="Index" class="btn-back">
                <i class="bi bi-arrow-left"></i>
                <span>Back to Import List</span>
            </a>
        </div>
    </div>

    

    <div class="info-card">
        <div class="info-grid">
            <div class="info-item">
                <span class="label">Supplier</span>
                <span class="value">@Model.SupplierName</span>
            </div>

            <div class="info-item">
                <span class="label">Staff in charge</span>
                <span class="value">
                    @Model.StaffName
                </span>
            </div>
            <div class="info-item">
                <span class="label">Invoice Number</span>
                <span class="value">@Model.InvoiceNumber</span>
            </div><div class="info-item">
                <span class="label">Note</span>
                <span class="value">@Model.Note</span>
            </div>

            <div class="info-item">
                <span class="label">Import Date</span>
                <span class="value">
                    <i class="bi bi-calendar3 me-1"></i> @Model.ImportDate?.ToString("dd MMM yyyy")
                </span>
            </div>

            <div class="info-item">
                <span class="label">Status</span>
                <span class="badge-status @badgeClass">
                    <span class="badge-dot"></span>
                    @statusText
                </span>
            </div>

            <div class="info-item total-box">
                <span class="label">Total Amount</span>
                <span class="value">@Model.TotalAmount.ToString("N0") ₫</span>
            </div>
        </div>
    </div>

    <div class="table-card">
        <div class="table-header">
            <h3><i class="bi bi-box-seam"></i> Imported Products</h3>
        </div>

        <table class="data-table">
            <thead>
                <tr >
                    <th>Product Info</th>
                    <th>Inventory</th>
                    <th>Date Info</th>
                    <th>Amount</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var d in Model.Details)
                {
                    
                    var subtotal = d.Quantity * d.ImportPrice;

                <tr class="detail-row">
                        <td>
                            <div class="product-info">
                            <div class="product-name">
                                <i class="bi bi-box"></i>

                                <a href="javascript:void(0)"
                                   class="product-link"
                                   data-bs-toggle="modal"
                                   data-bs-target="#productSnapshotModal"
                                   data-name="@d.ImportProductSnapshot?.ProductName"
                                   data-category="@d.ImportProductSnapshot?.ProductCategory"
                                   data-brand="@d.ImportProductSnapshot?.ProductBrand"
                                   data-image="@d.ImportProductSnapshot?.ProductImage">
                                    @d.ImportProductSnapshot?.ProductName
                                </a>
                            </div>

                                <div class="product-meta">
                                    <span>SKU: @d.SKU</span>
                                    <span>Batch: @d.BatchCode</span>
                                </div>
                            </div>
                        </td>

                        <td>
                            <div class="inventory-info">
                                <div>
                                    <span class="label">Quantity</span>
                                    <strong>@d.Quantity</strong>
                                </div>

                                <div>
                                    <span class="label">Stock Left</span>
                                    <strong>@d.StockLeft</strong>
                                </div>
                            </div>
                        </td>

                        <td>
                            <div class="date-info">
                                <div>
                                    <span class="label">MFG</span>
                                    @d.ManufacturingDate?.ToString("dd/MM/yyyy")
                                </div>

                                <div>
                                    <span class="label">EXP</span>
                                    @d.ExpiryDate?.ToString("dd/MM/yyyy")
                                </div>
                            </div>
                        </td>

                        <td>
                            <div class="amount-info">
                                <div>
                                    <span class="label">Unit price</span>
                                    @d.ImportPrice.ToString("N0") ₫
                                </div>

                                <div class="subtotal">
                                    <span class="label">Subtotal</span>
                                    @subtotal.ToString("N0") ₫
                                </div>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    <div class="table-pagination">
        <div class="pagination-info">
            Showing
            <span id="startItem">1</span> -
            <span id="endItem">1</span>
            of
            <span id="totalItems">@Model.Details.Count</span>
            products
        </div>

        <div class="pagination-controls">
            <button type="button" id="prevPage" class="page-btn">
                <i class="bi bi-chevron-left"></i>
            </button>

            <span id="pageInfo"></span>

            <button type="button" id="nextPage" class="page-btn">
                <i class="bi bi-chevron-right"></i>
            </button>
        </div>
    </div>
    </div>
</div>
@* Model product *@
<div class="modal fade" id="productSnapshotModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Product Snapshot</h5>
                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <div class="text-center mb-3">
                    <img id="snapshotImage"
                         src=""
                         class="img-fluid rounded"
                         style="max-height:220px;" />
                </div>

                <table class="table table-borderless">
                    <tr>
                        <th>Name</th>
                        <td id="snapshotName"></td>
                    </tr>

                    <tr>
                        <th>Category</th>
                        <td id="snapshotCategory"></td>
                    </tr>

                    <tr>
                        <th>Brand</th>
                        <td id="snapshotBrand"></td>
                    </tr>
                </table>

            </div>

        </div>
    </div>
</div>
@* Script *@
<script>
    document.addEventListener("DOMContentLoaded", function () {

        const modal = document.getElementById("productSnapshotModal");

        modal.addEventListener("show.bs.modal", function (event) {

            const button = event.relatedTarget;

            document.getElementById("snapshotName").textContent =
                button.dataset.name;

            document.getElementById("snapshotCategory").textContent =
                button.dataset.category;

            document.getElementById("snapshotBrand").textContent =
                button.dataset.brand;

            document.getElementById("snapshotImage").src =
                button.dataset.image;
        });

    });

    //Pagging    
    document.addEventListener("DOMContentLoaded", function () {

        const rows = [...document.querySelectorAll(".detail-row")];

        const pageSize = 5;

        let currentPage = 1;

        const totalPages = Math.ceil(rows.length / pageSize);

        function render() {

            rows.forEach((row, index) => {

                row.style.display =
                    (index >= (currentPage - 1) * pageSize &&
                     index < currentPage * pageSize)
                    ? ""
                    : "none";

            });

            const start = rows.length === 0
                ? 0
                : (currentPage - 1) * pageSize + 1;

            const end = Math.min(currentPage * pageSize, rows.length);

            document.getElementById("startItem").textContent = start;
            document.getElementById("endItem").textContent = end;

            document.getElementById("pageInfo").textContent =
                `${currentPage} / ${totalPages}`;

            document.getElementById("prevPage").disabled =
                currentPage === 1;

            document.getElementById("nextPage").disabled =
                currentPage === totalPages;
        }

        document.getElementById("prevPage")
            .addEventListener("click", function () {

                if (currentPage > 1) {

                    currentPage--;

                    render();

                }

            });

        document.getElementById("nextPage")
            .addEventListener("click", function () {

                if (currentPage < totalPages) {

                    currentPage++;

                    render();

                }

            });

        render();

    });

</script>