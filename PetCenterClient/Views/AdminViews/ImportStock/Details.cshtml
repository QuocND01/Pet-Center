@using PetCenterClient.DTOs
@model ReadImportStockDetailDto

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var productList = ViewBag.ProductList as SelectList;

    string statusText = Model.Status switch
    {
        0 => "Pending",
        1 => "Confirmed",
        2 => "Canceled",
        _ => "Unknown"
    };
}

<h2>Import Detail</h2>

<div>
    <p><b>Supplier:</b> @Model.SupplierName</p>
    <p><b>Staff:</b> @Model.StaffId</p>
    <p><b>Total:</b> @Model.TotalAmount</p>
    <p><b>Status:</b> @statusText</p>
</div>

<h3>Products</h3>

<table class="table">
    <thead>
        <tr>
            <th>Product</th>
            <th>Qty</th>
            <th>Import Price</th>
            <th>Stock Left</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var d in Model.Details)
        {
            var productName = productList?
            .FirstOrDefault(p => p.Value == d.ProductId.ToString())?.Text;

            <tr>
                <td>@productName</td>
                <td>@d.Quantity</td>
                <td>@d.ImportPrice</td>
                <td>@d.StockLeft</td>
            </tr>
        }
    </tbody>
</table>