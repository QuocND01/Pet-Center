@using PetCenterClient.ViewModels
@model ImportStockViewModel

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var productList = ViewBag.ProductList as SelectList;
    var staffDict = ViewBag.StaffDict as Dictionary<Guid, string>;
    string statusText = Model.Status switch
    {
        0 => "Cancel",
        1 => "Pending",
        2 => "Confirmed",
        _ => "Unknown"
    };

    string badgeClass = Model.Status switch
    {
        0 => "badge-inactive",
        1 => "badge-pending",
        2 => "badge-active",
        _ => "badge-inactive"
    };
}
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=Space+Grotesk:wght@400;500;600&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
<link rel="stylesheet" href="~/css/AdminViews/ManageImport/import_detail.css" asp-append-version="true" />
<div class="page-wrapper">
    <div class="page-header">

        <div class="page-title-group">
            <h1>Import Detail</h1>
            <p>View detailed information of this stock import</p>
        </div>

        <div class="nav-actions">
            <a asp-action="Index" class="btn-back">
                <i class="bi bi-arrow-left"></i>
                <span>Back to Import List</span>
            </a>
        </div>
    </div>

    

    <div class="info-card">
        <div class="info-grid">
            <div class="info-item">
                <span class="label">Supplier</span>
                <span class="value">@Model.SupplierName</span>
            </div>

            <div class="info-item">
                <span class="label">Staff in charge</span>
                <span class="value">
                    @Model.StaffName
                </span>
            </div>
            <div class="info-item">
                <span class="label">Invoice Number</span>
                <span class="value">@Model.InvoiceNumber</span>
            </div><div class="info-item">
                <span class="label">Note</span>
                <span class="value">@Model.Note</span>
            </div>

            <div class="info-item">
                <span class="label">Import Date</span>
                <span class="value">
                    <i class="bi bi-calendar3 me-1"></i> @Model.ImportDate?.ToString("dd MMM yyyy")
                </span>
            </div>

            <div class="info-item">
                <span class="label">Status</span>
                <span class="badge-status @badgeClass">
                    <span class="badge-dot"></span>
                    @statusText
                </span>
            </div>

            <div class="info-item total-box">
                <span class="label">Total Amount</span>
                <span class="value">@Model.TotalAmount.ToString("N0") ₫</span>
            </div>
        </div>
    </div>

    <div class="table-card">
        <div class="table-header">
            <h3><i class="bi bi-box-seam"></i> Imported Products</h3>
        </div>

        <table class="data-table">
            <thead>
                <tr>
                    <th>Product Info</th>
                    <th>Inventory</th>
                    <th>Date Info</th>
                    <th>Amount</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var d in Model.Details)
                {
                    var productName = productList?.FirstOrDefault(p => p.Value == d.ProductId.ToString())?.Text;
                    var subtotal = d.Quantity * d.ImportPrice;

                    <tr>
                        <td>
                            <div class="product-info">
                                <div class="product-name">
                                    <i class="bi bi-box"></i>
                                    @productName
                                </div>

                                <div class="product-meta">
                                    <span>SKU: @d.SKU</span>
                                    <span>Batch: @d.BatchCode</span>
                                </div>
                            </div>
                        </td>

                        <td>
                            <div class="inventory-info">
                                <div>
                                    <span class="label">Quantity</span>
                                    <strong>@d.Quantity</strong>
                                </div>

                                <div>
                                    <span class="label">Stock Left</span>
                                    <strong>@d.StockLeft</strong>
                                </div>
                            </div>
                        </td>

                        <td>
                            <div class="date-info">
                                <div>
                                    <span class="label">MFG</span>
                                    @d.ManufacturingDate?.ToString("dd/MM/yyyy")
                                </div>

                                <div>
                                    <span class="label">EXP</span>
                                    @d.ExpiryDate?.ToString("dd/MM/yyyy")
                                </div>
                            </div>
                        </td>

                        <td>
                            <div class="amount-info">
                                <div>
                                    <span class="label">Unit price</span>
                                    @d.ImportPrice.ToString("N0") ₫
                                </div>

                                <div class="subtotal">
                                    <span class="label">Subtotal</span>
                                    @subtotal.ToString("N0") ₫
                                </div>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>