@using PetCenterClient.DTOs
@model CreateImportStockDto

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=Space+Grotesk:wght@400;500;600&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
<link rel="stylesheet" href="~/css/AdminViews/ManageImport/create_import.css" asp-append-version="true" />


<div class="page-wrapper">
    <div class="page-header">
        <div class="page-title-group">
            <h1>Create Import Stock</h1>
            <p>Fill in the details to restock your inventory</p>
        </div>
        <a asp-action="Index" class="btn-back">
            <i class="bi bi-arrow-left"></i> Back to List
        </a>
    </div>

    <form asp-action="Create" method="post" class="form-container">
        <div class="info-card mb-4">
            <div class="card-header">
                <h3><i class="bi bi-truck"></i> Supplier Information</h3>
            </div>
            <div class="form-group mb-0">
                <label class="form-label">Select Supplier</label>
                <select asp-for="SupplierId" asp-items="ViewBag.SupplierList" class="search-input" style="padding-left: 14px;" required>
                    <option value="">-- Choose a supplier --</option>
                </select>
            </div>
        </div>
        
        <div class="table-card mb-4">
            <div class="table-header">
                <h3><i class="bi bi-box-seam"></i> Product List</h3>
                <button type="button" class="btn-create" id="addRow" style="font-size: 13px; padding: 6px 14px;">
                    <i class="bi bi-plus-lg"></i> Add Product
                </button>
            </div>

            <table class="data-table" id="detailTable">
                <thead>
                    <tr>
                        <th style="width: 40%">Product</th>
                        <th style="width: 15%">Quantity</th>
                        <th style="width: 25%">Import Price (₫)</th>
                        <th style="width: 10%; text-align: center;">Action</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>
                            <select name="Details[0].ProductId" class="search-input productSelect" style="padding-left: 14px;" required>
                                <option value="">-- Select Product --</option>
                                @foreach (var item in ViewBag.ProductList)
                                {
                                    <option value="@item.Value">@item.Text</option>
                                }
                            </select>
                        </td>
                        <td>
                            <input name="Details[0].Quantity" class="search-input quantity" type="number" min="1" placeholder="0" required />
                        </td>
                        <td>
                            <input name="Details[0].ImportPrice" class="search-input price" type="number" min="0" placeholder="0.00" required />
                        </td>
                        <td style="text-align: center;">
                            <button type="button" class="btn-action-danger removeRow">
                                <i class="bi bi-trash"></i>
                            </button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="footer-actions">
            <div class="total-display">
                <span class="label">Estimated Total Amount</span>
                <span class="value"><span id="totalAmount">0</span> ₫</span>
            </div>
            <button type="submit" class="btn-create" style="padding: 12px 32px; font-size: 15px;">
                <i class="bi bi-cloud-arrow-up"></i> Save Import Order
            </button>
        </div>
    </form>
</div>
<script>
    let rowIndex = 1;

    // Thêm dòng mới
    document.getElementById("addRow").addEventListener("click", function () {
        const tableBody = document.querySelector("#detailTable tbody");
            const productOptions = document.querySelector('.productSelect').innerHTML;

            const newRow = `
                <tr>
            <td>
                        <select name="Details[${rowIndex}].ProductId" class="search-input productSelect" style="padding-left: 14px;" required>
                            ${productOptions}
                </select>
            </td>
            <td>
                <input name="Details[${rowIndex}].Quantity" class="search-input quantity" type="number" min="1" placeholder="0" required />
            </td>
            <td>
                <input name="Details[${rowIndex}].ImportPrice" class="search-input price" type="number" min="0" placeholder="0.00" required />
            </td>
            <td style="text-align: center;">
                <button type="button" class="btn-action-danger removeRow">
                    <i class="bi bi-trash"></i>
                </button>
            </td>
                </tr>
        `;

            tableBody.insertAdjacentHTML("beforeend", newRow);
        rowIndex++;
    });

    // Xóa dòng và tính lại Index
    document.addEventListener("click", function (e) {
        if (e.target.closest(".removeRow")) {
            const rows = document.querySelectorAll("#detailTable tbody tr");
            if (rows.length > 1) {
                    e.target.closest("tr").remove();
                    reIndexRows(); // Cập nhật lại index cho name attribute
                calculateTotal();
            } else {
                alert("At least one product is required.");
            }
        }
    });

    function reIndexRows() {
        const rows = document.querySelectorAll("#detailTable tbody tr");
        rows.forEach((row, index) => {
                row.querySelector(".productSelect").name = `Details[${index}].ProductId`;
                row.querySelector(".quantity").name = `Details[${index}].Quantity`;
                row.querySelector(".price").name = `Details[${index}].ImportPrice`;
        });
        rowIndex = rows.length;
    }

    // Tính tổng tiền tự động
    document.addEventListener("input", function (e) {
        if (e.target.classList.contains("quantity") || e.target.classList.contains("price")) {
            calculateTotal();
        }
    });

    function calculateTotal() {
        let total = 0;
        document.querySelectorAll("#detailTable tbody tr").forEach(row => {
            const qty = parseFloat(row.querySelector(".quantity").value) || 0;
            const price = parseFloat(row.querySelector(".price").value) || 0;
            total += qty * price;
        });
        document.getElementById("totalAmount").innerText = total.toLocaleString('vi-VN');
    }

        // Chặn trùng sản phẩm
        document.addEventListener("change", function (e) {
            if (e.target.classList.contains("productSelect")) {
        const allSelects = document.querySelectorAll(".productSelect");
        const values = Array.from(allSelects).map(s => s.value).filter(v => v !== "");

        const hasDuplicate = values.some((v, i) => values.indexOf(v) !== i);

        if (hasDuplicate) {
            alert("This product is already in the list!");
                    e.target.value = "";
                }
        }
    });
</script>
