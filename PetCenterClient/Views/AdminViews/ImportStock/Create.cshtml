@using PetCenterClient.ViewModels
@model CreateImportViewModel

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=Space+Grotesk:wght@400;500;600&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
<link rel="stylesheet" href="~/css/AdminViews/ManageImport/create_import.css" asp-append-version="true" />

<div class="page-wrapper">
    <div class="page-header">
        <div class="page-title-group">
            <h1>Create Import Stock</h1>
            <p>Fill in the details to restock your inventory</p>
        </div>
        <a asp-action="Index" class="btn-back">
            <i class="bi bi-arrow-left"></i> Back to List
        </a>
    </div>

    <form asp-action="Create" method="post" class="form-container">
        <div class="info-card mb-4">
            <div class="card-header">
                <h3><i class="bi bi-truck"></i> Supplier Information</h3>
            </div>
            <div class="form-group mb-0">
                <label class="form-label">Select Supplier</label>
                <select asp-for="SupplierId" asp-items="ViewBag.SupplierList" class="search-input" style="padding-left: 14px;" required>
                    <option value="">-- Choose a supplier --</option>
                </select>
            </div>
            <div class="form-group mb-3">
                <label class="form-label-custom" asp-for="InvoiceNumber">Invoice Number</label>
                <input asp-for="InvoiceNumber" class="form-input-custom search-input" type="text" placeholder="Import invoice number" />
                <span asp-validation-for="InvoiceNumber" class="validation-message"></span>
            </div>
            <div class="form-group mb-3">
                <label class="form-label-custom" asp-for="Note">Note</label>
                <input asp-for="Note" class="form-input-custom search-input" type="text" placeholder="Note " />
                <span asp-validation-for="Note" class="validation-message"></span>
            </div>
        </div>

        <div class="table-card mb-4">
            <div class="table-header">
                <h3><i class="bi bi-box-seam"></i> Product List</h3>
                <button type="button" class="btn-create" id="addRow" style="font-size: 13px; padding: 6px 14px;">
                    <i class="bi bi-plus-lg"></i> Add Product
                </button>
            </div>

            <div style="overflow-x: auto;">
                <table class="data-table" id="detailTable" style="min-width: 1000px;">
                    <thead>
                        <tr>
                            <th style="width: 20%">Product</th>
                            <th style="width: 12%">SKU</th>
                            <th style="width: 12%">Batch</th>
                            <th style="width: 13%">Mfg Date</th>
                            <th style="width: 13%">Exp Date</th>
                            <th style="width: 10%">Quantity</th>
                            <th style="width: 15%">Import Price (₫)</th>
                            <th style="width: 5%; text-align: center;">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>
                                <input type="hidden"
                                       name="Details[0].ProductId"
                                       class="productIdInput"
                                       required />

                                <input type="text"
                                       class="search-input productPicker"
                                       placeholder="Click to select product"
                                       readonly
                                       style="padding-left:14px;cursor:pointer;" />
                            </td>

                            <td>
                                <input name="Details[0].SKU"
                                       class="search-input sku"
                                       type="text"
                                       readonly
                                       required />
                            </td>
                            <td>
                                <input name="Details[0].BatchCode" class="search-input batch" type="text" placeholder="Batch" required />
                            </td>
                            <td>
                                <input name="Details[0].ManufacturingDate" class="search-input mfg-date" type="date" />
                            </td>
                            <td>
                                <input name="Details[0].ExpiryDate" class="search-input exp-date" type="date" />
                            </td>
                            <td>
                                <input name="Details[0].Quantity" class="search-input quantity" type="number" min="1" placeholder="0" required />
                            </td>
                            <td>
                                <input name="Details[0].ImportPrice" class="search-input price" type="number" min="0" placeholder="0.00" required />
                            </td>
                            <td style="text-align: center;">
                                <button type="button" class="btn-action-danger removeRow">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div> <div class="footer-actions">
            <div class="total-display">
                <span class="label">Estimated Total Amount</span>
                <span class="value"><span id="totalAmount">0</span> ₫</span>
            </div>
            <button type="submit" class="btn-create" style="padding: 12px 32px; font-size: 15px;">
                <i class="bi bi-cloud-arrow-up"></i> Save Import Order
            </button>
        </div>
    </form>
    <div class="modal fade" id="productModal" tabindex="-1">
        <div class="modal-dialog modal-xl">
            <div class="modal-content">

                <div class="modal-header">
                    <h5 class="modal-title">Select Product</h5>

                    <button type="button"
                            class="btn-close"
                            data-bs-dismiss="modal">
                    </button>
                </div>

                <div class="modal-body">

                    <input type="text"
                           id="productKeyword"
                           class="form-control mb-3"
                           placeholder="Search product..." />

                    <div class="product-table-wrapper">
                        <table class="product-table">
                            <thead>
                                <tr>
                                    <th>Product</th>
                                    <th>SKU</th>
                                    <th>Brand</th>
                                    <th width="100"></th>
                                </tr>
                            </thead>

                            <tbody id="productTableBody">
                            </tbody>
                        </table>
                    </div>

                </div>

            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<script>

    const API_BASE = "https://localhost:7004";

    let rowIndex = 1;
    let currentRow = null;

    const productModal = new bootstrap.Modal(
        document.getElementById("productModal")
    );

    function createRow(index) {

        return `
            <tr>

                <td>
                    <input type="hidden"
                           name="Details[${index}].ProductId"
                           class="productIdInput"
                           required />

                    <input type="text"
                           class="search-input productPicker"
                           placeholder="Click to select product"
                           readonly
                           style="padding-left:14px;cursor:pointer;" />
                </td>

                <td>
                    <input name="Details[${index}].SKU"
                           class="search-input sku"
                           type="text"
                           readonly
                           required />
                </td>

                <td>
                    <input name="Details[${index}].BatchCode"
                           class="search-input batch"
                           type="text"
                           placeholder="Batch"
                           required />
                </td>

                <td>
                    <input name="Details[${index}].ManufacturingDate"
                           class="search-input mfg-date"
                           type="date" />
                </td>

                <td>
                    <input name="Details[${index}].ExpiryDate"
                           class="search-input exp-date"
                           type="date" />
                </td>

                <td>
                    <input name="Details[${index}].Quantity"
                           class="search-input quantity"
                           type="number"
                           min="1"
                           placeholder="0"
                           required />
                </td>

                <td>
                    <input name="Details[${index}].ImportPrice"
                           class="search-input price"
                           type="number"
                           min="0"
                           placeholder="0.00"
                           required />
                </td>

                <td style="text-align:center;">
                    <button type="button"
                            class="btn-action-danger removeRow">
                        <i class="bi bi-trash"></i>
                    </button>
                </td>

            </tr>
        `;
    }

    document.getElementById("addRow")
        .addEventListener("click", function () {

            document.querySelector("#detailTable tbody")
                .insertAdjacentHTML(
                    "beforeend",
                    createRow(rowIndex)
                );

            rowIndex++;
        });

    document.addEventListener("click", function (e) {

        const removeBtn = e.target.closest(".removeRow");

        if (!removeBtn)
            return;

        const rows = document.querySelectorAll(
            "#detailTable tbody tr"
        );

        if (rows.length <= 1) {
            alert("At least one product is required.");
            return;
        }

        removeBtn.closest("tr").remove();

        reIndexRows();

        calculateTotal();
    });

    function reIndexRows() {

        const rows = document.querySelectorAll(
            "#detailTable tbody tr"
        );

        rows.forEach((row, index) => {

            row.querySelector(".productIdInput")
                .name = `Details[${index}].ProductId`;

            row.querySelector(".sku")
                .name = `Details[${index}].SKU`;

            row.querySelector(".batch")
                .name = `Details[${index}].BatchCode`;

            row.querySelector(".mfg-date")
                .name = `Details[${index}].ManufacturingDate`;

            row.querySelector(".exp-date")
                .name = `Details[${index}].ExpiryDate`;

            row.querySelector(".quantity")
                .name = `Details[${index}].Quantity`;

            row.querySelector(".price")
                .name = `Details[${index}].ImportPrice`;
        });

        rowIndex = rows.length;
    }

    document.addEventListener("input", function (e) {

        if (
            e.target.classList.contains("quantity") ||
            e.target.classList.contains("price")
        ) {
            calculateTotal();
        }
    });

    function calculateTotal() {

        let total = 0;

        document
            .querySelectorAll("#detailTable tbody tr")
            .forEach(row => {

                const qty =
                    parseFloat(
                        row.querySelector(".quantity").value
                    ) || 0;

                const price =
                    parseFloat(
                        row.querySelector(".price").value
                    ) || 0;

                total += qty * price;
            });

        document.getElementById("totalAmount")
            .innerText = total.toLocaleString("vi-VN");
    }

    document.addEventListener("click", function (e) {

        const picker = e.target.closest(".productPicker");

        if (!picker)
            return;

        currentRow = picker.closest("tr");

        loadProducts();

        productModal.show();
    });

    async function loadProducts(keyword = "") {

            const response = await fetch(
        `${API_BASE}/api/Products/admin?page=1&pageSize=999&search=${encodeURIComponent(keyword)}`
    );

        const result = await response.json();

        let html = "";

        result.data.forEach(p => {

            html += `
                <tr>

                    <td>${p.productName}</td>

                    <td>${p.sku ?? ""}</td>

                    <td>${p.brandName ?? ""}</td>

                    <td>
                        <button
                            type="button"
                            class="btn-select-product btnSelectProduct"
                            data-id="${p.productId}"
                            data-name="${p.productName}"
                            data-sku="${p.sku ?? ""}">
                            Select
                        </button>
                    </td>

                </tr>
            `;
        });

        document.getElementById(
            "productTableBody"
        ).innerHTML = html;
    }

    let searchTimer;

    document.getElementById("productKeyword")
        .addEventListener("input", function () {

            clearTimeout(searchTimer);

            searchTimer = setTimeout(() => {
                loadProducts(this.value);
            }, 300);
        });

    document.addEventListener("click", function (e) {

        const btn = e.target.closest(
            ".btnSelectProduct"
        );

        if (!btn)
            return;

        const productId = btn.dataset.id;
        const productName = btn.dataset.name;
        const sku = btn.dataset.sku;

        const selectedIds =
            [...document.querySelectorAll(".productIdInput")]
            .map(x => x.value)
            .filter(Boolean);

        if (
            selectedIds.includes(productId) &&
            currentRow.querySelector(".productIdInput").value !== productId
        ) {
            alert("This product is already selected.");
            return;
        }

        currentRow.querySelector(".productIdInput")
            .value = productId;

        currentRow.querySelector(".productPicker")
            .value = productName;

        currentRow.querySelector(".sku")
            .value = sku;

        productModal.hide();
    });

</script>