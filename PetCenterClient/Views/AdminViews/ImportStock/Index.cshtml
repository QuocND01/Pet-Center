@using PetCenterClient.DTOs
@model List<ReadImportHeaderDto>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var staffDict = ViewBag.StaffDict as Dictionary<Guid, string>;
}
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=Space+Grotesk:wght@400;500;600&display=swap" rel="stylesheet" />

<link rel="stylesheet" href="~/css/AdminViews/ManageImport/manage_import.css" asp-append-version="true" />

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
<div class="page-wrapper">
    <div class="page-header">
        <div class="page-title-group">
            <h1>Import Stocks</h1>
            <p>Manage and track your warehouse inbound shipments</p>
        </div>

        <div class="top-actions">
            <a asp-action="Create" class="btn-create">
                <i class="bi bi-plus-lg"></i> Create Import
            </a>
        </div>
    </div>

    <div class="table-card">
        <table class="data-table">
            <thead>
                <tr>
                    <th>
                        <a asp-action="Index" asp-route-sortOrder="@ViewBag.IdSort">ID <i class="bi bi-hash"></i></a>
                    </th>
                    <th>Supplier</th>
                    <th>Staff</th>
                    <th>
                        <a asp-action="Index" asp-route-sortOrder="@ViewBag.TotalSort">Total <i class="bi bi-arrow-down-up"></i></a>
                    </th>
                    <th>
                        <a asp-action="Index" asp-route-sortOrder="@ViewBag.DateSort">Date <i class="bi bi-arrow-down-up"></i></a>
                    </th>
                    <th>
                        <a asp-action="Index" asp-route-sortOrder="@ViewBag.StatusSort">Status <i class="bi bi-arrow-down-up"></i></a>
                    </th>
                    <th style="text-align: right;">Action</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    string statusText = item.Status switch
                    {
                        0 => "Pending",
                        1 => "Confirmed",
                        2 => "Cancelled",
                        _ => "Unknown"
                    };

                    string badgeClass = item.Status switch
                    {
                        1 => "badge-active",
                        2 => "badge-inactive",
                        _ => "badge-pending"
                    };

                    <tr>
                        <td class="row-num">@item.ImportId.ToString().Substring(0, 8)...</td>
                        <td class="customer-name">@item.SupplierName</td>
                        <td class="email-cell">
                            @(staffDict != null && staffDict.ContainsKey(item.StaffId)
                                                    ? staffDict[item.StaffId]
                                                    : "Unknown Staff")
                    </td>
                    <td class="price-text">@item.TotalAmount.ToString("N0") ₫</td>
                    <td class="email-cell">@item.ImportDate?.ToString("dd MMM yyyy")</td>
                    <td>
                        <span class="badge-status @badgeClass">
                            <span class="badge-dot"></span>
                            @statusText
                        </span>
                    </td>
                    <td>
                        <div class="action-buttons">
                            <a asp-action="Details" asp-route-id="@item.ImportId" class="btn-detail" title="View Details">
                                <i class="bi bi-eye"></i>
                            </a>

                            @if (item.Status == 0)
                                {
                                    <a asp-action="Confirm" asp-route-id="@item.ImportId" class="btn-action-success" title="Confirm">
                                        <i class="bi bi-check-lg"></i>
                                    </a>
                                }

                                <a asp-action="Cancel" asp-route-id="@item.ImportId" class="btn-action-danger" title="Cancel">
                                    <i class="bi bi-x-lg"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>