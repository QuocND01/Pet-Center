@using PetCenterClient.ViewModels
@model ReadDiseaseViewModel

<div class="modal-header bg-light">
    <h5 class="modal-title fw-bold"><i class="bi bi-journal-medical"></i> @Model.Name</h5>
    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
</div>
<div class="modal-body p-4">
    <div class="d-flex gap-2 mb-4">
        <span class="badge bg-primary fs-6">Target: @Model.SpeciesName</span>
        @if (Model.IsSystem)
        {
            <span class="badge bg-danger fs-6"><i class="bi bi-shield-lock"></i> System Default</span>
        }
    </div>

    <h6 class="fw-bold text-uppercase text-secondary mb-2">Description</h6>
    <div class="p-3 bg-light rounded mb-4" style="border-left: 4px solid #0d6efd;">
        @Model.Description
    </div>

    <h6 class="fw-bold text-uppercase text-secondary mb-2">Recommendation / Treatment</h6>
    <div class="p-3 rounded" style="background-color: #f0fdf4; border-left: 4px solid #22c55e;">
        @Model.Recommendation
    </div>
</div>