@using PetCenterClient.ViewModels
@model IEnumerable<ReadDiseaseViewModel>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Disease Dictionary";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold m-0"><i class="bi bi-virus"></i> Medical Disease Dictionary</h3>
        <button class="btn btn-primary" onclick="openMutateModal(null)">+ Add New Disease</button>
    </div>

    <div class="card shadow-sm border-0 mb-4 bg-light">
        <div class="card-body p-3">
            <form method="get" action="/Diseases/Index" class="d-flex gap-2 w-75">
                <input type="text" name="search" class="form-control" placeholder="Search disease name..." value="@ViewBag.SearchKeyword" />

                <select name="species" class="form-select" style="max-width: 180px;">
                    <option value="">All Species</option>
                    <option value="1" selected="@(ViewBag.SelectedSpecies == 1 ? "selected" : null)">Dog 🐶</option>
                    <option value="2" selected="@(ViewBag.SelectedSpecies == 2 ? "selected" : null)">Cat 🐱</option>
                    <option value="3" selected="@(ViewBag.SelectedSpecies == 3 ? "selected" : null)">Both 🐾</option>
                </select>

                <button type="submit" class="btn btn-dark px-4">Search</button>

                @if (!string.IsNullOrEmpty(ViewBag.SearchKeyword) || ViewBag.SelectedSpecies != null)
                {
                    <a href="/Diseases/Index" class="btn btn-outline-secondary">Clear</a>
                }
            </form>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <table class="table table-hover align-middle m-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Disease Name</th>
                        <th>Target Species</th>
                        <th>Type</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-dark">@item.Name</td>
                                <td><span class="badge bg-secondary">@item.SpeciesName</span></td>
                                <td>
                                    @if (item.IsSystem)
                                    {
                                        <span class="badge bg-danger"><i class="bi bi-shield-lock"></i> System</span>
                                    }
                                    else
                                    {

                                        <span class="badge bg-info text-dark">Custom</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <button class="btn btn-sm btn-light btn-view-disease" data-id="@item.DiseaseId" title="View Details"><i class="bi bi-eye"></i></button>

                                    @if (!item.IsSystem)
                                    {
                                        <button class="btn btn-sm btn-outline-dark" onclick="openMutateModal('@item.DiseaseId', '@item.Name', '@item.Species', '@item.IsSystem')" title="Edit"><i class="bi bi-pencil"></i></button>
                                        <button class="btn btn-sm btn-outline-danger" onclick="deleteDisease('@item.DiseaseId')" title="Delete"><i class="bi bi-trash"></i></button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-sm btn-outline-secondary disabled" title="System data cannot be edited"><i class="bi bi-pencil"></i></button>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="4" class="text-center py-5 text-muted">No diseases found in the dictionary.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="diseaseDetailModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content" style="border-radius: 12px; border:none;" id="diseaseModalBody"></div>
    </div>
</div>

<div class="modal fade" id="mutateDiseaseModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content" style="border-radius: 15px; border:none; box-shadow: 0 10px 40px rgba(0,0,0,0.1);">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold" id="mutateModalTitle">Add Disease</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <input type="hidden" id="mutDiseaseId" />
                <div id="systemWarning" class="alert alert-warning d-none" role="alert">
                    <i class="bi bi-exclamation-triangle"></i> You are editing a System Default disease. Be careful!
                </div>
                <div class="row g-3">
                    <div class="col-8">
                        <label class="form-label text-muted fw-bold" style="font-size: 13px;">DISEASE NAME</label>
                        <input type="text" id="mutName" class="form-control bg-light border-0">
                    </div>
                    <div class="col-4">
                        <label class="form-label text-muted fw-bold" style="font-size: 13px;">TARGET SPECIES</label>
                        <select id="mutSpecies" class="form-select bg-light border-0">
                            <option value="1">Dog</option>
                            <option value="2">Cat</option>
                            <option value="3">Both (Dog & Cat)</option>
                        </select>
                    </div>
                    <div class="col-12">
                        <label class="form-label text-muted fw-bold" style="font-size: 13px;">DESCRIPTION / SYMPTOMS</label>
                        <textarea id="mutDescription" class="form-control bg-light border-0" rows="3"></textarea>
                    </div>
                    <div class="col-12">
                        <label class="form-label text-muted fw-bold" style="font-size: 13px;">TREATMENT RECOMMENDATION</label>
                        <textarea id="mutRecommendation" class="form-control bg-light border-0" rows="3"></textarea>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary px-4" onclick="saveDisease()">Save Disease</button>
            </div>
        </div>
    </div>
</div>

<script>
    // Khởi tạo hiển thị Modal Detail
    document.addEventListener("click", function (e) {
        var btnView = e.target.closest(".btn-view-disease");
        if (btnView) {
            var diseaseId = btnView.getAttribute("data-id");
            var modalBody = document.getElementById("diseaseModalBody");
            var modal = new bootstrap.Modal(document.getElementById('diseaseDetailModal'));
            modalBody.innerHTML = "<div class='text-center py-5'><div class='spinner-border text-primary'></div></div>";
            modal.show();
            fetch('/Diseases/Details/' + diseaseId)
                .then(r => r.text())
                .then(html => modalBody.innerHTML = html);
        }
    });

    function deleteDisease(id) {
        if (confirm("Are you sure you want to delete this custom disease?")) {
            fetch('/Diseases/Delete/' + id, { method: 'POST' })
            .then(r => r.json())
            .then(d => {
                if (d.success) location.reload();
                else alert("Failed to delete. It might be a system disease.");
            });
        }
    }

    var mutateModal;
    function openMutateModal(id, name, species, isSystem) {
        if (!mutateModal) mutateModal = new bootstrap.Modal(document.getElementById('mutateDiseaseModal'));

        document.getElementById('mutDiseaseId').value = id || '';
        document.getElementById('mutateModalTitle').innerText = id ? 'Edit Disease' : 'Add New Disease';

        var nameInput = document.getElementById('mutName'); // Lấy element của Disease Name

        if (!id) {
            // Add mới
            nameInput.value = '';
            nameInput.readOnly = false; // Cho phép nhập khi thêm mới
            document.getElementById('mutSpecies').value = '3'; // Default both
            document.getElementById('mutDescription').value = '';
            document.getElementById('mutRecommendation').value = '';
            document.getElementById('systemWarning').classList.add('d-none');
        } else {
            // Edit: Đổ tạm tên và loài vào form
            nameInput.value = name;
            nameInput.readOnly = true;  // Chỉ đọc (không cho sửa) khi cập nhật
            document.getElementById('mutSpecies').value = species;

            if(isSystem === 'True') document.getElementById('systemWarning').classList.remove('d-none');
            else document.getElementById('systemWarning').classList.add('d-none');
        }
        mutateModal.show();
    }

    function saveDisease() {
        var id = document.getElementById('mutDiseaseId').value;
        var data = {
            name: document.getElementById('mutName').value,
            species: parseInt(document.getElementById('mutSpecies').value),
            description: document.getElementById('mutDescription').value,
            recommendation: document.getElementById('mutRecommendation').value
        };

        if(!data.name) return alert("Disease Name is required!");

        var url = id ? '/Diseases/Update/' + id : '/Diseases/Add';

        // Gửi dạng JSON (không có ảnh)
        fetch(url, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        })
        .then(r => r.json())
        .then(d => {
            if (d.success) location.reload();
            else alert("Lỗi từ Backend API:\n\n" + (d.message || "Failed to save."));
        });
    }
</script>