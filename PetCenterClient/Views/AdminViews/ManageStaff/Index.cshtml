@using PetCenterClient.ViewModels.ManageStaff
@model StaffIndexViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Staff Management";

    string status = Model.Status ?? "active";
    string today = DateTime.Now.ToString("yyyy-MM-dd");

    string PageUrl(int p) =>
        Url.Action("Index", new { search = Model.Search, status = Model.Status, roleId = Model.RoleId, page = p })!;
}

<link rel="stylesheet" href="~/css/AdminViews/ManageStaff/manage-staff.css" asp-append-version="true" />

<style>
    .avatar-img { width: 40px; height: 40px; border-radius: 50%; object-fit: cover; flex-shrink: 0; }
    .role-pill { display: inline-block; padding: 3px 11px; border-radius: 20px; font-size: 12px; font-weight: 600;
                 background: var(--accent-light); color: var(--accent); }
    .vet-section { border-top: 1px dashed var(--border); margin-top: 8px; padding-top: 16px; }
    .modal-vet-hint { font-size: 12px; color: var(--text-muted); }

    /* Make modal body scroll so header + footer (Create/Save buttons) stay reachable
       even when the Vet section expands. */
    #createStaffModal .modal-content,
    #editStaffModal .modal-content,
    #viewStaffModal .modal-content {
        max-height: calc(100vh - 3.5rem);
    }
    #createStaffModal .modal-body,
    #editStaffModal .modal-body,
    #viewStaffModal .modal-body {
        max-height: calc(100vh - 200px);
        overflow-y: auto;
    }
</style>

<div class="page-wrapper">

    <!-- HEADER -->
    <div class="page-header">
        <div class="page-title-group">
            <h1>Staff Management</h1>
            <p>View and manage all staff members</p>
        </div>
        <div class="header-stat">
            <span class="num">@Model.TotalCount</span>
            <span class="label">Total Staff</span>
        </div>
    </div>

    @if (TempData["StaffSuccess"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mx-4" role="alert">
            <i class="bi bi-check-circle"></i> @TempData["StaffSuccess"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["StaffError"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mx-4" role="alert">
            <i class="bi bi-exclamation-triangle"></i> @TempData["StaffError"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- TOOLBAR / FILTER -->
    <form asp-action="Index" method="get" class="toolbar">
        <div class="search-wrap">
            <i class="bi bi-search"></i>
            <input type="text" name="search" value="@Model.Search" class="search-input"
                   placeholder="Search name, email, phone…" />
        </div>

        <select name="roleId" class="filter-select">
            <option value="">All Roles</option>
            @foreach (var r in Model.Roles)
            {
                <option value="@r.RoleId" selected="@(Model.RoleId == r.RoleId)">@r.RoleName</option>
            }
        </select>

        <select name="status" class="filter-select">
            <option value="active" selected="@(status == "active")">Active</option>
            <option value="inactive" selected="@(status == "inactive")">Inactive</option>
            <option value="all" selected="@(status == "all")">All Status</option>
        </select>

        <button type="submit" class="filter-btn btn-apply"><i class="bi bi-funnel"></i> Apply</button>
        <a asp-action="Index" class="filter-btn btn-clear"><i class="bi bi-x-circle"></i> Clear</a>
        <button type="button" class="filter-btn btn-add" data-bs-toggle="modal" data-bs-target="#createStaffModal">
            <i class="bi bi-plus-lg"></i> Add Staff
        </button>
    </form>

    <!-- TABLE -->
    <div class="table-card">
        <table class="data-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Staff</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Role</th>
                    <th>Gender</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Items.Any())
                {
                    <tr>
                        <td colspan="8">
                            <div class="empty-state">
                                <div class="empty-icon"><i class="bi bi-person-badge"></i></div>
                                <h3>No staff members found</h3>
                                <p>Try adjusting your filters or add a new staff member.</p>
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    int i = (Model.CurrentPage - 1) * Model.PageSize + 1;
                    foreach (var s in Model.Items)
                    {
                        var initials = string.Join("", (s.FullName ?? "")
                            .Split(' ', StringSplitOptions.RemoveEmptyEntries)
                            .Take(2).Select(w => w[0].ToString().ToUpper()));
                        var genderClass = s.Gender?.ToLower() == "male" ? "male"
                            : s.Gender?.ToLower() == "female" ? "female" : "";
                        <tr>
                            <td><span class="row-num">@i</span></td>
                            <td>
                                <div class="staff-cell">
                                    @if (!string.IsNullOrEmpty(s.Avatar))
                                    {
                                        <img src="@s.Avatar" class="avatar-img" alt="avatar" />
                                    }
                                    else
                                    {
                                        <div class="staff-avatar @genderClass">@initials</div>
                                    }
                                    <div>
                                        <div class="staff-name" title="@s.FullName">@s.FullName</div>
                                        <div class="staff-id-sub">@s.StaffId.ToString()[..8]…</div>
                                    </div>
                                </div>
                            </td>
                            <td><span class="email-cell" title="@s.Email">@s.Email</span></td>
                            <td><span class="phone-cell">@s.PhoneNumber</span></td>
                            <td><span class="role-pill">@(s.RoleName ?? "—")</span></td>
                            <td>
                                <span class="gender-cell">
                                    @if (s.Gender?.ToLower() == "male")
                                    {
                                        <i class="bi bi-gender-male" style="color:#3b82f6"></i>
                                    }
                                    else if (s.Gender?.ToLower() == "female")
                                    {
                                        <i class="bi bi-gender-female" style="color:#ec4899"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-gender-ambiguous" style="color:#8b5cf6"></i>
                                    }
                                    @(s.Gender ?? "—")
                                </span>
                            </td>
                            <td>
                                @if (s.IsActive)
                                {
                                    <span class="badge-status badge-active"><span class="badge-dot"></span> Active</span>
                                }
                                else
                                {
                                    <span class="badge-status badge-inactive"><span class="badge-dot"></span> Inactive</span>
                                }
                            </td>
                            <td>
                                <div class="action-group">
                                    <button type="button" class="btn-action btn-view js-view" title="View"
                                            data-id="@s.StaffId">
                                        <i class="bi bi-eye"></i>
                                    </button>
                                    @if (s.IsActive)
                                    {
                                        <button type="button" class="btn-action btn-edit js-edit" title="Edit"
                                                data-id="@s.StaffId">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <button type="button" class="btn-action btn-delete js-delete" title="Delete"
                                                data-id="@s.StaffId" data-name="@s.FullName">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                        i++;
                    }
                }
            </tbody>
        </table>
    </div>

    <!-- PAGINATION -->
    @if (Model.TotalPages > 1)
    {
        <div class="pagination-wrap">
            <a class="page-btn @(Model.CurrentPage <= 1 ? "disabled" : "")" href="@PageUrl(Model.CurrentPage - 1)">
                <i class="bi bi-chevron-left"></i>
            </a>
            @for (int p = 1; p <= Model.TotalPages; p++)
            {
                <a class="page-btn @(p == Model.CurrentPage ? "active" : "")" href="@PageUrl(p)">@p</a>
            }
            <a class="page-btn @(Model.CurrentPage >= Model.TotalPages ? "disabled" : "")" href="@PageUrl(Model.CurrentPage + 1)">
                <i class="bi bi-chevron-right"></i>
            </a>
        </div>
    }
</div>

@* ════════════════════════ CREATE MODAL ════════════════════════ *@
<div class="modal fade" id="createStaffModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <form asp-action="Create" method="post" enctype="multipart/form-data" id="createStaffForm">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-person-plus"></i> Add Staff</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-danger js-modal-error" style="display:none"></div>
                    <div class="field-row">
                        <div class="field-group">
                            <label class="field-label">Full Name *</label>
                            <input name="FullName" class="field-input" maxlength="50" required />
                        </div>
                        <div class="field-group">
                            <label class="field-label">Email *</label>
                            <input name="Email" type="email" class="field-input" maxlength="255" required />
                        </div>
                    </div>
                    <div class="field-row">
                        <div class="field-group">
                            <label class="field-label">Phone Number *</label>
                            <input name="PhoneNumber" class="field-input" pattern="^(0[3|5|7|8|9])[0-9]{8}$"
                                   title="Valid 10-digit Vietnamese phone number" required />
                        </div>
                        <div class="field-group">
                            <label class="field-label">Gender *</label>
                            <select name="Gender" class="field-select" required>
                                <option value="">— Select —</option>
                                <option value="Male">Male</option>
                                <option value="Female">Female</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>
                    </div>
                    <div class="field-row">
                        <div class="field-group">
                            <label class="field-label">Birth Date *</label>
                            <input name="BirthDate" type="date" class="field-input" required />
                        </div>
                        <div class="field-group">
                            <label class="field-label">Hire Date *</label>
                            <input name="HireDate" type="date" class="field-input" value="@today" required />
                        </div>
                    </div>
                    <div class="field-row">
                        <div class="field-group">
                            <label class="field-label">Role *</label>
                            <select name="RoleId" class="field-select js-role-select" data-target="create" required>
                                <option value="">— Select —</option>
                                @foreach (var r in Model.Roles)
                                {
                                    <option value="@r.RoleId" data-rolename="@r.RoleName">@r.RoleName</option>
                                }
                            </select>
                        </div>
                        <div class="field-group">
                            <label class="field-label">Avatar (optional)</label>
                            <input name="Avatar" type="file" accept="image/*" class="field-input" />
                        </div>
                    </div>
                    <div class="field-row">
                        <div class="field-group">
                            <label class="field-label">Password *</label>
                            <input name="Password" type="password" class="field-input" minlength="6" maxlength="100" required />
                        </div>
                        <div class="field-group">
                            <label class="field-label">Confirm Password *</label>
                            <input name="ConfirmPassword" type="password" class="field-input" minlength="6" maxlength="100" required />
                        </div>
                    </div>

                    <!-- VET SECTION -->
                    <div class="vet-section" id="createVetSection" style="display:none">
                        <p class="modal-vet-hint mb-2"><i class="bi bi-heart-pulse"></i> Veterinarian profile</p>
                        <div class="field-row">
                            <div class="field-group">
                                <label class="field-label">License Number *</label>
                                <input name="LicenseNumber" class="field-input js-vet-create" maxlength="50" />
                            </div>
                            <div class="field-group">
                                <label class="field-label">Experience Years *</label>
                                <input name="ExperienceYears" type="number" step="0.1" min="0" max="100"
                                       class="field-input js-vet-create" />
                            </div>
                        </div>
                        <div class="field-row full">
                            <div class="field-group">
                                <label class="field-label">Description</label>
                                <textarea name="Description" class="field-input" rows="2" maxlength="255"></textarea>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn-cancel" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn-submit primary"><i class="bi bi-check-lg"></i> Create</button>
                </div>
            </form>
        </div>
    </div>
</div>

@* ════════════════════════ EDIT MODAL ════════════════════════ *@
<div class="modal fade" id="editStaffModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <form asp-action="Edit" method="post" enctype="multipart/form-data" id="editStaffForm">
                <input type="hidden" name="id" id="editStaffId" />
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-pencil-square"></i> Update Staff</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-danger js-modal-error" style="display:none"></div>
                    <div class="field-row">
                        <div class="field-group">
                            <label class="field-label">Full Name *</label>
                            <input name="FullName" id="editFullName" class="field-input" maxlength="50" required />
                        </div>
                        <div class="field-group">
                            <label class="field-label">Email *</label>
                            <input name="Email" id="editEmail" type="email" class="field-input" maxlength="255" required />
                        </div>
                    </div>
                    <div class="field-row">
                        <div class="field-group">
                            <label class="field-label">Phone Number *</label>
                            <input name="PhoneNumber" id="editPhone" class="field-input"
                                   pattern="^(0[3|5|7|8|9])[0-9]{8}$" required />
                        </div>
                        <div class="field-group">
                            <label class="field-label">Gender *</label>
                            <select name="Gender" id="editGender" class="field-select" required>
                                <option value="Male">Male</option>
                                <option value="Female">Female</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>
                    </div>
                    <div class="field-row">
                        <div class="field-group">
                            <label class="field-label">Birth Date *</label>
                            <input name="BirthDate" id="editBirthDate" type="date" class="field-input" required />
                        </div>
                        <div class="field-group">
                            <label class="field-label">Hire Date *</label>
                            <input name="HireDate" id="editHireDate" type="date" class="field-input" required />
                        </div>
                    </div>
                    <div class="field-row">
                        <div class="field-group">
                            <label class="field-label">Role *</label>
                            <select name="RoleId" id="editRole" class="field-select js-role-select" data-target="edit" required>
                                @foreach (var r in Model.Roles)
                                {
                                    <option value="@r.RoleId" data-rolename="@r.RoleName">@r.RoleName</option>
                                }
                            </select>
                        </div>
                        <div class="field-group">
                            <label class="field-label">New Avatar (optional)</label>
                            <input name="Avatar" type="file" accept="image/*" class="field-input" />
                        </div>
                    </div>

                    <div class="field-row full">
                        <div class="field-group">
                            <label class="toggle-group" style="cursor:pointer">
                                <input type="checkbox" name="ResetPassword" value="true" />
                                <span class="toggle-label">Reset password to default <strong>123456</strong></span>
                            </label>
                        </div>
                    </div>

                    <!-- VET SECTION (license & experience are read-only) -->
                    <div class="vet-section" id="editVetSection" style="display:none">
                        <p class="modal-vet-hint mb-2"><i class="bi bi-heart-pulse"></i> Veterinarian profile
                            — license, experience years &amp; rating cannot be changed here.</p>
                        <div class="field-row">
                            <div class="field-group">
                                <label class="field-label">License Number</label>
                                <input id="editLicense" class="field-value" disabled />
                            </div>
                            <div class="field-group">
                                <label class="field-label">Experience Years</label>
                                <input id="editExperience" class="field-value" disabled />
                            </div>
                        </div>
                        <div class="field-row full">
                            <div class="field-group">
                                <label class="field-label">Description</label>
                                <textarea name="Description" id="editDescription" class="field-input" rows="2"
                                          maxlength="255"></textarea>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn-cancel" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn-submit warning"><i class="bi bi-check-lg"></i> Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

@* ════════════════════════ DELETE MODAL ════════════════════════ *@
<div class="modal fade" id="deleteStaffModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="Delete" method="post" id="deleteStaffForm">
                <input type="hidden" name="id" id="deleteStaffId" />
                <div class="modal-header">
                    <h5 class="modal-title text-danger"><i class="bi bi-exclamation-triangle"></i> Confirm Delete</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to deactivate <strong id="deleteStaffName"></strong>?</p>
                    <p class="modal-vet-hint">This is a soft delete — the account will be set to inactive and can be reactivated later.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn-cancel" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn-submit danger"><i class="bi bi-trash"></i> Yes, Deactivate</button>
                </div>
            </form>
        </div>
    </div>
</div>

@* ════════════════════════ VIEW DETAIL MODAL ════════════════════════ *@
<div class="modal fade" id="viewStaffModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-person-vcard"></i> Staff Detail</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="detail-section-title"><i class="bi bi-person"></i> Account Information</div>
                <div class="detail-grid">
                    <div class="field-group"><label class="field-label">Full Name</label>
                        <div class="field-value" id="vFullName">—</div></div>
                    <div class="field-group"><label class="field-label">Status</label>
                        <div class="field-value" id="vStatus">—</div></div>
                    <div class="field-group"><label class="field-label">Email</label>
                        <div class="field-value" id="vEmail">—</div></div>
                    <div class="field-group"><label class="field-label">Phone Number</label>
                        <div class="field-value" id="vPhone">—</div></div>
                    <div class="field-group"><label class="field-label">Gender</label>
                        <div class="field-value" id="vGender">—</div></div>
                    <div class="field-group"><label class="field-label">Role</label>
                        <div class="field-value" id="vRole">—</div></div>
                    <div class="field-group"><label class="field-label">Birth Date</label>
                        <div class="field-value" id="vBirth">—</div></div>
                    <div class="field-group"><label class="field-label">Hire Date</label>
                        <div class="field-value" id="vHire">—</div></div>
                    <div class="field-group"><label class="field-label">Created At</label>
                        <div class="field-value" id="vCreated">—</div></div>
                    <div class="field-group"><label class="field-label">Updated At</label>
                        <div class="field-value" id="vUpdated">—</div></div>
                </div>

                <div id="vVetWrap" style="display:none">
                    <div class="detail-section-title" style="margin-top:24px">
                        <i class="bi bi-heart-pulse"></i> Veterinarian Profile
                    </div>
                    <div class="detail-grid">
                        <div class="field-group"><label class="field-label">License Number</label>
                            <div class="field-value" id="vLicense">—</div></div>
                        <div class="field-group"><label class="field-label">Experience Years</label>
                            <div class="field-value" id="vExperience">—</div></div>
                        <div class="field-group"><label class="field-label">Rating (from appointments)</label>
                            <div class="field-value" id="vRating">—</div></div>
                        <div class="field-group"><label class="field-label">Description</label>
                            <div class="field-value" id="vDescription">—</div></div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-cancel" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // ── Vet section toggle (shared by create & edit) ──
        function toggleVet(target) {
            var select = document.querySelector('.js-role-select[data-target="' + target + '"]');
            if (!select) return;
            var opt = select.options[select.selectedIndex];
            var isVet = opt && opt.getAttribute('data-rolename') === 'Veterinarian';

            var section = document.getElementById(target === 'create' ? 'createVetSection' : 'editVetSection');
            if (section) section.style.display = isVet ? 'block' : 'none';

            if (target === 'create') {
                document.querySelectorAll('.js-vet-create').forEach(function (el) {
                    el.required = isVet;
                    if (!isVet) el.value = '';
                });
            }
        }

        document.querySelectorAll('.js-role-select').forEach(function (sel) {
            sel.addEventListener('change', function () { toggleVet(this.getAttribute('data-target')); });
        });

        // ── In-modal error helpers ──
        function showModalError(form, msg) {
            var box = form.querySelector('.js-modal-error');
            if (!box) { alert(msg); return; }
            box.textContent = msg;
            box.style.display = 'block';
            box.scrollIntoView({ block: 'nearest' });
        }
        function clearModalError(form) {
            var box = form.querySelector('.js-modal-error');
            if (box) { box.textContent = ''; box.style.display = 'none'; }
        }

        // ── AJAX submit: keep modal open & show server errors inline ──
        async function ajaxSubmit(form, btn) {
            var original = btn ? btn.innerHTML : '';
            if (btn) { btn.disabled = true; btn.innerHTML = '<i class="bi bi-hourglass-split"></i> Saving...'; }
            try {
                var res = await fetch(form.action, { method: 'POST', body: new FormData(form) });
                var json = await res.json();
                if (json.success) { window.location.reload(); return; }
                showModalError(form, json.message || 'An error occurred. Please try again.');
            } catch (err) {
                showModalError(form, 'Request failed: ' + err.message);
            } finally {
                if (btn) { btn.disabled = false; btn.innerHTML = original; }
            }
        }

        // ── Create submit (HTML5 validation runs before this fires) ──
        document.getElementById('createStaffForm').addEventListener('submit', function (e) {
            e.preventDefault();
            clearModalError(this);
            var pwd = this.querySelector('[name="Password"]').value;
            var cfm = this.querySelector('[name="ConfirmPassword"]').value;
            if (pwd !== cfm) { showModalError(this, 'The password and confirmation password do not match.'); return; }
            ajaxSubmit(this, this.querySelector('button[type="submit"]'));
        });

        // ── Edit submit ──
        document.getElementById('editStaffForm').addEventListener('submit', function (e) {
            e.preventDefault();
            clearModalError(this);
            ajaxSubmit(this, this.querySelector('button[type="submit"]'));
        });

        // ── Delete modal ──
        document.querySelectorAll('.js-delete').forEach(function (btn) {
            btn.addEventListener('click', function () {
                document.getElementById('deleteStaffId').value = this.dataset.id;
                document.getElementById('deleteStaffName').textContent = this.dataset.name;
                new bootstrap.Modal(document.getElementById('deleteStaffModal')).show();
            });
        });

        // ── Edit modal: fetch detail & prefill ──
        document.querySelectorAll('.js-edit').forEach(function (btn) {
            btn.addEventListener('click', async function () {
                var id = this.dataset.id;
                var form = document.getElementById('editStaffForm');
                clearModalError(form);
                try {
                    var res = await fetch('/Staff/GetDetail?id=' + id);
                    var json = await res.json();
                    if (!json.success) { alert(json.message || 'Failed to load staff.'); return; }
                    var d = json.data;

                    document.getElementById('editStaffId').value = d.staffId;
                    document.getElementById('editFullName').value = d.fullName || '';
                    document.getElementById('editEmail').value = d.email || '';
                    document.getElementById('editPhone').value = d.phoneNumber || '';
                    document.getElementById('editGender').value = d.gender || 'Male';
                    document.getElementById('editBirthDate').value = (d.birthDate || '').substring(0, 10);
                    document.getElementById('editHireDate').value = (d.hireDate || '').substring(0, 10);
                    if (d.roleId) document.getElementById('editRole').value = d.roleId;

                    var vet = d.vetProfile;
                    document.getElementById('editLicense').value = vet ? (vet.licenseNumber || '') : '';
                    document.getElementById('editExperience').value = vet ? (vet.experienceYears ?? '') : '';
                    document.getElementById('editDescription').value = vet ? (vet.description || '') : '';

                    toggleVet('edit');
                    new bootstrap.Modal(document.getElementById('editStaffModal')).show();
                } catch (err) {
                    alert('Error loading staff: ' + err.message);
                }
            });
        });

        // ── View detail modal ──
        function fmtDate(s) { return s ? s.substring(0, 10).split('-').reverse().join('/') : '—'; }
        function fmtDateTime(s) {
            if (!s) return '—';
            var d = new Date(s);
            if (isNaN(d.getTime())) return s;
            var p = function (n) { return ('0' + n).slice(-2); };
            return p(d.getDate()) + '/' + p(d.getMonth() + 1) + '/' + d.getFullYear() + ' ' + p(d.getHours()) + ':' + p(d.getMinutes());
        }
        document.querySelectorAll('.js-view').forEach(function (btn) {
            btn.addEventListener('click', async function () {
                try {
                    var res = await fetch('/Staff/GetDetail?id=' + this.dataset.id);
                    var json = await res.json();
                    if (!json.success) { alert(json.message || 'Failed to load staff.'); return; }
                    var d = json.data;
                    document.getElementById('vFullName').textContent = d.fullName || '—';
                    document.getElementById('vFullName').setAttribute('title', d.fullName || '');
                    document.getElementById('vStatus').innerHTML = d.isActive
                        ? '<span class="badge-status badge-active"><span class="badge-dot"></span> Active</span>'
                        : '<span class="badge-status badge-inactive"><span class="badge-dot"></span> Inactive</span>';
                    document.getElementById('vEmail').textContent = d.email || '—';
                    document.getElementById('vEmail').setAttribute('title', d.email || '');
                    document.getElementById('vPhone').textContent = d.phoneNumber || '—';
                    document.getElementById('vPhone').setAttribute('title', d.phoneNumber || '');
                    document.getElementById('vGender').textContent = d.gender || '—';
                    document.getElementById('vGender').setAttribute('title', d.gender || '');
                    document.getElementById('vRole').textContent = d.roleName || '—';
                    document.getElementById('vRole').setAttribute('title', d.roleName || '');
                    document.getElementById('vBirth').textContent = fmtDate(d.birthDate);
                    document.getElementById('vHire').textContent = fmtDate(d.hireDate);
                    document.getElementById('vCreated').textContent = fmtDateTime(d.createdAt);
                    document.getElementById('vUpdated').textContent = d.updatedAt ? fmtDateTime(d.updatedAt) : 'Never';

                    var vet = d.vetProfile;
                    var wrap = document.getElementById('vVetWrap');
                    if (vet) {
                        wrap.style.display = 'block';
                        document.getElementById('vLicense').textContent = vet.licenseNumber || '—';
                        document.getElementById('vLicense').setAttribute('title', vet.licenseNumber || '');
                        document.getElementById('vExperience').textContent = (vet.experienceYears ?? 0);
                        document.getElementById('vRating').textContent = '★ ' + (vet.rating ?? 0) + ' / 5';
                        document.getElementById('vDescription').textContent = vet.description || '—';
                        document.getElementById('vDescription').setAttribute('title', vet.description || '');
                    } else {
                        wrap.style.display = 'none';
                    }
                    new bootstrap.Modal(document.getElementById('viewStaffModal')).show();
                } catch (err) {
                    alert('Error loading staff: ' + err.message);
                }
            });
        });
    </script>
}
