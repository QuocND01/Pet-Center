@model PetCenterClient.DTOs.StaffDetailDto
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Staff Detail";
    var initials = string.Join("", (Model.FullName ?? "")
        .Split(' ', StringSplitOptions.RemoveEmptyEntries)
        .Take(2).Select(w => w[0].ToString().ToUpper()));
}

<link rel="stylesheet" href="~/css/AdminViews/ManageStaff/manage-staff.css" asp-append-version="true" />

<div class="form-page-wrapper">
    <a asp-action="Index" class="back-link"><i class="bi bi-arrow-left"></i> Back to list</a>

    <div class="form-card">
        <div class="form-card-header">
            @if (!string.IsNullOrEmpty(Model.Avatar))
            {
                <img src="@Model.Avatar" style="width:42px;height:42px;border-radius:10px;object-fit:cover" alt="avatar" />
            }
            else
            {
                <div class="form-card-header-icon">@initials</div>
            }
            <div style="flex:1">
                <h2>@Model.FullName</h2>
                <p>
                    @(Model.RoleName ?? "No role") ·
                    @if (Model.IsActive)
                    {
                        <span class="badge-status badge-active"><span class="badge-dot"></span> Active</span>
                    }
                    else
                    {
                        <span class="badge-status badge-inactive"><span class="badge-dot"></span> Inactive</span>
                    }
                </p>
            </div>
        </div>

        <div class="form-card-body">
            <div class="detail-section-title"><i class="bi bi-person"></i> Account Information</div>
            <div class="detail-grid">
                <div class="field-group">
                    <label class="field-label">Email</label>
                    <div class="field-value" title="@Model.Email">@Model.Email</div>
                </div>
                <div class="field-group">
                    <label class="field-label">Phone Number</label>
                    <div class="field-value" title="@Model.PhoneNumber">@Model.PhoneNumber</div>
                </div>
                <div class="field-group">
                    <label class="field-label">Gender</label>
                    <div class="field-value" title="@Model.Gender">@(Model.Gender ?? "—")</div>
                </div>
                <div class="field-group">
                    <label class="field-label">Role</label>
                    <div class="field-value" title="@Model.RoleName">@(Model.RoleName ?? "—")</div>
                </div>
                <div class="field-group">
                    <label class="field-label">Birth Date</label>
                    <div class="field-value">@Model.BirthDate.ToString("dd/MM/yyyy")</div>
                </div>
                <div class="field-group">
                    <label class="field-label">Hire Date</label>
                    <div class="field-value">@Model.HireDate.ToString("dd/MM/yyyy")</div>
                </div>
                <div class="field-group">
                    <label class="field-label">Created At</label>
                    <div class="field-value">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div>
                </div>
                <div class="field-group">
                    <label class="field-label">Updated At</label>
                    <div class="field-value @(Model.UpdatedAt == null ? "empty" : "")">
                        @(Model.UpdatedAt?.ToString("dd/MM/yyyy HH:mm") ?? "Never")
                    </div>
                </div>
            </div>

            @if (Model.VetProfile != null)
            {
                <div class="detail-section-title" style="margin-top:28px">
                    <i class="bi bi-heart-pulse"></i> Veterinarian Profile
                </div>
                <div class="detail-grid">
                    <div class="field-group">
                        <label class="field-label">License Number</label>
                        <div class="field-value @(string.IsNullOrEmpty(Model.VetProfile.LicenseNumber) ? "empty" : "")" title="@Model.VetProfile.LicenseNumber">
                            @(string.IsNullOrEmpty(Model.VetProfile.LicenseNumber) ? "—" : Model.VetProfile.LicenseNumber)
                        </div>
                    </div>
                    <div class="field-group">
                        <label class="field-label">Experience Years</label>
                        <div class="field-value">@(Model.VetProfile.ExperienceYears?.ToString("0.##") ?? "0")</div>
                    </div>
                    <div class="field-group">
                        <label class="field-label">Rating (from appointments)</label>
                        <div class="field-value">
                            <i class="bi bi-star-fill" style="color:#f59e0b"></i> @Model.VetProfile.Rating.ToString("0.0") / 5
                        </div>
                    </div>
                    <div class="field-group">
                        <label class="field-label">Description</label>
                        <div class="field-value multiline @(string.IsNullOrEmpty(Model.VetProfile.Description) ? "empty" : "")" title="@Model.VetProfile.Description">
                            @(string.IsNullOrEmpty(Model.VetProfile.Description) ? "—" : Model.VetProfile.Description)
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="form-card-footer">
            <a asp-action="Index" class="btn-cancel">Back to list</a>
        </div>
    </div>
</div>
