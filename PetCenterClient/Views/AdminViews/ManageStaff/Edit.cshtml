@model PetCenterClient.DTOs.StaffDto
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h4>@(Model?.StaffId == Guid.Empty || Model == null ? "Add New Staff" : "Edit Staff")</h4>
        </div>
        <div class="card-body">
            <form asp-action="@(ViewContext.RouteData.Values["action"])">
                <input type="hidden" asp-for="StaffId" />
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label font-weight-bold">Full Name</label>
                        <input asp-for="FullName" class="form-control" required />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label font-weight-bold">Email</label>
                        <input asp-for="Email" type="email" class="form-control" required />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label font-weight-bold">Phone Number</label>
                        <input asp-for="PhoneNumber" class="form-control" required />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label font-weight-bold">Gender</label>
                        <select asp-for="Gender" class="form-control">
                            <option value="Male">Male</option>
                            <option value="Female">Female</option>
                            <option value="Other">Other</option>
                        </select>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="BirthDay" class="form-label font-weight-bold">Birthday</label>
                        <input asp-for="BirthDay" type="date" class="form-control" asp-format="{0:yyyy-MM-dd}" />
                        <span asp-validation-for="BirthDay" class="text-danger"></span>
                    </div>
                    @if (ViewContext.RouteData.Values["action"]?.ToString() == "Create")
                    {
                        <div class="col-md-6 mb-3">
                            <label class="form-label font-weight-bold">Password</label>
                            <input asp-for="Password" type="password" class="form-control" required />
                        </div>
                    }
                    <div class="col-md-6 mb-3 d-flex align-items-end">
                        <div class="form-check">
                            <input asp-for="IsActive" class="form-check-input" type="checkbox" checked />
                            <label class="form-check-label">Is Active</label>
                        </div>
                    </div>
                </div>
                <div class="mt-3">
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
                </div>
            </form>
        </div>
    </div>
</div>