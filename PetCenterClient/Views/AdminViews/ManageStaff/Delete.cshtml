@model PetCenterClient.DTOs.StaffDto
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container mt-4">
    <div class="alert alert-danger shadow">
        <h3><i class="bi bi-exclamation-triangle"></i> Are you sure?</h3>
        <p>You are about to delete staff: <strong>@Model.FullName</strong></p>
        <hr>
        <div class="row">
            <div class="col-sm-3">Email:</div>
            <div class="col-sm-9">@Model.Email</div>
        </div>

        <form asp-action="Delete" method="post" class="mt-4">
            <input type="hidden" asp-for="StaffId" />
            <button type="submit" class="btn btn-danger btn-lg">Confirm Delete</button>
            <a asp-action="Index" class="btn btn-secondary btn-lg">Cancel</a>
        </form>
    </div>
</div>