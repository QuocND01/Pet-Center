@model PetCenterClient.ViewModels.Service.ServiceViewModel.ReadServiceViewModel

<style>

    .confirm-container {
        padding: 10px;
    }

    .confirm-icon {
        width: 70px;
        height: 70px;
        margin: 0 auto 20px;
        border-radius: 50%;
        background: rgba(220,53,69,.12);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 32px;
        color: #dc3545;
    }

    .confirm-title {
        font-size: 22px;
        font-weight: 700;
        color: #212529;
    }

    .confirm-message {
        color: #6c757d;
        margin-top: 8px;
        margin-bottom: 25px;
    }

    .service-card {
        border: 1px solid #e9ecef;
        border-radius: 18px;
        padding: 20px;
        background: #fafafa;
        text-align: center;
    }

    .service-image {
        width: 150px;
        height: 150px;
        object-fit: cover;
        border-radius: 18px;
        border: 3px solid #fff;
        box-shadow: 0 5px 20px rgba(0,0,0,.1);
    }

    .service-name {
        margin-top: 15px;
        font-size: 22px;
        font-weight: 700;
        color: #212529;
        white-space: normal;
        overflow-wrap: anywhere;
    }

    .service-price {
        font-size: 18px;
        font-weight: 600;
        color: #198754;
        margin-top: 8px;
    }

    .status-badge {
        display: inline-block;
        margin-top: 12px;
        padding: 6px 14px;
        border-radius: 999px;
        background: #fff3cd;
        color: #856404;
        font-size: 13px;
        font-weight: 600;
    }

    .info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
        margin-top: 20px;
        text-align: left;
    }

    .info-item {
        background: #fff;
        border-radius: 12px;
        min-width: 0;
        padding: 12px;
        border: 1px solid #e9ecef;
    }

    .info-label {
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
        color: #6c757d;
        margin-bottom: 4px;
    }

    .info-value {
        font-size: 15px;
        color: #212529;
        white-space: normal;
        overflow-wrap: anywhere;
    }

    .btn-confirm {
        min-width: 130px;
        border-radius: 10px;
        font-weight: 600;
    }

    .btn-cancel {
        min-width: 130px;
        border-radius: 10px;
        font-weight: 600;
    }

    .service-card {
        overflow: hidden;
    }

</style>

<form asp-action="ChangeStatusConfirmed"
      asp-controller="Service"
      method="post">

     
    @Html.AntiForgeryToken()

    <input type="hidden"
           name="id"
           value="@Model.ServiceId" />

    <input type="hidden"
           name="status"
           value="@((int)ViewBag.Status)" />

    <div class="confirm-container">

        <div class="text-center">

            <div class="confirm-icon">
                <i class="bi bi-exclamation-triangle-fill"></i>
            </div>

            <div class="confirm-title">
                Change Service Status
            </div>

            <div class="confirm-message">
                Are you sure you want to change the status of this service?
            </div>

        </div>

        <div class="service-card">

            @if (Model.ImageFiles != null && Model.ImageFiles.Any())
            {
                <img src="@Model.ImageFiles.First()"
                     class="service-image"
                     alt="Service Image" />
            }
            else
            {
                <img src="https://via.placeholder.com/150?text=Service"
                     class="service-image"
                     alt="No Image" />
            }

            <div class="service-name">
                @Model.ServiceName
            </div>

            <div class="service-price">
                @Model.Price.ToString("N0") ₫
            </div>

            <div class="status-badge">
                New Status: @ViewBag.Status
            </div>

            <div class="info-grid">

                <div class="info-item">
                    <div class="info-label">
                        Duration
                    </div>

                    <div class="info-value">
                        @Model.Duration minutes
                    </div>
                </div>

                <div class="info-item">
                    <div class="info-label">
                        Service Type
                    </div>

                    <div class="info-value">
                        @(Model.ServiceType == 1 ? "Grooming" : "Vet")
                    </div>
                </div>

            </div>

        </div>

        <div class="d-flex justify-content-end gap-2 mt-4">

            <button type="button"
                    class="btn btn-outline-secondary btn-cancel"
                    data-bs-dismiss="modal">

                Cancel

            </button>

            <button type="submit"
                    class="btn btn-danger btn-confirm">

                <i class="bi bi-check-circle-fill me-1"></i>
                Confirm

            </button>

        </div>

    </div>
     

</form>
