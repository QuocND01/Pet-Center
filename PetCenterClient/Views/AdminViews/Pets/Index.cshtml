@using PetCenterClient.ViewModels
@model IEnumerable<ReadVetPetListViewModel>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Pet Directory";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold m-0">🐾 Clinic Patients</h3>
        <button class="btn btn-primary" onclick="openVetMutateModal(null)">+ Register New Patient</button>
    </div>

    <div class="card shadow-sm border-0 mb-4 bg-light">
        <div class="card-body p-3">
            <form method="get" action="/VetPets/Index" class="d-flex gap-2 w-50">
                <input type="text" name="search" class="form-control" placeholder="Search by breed, species, or owner name..." value="@ViewBag.SearchKeyword" />
                <button type="submit" class="btn btn-dark px-4">Search</button>
                @if (!string.IsNullOrEmpty(ViewBag.SearchKeyword))
                {
                    <a href="/VetPets/Index" class="btn btn-outline-secondary">Clear</a>
                }
            </form>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <table class="table table-hover align-middle m-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Pet Info</th>
                        <th>Species / Breed</th>
                        <th>Age / Gender</th>
                        <th>Owner Info</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var pet in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center gap-3">
                                        <div style="width:45px; height:45px; border-radius:50%; background:#f1f5f9; display:flex; align-items:center; justify-content:center; overflow:hidden;">
                                            @if (!string.IsNullOrEmpty(pet.PetAvatar))
                                            {
                                                <img src="@pet.PetAvatar" style="width:100%; height:100%; object-fit:cover;" />
                                            }
                                            else
                                            {
                                                <span class="fs-5">@(pet.Species.ToLower() == "cat" ? "🐱" : "🐶")</span>
                                            }
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="fw-bold text-dark">@pet.PetName</div>
                                    <small class="text-muted">@pet.Breed</small>
                                </td>
                                <td>
                                    <div>@pet.Gender</div>
                                    <span class="badge bg-secondary">@pet.Age</span>
                                </td>
                                <td>
                                    <div class="fw-bold">👤 @pet.OwnerName</div>
                                    <small class="text-muted">📞 @pet.OwnerPhone</small>
                                </td>
                                <td class="text-end pe-4">
                                    <button class="btn btn-sm btn-light btn-view-vet-pet" data-id="@pet.PetId" title="Medical Profile">
                                        <!-- medical file SVG -->
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                                            <path d="M8 0a2 2 0 0 0-2 2v1H3.5A1.5 1.5 0 0 0 2 4.5v9A1.5 1.5 0 0 0 3.5 15h9A1.5 1.5 0 0 0 14 13.5v-9A1.5 1.5 0 0 0 12.5 3H10V2a2 2 0 0 0-2-2z"/>
                                        </svg>
                                    </button>
                                    <button class="btn btn-sm btn-outline-dark" onclick="openVetMutateModal('@pet.PetId')" title="Edit">
                                        <!-- pencil SVG -->
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                                            <path d="M12.146.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-9.5 9.5a.5.5 0 0 1-.233.13l-5 1a.5.5 0 0 1-.606-.606l1-5a.5.5 0 0 1 .13-.233l9.5-9.5z"/>
                                        </svg>
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger" onclick="deleteVetPet('@pet.PetId')" title="Delete (soft delete)">
                                        <!-- trash SVG -->
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                                            <path d="M5.5 5.5a.5.5 0 0 1 .5-.5h4a.5.5 0 0 1 0 1H6a.5.5 0 0 1-.5-.5z"/>
                                            <path d="M6.5 4a.5.5 0 0 1 .5-.5h2a.5.5 0 0 1 .5.5V13a1 1 0 0 1-1 1h-1a1 1 0 0 1-1-1V4z"/>
                                        </svg>
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="5" class="text-center py-5 text-muted">No patient records found.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="vetPetDetailModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content" style="border-radius: 12px; border:none;" id="vetPetModalBody"></div>
    </div>
</div>

<div class="modal fade" id="vetMutatePetModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius: 15px; border:none; box-shadow: 0 10px 40px rgba(0,0,0,0.1);">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold" id="vetMutateModalTitle">Register Patient</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <input type="hidden" id="vMutPetId" />
                <div class="row g-3">

                    <div class="col-12" id="customerInputGroup">
                        <label class="form-label text-muted fw-bold" style="font-size: 13px;">OWNER</label>
                        <select id="vMutCustomerId" class="form-select bg-light border-0">
                            <option value="">-- Select an owner --</option>
                        </select>
                        <small class="text-warning">* Required when registering a new pet.</small>
                    </div>

                    <div class="col-12">
                        <label class="form-label text-muted fw-bold" style="font-size: 13px;">PET NAME</label>
                        <input type="text" id="vMutPetName" class="form-control bg-light border-0" placeholder="Pet's name">
                    </div>

                    <div class="col-12">
                        <label class="form-label text-muted fw-bold" style="font-size: 13px;">PET AVATAR</label>
                        <input type="file" id="vMutImage" class="form-control bg-light border-0" accept="image/*">
                    </div>

                    <div class="col-6">
                        <label class="form-label text-muted fw-bold" style="font-size: 13px;">SPECIES</label>
                        <select id="vMutSpecies" class="form-select bg-light border-0">
                            <option value="Dog">Dog</option>
                            <option value="Cat">Cat</option>
                        </select>
                    </div>
                    <div class="col-6">
                        <label class="form-label text-muted fw-bold" style="font-size: 13px;">GENDER</label>
                        <select id="vMutGender" class="form-select bg-light border-0">
                            <option value="Male">Male</option>
                            <option value="Female">Female</option>
                        </select>
                    </div>
                    <div class="col-12">
                        <label class="form-label text-muted fw-bold" style="font-size: 13px;">BREED</label>
                        <input type="text" id="vMutBreed" class="form-control bg-light border-0">
                    </div>
                    <div class="col-6">
                        <label class="form-label text-muted fw-bold" style="font-size: 13px;">BIRTHDAY</label>
                        <input type="date" id="vMutDob" class="form-control bg-light border-0">
                    </div>
                    <div class="col-6">
                        <label class="form-label text-muted fw-bold" style="font-size: 13px;">WEIGHT (kg)</label>
                        <input type="number" step="0.1" id="vMutWeight" class="form-control bg-light border-0">
                    </div>
                    <div class="col-12">
                        <label class="form-label text-muted fw-bold" style="font-size: 13px;">MEDICAL NOTES</label>
                        <textarea id="vMutNote" class="form-control bg-light border-0" rows="2"></textarea>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary px-4" onclick="saveVetPet()">Save Record</button>
            </div>
        </div>
    </div>
</div>

<script>
    // Shared helper to populate modal inputs for pet mutate forms (copied here so admin view can use it)
    function populatePetModal(data, prefix) {
        const v = (obj, camel, pascal) => (obj && obj[camel] !== undefined ? obj[camel] : (obj && pascal && obj[pascal] !== undefined ? obj[pascal] : undefined));
        const set = (id, value) => { const el = document.getElementById(id); if (el) el.value = value ?? ''; };

        set(prefix + 'PetName', v(data, 'petName', 'PetName') || '');
        set(prefix + 'Species', v(data, 'species', 'Species') || 'Dog');
        set(prefix + 'Breed', v(data, 'breed', 'Breed') || '');
        set(prefix + 'Gender', v(data, 'gender', 'Gender') || 'Male');

        const dobVal = v(data, 'dateOfBirth', 'DateOfBirth');
        if (dobVal) {
            const dt = new Date(dobVal);
            if (!isNaN(dt)) {
                const month = (dt.getMonth() + 1).toString().padStart(2, '0');
                const day = dt.getDate().toString().padStart(2, '0');
                set(prefix + 'Dob', dt.getFullYear() + '-' + month + '-' + day);
            } else {
                set(prefix + 'Dob', '');
            }
        } else {
            set(prefix + 'Dob', '');
        }

        set(prefix + 'Weight', (v(data, 'weight', 'Weight') ?? ''));
        set(prefix + 'Note', (v(data, 'note', 'Note') ?? ''));
    }

    document.addEventListener("click", function (e) {
        var btnView = e.target.closest(".btn-view-vet-pet");
        if (btnView) {
            var petId = btnView.getAttribute("data-id");
            var modalBody = document.getElementById("vetPetModalBody");
            var modal = new bootstrap.Modal(document.getElementById('vetPetDetailModal'));
            modalBody.innerHTML = "<div class='text-center py-5'><div class='spinner-border text-primary'></div></div>";
            modal.show();
            fetch('/VetPets/Details/' + petId)
                .then(r => r.text())
                .then(html => modalBody.innerHTML = html);
        }
    });

    function deleteVetPet(id) {
        if (confirm("Are you sure you want to delete this patient's record? This is a soft delete.")) {
            fetch('/VetPets/Delete/' + id, { method: 'POST' })
            .then(r => r.json())
            .then(d => {
                if (d.success) location.reload();
                else alert("Failed to delete.");
            });
        }
    }

    var vetMutateModal;
    function openVetMutateModal(id) {
        if (!vetMutateModal) vetMutateModal = new bootstrap.Modal(document.getElementById('vetMutatePetModal'));
        document.getElementById('vMutPetId').value = id || '';
        document.getElementById('vetMutateModalTitle').innerText = id ? 'Edit Patient Record' : 'Register New Patient';

        document.getElementById('customerInputGroup').style.display = id ? 'none' : 'block';

        // Reset file input
        document.getElementById('vMutImage').value = '';

        if (!id) {
            document.getElementById('vMutCustomerId').value = '';
            document.getElementById('vMutPetName').value = '';
            document.getElementById('vMutBreed').value = '';
            document.getElementById('vMutDob').value = '';
            document.getElementById('vMutWeight').value = '';
            document.getElementById('vMutNote').value = '';
            vetMutateModal.show();
            } else {
            // editing: fetch pet details from API and prefill
            fetch('/VetPets/GetJson/' + id)
                .then(r => { if (!r.ok) throw new Error('failed'); return r.json(); })
                .then(data => {
                    populatePetModal(data, 'vMut');
                })
                .catch(err => console.log('[openVetMutateModal] fetch error', err))
                .finally(() => vetMutateModal.show());
        }
        // Load customers into select when opening for create
        if (!id) {
            fetch('/Customer/GetAll')
                .then(r => r.json())
                .then(list => {
                    var sel = document.getElementById('vMutCustomerId');
                    sel.innerHTML = '<option value="">-- Select an owner --</option>';
                    list.forEach(function (c) {
                        var opt = document.createElement('option');
                        opt.value = c.id;
                        opt.text = c.text;
                        sel.appendChild(opt);
                    });
                });
        }
    }

    function saveVetPet() {
        var id = document.getElementById('vMutPetId').value;
        var customerId = document.getElementById('vMutCustomerId').value;
        var petName = document.getElementById('vMutPetName').value;

        if(!id && !customerId) return alert("Please select an owner for new pets!");
        if(!petName) return alert("Pet name is required!");
        if(!document.getElementById('vMutBreed').value) return alert("Breed is required!");

        // Dùng FormData thay vì JSON
        var formData = new FormData();
        formData.append('Species', document.getElementById('vMutSpecies').value);
        formData.append('Gender', document.getElementById('vMutGender').value);
        formData.append('Breed', document.getElementById('vMutBreed').value);
        formData.append('PetName', petName);

        var dob = document.getElementById('vMutDob').value;
        if(dob) formData.append('DateOfBirth', dob);

        var weight = document.getElementById('vMutWeight').value;
        if(weight) formData.append('Weight', weight);

        var note = document.getElementById('vMutNote').value;
        if(note) formData.append('Note', note);

        // Nạp file ảnh nếu có
        var fileInput = document.getElementById('vMutImage');
        if (fileInput.files.length > 0) {
            formData.append('ImageFile', fileInput.files[0]);
        }

        var url = id ? '/VetPets/Update/' + id : '/VetPets/Add?customerId=' + customerId;

        fetch(url, {
            method: 'POST',
            body: formData // Không set header Content-Type
        })
        .then(r => r.json())
        .then(d => {
            if (d.success) location.reload();
            else alert("Failed to save.");
        });
    }
</script>