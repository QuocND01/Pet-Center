@using PetCenterClient.ViewModels
@model ReadVetPetDetailViewModel

<div class="modal-header bg-light">
    <h5 class="modal-title fw-bold">🏥 Patient Medical Profile</h5>
    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
</div>
<div class="modal-body p-4">
    <div class="row mb-4">
        <div class="col-md-3 text-center">
            <div style="width:120px; height:120px; border-radius:50%; background:#e2e8f0; display:inline-flex; align-items:center; justify-content:center; overflow:hidden; border: 4px solid white; box-shadow: 0 4px 10px rgba(0,0,0,0.1);">
                @if (!string.IsNullOrEmpty(Model.PetAvatar))
                {
                    <img src="@Model.PetAvatar" style="width:100%; height:100%; object-fit:cover;" />
                }
                else
                {
                    <span style="font-size: 50px;">@(Model.Species.ToLower() == "cat" ? "🐈" : "🐕")</span>
                }
            </div>
        </div>
        <div class="col-md-9 d-flex flex-column justify-content-center">
            <h3 class="fw-bold text-dark mb-1">@Model.PetName</h3>
            <p class="text-muted mb-2">@Model.Breed • @Model.Species • @Model.Gender • @Model.Age</p>
            <div class="d-flex gap-3">
                <span class="badge bg-primary fs-6">DOB: @(Model.DateOfBirth?.ToString("MMM dd, yyyy") ?? "Unknown")</span>
                <span class="badge bg-success fs-6">Weight: @(Model.Weight?.ToString("0.0") ?? "--") kg</span>
            </div>
        </div>
    </div>

    <div class="card bg-light border-0 mb-4">
        <div class="card-body">
            <h6 class="fw-bold text-uppercase text-secondary mb-3"><i class="bi bi-person-badge"></i> Owner Information</h6>
            <div class="row">
                <div class="col-6">
                    <small class="text-muted d-block">Owner Name</small>
                    <span class="fw-bold fs-5">@Model.OwnerName</span>
                </div>
                <div class="col-6">
                    <small class="text-muted d-block">Contact Phone</small>
                    <span class="fw-bold fs-5 text-primary">@Model.OwnerPhone</span>
                </div>
            </div>
        </div>
    </div>

    <div>
        <h6 class="fw-bold text-uppercase text-secondary mb-2"><i class="bi bi-journal-medical"></i> Medical Notes / Alerts</h6>
        <div class="p-3 border rounded-3" style="background: #fffbea; border-color: #fef08a !important;">
            <p class="mb-0 text-dark" style="line-height: 1.6;">
                @(string.IsNullOrEmpty(Model.Note) ? "No medical alerts or notes recorded for this patient." : Model.Note)
            </p>
        </div>
    </div>
</div>
<div class="modal-footer bg-light border-0">
    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close Profile</button>
    <button type="button" class="btn btn-primary">+ Add Medical Record</button>
</div>