@model PetCenterClient.ViewModels.Appointment.AppointmentDetailViewModel
@{
    ViewData["Title"] = "Operation Track Detail";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    string statusText = Model.Status switch
    {
        0 => "Cancelled",
        1 => "Pending",
        2 => "Confirmed",
        3 => "In Progress",
        4 => "Completed",
        _ => "Unknown"
    };
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js"></script>

<style>
    .operation-wrapper {
        background-color: #f8f9fa;
        min-height: 100vh;
    }

    .status-banner {
        border-left: 4px solid #198754;
        background: #ffffff;
    }

    .service-card-item {
        border-left: 4px solid #198754;
        background: #fff;
        transition: all 0.2s;
    }

    .service-card-item.completed-state {
        border-left-color: #6c757d;
        opacity: 0.8;
        background: #fdfdfd;
    }

    .btn-emerald {
        background-color: #198754;
        color: white;
        border: none;
        font-weight: bold;
    }

    .btn-emerald:hover {
        background-color: #146c43;
        color: white;
    }

    .btn-emerald:disabled {
        background-color: #a3cfbb;
        color: white;
        cursor: not-allowed;
    }

    .status-indicator-box {
        padding: 0.5rem 1rem;
        border-radius: 8px;
        font-weight: bold;
        text-align: center;
    }

    /* FIX LỖI THIẾU MÀU CHO TRẠNG THÁI PIPELINE */
    .badge-status-0 { bg-color: #f8d7da; color: #842029; background-color: #f8d7da; }
    .badge-status-1 { bg-color: #fff3cd; color: #664d03; background-color: #fff3cd; }
    .badge-status-2 { bg-color: #cff4fc; color: #055160; background-color: #cff4fc; }
    .badge-status-3 { bg-color: #e0cffc; color: #350a4f; background-color: #e0cffc; }
    .badge-status-4 { bg-color: #d1e7dd; color: #0f5132; background-color: #d1e7dd; }
</style>

<div class="operation-wrapper py-5">
    <div class="container">

        <!-- MESSAGES -->
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show rounded-3 small mb-4" role="alert">
                <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show rounded-3 small mb-4" role="alert">
                <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <!-- BACK TO OVERVIEW -->
        <div class="mb-3">
            <a asp-action="StaffAppointments" class="text-success fw-bold text-decoration-none small">
                <i class="fas fa-chevron-left me-1"></i> Return to Console
            </a>
        </div>

        <div class="row g-4">
            <!-- CỘT TRÁI: THÔNG TIN PATIENT & LOGS DỊCH VỤ -->
            <div class="col-lg-8">

                <!-- BANNER THÔNG TIN CHUNG -->
                <div class="status-banner p-4 rounded-4 shadow-sm mb-4">
                    <span class="text-muted text-uppercase small fw-bold tracking-wider">Active Track Tracking</span>
                    <h2 class="fw-bold text-dark my-1">Patient: @Model.PetName</h2>
                    <p class="text-secondary small m-0"><i class="far fa-user me-1"></i><strong>Customer Account:</strong> @Model.CustomerName</p>
                    @if (!string.IsNullOrEmpty(Model.Note))
                    {
                        <div class="mt-3 p-3 bg-light rounded-3 text-secondary small">
                            <i class="far fa-comment-dots text-success me-1"></i> <strong>Medical Note:</strong> "@Model.Note"
                        </div>
                    }
                </div>

                <!-- CHI TIẾT CÁC HẠNG MỤC DỊCH VỤ CỦA LỊCH HẸN -->
                <div class="bg-white rounded-4 shadow-sm p-4 border-0">
                    <h5 class="fw-bold text-dark mb-3"><i class="fas fa-notes-medical text-success me-2"></i>Treatment Log / Services</h5>

                    <div class="d-flex flex-column gap-3">
                        @if (Model.AppointmentServices != null && Model.AppointmentServices.Any())
{
    foreach (var srv in Model.AppointmentServices)
    {
        // Bọc tính toán logic vào khối @{ } để tránh lỗi compile giao diện
        
            bool isSrvDone = (srv.Status == 2); 
        

        <div class="p-3 rounded-3 border service-card-item @(isSrvDone ? "completed-state" : "") shadow-sm d-flex justify-content-between align-items-center">
            <div>
                <h6 class="fw-bold text-dark mb-1">@srv.ServiceName</h6>
                <span class="text-muted small">@srv.Price.ToString("N0") đ • <i class="far fa-clock me-1"></i>@srv.Duration min</span>
            </div>
            <div>
                @if (isSrvDone)
                {
                    <span class="badge bg-success-subtle text-success border border-success-subtle p-2">
                        <i class="fas fa-check-circle me-1"></i>
                        Completed at: @(srv.CompleteAt.HasValue ? srv.CompleteAt.Value.ToString("HH:mm dd/MM/yyyy") : "N/A")
                    </span>
                }
                else
                {
                    if (Model.Status == 4)
                    {
                        <span class="badge bg-success-subtle text-success border border-success-subtle p-2">
                            <i class="fas fa-check-circle me-1"></i>Completed
                        </span>
                    }
                    else if (Model.Status == 3) 
                    {
                        <form asp-action="CompleteAppointmentService" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="appointmentId" value="@Model.AppointmentId" />
                            <input type="hidden" name="appointmentServiceId" value="@srv.AppointmentServiceId" />
                            <button type="submit" class="btn btn-emerald btn-sm rounded-2 px-3">
                                <i class="fas fa-check me-1"></i> Mark Done
                            </button>
                        </form>
                    }
                    else
                    {
                        <span class="text-muted small italic"><i class="fas fa-lock me-1"></i> Awaiting Step 3</span>
                    }
                }
            </div>
        </div>
    }
}
                    </div>
                </div>

            </div>

            <!-- CỘT PHẢI: BẢNG ĐIỀU KHIỂN TRẠNG THÁI (PIPELINE PROCESSOR) -->
            <div class="col-lg-4">
                <div class="bg-white rounded-4 shadow-sm p-4 border-0 text-center sticky-sidebar">
                    <h5 class="fw-bold text-dark pb-2 mb-3 border-bottom text-start"><i class="fas fa-shield-alt text-success me-2"></i>Workflow Action</h5>

                    <!-- BOX HIỂN THỊ TRẠNG THÁI HIỆN TẠI -->
                    <div class="mb-4">
                        <label class="text-muted small d-block mb-1 text-start fw-bold">Current Pipeline State</label>
                        <div class="status-indicator-box badge-status-@Model.Status shadow-sm">
                            State @Model.Status: @statusText
                        </div>
                    </div>

                    <!-- THỜI GIAN LÀM VIỆC -->
                    <div class="text-start p-3 bg-light rounded-3 mb-4 small">
                        <div class="mb-2"><strong><i class="far fa-calendar-alt text-success me-2"></i>Date:</strong> @Model.AppointmentStart.ToString("dd MMMM, yyyy")</div>
                        <div><strong><i class="far fa-clock text-success me-2"></i>Time Window:</strong> @Model.AppointmentStart.ToString("hh:mm tt")</div>
                    </div>

                    <!-- FORM SUBMIT TIẾN TRÌNH TIẾP THEO -->
                    @if (Model.Status > 0 && Model.Status < 4)
                    {
                        <form asp-action="ForwardAppointment" method="post" id="forwardWorkflowForm">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="appointmentId" value="@Model.AppointmentId" />

                            <button type="button" class="btn btn-emerald btn-lg w-100 shadow rounded-3 py-3" onclick="confirmWorkflowTransition()">
                                FORWARD PROGRESS <i class="fas fa-arrow-alt-circle-right ms-2"></i>
                            </button>
                        </form>
                    }
                    else
                    {
                        <button class="btn btn-secondary btn-lg w-100 rounded-3 py-3" disabled>
                            <i class="fas fa-lock me-2"></i> Terminal Track State
                        </button>
                    }
                </div>
            </div>
        </div>

    </div>
</div>

<!-- MODAL CONFIRMATION -->
<div class="modal fade" id="confirmForwardModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-body p-4 text-center">
                <i class="fas fa-exclamation-triangle text-warning fs-1 mb-3"></i>
                <h5 class="fw-bold text-dark">Promote Stage?</h5>
                <p class="text-muted small">Are you sure you want to push this operation tracking file to the next systematic pipeline node?</p>
                <div class="d-flex gap-2 justify-content-center mt-3">
                    <button type="button" class="btn btn-light btn-sm px-3 rounded-3 fw-bold" data-bs-dismiss="modal">Abort</button>
                    <button type="button" class="btn btn-emerald btn-sm px-3 rounded-3 fw-bold" id="btnModalConfirmSubmit">Execute</button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    const workflowModal = new bootstrap.Modal(document.getElementById('confirmForwardModal'));

    function confirmWorkflowTransition() {
        workflowModal.show();
    }

    document.getElementById('btnModalConfirmSubmit').addEventListener('click', function() {
        workflowModal.hide();
        document.getElementById('forwardWorkflowForm').submit();
    });
</script>