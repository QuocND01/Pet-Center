@using static PetCenterClient.ViewModels.MedicalRecord.MedicalRecordViewModel
@model CreateMedicalRecordViewModel

<style>
    .page-card { background: #fff; border-radius: 18px; padding: 28px; }
    .section-card { background: #f8f9fa; border-radius: 14px; padding: 20px; margin-bottom: 20px; }
    .section-title { font-size: 16px; font-weight: 700; margin-bottom: 14px; }
    .form-control, .form-select { min-height: 44px; border-radius: 10px; }
    textarea.form-control { min-height: 90px; resize: vertical; }
</style>

<div class="page-card">
    <h5 class="mb-1 fw-bold">Add Medical Record</h5>
    <p class="text-muted small mb-3">Create a new medical record for a completed appointment</p>

    <form asp-action="Create" asp-controller="MedicalRecord" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="section-card">
            <div class="section-title">Appointment</div>
            <div class="mb-3">
                <label class="form-label fw-semibold">Select Completed Appointment <span class="text-danger">*</span></label>
                <select asp-for="AppointmentId" class="form-select">
                    <option value="">-- Select an appointment --</option>
                    @if (ViewBag.CompletedAppointments != null)
                    {
                        foreach (var a in (IEnumerable<CompletedAppointmentViewModel>)ViewBag.CompletedAppointments)
                        {
                            <option value="@a.AppointmentId" data-species="@(a.PetSpecies.ToLower().Contains("dog") ? 1 : a.PetSpecies.ToLower().Contains("cat") ? 2 : 0)">@a.DisplayText</option>
                        }
                    }
                </select>
                <span asp-validation-for="AppointmentId" class="text-danger"></span>
            </div>
        </div>

        <div class="section-card">
            <div class="section-title">Medical Information</div>
            
            <div class="mb-3">
                <label class="form-label fw-semibold">Disease</label>
                <select asp-for="DiseaseId" class="form-select" id="diseaseSelect">
                    <option value="">-- Other / Custom Disease --</option>
                    @if (ViewBag.Diseases != null)
                    {
                        foreach (var d in (IEnumerable<ReadDiseaseViewModel>)ViewBag.Diseases)
                        {
                            <option value="@d.DiseaseId" data-species="@d.Species" data-rec="@d.Recommendation">@d.Name</option>
                        }
                    }
                </select>
            </div>

            <div class="mb-3" id="customDiseaseGroup">
                <label asp-for="CustomDiseaseName" class="form-label fw-semibold">Custom Disease Name</label>
                <input asp-for="CustomDiseaseName" class="form-control" placeholder="Enter custom disease name..." />
                <span asp-validation-for="CustomDiseaseName" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Diagnosis" class="form-label fw-semibold">
                    Diagnosis <span class="text-danger">*</span>
                </label>
                <textarea asp-for="Diagnosis" class="form-control" placeholder="Enter diagnosis..."></textarea>
                <span asp-validation-for="Diagnosis" class="text-danger"></span>
            </div>
            
            <div class="mb-3">
                <label asp-for="Treatment" class="form-label fw-semibold">
                    Treatment <span class="text-danger">*</span>
                </label>
                <textarea asp-for="Treatment" class="form-control" placeholder="Enter treatment plan..."></textarea>
                <span asp-validation-for="Treatment" class="text-danger"></span>
            </div>
            
            <div class="mb-3">
                <label asp-for="Note" class="form-label fw-semibold">Note</label>
                <textarea asp-for="Note" class="form-control" placeholder="Additional notes (optional)..."></textarea>
                <span asp-validation-for="Note" class="text-danger"></span>
            </div>
        </div>

        <div class="text-end">
            <button type="submit" class="btn btn-success px-4">
                <i class="bi bi-check-circle me-1"></i> Create Record
            </button>
        </div>
    </form>
</div>

<script>
$(document).ready(function() {
    var $appSelect = $('#AppointmentId');
    var $diseaseSelect = $('#diseaseSelect');
    var $customDiseaseGroup = $('#customDiseaseGroup');
    var $treatment = $('#Treatment');

    function filterDiseases() {
        var selectedApp = $appSelect.find('option:selected');
        var species = selectedApp.data('species');

        $diseaseSelect.find('option').each(function() {
            var $opt = $(this);
            var optSpecies = $opt.data('species');
            
            if (!optSpecies || !species || optSpecies == species) {
                $opt.show();
            } else {
                $opt.hide();
            }
        });

        var selectedDisease = $diseaseSelect.find('option:selected');
        if (selectedDisease.css('display') === 'none') {
            $diseaseSelect.val('');
            $customDiseaseGroup.show();
        }
    }

    function handleDiseaseChange() {
        var selectedDisease = $diseaseSelect.find('option:selected');
        var rec = selectedDisease.data('rec');
        var val = $diseaseSelect.val();

        if (val) {
            $customDiseaseGroup.hide();
            $('#CustomDiseaseName').val('');
            if (rec) {
                $treatment.val(rec);
            }
        } else {
            $customDiseaseGroup.show();
        }
    }

    $appSelect.on('change', filterDiseases);
    $diseaseSelect.on('change', handleDiseaseChange);

    filterDiseases();
    handleDiseaseChange();
});
</script>
