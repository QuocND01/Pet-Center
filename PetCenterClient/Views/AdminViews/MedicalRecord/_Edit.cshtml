@using static PetCenterClient.ViewModels.MedicalRecord.MedicalRecordViewModel
@model UpdateMedicalRecordViewModel

<style>
    .page-card { background:#fff; border-radius:16px; padding:24px; }
    .section-card { background:#f8f9fa; border-radius:12px; padding:18px; margin-bottom:16px; }
    .form-control { min-height:44px; border-radius:10px; }
    textarea.form-control { min-height:90px; resize:vertical; }
</style>

<div class="page-card">
    <h5 class="fw-bold mb-1">Edit Medical Record</h5>
    <p class="text-muted small mb-3">Update diagnosis, treatment and notes</p>

    <form asp-action="Edit" asp-controller="MedicalRecord" asp-route-id="@Model.RecordId" method="post">
        <input type="hidden" asp-for="RecordId" />
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="section-card">
            <div class="mb-3">
                <label class="form-label fw-semibold">Disease</label>
                <select asp-for="DiseaseId" class="form-select" id="diseaseSelect">
                    <option value="">-- Other / Custom Disease --</option>
                    @if (ViewBag.Diseases != null)
                    {
                        foreach (var d in (IEnumerable<ReadDiseaseViewModel>)ViewBag.Diseases)
                        {
                            <option value="@d.DiseaseId" data-species="@d.Species" data-rec="@d.Recommendation">@d.Name</option>
                        }
                    }
                </select>
            </div>

            <div class="mb-3" id="customDiseaseGroup">
                <label asp-for="CustomDiseaseName" class="form-label fw-semibold">Custom Disease Name</label>
                <input asp-for="CustomDiseaseName" class="form-control" maxlength="255" placeholder="Enter custom disease name..." />
                <span asp-validation-for="CustomDiseaseName" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Diagnosis" class="form-label fw-semibold">
                    Diagnosis <span class="text-danger">*</span>
                </label>
                <textarea asp-for="Diagnosis" class="form-control" maxlength="255" placeholder="Enter diagnosis..."></textarea>
                <span asp-validation-for="Diagnosis" class="text-danger"></span>
            </div>
            
            <div class="mb-3">
                <label asp-for="Treatment" class="form-label fw-semibold">
                    Treatment <span class="text-danger">*</span>
                </label>
                <textarea asp-for="Treatment" class="form-control" maxlength="255" placeholder="Enter treatment plan..."></textarea>
                <span asp-validation-for="Treatment" class="text-danger"></span>
            </div>
            
            <div class="mb-3">
                <label asp-for="Note" class="form-label fw-semibold">Note</label>
                <textarea asp-for="Note" class="form-control" maxlength="255" placeholder="Additional notes (optional)..."></textarea>
                <span asp-validation-for="Note" class="text-danger"></span>
            </div>
        </div>

        <div class="text-end">
            <button type="submit" class="btn btn-primary px-4">
                <i class="bi bi-check-circle me-1"></i> Save Changes
            </button>
        </div>
    </form>
</div>

<script>
$(document).ready(function() {
    var $diseaseSelect = $('#diseaseSelect');
    var $customDiseaseGroup = $('#customDiseaseGroup');
    var $treatment = $('#Treatment');
    
    var speciesStr = "@(ViewBag.PetSpecies ?? "")";
    var species = speciesStr.toLowerCase().indexOf("dog") !== -1 ? 1 : (speciesStr.toLowerCase().indexOf("cat") !== -1 ? 2 : 0);

    function filterDiseases() {
        $diseaseSelect.find('option').each(function() {
            var $opt = $(this);
            var optSpecies = $opt.data('species');
            
            if (!optSpecies || !species || optSpecies == species) {
                $opt.show();
            } else {
                $opt.hide();
            }
        });
    }

    function handleDiseaseChange() {
        var selectedDisease = $diseaseSelect.find('option:selected');
        var rec = selectedDisease.data('rec');
        var val = $diseaseSelect.val();

        if (val) {
            $customDiseaseGroup.hide();
            $('#CustomDiseaseName').val('');
            if (rec) {
                $treatment.val(rec);
            }
        } else {
            $customDiseaseGroup.show();
        }
    }

    $diseaseSelect.on('change', handleDiseaseChange);

    filterDiseases();
    
    // On edit, only set initial visibility, don't overwrite current treatment
    var initialVal = $diseaseSelect.val();
    if (initialVal) {
        $customDiseaseGroup.hide();
    } else {
        $customDiseaseGroup.show();
    }
});
</script>
