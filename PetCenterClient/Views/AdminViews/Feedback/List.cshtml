@model List<PetCenterClient.DTOs.FeedbackDTO>
<link rel="stylesheet" href="~/css/feedback.css" />

<div class="container">

	<h2>Feedback Management</h2>

	<table>

		<tr>
			<th>Product</th>
			<th>Customer</th>
			<th>Rating</th>
			<th>Comment</th>
			<th>Visible</th>
			<th>Created</th>
			<th>Actions</th>
		</tr>

		@foreach (var f in Model)
		{
			<tr>

				<td>@f.ProductId</td>
				<td>@f.CustomerId</td>
				<td>@f.Rating ⭐</td>
				<td>@f.Comment</td>
				<td>@f.IsVisible</td>
				<td>@f.CreatedDate.ToString("dd/MM/yyyy")</td>

				<td>

					<a class="btn btn-view" href="/Feedback/Detail/@f.FeedbackId">Detail</a>

					<a class="btn btn-toggle" href="/Feedback/Toggle/@f.FeedbackId">Toggle</a>

					<form method="post" action="/Feedback/Delete" style="display:inline;">
						<input type="hidden" name="id" value="@f.FeedbackId" />
						<button class="btn btn-delete">Delete</button>
					</form>

					<a class="btn btn-reply" href="/Feedback/Reply/@f.FeedbackId">Reply</a>

				</td>

			</tr>
		}

	</table>

</div>