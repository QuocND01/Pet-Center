@model IEnumerable<PetCenterClient.DTOs.FeedbackDTO>
@{
    ViewData["Title"] = "Feedback Management";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>💬 Feedback Management</h2>
    </div>

    <div class="card shadow-sm mb-4 border-0">
        <div class="card-body bg-light rounded">

            <form asp-action="List" method="get" class="row g-3 align-items-end">

                <div class="col-md-2">
                    <label class="form-label small fw-bold">Rating</label>
                    <input type="number" name="rating" min="1" max="5"
                           value="@Context.Request.Query["rating"]"
                           class="form-control" />
                </div>

                <div class="col-md-3">
                    <label class="form-label small fw-bold">Product ID</label>
                    <input type="text" name="productId"
                           value="@Context.Request.Query["productId"]"
                           class="form-control"
                           placeholder="GUID..." />
                </div>

                <div class="col-md-2">
                    <label class="form-label small fw-bold">Status</label>
                    <select name="isVisible" class="form-select">
                        <option value="">All</option>
                        <option value="true"
                                selected="@(Context.Request.Query["isVisible"] == "true")">
                            Visible
                        </option>
                        <option value="false"
                                selected="@(Context.Request.Query["isVisible"] == "false")">
                            Hidden
                        </option>
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label small fw-bold">From</label>
                    <input type="date" name="fromDate"
                           value="@Context.Request.Query["fromDate"]"
                           class="form-control" />
                </div>

                <div class="col-md-2">
                    <label class="form-label small fw-bold">To</label>
                    <input type="date" name="toDate"
                           value="@Context.Request.Query["toDate"]"
                           class="form-control" />
                </div>

                <div class="col-md-1">
                    <button class="btn btn-primary w-100">Filter</button>
                </div>

                <div class="col-md-1">
                    <a asp-action="List" class="btn btn-outline-secondary w-100">Clear</a>
                </div>

            </form>
        </div>
    </div>

    <div class="table-responsive shadow-sm">
        <table class="table table-hover border">

            <thead class="table-dark text-center">
                <tr>
                    <th class="text-start">Product</th>
                    <th>Customer</th>
                    <th>Rating</th>
                    <th>Comment</th>
                    <th>Status</th>
                    <th>Created</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center py-4 text-muted">
                            No feedback found
                        </td>
                    </tr>
                }

                @foreach (var f in Model)
                {
                    <tr class="align-middle text-center">

                        <td class="text-start">@f.ProductId</td>
                        <td>@f.CustomerId</td>

                        <td>
                            @for (int i = 0; i < f.Rating; i++)
                            {
                                <span>⭐</span>
                            }
                        </td>

                        <td>@f.Comment</td>

                        <td>
                            @if (f.IsVisible)
                            {
                                <span class="badge bg-success">Visible</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Hidden</span>
                            }
                        </td>

                        <td>@f.CreatedDate.ToString("dd/MM/yyyy HH:mm")</td>

                        <td>
                            <div class="d-flex flex-wrap gap-2 justify-content-center">

                                <a asp-action="Detail"
                                   asp-route-id="@f.FeedbackId"
                                   class="btn btn-sm btn-info text-white">
                                    Detail
                                </a>

                                <a asp-action="Toggle"
                                   asp-route-id="@f.FeedbackId"
                                   class="btn btn-sm btn-warning">
                                    @(f.IsVisible ? "Hide" : "Show")
                                </a>

                                <a asp-action="Reply"
                                   asp-route-id="@f.FeedbackId"
                                   class="btn btn-sm btn-primary">
                                    Reply
                                </a>

                                <form asp-action="Delete"
                                      asp-route-id="@f.FeedbackId"
                                      method="post"
                                      class="d-inline">
                                    <button class="btn btn-sm btn-danger"
                                            onclick="return confirm('Delete?')">
                                        Delete
                                    </button>
                                </form>

                            </div>
                        </td>

                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
