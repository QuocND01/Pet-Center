@model PetCenterClient.DTOs.FeedbackDTO
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Feedback Detail";
}

<div class="container mt-4">

    <h3>📄 Feedback Detail</h3>

    <div class="card shadow-sm mt-3">
        <div class="card-body">

            <p><b>Product:</b> @Model.ProductId</p>
            <p><b>Customer:</b> @Model.CustomerId</p>
            <p><b>Rating:</b> @Model.Rating ⭐</p>
            <p><b>Comment:</b> @Model.Comment</p>
            <p><b>Created:</b> @Model.CreatedDate.ToString("dd/MM/yyyy HH:mm")</p>

            <p>
                <b>Status:</b>
                @if (Model.IsVisible)
                {
                    <span class="badge bg-success">Visible</span>
                }
                else
                {
                    <span class="badge bg-secondary">Hidden</span>
                }
            </p>

        </div>
    </div>

    <div class="card shadow-sm mt-3">
        <div class="card-body">

            <h5>Staff Reply</h5>

            @if (Model.Reply != null)
            {
                <p><b>Staff:</b> @Model.StaffId</p>

                <p>@Model.Reply</p>

                <p class="text-muted">
                    @Model.ReplyDate?.ToString("dd/MM/yyyy HH:mm")
                </p>

                <a asp-action="Reply"
                   asp-route-id="@Model.FeedbackId"
                   class="btn btn-primary">
                    Edit Reply
                </a>

            }
            else
            {
                <p class="text-muted">No reply yet</p>

                <a asp-action="Reply"
                   asp-route-id="@Model.FeedbackId"
                   class="btn btn-primary">
                    Reply now
                </a>
            }

        </div>
    </div>

    <a asp-action="AdminList" class="btn btn-secondary mt-3">Back</a>

</div>
