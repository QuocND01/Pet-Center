@{
    ViewData["Title"] = "Feedback Management";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    /* ── TOKENS ───────────────────────────────────────────── */
    :root {
        --fb-bg: #f3f4f6;
        --fb-card: #ffffff;
        --fb-border: #e5e7eb;
        --fb-ink: #111827;
        --fb-ink2: #374151;
        --fb-muted: #9ca3af;
        --fb-green: #2ecc71;
        --fb-green2: #27ae60;
        --fb-green-bg: #dcfce7;
        --fb-green-text: #166534;
        --fb-yellow: #f59e0b;
        --fb-yellow-bg: #fef3c7;
        --fb-yellow-text: #92400e;
        --fb-red: #ef4444;
        --fb-red-bg: #fee2e2;
        --fb-red-text: #991b1b;
        --fb-blue: #3b82f6;
        --fb-blue-bg: #dbeafe;
        --fb-blue-text: #1e40af;
        --fb-purple: #8b5cf6;
        --fb-purple-bg: #ede9fe;
        --fb-purple-text: #5b21b6;
        --radius: 12px;
        --shadow: 0 1px 3px rgba(0,0,0,.08), 0 4px 16px rgba(0,0,0,.04);
        --shadow-lg: 0 8px 32px rgba(0,0,0,.12);
    }

    /* ── PAGE HEADER ─────────────────────────────────────── */
    .fb-header {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        margin-bottom: 24px;
        flex-wrap: wrap;
        gap: 12px;
    }
    .fb-header-left h1 {
        font-size: 22px;
        font-weight: 800;
        color: var(--fb-ink);
        margin: 0 0 2px;
    }
    .fb-header-left p {
        font-size: 13px;
        color: var(--fb-muted);
        margin: 0;
    }    

    /* ── FILTER BAR ──────────────────────────────────────── */
    .fb-filter-card {
        background: var(--fb-card);
        border: 1px solid var(--fb-border);
        border-radius: var(--radius);
        padding: 16px 18px;
        margin-bottom: 18px;
        box-shadow: var(--shadow);
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        align-items: flex-end;
    }
    .fb-filter-group {
        display: flex; flex-direction: column; gap: 4px;
    }
    .fb-filter-group label {
        font-size: 11px; font-weight: 800;
        color: var(--fb-muted); text-transform: uppercase;
        letter-spacing: .05em;
    }
    .fb-filter-group select,
    .fb-filter-group input {
        height: 36px;
        border: 1.5px solid var(--fb-border);
        border-radius: 8px;
        padding: 0 12px;
        font-size: 13px;
        font-family: inherit;
        color: var(--fb-ink);
        background: #fff;
        outline: none;
        transition: border .2s;
        min-width: 130px;
    }
    .fb-filter-group select:focus,
    .fb-filter-group input:focus { border-color: var(--fb-green); }
    .fb-filter-group.search input { min-width: 220px; }
    .fb-btn {
        height: 36px; padding: 0 16px;
        border-radius: 8px; border: none;
        font-size: 13px; font-weight: 700;
        font-family: inherit; cursor: pointer;
        display: inline-flex; align-items: center; gap: 6px;
        transition: all .2s;
    }
    .fb-btn-primary {
        background: var(--fb-green); color: #fff;
    }
    .fb-btn-primary:hover { background: var(--fb-green2); }
    .fb-btn-ghost {
        background: #f9fafb; color: var(--fb-ink2);
        border: 1.5px solid var(--fb-border);
    }
    .fb-btn-ghost:hover { background: #f3f4f6; }

    /* ── TABLE ───────────────────────────────────────────── */
    .fb-table-card {
        background: var(--fb-card);
        border: 1px solid var(--fb-border);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        overflow: hidden;
    }
    .fb-table-head {
        padding: 14px 18px;
        border-bottom: 1px solid var(--fb-border);
        display: flex; align-items: center;
        justify-content: space-between; gap: 12px;
    }
    .fb-table-title {
        font-size: 14px; font-weight: 800;
        color: var(--fb-ink);
    }
    .fb-count-badge {
        background: var(--fb-green-bg);
        color: var(--fb-green-text);
        font-size: 11px; font-weight: 800;
        padding: 2px 10px; border-radius: 100px;
    }
    table.fb-table {
        width: 100%; border-collapse: collapse;
        font-size: 13px;
        table-layout: fixed;
    }
    .fb-table thead th {
        padding: 11px 14px;
        background: #f9fafb;
        color: var(--fb-muted);
        font-size: 11px; font-weight: 800;
        text-transform: uppercase; letter-spacing: .05em;
        border-bottom: 1px solid var(--fb-border);
        white-space: nowrap;
    }
    .fb-table tbody tr {
        border-bottom: 1px solid var(--fb-border);
        transition: background .15s;
    }
    .fb-table tbody tr:last-child { border-bottom: none; }
    .fb-table tbody tr:hover { background: #f9fafb; }
    .fb-table td {
        padding: 12px 14px;
        color: var(--fb-ink2);
        vertical-align: middle;
    }

    .fb-table col.col-no {
        width: 44px;
    }

    .fb-table col.col-customer {
        width: 130px;
    }

    .fb-table col.col-product {
        width: 150px;
    }

    .fb-table col.col-stars {
        width: 90px;
    }

    .fb-table col.col-content {
        width: auto;
    }
    .fb-table col.col-status {
        width: 130px;
    }

    .fb-table col.col-date {
        width: 120px;
    }

    .fb-table col.col-actions {
        width: 230px;
    }

    /* Stars */
    .fb-stars { display: flex; gap: 2px; }
    .fb-star { font-size: 14px; color: #d1d5db; }
    .fb-star.on { color: #f59e0b; }

    /* Reply badge */
    .fb-badge {
        display: inline-flex; align-items: center; gap: 4px;
        padding: 3px 10px; border-radius: 100px;
        font-size: 11px; font-weight: 800;
    }
    .fb-badge-replied   { background: var(--fb-green-bg);  color: var(--fb-green-text); }
    .fb-badge-pending   { background: var(--fb-yellow-bg); color: var(--fb-yellow-text); }
    .fb-badge-hidden    { background: #f3f4f6; color: var(--fb-muted); }

    /* Action buttons */
    .fb-actions { display: flex; gap: 6px; flex-wrap: wrap; }
    .fb-action-btn {
        height: 30px; padding: 0 12px;
        border-radius: 6px; border: 1.5px solid var(--fb-border);
        font-size: 11px; font-weight: 800;
        font-family: inherit; cursor: pointer;
        display: inline-flex; align-items: center; gap: 4px;
        transition: all .18s; background: #fff;
        color: var(--fb-ink2); white-space: nowrap;
    }
    .fb-action-btn:hover { background: #f3f4f6; }
    .fb-action-btn.reply  { border-color: var(--fb-green);  color: var(--fb-green2); }
    .fb-action-btn.reply:hover  { background: var(--fb-green-bg); }
    .fb-action-btn.edit   { border-color: var(--fb-blue);   color: var(--fb-blue);   }
    .fb-action-btn.edit:hover   { background: var(--fb-blue-bg);  }
    .fb-action-btn.delete { border-color: var(--fb-red);    color: var(--fb-red);    }
    .fb-action-btn.delete:hover { background: var(--fb-red-bg);   }
    .fb-action-btn.detail { border-color: var(--fb-purple); color: var(--fb-purple); }
    .fb-action-btn.detail:hover { background: var(--fb-purple-bg); }
    .fb-action-btn.hide   { border-color: var(--fb-muted);  color: var(--fb-muted);  }
    .fb-action-btn.hide:hover { background: #f3f4f6; }

    /* Comment truncate */
    .fb-comment {
        width: 100%;
        white-space: nowrap; 
        overflow: hidden;
        text-overflow: ellipsis; 
        color: var(--fb-ink2);
        display: block;
    }
    

    /* ── PAGINATION ──────────────────────────────────────── */
    .fb-pagination {
        display: flex; align-items: center;
        justify-content: space-between;
        padding: 14px 18px;
        border-top: 1px solid var(--fb-border);
        flex-wrap: wrap; gap: 10px;
    }
    .fb-page-info {
        font-size: 12px; color: var(--fb-muted); font-weight: 700;
    }
    .fb-page-btns { display: flex; gap: 4px; }
    .fb-page-btn {
        width: 32px; height: 32px;
        border-radius: 6px; border: 1.5px solid var(--fb-border);
        background: #fff; color: var(--fb-ink2);
        font-size: 12px; font-weight: 800;
        cursor: pointer; display: flex;
        align-items: center; justify-content: center;
        transition: all .18s;
    }
    .fb-page-btn:hover:not(:disabled) { background: #f3f4f6; }
    .fb-page-btn.active {
        background: var(--fb-green);
        border-color: var(--fb-green); color: #fff;
    }
    .fb-page-btn:disabled { opacity: .4; cursor: default; }

    /* ── LOADING / EMPTY ─────────────────────────────────── */
    .fb-loading {
        text-align: center; padding: 48px 24px;
        color: var(--fb-muted); font-size: 13px; font-weight: 700;
    }
    .fb-empty {
        text-align: center; padding: 48px 24px;
    }
    .fb-empty-icon { font-size: 40px; margin-bottom: 10px; }
    .fb-empty-text {
        font-size: 14px; font-weight: 700;
        color: var(--fb-muted);
    }

    /* ── MODAL OVERLAY ───────────────────────────────────── */
    .fb-overlay {
        display: none; position: fixed;
        inset: 0; background: rgba(0,0,0,.45);
        z-index: 2000; align-items: center;
        justify-content: center; padding: 20px;
    }
    .fb-overlay.open { display: flex; }
    .fb-modal {
        background: #fff; border-radius: 16px;
        box-shadow: var(--shadow-lg);
        width: 100%; max-width: 560px;
        max-height: 90vh; overflow-y: auto;
        animation: modalIn .2s ease;
    }
    .fb-modal.wide { max-width: 680px; }
    @@keyframes modalIn {
        from { transform: translateY(16px); opacity: 0; }
        to   { transform: translateY(0);    opacity: 1; }
    }
    .fb-modal-header {
        padding: 18px 22px 14px;
        border-bottom: 1px solid var(--fb-border);
        display: flex; align-items: center;
        justify-content: space-between;
    }
    .fb-modal-header h3 {
        font-size: 15px; font-weight: 800;
        color: var(--fb-ink); margin: 0;
        display: flex; align-items: center; gap: 8px;
    }
    .fb-modal-close {
        width: 30px; height: 30px; border-radius: 8px;
        border: 1.5px solid var(--fb-border);
        background: #fff; cursor: pointer;
        display: flex; align-items: center; justify-content: center;
        font-size: 14px; color: var(--fb-muted);
        transition: all .18s;
    }
    .fb-modal-close:hover { background: var(--fb-red-bg); color: var(--fb-red); border-color: var(--fb-red); }
    .fb-modal-body { 
        padding: 20px 22px; 
        overflow-y: auto;
        overflow-x: hidden;
    }
    .fb-modal-footer {
        padding: 14px 22px 18px;
        border-top: 1px solid var(--fb-border);
        display: flex; justify-content: flex-end; gap: 8px;
    }

    /* Detail sections */
    .fb-detail-section {
        background: #f9fafb; border-radius: 10px;
        padding: 14px 16px; margin-bottom: 14px;
    }
    .fb-detail-section:last-child { margin-bottom: 0; }
    .fb-detail-section-title {
        font-size: 10px; font-weight: 900;
        color: var(--fb-muted); text-transform: uppercase;
        letter-spacing: .08em; margin-bottom: 10px;
    }
    .fb-detail-row {
        display: flex; gap: 8px;
        font-size: 13px; margin-bottom: 6px;
        align-items: flex-start;
    }
    .fb-detail-row:last-child { margin-bottom: 0; }
    .fb-detail-lbl {
        font-weight: 800; color: var(--fb-muted);
        min-width: 100px; flex-shrink: 0;
    }
    .fb-detail-val { color: var(--fb-ink2); }

    /* Reply section in detail */
    .fb-reply-box {
        background: linear-gradient(135deg, #dcfce7, #f0fdf4);
        border: 1.5px solid #bbf7d0;
        border-radius: 10px; padding: 14px 16px;
        margin-top: 14px;
    }
    .fb-reply-box-title {
        font-size: 11px; font-weight: 900;
        color: var(--fb-green2); text-transform: uppercase;
        letter-spacing: .08em; margin-bottom: 8px;
        display: flex; align-items: center; gap: 6px;
    }
    .fb-reply-box-content {
        font-size: 13px; color: var(--fb-ink2);
        line-height: 1.6;
        white-space: pre-wrap; 
        overflow-wrap: break-word;
        word-break: break-word;
    }
    .fb-reply-box-meta {
        font-size: 11px; color: var(--fb-muted);
        margin-top: 8px; font-weight: 700;
    }

    /* Form elements in modal */
    .fb-form-group { margin-bottom: 16px; }
    .fb-form-group:last-child { margin-bottom: 0; }
    .fb-form-label {
        display: block; font-size: 12px; font-weight: 800;
        color: var(--fb-ink2); margin-bottom: 6px;
    }
    .fb-form-label span { color: var(--fb-red); }
    .fb-form-input,
    .fb-form-textarea {
        width: 100%; 
        border: 1.5px solid var(--fb-border);
        border-radius: 8px; 
        padding: 9px 12px;
        font-size: 13px; 
        font-family: inherit;
        color: var(--fb-ink); 
        outline: none;
        transition: border .2s; 
        resize: none;
        box-sizing: border-box;
    }
    .fb-form-input:focus,
    .fb-form-textarea:focus { border-color: var(--fb-green); }
    .fb-form-textarea { 
        min-height: 110px;
        max-height: 50vh;
        line-height: 1.6;
        overflow-y: hidden;
        resize: none;
        transition: height .12s ease;
    }
    .fb-char-count {
        text-align: right; font-size: 11px;
        color: var(--fb-muted); margin-top: 4px;
        font-weight: 700;
    }
    .fb-form-hint {
        font-size: 11px; color: var(--fb-muted);
        margin-top: 5px; font-weight: 600;
    }

    /* Context box inside reply modal */
    .fb-context-box {
        background: #f9fafb; border: 1.5px solid var(--fb-border);
        border-radius: 8px; padding: 12px 14px;
        margin-bottom: 16px;
    }
    .fb-context-box-lbl {
        font-size: 10px; font-weight: 900;
        color: var(--fb-muted); text-transform: uppercase;
        letter-spacing: .08em; margin-bottom: 6px;
    }
    .fb-context-comment {
        font-size: 13px; 
        color: var(--fb-ink2);
        line-height: 1.6; 
        font-style: italic;
        white-space: pre-wrap; 
        overflow-wrap: break-word;
        word-break: break-word;
    }

    /* Delete confirm modal */
    .fb-confirm-icon {
        width: 54px; height: 54px; border-radius: 50%;
        background: var(--fb-red-bg);
        display: flex; align-items: center; justify-content: center;
        font-size: 24px; margin: 0 auto 14px;
    }
    .fb-confirm-title {
        text-align: center; font-size: 16px;
        font-weight: 800; color: var(--fb-ink);
        margin-bottom: 6px;
    }
    .fb-confirm-desc {
        text-align: center; font-size: 13px;
        color: var(--fb-muted); line-height: 1.6;
    }
    .fb-btn-danger {
        background: var(--fb-red); color: #fff;
    }
    .fb-btn-danger:hover { background: #dc2626; }

    /* Toast */
    .fb-toast-wrap {
        position: fixed; top: 20px; right: 20px;
        z-index: 9999; display: flex;
        flex-direction: column; gap: 8px;
        pointer-events: none;
    }
    .fb-toast {
        background: var(--fb-ink);
        color: #fff; font-size: 13px; font-weight: 700;
        padding: 12px 18px; border-radius: 10px;
        box-shadow: var(--shadow-lg);
        display: flex; align-items: center; gap: 8px;
        animation: toastIn .25s ease;
        pointer-events: all;
        max-width: 320px;
    }
    .fb-toast.success { background: var(--fb-green2); }
    .fb-toast.error   { background: var(--fb-red);    }
    @@keyframes toastIn {
        from { transform: translateX(20px); opacity: 0; }
        to   { transform: translateX(0);    opacity: 1; }
    }

    /* ── PAGE HEADER ── */
    .fb-page-header {
        background: #fff;
        border-bottom: 1px solid var(--fb-border);
        padding: 24px 32px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 28px;
        gap: 16px;
        flex-wrap: wrap;
    }

    .fb-page-title-group h1 {
        font-size: 22px;
        font-weight: 700;
        color: var(--fb-ink);
        margin: 0 0 4px;
        letter-spacing: -0.3px;
    }

    .fb-page-title-group p {
        font-size: 13px;
        color: var(--fb-muted);
        margin: 0;
    }

    .fb-header-right {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .fb-header-stat {
        display: flex;
        align-items: center;
        gap: 10px;
        background: #eef2ff;
        padding: 10px 20px;
        border-radius: 40px;
    }

        .fb-header-stat .num {
            font-size: 20px;
            font-weight: 700;
            color: #6366f1;
        }

        .fb-header-stat .label {
            font-size: 13px;
            color: #6366f1;
            font-weight: 500;
        }

    .fb-product-name {
        display: block;
        width: 100%;
        max-width: 140px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        font-size: 12px;
        font-weight: 600;
        color: var(--fb-ink2);
        cursor: default;
    }

    .fb-detail-content-text {
        font-size: 13px;
        color: var(--fb-ink2);
        line-height: 1.7;
        font-style: italic;
        white-space: pre-wrap; 
        overflow-wrap: break-word;
        word-break: break-word; 
        max-width: 100%;
    }

    .fb-context-media {
        margin-top: 10px;
        padding-top: 10px;
        border-top: 1px dashed var(--fb-border);
    }

    .fb-context-media-lbl {
        font-size: 10px;
        font-weight: 900;
        color: var(--fb-muted);
        text-transform: uppercase;
        letter-spacing: .08em;
        margin-bottom: 8px;
    }

    .fb-context-media-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
    }

    .fb-context-media-thumb {
        position: relative;
        width: 56px;
        height: 56px;
        flex-shrink: 0;
        border-radius: 6px;
        overflow: hidden;
        border: 1.5px solid var(--fb-border);
        cursor: pointer;
        transition: border-color .15s;
    }

    .fb-context-media-thumb:hover {
            border-color: var(--fb-green);
    }

    .fb-context-media-thumb img,
    .fb-context-media-thumb video {
            width: 56px;
            height: 56px;
            object-fit: cover;
            display: block;
    }

    .fb-context-media-play {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(0,0,0,.25);
    }

    .fb-context-media-play span {
            background: rgba(0,0,0,.6);
            border-radius: 50%;
            width: 20px;
            height: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-size: 9px;
    }

    .fb-context-media-loading {
        font-size: 11px;
        color: var(--fb-muted);
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 6px;
    }
</style>

<!-- ══ TOAST CONTAINER ═══════════════════════════════════════ -->
<div class="fb-toast-wrap" id="fbToastWrap"></div>

<!-- ══ PAGE HEADER ══════════════════════════════════════════ -->
<div class="fb-page-header">
    <div class="fb-page-title-group">
        <h1><i class="bi bi-chat-left-text me-2" style="color:#6366f1"></i>Feedback Management</h1>
        <p>Manage and respond to customer product reviews and feedback.</p>
    </div>
    <div class="fb-header-right">
        <div class="fb-header-stat">
            <span class="num" id="statTotal">—</span>
            <span class="label">Total Feedback</span>
        </div>
    </div>
</div>

<!-- ══ FILTER BAR ════════════════════════════════════════════ -->
<div class="fb-filter-card">
    <div class="fb-filter-group search">
        <label>Search</label>
        <input type="text" id="fKeyword" placeholder="Search within the feedback content...." />
    </div>
    <div class="fb-filter-group">
        <label>Status</label>
        <select id="fHasReply">
            <option value="">All</option>
            <option value="false">No reply</option>
            <option value="true">Replied</option>
        </select>
    </div>
    <div class="fb-filter-group">
        <label>Stars</label>
        <select id="fRating">
            <option value="">All</option>
            <option value="5">⭐⭐⭐⭐⭐  5 stars</option>
            <option value="4">⭐⭐⭐⭐  4 stars</option>
            <option value="3">⭐⭐⭐  3 stars</option>
            <option value="2">⭐⭐  2 stars</option>
            <option value="1">⭐  1 stars</option>
        </select>
    </div>
    <div class="fb-filter-group">
        <label>Sort</label>
        <select id="fSortBy">
            <option value="newest">Latest</option>
            <option value="oldest">Oldest</option>
            <option value="rating_desc">Highest number of stars</option>
            <option value="rating_asc">Smallest number of stars</option>
        </select>
    </div>
    <div class="fb-filter-group">
        <label>View Page</label>
        <select id="fPageSize">
            <option value="10">10 / page</option>
            <option value="20">20 / page</option>
            <option value="50">50 / page</option>
        </select>
    </div>
    <button class="fb-btn fb-btn-primary" onclick="loadFeedbacks(1)">
        <i class="bi bi-search"></i> Filter
    </button>
    <button class="fb-btn fb-btn-ghost" onclick="resetFilter()">
        <i class="bi bi-arrow-counterclockwise"></i> Reset
    </button>
</div>

<!-- ══ TABLE CARD ════════════════════════════════════════════ -->
<div class="fb-table-card">
    <div class="fb-table-head">
        <div style="display:flex;align-items:center;gap:10px">
            <span class="fb-table-title">Feedback List</span>
            <span class="fb-count-badge" id="totalBadge">No Result</span>
        </div>
    </div>

    <div id="fbTableBody">
        <div class="fb-loading">
            <i class="bi bi-arrow-repeat" style="font-size:22px;display:block;margin-bottom:8px"></i>
            loading data...
        </div>
    </div>

    <div class="fb-pagination" id="fbPagination" style="display:none">
        <div class="fb-page-info" id="pageInfo"></div>
        <div class="fb-page-btns" id="pageBtns"></div>
    </div>
</div>

<!-- ══ MODAL: DETAIL ═════════════════════════════════════════ -->
<div class="fb-overlay" id="modalDetail">
    <div class="fb-modal wide">
        <div class="fb-modal-header">
            <h3><i class="bi bi-info-circle" style="color:var(--fb-purple)"></i>Feedback Detail</h3>
            <button class="fb-modal-close" onclick="closeModal('modalDetail')">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
        <div class="fb-modal-body" id="detailBody">
            <!-- dynamic -->
        </div>
        <div class="fb-modal-footer">
            <button class="fb-btn fb-btn-ghost" onclick="closeModal('modalDetail')">Close</button>
        </div>
    </div>
</div>

<!-- ══ MODAL: REPLY / EDIT REPLY ═════════════════════════════ -->
<div class="fb-overlay" id="modalReply">
    <div class="fb-modal">
        <div class="fb-modal-header">
            <h3 id="replyModalTitle">
                <i class="bi bi-reply" style="color:var(--fb-green2)"></i> Reply Feedback
            </h3>
            <button class="fb-modal-close" onclick="closeModal('modalReply')">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
        <div class="fb-modal-body">
            <div class="fb-context-box">
                <div class="fb-context-box-lbl">Customer Feedback Content</div>
                <div class="fb-context-comment" id="replyContextComment">–</div>
                <div style="margin-top:8px;display:flex;gap:8px;align-items:center">
                    <div id="replyContextStars" class="fb-stars"></div>
                    <span id="replyContextDate" style="font-size:11px;color:var(--fb-muted);font-weight:700"></span>
                </div>
                <div id="replyContextMedia" class="fb-context-media" style="display:none"></div>
            </div>
            <div class="fb-form-group">
                <label class="fb-form-label">
                    Feedback Content <span>*</span>
                </label>
                <textarea class="fb-form-textarea" id="replyContent"
                          placeholder="Thank you for your feedback! We..."
                          maxlength="1000"
                          oninput="updateCharCount(this,'replyCharCount',1000); autoGrowTextarea(this)"></textarea>
                <div class="fb-char-count"><span id="replyCharCount">0</span> / 1000 characters</div>
                <div class="fb-form-hint">
                    <i class="bi bi-lightbulb"></i>
                    A professional and courteous response will make a good impression on customers..
                </div>
            </div>
            <input type="hidden" id="replyFeedbackId" />
            <input type="hidden" id="replyMode" value="new" /> <!-- new | edit -->
        </div>
        <div class="fb-modal-footer">
            <button class="fb-btn fb-btn-ghost" onclick="closeModal('modalReply')">Cancel</button>
            <button class="fb-btn fb-btn-primary" onclick="submitReply()" id="replySubmitBtn">
                <i class="bi bi-send"></i> Send Reply
            </button>
        </div>
    </div>
</div>

<!-- ══ MODAL: CONFIRM DELETE ════════════════════════════════ -->
<div class="fb-overlay" id="modalDelete">
    <div class="fb-modal" style="max-width:420px">
        <div class="fb-modal-body" style="padding:28px 24px">
            <div class="fb-confirm-icon">🗑️</div>
            <div class="fb-confirm-title">Delete Reply?</div>
            <div class="fb-confirm-desc">
                This action will delete all submitted Reply.<br>
                You can Reply after deleting.
            </div>
            <input type="hidden" id="deleteFeedbackId" />
        </div>
        <div class="fb-modal-footer">
            <button class="fb-btn fb-btn-ghost" onclick="closeModal('modalDelete')">Cancel</button>
            <button class="fb-btn fb-btn-danger" onclick="confirmDeleteReply()">
                <i class="bi bi-trash3"></i> Delete Reply
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // ── STATE ────────────────────────────────────────────────────
        const STAFF_ID = '@ViewBag.StaffId';
        let currentPage = 1;
        let totalPages  = 1;

        // ── INIT ─────────────────────────────────────────────────────
        document.addEventListener('DOMContentLoaded', () => {
            loadFeedbacks(1);

            // Enter key on search
            document.getElementById('fKeyword')
                .addEventListener('keydown', e => { if (e.key === 'Enter') loadFeedbacks(1); });
        });

        // ── LOAD LIST ────────────────────────────────────────────────
        async function loadFeedbacks(page) {
            currentPage = page;
            showTableLoading();

            const params = buildParams(page);

            try {
                const res  = await fetch(`/AdminFeedback/GetList?${params}`);
                const json = await res.json();

                if (!json.success || !json.data) {
                    showTableEmpty('Unable to load data. Please try again.');
                    return;
                }

                const data = json.data;
                renderTable(data.items);
                renderPagination(data.page, data.totalPages, data.totalCount);
                updateStats(data.items, data.totalCount);

            } catch (err) {
                showTableEmpty('An error occurred while connecting to the server.');
            }
        }

        function buildParams(page) {
            const p = new URLSearchParams();
            p.set('page',     page);
            p.set('pageSize', document.getElementById('fPageSize').value);

            const keyword  = document.getElementById('fKeyword').value.trim();
            const hasReply = document.getElementById('fHasReply').value;
            const rating   = document.getElementById('fRating').value;
            const sortBy   = document.getElementById('fSortBy').value;

            if (keyword)  p.set('keyword',  keyword);
            if (hasReply) p.set('hasReply', hasReply);
            if (rating)   p.set('rating',   rating);
            if (sortBy)   p.set('sortBy',   sortBy);

            return p.toString();
        }

        // ── RENDER TABLE ─────────────────────────────────────────────
        function renderTable(items) {
            if (!items || items.length === 0) {
                showTableEmpty('No feedback matches the filter.');
                return;
            }

            const rows = items.map(f => {
                const stars   = `<div class="fb-stars">${renderStars(f.rating)}</div>`;
                const badge   = renderReplyBadge(f.hasReply, f.isVisible);
                const comment = escHtml(f.comment || '–');
                const date    = formatDate(f.createdDate);
                const actions = renderActions(f);

                // ── Cột Product: ảnh + tên ────────────────────────────
                const productCell = f.productImage
                        ? `<div style="display:flex;flex-direction:column;align-items:center;gap:6px;text-align:center">
                        <img src="${f.productImage}"
                        style="width:44px;height:44px;object-fit:cover;
                           border-radius:6px;border:1px solid var(--fb-border)"
                        onerror="this.style.display='none'">
                <span class="fb-product-name" title="${escHtml(f.productName||'')}">
                   ${escHtml(f.productName || '–')}
               </span>
           </div>`
        : `<div style="text-align:center">
               <span class="fb-product-name" title="${escHtml(f.productName||'')}">
                   ${escHtml(f.productName || '–')}
               </span>
           </div>`;

                return `
                <tr>
                    <td>
                        <span style="font-size:13px;font-weight:800;color:var(--fb-muted)">
                            #${f.rowNumber}
                        </span>
                    </td>
                    <td>
                        <span style="font-size:13px;font-weight:700;color:var(--fb-ink2)">
                            ${escHtml(f.customerName || 'Customer')}
                        </span>
                    </td>
                    <td>${productCell}</td>
                    <td>${stars}</td>
                    <td><div class="fb-comment" title="${comment}">${comment}</div></td>
                    <td>${badge}</td>
                    <td style="font-size:12px;color:var(--fb-muted);white-space:nowrap">${date}</td>
                    <td><div class="fb-actions">${actions}</div></td>
                </tr>`;
            }).join('');

                document.getElementById('fbTableBody').innerHTML = `
        <table class="fb-table">
            <colgroup>
                <col class="col-no">
                <col class="col-customer">
                <col class="col-product">
                <col class="col-stars">
                <col class="col-content">
                <col class="col-status">
                <col class="col-date">
                <col class="col-actions">
            </colgroup>
            <thead>
                <tr>
                    <th>#</th>
                    <th>Customer</th>
                    <th>Product</th>
                    <th>Stars</th>
                    <th>Content</th>
                    <th>Status</th>
                    <th>Creation date</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>${rows}</tbody>
        </table>`;
        }

        function renderStars(rating) {
            const r = rating || 0;
            return Array.from({length: 5}, (_, i) =>
                `<span class="fb-star ${i < r ? 'on' : ''}">★</span>`
            ).join('');
        }

        function renderReplyBadge(hasReply, isVisible) {
            if (!isVisible)
                return `<span class="fb-badge fb-badge-hidden"><i class="bi bi-eye-slash"></i> Hidden</span>`;
            if (hasReply)
                return `<span class="fb-badge fb-badge-replied"><i class="bi bi-check-circle"></i>Replied</span>`;
            return `<span class="fb-badge fb-badge-pending"><i class="bi bi-clock"></i> Waiting for a reply</span>`;
        }

        function renderActions(f) {
            const detailBtn = `
                <button class="fb-action-btn detail"
                        onclick="openDetail('${f.feedbackId}')">
                    <i class="bi bi-eye"></i> Detail
                </button>`;

            const hideBtn = f.isVisible
                ? `<button class="fb-action-btn hide"
                           onclick="toggleVisibility('${f.feedbackId}', false)">
                       <i class="bi bi-eye-slash"></i>
                   </button>`
                : `<button class="fb-action-btn"
                           onclick="toggleVisibility('${f.feedbackId}', true)"
                           style="border-color:var(--fb-blue);color:var(--fb-blue)">
                       <i class="bi bi-eye"></i>
                   </button>`;

            if (!f.hasReply) {
                return `
                    ${detailBtn}
                    <button class="fb-action-btn reply"
                            onclick="openReply('${f.feedbackId}','${escHtml(f.comment||'')}',${f.rating},'${f.createdDate}')">
                        <i class="bi bi-reply"></i> Reply
                    </button>
                    ${hideBtn}`;
            }

            return `
                ${detailBtn}
                <button class="fb-action-btn edit"
                        onclick="openEditReply('${f.feedbackId}','${escHtml(f.comment||'')}',${f.rating},'${f.createdDate}','${escHtml(f.replyContent||'')}')">
                    <i class="bi bi-pencil"></i> Edit Reply
                </button>
                <button class="fb-action-btn delete"
                        onclick="openDeleteReply('${f.feedbackId}')">
                    <i class="bi bi-trash3"></i>
                </button>
                ${hideBtn}`;
        }

        // ── PAGINATION ────────────────────────────────────────────────
        function renderPagination(page, pages, total) {
            totalPages = pages;
            const pageSize = parseInt(document.getElementById('fPageSize').value);
            const from = (page - 1) * pageSize + 1;
            const to   = Math.min(page * pageSize, total);

            document.getElementById('pageInfo').textContent =
                `View ${from}–${to} trong ${total} Result`;

            const btns = [];
            btns.push(`<button class="fb-page-btn" onclick="loadFeedbacks(${page-1})"
                ${page===1?'disabled':''}>‹</button>`);

            const range = buildPageRange(page, pages);
            range.forEach(p => {
                if (p === '…')
                    btns.push(`<button class="fb-page-btn" disabled>…</button>`);
                else
                    btns.push(`<button class="fb-page-btn ${p===page?'active':''}"
                        onclick="loadFeedbacks(${p})">${p}</button>`);
            });

            btns.push(`<button class="fb-page-btn" onclick="loadFeedbacks(${page+1})"
                ${page===pages?'disabled':''}>›</button>`);

            document.getElementById('pageBtns').innerHTML = btns.join('');
            document.getElementById('fbPagination').style.display = 'flex';
        }

        function buildPageRange(current, total) {
            if (total <= 7) return Array.from({length:total}, (_,i)=>i+1);
            const pages = [1];
            if (current > 3) pages.push('…');
            for (let i = Math.max(2, current-1); i <= Math.min(total-1, current+1); i++)
                pages.push(i);
            if (current < total - 2) pages.push('…');
            pages.push(total);
            return pages;
        }

        // ── STATS ─────────────────────────────────────────────────────
        function updateStats(items, total) {
            document.getElementById('statTotal').textContent = total;           
            document.getElementById('totalBadge').textContent    = `${total} Result`;
        }

        // ── DETAIL MODAL ─────────────────────────────────────────────
        async function openDetail(feedbackId) {
            try {
                const res  = await fetch(`/AdminFeedback/GetDetail?feedbackId=${feedbackId}`);
                const json = await res.json();
                if (!json.success) { showToast('Details cannot be loaded.', 'error'); return; }

                const f = json.data;
                document.getElementById('detailBody').innerHTML = buildDetailHtml(f);
                openModal('modalDetail');
            } catch {
                showToast('Connection error.', 'error');
            }
        }

                function buildDetailHtml(f) {
            const stars = `<div class="fb-stars" style="display:inline-flex">${renderStars(f.rating)}</div>`;

            // ── Product block ─────────────────────────────────────────
            const productBlock = `
                <div style="display:flex;align-items:center;gap:12px">
                    ${f.productImage
                        ? `<img src="${f.productImage}"
                                style="width:56px;height:56px;object-fit:cover;
                                       border-radius:8px;border:1px solid var(--fb-border)"
                                onerror="this.style.display='none'">`
                        : ''}
                    <span style="font-weight:700;font-size:13px;color:var(--fb-ink2)">
                        ${escHtml(f.productName || '–')}
                    </span>
                </div>`;

            // ── Reply section ─────────────────────────────────────────
            const replySection = f.hasReply ? `
                <div class="fb-reply-box">
                    <div class="fb-reply-box-title">
                        <i class="bi bi-reply-fill"></i> Feedback from staff
                    </div>
                    <div class="fb-reply-box-content">${escHtml(f.replyContent || '')}</div>
                    <div class="fb-reply-box-meta">
                        <i class="bi bi-clock"></i> ${formatDate(f.replyDate)}
                        &nbsp;·&nbsp;
                        <i class="bi bi-person-badge"></i>
                        ${escHtml(f.staffName || 'Staff')}
                    </div>
                </div>` : `
                <div style="background:#fef3c7;border:1.5px solid #fcd34d;border-radius:10px;
                            padding:12px 14px;margin-top:14px;font-size:13px;
                            color:#92400e;font-weight:700;display:flex;gap:8px;align-items:center">
                    <i class="bi bi-clock-history"></i>
                    This feedback has not yet received a reply.
                </div>`;

            return `
                <div class="fb-detail-section">
                    <div class="fb-detail-section-title">Feedback Information</div>
                    <div class="fb-detail-row">
                        <span class="fb-detail-lbl">Feedback ID</span>
                        <span class="fb-detail-val" style="font-family:monospace;font-size:12px">
                            ${f.feedbackId}
                        </span>
                    </div>
                    <div class="fb-detail-row">
                        <span class="fb-detail-lbl">Stars</span>
                        <span class="fb-detail-val">${stars} (${f.rating}/5)</span>
                    </div>
                    <div class="fb-detail-row">
                        <span class="fb-detail-lbl">Creation Date</span>
                        <span class="fb-detail-val">${formatDate(f.createdDate)}</span>
                    </div>
                    <div class="fb-detail-row">
                        <span class="fb-detail-lbl">Display</span>
                        <span class="fb-detail-val">
                            ${f.isVisible
                                ? '<span class="fb-badge fb-badge-replied">Display</span>'
                                : '<span class="fb-badge fb-badge-hidden">Hidden</span>'}
                        </span>
                    </div>
                </div>

                <div class="fb-detail-section">
                    <div class="fb-detail-section-title">Customer</div>
                    <div class="fb-detail-row">
                        <span class="fb-detail-lbl">Full Name</span>
                        <span class="fb-detail-val" style="font-weight:700">
                            ${escHtml(f.customerName || '–')}
                        </span>
                    </div>
                    <div class="fb-detail-row">
                        <span class="fb-detail-lbl">Email</span>
                        <span class="fb-detail-val" style="color:var(--fb-blue)">
                            ${escHtml(f.customerEmail || '–')}
                        </span>
                    </div>
                </div>

                <div class="fb-detail-section">
                    <div class="fb-detail-section-title">Product</div>
                    <div class="fb-detail-row">
                        <span class="fb-detail-lbl">Information</span>
                        <span class="fb-detail-val">${productBlock}</span>
                    </div>
                    <div class="fb-detail-row">
                        <span class="fb-detail-lbl">Order ID</span>
                        <span class="fb-detail-val" style="font-family:monospace;font-size:12px">
                            ${f.orderId}
                        </span>
                    </div>
                </div>

            <div class="fb-detail-section">
                <div class="fb-detail-section-title">Feedback Content</div>
                <div class="fb-detail-content-text">
                    "${escHtml(f.comment || 'No Content')}"
                </div>

            <!-- Media files (images + videos) -->
            ${f.mediaFiles && f.mediaFiles.length > 0 ? `
            <div style="margin-top:14px;">
                <div style="font-size:10px;font-weight:900;color:var(--fb-muted);
                            text-transform:uppercase;letter-spacing:.08em;margin-bottom:10px;">
                    Attached Media (${f.mediaFiles.length} file${f.mediaFiles.length > 1 ? 's' : ''})
                </div>
                <div style="display:flex;flex-wrap:wrap;gap:8px;">
                    ${f.mediaFiles.map(m => {
                        if (m.mediaType === 'video') {
                            return `
                            <div style="position:relative;width:88px;height:88px;flex-shrink:0;
                                        border-radius:8px;overflow:hidden;
                                        border:1.5px solid var(--fb-border);cursor:pointer;"
                                 onclick="window.open('${m.mediaUrl}', '_blank')">
                                <video src="${m.mediaUrl}" muted
                                       style="width:88px;height:88px;object-fit:cover;display:block;">
                                </video>
                                <div style="position:absolute;inset:0;display:flex;align-items:center;
                                            justify-content:center;background:rgba(0,0,0,.25);">
                                    <div style="background:rgba(0,0,0,.6);border-radius:50%;
                                                width:28px;height:28px;display:flex;align-items:center;
                                                justify-content:center;">
                                        <span style="color:#fff;font-size:12px;">▶</span>
                                    </div>
                                </div>
                                <div style="position:absolute;bottom:3px;right:4px;
                                            background:rgba(0,0,0,.6);color:#fff;
                                            font-size:9px;font-weight:800;padding:1px 5px;
                                            border-radius:100px;">VIDEO</div>
                            </div>`;
                        }
                        return `
                        <img src="${m.mediaUrl}"
                             onclick="window.open('${m.mediaUrl}', '_blank')"
                             style="width:88px;height:88px;object-fit:cover;border-radius:8px;
                                    border:1.5px solid var(--fb-border);cursor:pointer;flex-shrink:0;"
                             onerror="this.parentElement.style.display='none'">`;
                    }).join('')}
                </div>
            </div>` : ''}
        </div>

        ${replySection}`;
        }

        // ── REPLY MODAL ───────────────────────────────────────────────
        function openReply(feedbackId, comment, rating, createdDate) {
            document.getElementById('replyModalTitle').innerHTML =
                `<i class="bi bi-reply" style="color:var(--fb-green2)"></i> Feedback Reply`;
            document.getElementById('replySubmitBtn').innerHTML =
                `<i class="bi bi-send"></i> Send Reply`;
            const textarea = document.getElementById('replyContent');
            document.getElementById('replyContent').value    = '';
            document.getElementById('replyFeedbackId').value = feedbackId;
            document.getElementById('replyMode').value       = 'new';
            document.getElementById('replyContextComment').textContent = comment || 'No Content';
            document.getElementById('replyContextStars').innerHTML     = renderStars(rating);
            document.getElementById('replyContextDate').textContent    = formatDate(createdDate);
            document.getElementById('replyCharCount').textContent      = '0';
            autoGrowTextarea(textarea);
            openModal('modalReply');
            setTimeout(() => document.getElementById('replyContent').focus(), 200);
            loadContextMedia(feedbackId);
        }

        function openEditReply(feedbackId, comment, rating, createdDate, existingReply) {
            document.getElementById('replyModalTitle').innerHTML =
                `<i class="bi bi-pencil-square" style="color:var(--fb-blue)"></i> Edit Reply`;
            document.getElementById('replySubmitBtn').innerHTML =
                `<i class="bi bi-check-lg"></i> Edit`;
            const textarea = document.getElementById('replyContent');
            document.getElementById('replyContent').value    = existingReply || '';
            document.getElementById('replyFeedbackId').value = feedbackId;
            document.getElementById('replyMode').value       = 'edit';
            document.getElementById('replyContextComment').textContent = comment || 'No Content';
            document.getElementById('replyContextStars').innerHTML     = renderStars(rating);
            document.getElementById('replyContextDate').textContent    = formatDate(createdDate);
            document.getElementById('replyCharCount').textContent      = (existingReply||'').length;
            openModal('modalReply');
            setTimeout(() => {
                autoGrowTextarea(textarea);
                textarea.focus();
            }, 50);
            loadContextMedia(feedbackId);
        }

        async function loadContextMedia(feedbackId) {
            const wrap = document.getElementById('replyContextMedia');

            wrap.style.display = 'block';
            wrap.innerHTML = `
                <div class="fb-context-media-loading">
                    <i class="bi bi-arrow-repeat" style="animation:spin 1s linear infinite"></i>
                    Loading attachments...
                </div>`;

            try {
                const res  = await fetch(`/AdminFeedback/GetDetail?feedbackId=${feedbackId}`);
                const json = await res.json();

                const media = json?.success ? (json.data?.mediaFiles || []) : [];

                if (!media.length) {
                    wrap.style.display = 'none'; 
                    wrap.innerHTML = '';
                    return;
                }

                const thumbs = media.map(m => {
                    if (m.mediaType === 'video') {
                        return `
                            <div class="fb-context-media-thumb" onclick="window.open('${m.mediaUrl}', '_blank')">
                                <video src="${m.mediaUrl}" muted></video>
                                <div class="fb-context-media-play"><span>▶</span></div>
                            </div>`;
                    }
                    return `
                        <div class="fb-context-media-thumb" onclick="window.open('${m.mediaUrl}', '_blank')">
                            <img src="${m.mediaUrl}" onerror="this.parentElement.style.display='none'">
                        </div>`;
                }).join('');

                wrap.innerHTML = `
                    <div class="fb-context-media-lbl">
                        Attachments (${media.length} file${media.length > 1 ? 's' : ''})
                    </div>
                    <div class="fb-context-media-grid">${thumbs}</div>`;

            } catch {
                wrap.style.display = 'none';
                wrap.innerHTML = '';
            }
        }

        async function submitReply() {
            const content    = document.getElementById('replyContent').value.trim();
            const feedbackId = document.getElementById('replyFeedbackId').value;
            const mode       = document.getElementById('replyMode').value;

            if (!content) {
                showToast('Please enter your Reply.', 'error');
                document.getElementById('replyContent').focus();
                return;
            }

            const btn = document.getElementById('replySubmitBtn');
            btn.disabled = true;
            btn.innerHTML = `<i class="bi bi-arrow-repeat"></i> Sending...`;

            try {
                let url, body;
                if (mode === 'new') {
                    url  = '/AdminFeedback/Reply';
                    body = { feedbackId, staffId: STAFF_ID, replyContent: content };
                } else {
                    url  = '/AdminFeedback/UpdateReply';
                    body = { feedbackId, replyContent: content };
                }

                const res  = await fetch(url, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(body)
                });
                const json = await res.json();

                if (json.success) {
                    closeModal('modalReply');
                    showToast(json.message || 'Complete!', 'success');
                    loadFeedbacks(currentPage);
                } else {
                    showToast(json.message || 'An error occurred.', 'error');
                }
            } catch {
                showToast('Server connection error.', 'error');
            } finally {
                btn.disabled = false;
                btn.innerHTML = mode === 'new'
                    ? `<i class="bi bi-send"></i> Send Reply`
                    : `<i class="bi bi-check-lg"></i> Edit`;
            }
        }

        // ── DELETE REPLY ──────────────────────────────────────────────
        function openDeleteReply(feedbackId) {
            document.getElementById('deleteFeedbackId').value = feedbackId;
            openModal('modalDelete');
        }

        async function confirmDeleteReply() {
            const feedbackId = document.getElementById('deleteFeedbackId').value;
            try {
                const res  = await fetch('/AdminFeedback/DeleteReply', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(feedbackId)
                });
                const json = await res.json();

                if (json.success) {
                    closeModal('modalDelete');
                    showToast(json.message || 'Reply has been deleted..', 'success');
                    loadFeedbacks(currentPage);
                } else {
                    showToast(json.message || 'An error occurred.', 'error');
                }
            } catch {
                showToast('Server connection error.', 'error');
            }
        }

        // ── TOGGLE VISIBILITY ─────────────────────────────────────────
        async function toggleVisibility(feedbackId, isVisible) {
            try {
                const res  = await fetch('/AdminFeedback/ToggleVisibility', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ feedbackId, isVisible })
                });
                const json = await res.json();
                if (json.success) {
                    showToast(json.message || 'Updated.', 'success');
                    loadFeedbacks(currentPage);
                } else {
                    showToast(json.message || 'An error occurred.', 'error');
                }
            } catch {
                showToast('Server connection error.', 'error');
            }
        }

        // ── RESET FILTER ──────────────────────────────────────────────
        function resetFilter() {
            document.getElementById('fKeyword').value  = '';
            document.getElementById('fHasReply').value = '';
            document.getElementById('fRating').value   = '';
            document.getElementById('fSortBy').value   = 'newest';
            document.getElementById('fPageSize').value = '10';
            loadFeedbacks(1);
        }

        // ── MODAL HELPERS ─────────────────────────────────────────────
        function openModal(id)  { document.getElementById(id).classList.add('open'); }
        function closeModal(id) { document.getElementById(id).classList.remove('open'); }

        // Close on overlay click
        document.querySelectorAll('.fb-overlay').forEach(overlay => {
            overlay.addEventListener('click', e => {
                if (e.target === overlay) overlay.classList.remove('open');
            });
        });

        // ── TABLE STATE HELPERS ───────────────────────────────────────
        function showTableLoading() {
            document.getElementById('fbTableBody').innerHTML = `
                <div class="fb-loading">
                    <i class="bi bi-arrow-repeat"
                       style="font-size:22px;display:block;margin-bottom:8px;
                              animation:spin 1s linear infinite"></i>
                    Loading data...
                </div>`;
            document.getElementById('fbPagination').style.display = 'none';
        }

        function showTableEmpty(msg) {
            document.getElementById('fbTableBody').innerHTML = `
                <div class="fb-empty">
                    <div class="fb-empty-icon">💬</div>
                    <div class="fb-empty-text">${msg}</div>
                </div>`;
            document.getElementById('fbPagination').style.display = 'none';
            document.getElementById('totalBadge').textContent = '0 Result';
        }

        // ── TOAST ─────────────────────────────────────────────────────
        function showToast(msg, type = 'success') {
            const wrap = document.getElementById('fbToastWrap');
            const icon = type === 'success' ? '✓' : '✕';
            const el   = document.createElement('div');
            el.className = `fb-toast ${type}`;
            el.innerHTML = `<span>${icon}</span> ${msg}`;
            wrap.appendChild(el);
            setTimeout(() => el.remove(), 3500);
        }

        // ── UTILS ─────────────────────────────────────────────────────
        function updateCharCount(el, countId, max) {
            document.getElementById(countId).textContent = el.value.length;
        }

        function formatDate(dateStr) {
            if (!dateStr) return '–';
            const d = new Date(dateStr);
            if (isNaN(d)) return '–';
            return d.toLocaleDateString('vi-VN', {
                day: '2-digit', month: '2-digit', year: 'numeric',
                hour: '2-digit', minute: '2-digit'
            });
        }

        function escHtml(str) {
            return String(str)
                .replace(/&/g,'&amp;')
                .replace(/</g,'&lt;')
                .replace(/>/g,'&gt;')
                .replace(/"/g,'&quot;')
                .replace(/'/g,'&#39;');
        }

        function autoGrowTextarea(el) {
            el.style.height = 'auto';
            const maxHeightPx = window.innerHeight * 0.5;

            if (el.scrollHeight > maxHeightPx) {
                el.style.height = maxHeightPx + 'px';
                el.style.overflowY = 'auto';
            } else {
                el.style.height = el.scrollHeight + 'px';
                el.style.overflowY = 'hidden';
            }
        }

        window.addEventListener('resize', () => {
            const textarea = document.getElementById('replyContent');
            if (document.getElementById('modalReply').classList.contains('open')) {
                autoGrowTextarea(textarea);
            }
        });
    </script>

    <style>
        @@keyframes spin {
            from { transform: rotate(0deg);   }
            to   { transform: rotate(360deg); }
        }
    </style>
}
