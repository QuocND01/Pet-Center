@using static PetCenterClient.ViewModels.PrescriptionItem.PrescriptionItemViewModel
@model UpdatePrescriptionItemViewModel

<style>
    .page-card { background:#fff; border-radius:14px; padding:20px; }
    .form-control { min-height:42px; border-radius:10px; }
</style>

<div class="page-card">
    <h6 class="fw-bold mb-3">Edit Prescription Item</h6>

    <form asp-action="Edit" asp-controller="PrescriptionItem" asp-route-id="@Model.PrescriptionItemId" method="post">
        <input type="hidden" asp-for="PrescriptionItemId" />
        <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

        <div class="row">
            <div class="col-12 mb-3">
                <label asp-for="MedicineName" class="form-label fw-semibold">
                    Medicine Name <span class="text-danger">*</span>
                </label>
                <input asp-for="MedicineName" class="form-control" />
                <span asp-validation-for="MedicineName" class="text-danger"></span>
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="Dosage" class="form-label fw-semibold">
                    Dosage <span class="text-danger">*</span>
                </label>
                <input asp-for="Dosage" class="form-control" />
                <span asp-validation-for="Dosage" class="text-danger"></span>
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="Duration" class="form-label fw-semibold">
                    Duration <span class="text-danger">*</span>
                </label>
                <input asp-for="Duration" class="form-control" />
                <span asp-validation-for="Duration" class="text-danger"></span>
            </div>
            <div class="col-md-4 mb-3">
                <label asp-for="Quantity" class="form-label fw-semibold">
                    Quantity <span class="text-danger">*</span>
                </label>
                <input asp-for="Quantity" type="number" min="1" class="form-control" />
                <span asp-validation-for="Quantity" class="text-danger"></span>
            </div>
            <div class="col-md-8 mb-3">
                <label asp-for="Note" class="form-label fw-semibold">Note</label>
                <input asp-for="Note" class="form-control" />
                <span asp-validation-for="Note" class="text-danger"></span>
            </div>
        </div>

        <div class="text-end">
            <button type="submit" class="btn btn-primary px-4">
                <i class="bi bi-check-circle me-1"></i> Save Changes
            </button>
        </div>
    </form>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
