@using static PetCenterClient.ViewModels.PrescriptionItem.PrescriptionItemViewModel
@model CreatePrescriptionItemViewModel

<style>
    .page-card { background:#fff; border-radius:14px; padding:20px; }
    .form-control, .form-select { min-height:42px; border-radius:10px; }
</style>

<div class="page-card">
    <h6 class="fw-bold mb-3">Add Prescription Item</h6>

    <form asp-action="Create" asp-controller="PrescriptionItem" method="post">
        <input type="hidden" asp-for="RecordId" />
        <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

        <div class="row">
            <div class="col-12 mb-3">
                <label asp-for="MedicineName" class="form-label fw-semibold">
                    Medicine Name <span class="text-danger">*</span>
                </label>
                <input asp-for="MedicineName" class="form-control" placeholder="e.g. Amoxicillin" />
                <span asp-validation-for="MedicineName" class="text-danger"></span>
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="Dosage" class="form-label fw-semibold">
                    Dosage <span class="text-danger">*</span>
                </label>
                <input asp-for="Dosage" class="form-control" placeholder="e.g. 250mg twice daily" />
                <span asp-validation-for="Dosage" class="text-danger"></span>
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="Duration" class="form-label fw-semibold">
                    Duration <span class="text-danger">*</span>
                </label>
                <input asp-for="Duration" class="form-control" placeholder="e.g. 7 days" />
                <span asp-validation-for="Duration" class="text-danger"></span>
            </div>
            <div class="col-md-4 mb-3">
                <label asp-for="Quantity" class="form-label fw-semibold">
                    Quantity <span class="text-danger">*</span>
                </label>
                <input asp-for="Quantity" type="number" min="1" class="form-control" />
                <span asp-validation-for="Quantity" class="text-danger"></span>
            </div>
            <div class="col-md-8 mb-3">
                <label asp-for="Note" class="form-label fw-semibold">Note</label>
                <input asp-for="Note" class="form-control" placeholder="Additional instructions..." />
                <span asp-validation-for="Note" class="text-danger"></span>
            </div>
        </div>

        <div class="text-end">
            <button type="submit" class="btn btn-success px-4">
                <i class="bi bi-plus-circle me-1"></i> Add Item
            </button>
        </div>
    </form>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
