@model PetCenterClient.ViewModels.Brand.ReadBrandViewModel

<style>

    .detail-card {
        background: #fff;
        border: 1px solid #e9ecef;
        border-radius: 18px;
        padding: 25px;
        max-width: 100%;
        overflow: hidden;
    }

    .brand-header {
        text-align: center;
        margin-bottom: 30px;
    }

    .brand-logo {
        width: 150px;
        height: 150px;
        object-fit: cover;
        border-radius: 18px;
        border: 4px solid #fff;
        box-shadow: 0 6px 25px rgba(0,0,0,.12);
    }

    .brand-name {
        margin-top: 15px;
        font-size: 20px;
        font-weight: 700;
        color: #212529;
        white-space: normal;
        overflow-wrap: anywhere;
        word-break: break-word;
        line-height: 1.5;
    }

    .info-item {
        background: #f8f9fa;
        border-radius: 12px;
        padding: 15px 18px;
        margin-bottom: 15px;
        min-width: 0;
    }

    .info-label {
        font-size: 13px;
        font-weight: 700;
        text-transform: uppercase;
        color: #6c757d;
        margin-bottom: 6px;
        letter-spacing: .5px;
    }

    .info-value {
        font-size: 16px;
        color: #212529;
        white-space: normal;
        overflow-wrap: anywhere;
        word-break: break-word;
        line-height: 1.5;
    }

    .empty-value {
        color: #6c757d;
        font-style: italic;
    }

</style>

<div class="detail-card">
    <div class="brand-header">

        @if (!string.IsNullOrEmpty(Model.BrandLogo))
        {
            <img src="@Model.BrandLogo"
                 class="brand-logo"
                 alt="Brand Logo" />
        }
        else
        {
            <img src="https://via.placeholder.com/150?text=Brand"
                 class="brand-logo"
                 alt="No Logo" />
        }

    </div>

    <div class="info-item">

        <div class="info-label">
            Brand Name
        </div>

        <div class="info-value">
            @Model.BrandName
        </div>

    </div>

    <div class="info-item">

        <div class="info-label">
            Description
        </div>

        <div class="info-value">

            @if (!string.IsNullOrWhiteSpace(Model.BrandDescription))
            {
                @Model.BrandDescription
            }
            else
            {
                <span class="empty-value">
                    No description available
                </span>
            }

        </div>

    </div>

    @* <div class="info-item">

        <div class="info-label">
            Brand Logo
        </div>

        <div class="info-value">

            @if (!string.IsNullOrEmpty(Model.BrandLogo))
            {
                <span class="text-success">
                    Logo uploaded
                </span>
            }
            else
            {
                <span class="empty-value">
                    No logo uploaded
                </span>
            }

        </div>

    </div> *@


</div>
