@model PetCenterClient.DTOs.ReadBrandDTOs

<style>

    .brand-logo {
        width: 120px;
        height: 120px;
        object-fit: cover;
        border-radius: 8px;
        border: 1px solid #ddd;
    }

</style>

<div class="row">

    <div class="col-md-12 mb-3">
        <label class="fw-bold">Brand Name</label>
        <div>@Model.BrandName</div>
    </div>


    <div class="col-md-12 mb-3">
        <label class="fw-bold">Description</label>
        <div>
            @if (!string.IsNullOrEmpty(Model.BrandDescription))
            {
                @Model.BrandDescription
            }
            else
            {
                <span class="text-muted">No description</span>
            }
        </div>
    </div>

    <!-- Logo -->

    <div class="col-md-12 mb-3">

        <label class="fw-bold">Brand Logo</label>

        <div class="mt-2">

            @if (!string.IsNullOrEmpty(Model.BrandLogo))
            {
                <img src="@Model.BrandLogo" class="brand-logo" />
            }
            else
            {
                <span>No logo</span>
            }

        </div>

    </div>

</div>