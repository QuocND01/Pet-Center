@model PetCenterClient.ViewModels.Brand.CreateBrandViewModel

<style>
    body {
        background: #f4f6f9;
    }

    .page-container {
        max-width: 900px;
        margin: 40px auto;
        padding: 0 15px;
    }

    .brand-card {
        background: #fff;
        border-radius: 20px;
        padding: 35px;
        box-shadow: 0 10px 35px rgba(0, 0, 0, 0.08);
    }

    .page-title {
        font-size: 30px;
        font-weight: 700;
        color: #212529;
        margin-bottom: 5px;
    }

    .page-subtitle {
        color: #6c757d;
        margin-bottom: 30px;
    }

    .form-label {
        font-weight: 600;
        color: #343a40;
        margin-bottom: 8px;
    }

    .form-control {
        border-radius: 12px;
        border: 1px solid #dee2e6;
        min-height: 48px;
        transition: all .25s ease;
    }

    textarea.form-control {
        min-height: 120px;
        resize: vertical;
    }

    .form-control:focus {
        border-color: #4f46e5;
        box-shadow: 0 0 0 0.2rem rgba(79, 70, 229, .15);
    }

    .upload-box {
        border: 2px dashed #ced4da;
        border-radius: 16px;
        padding: 30px;
        text-align: center;
        background: #fafafa;
        cursor: pointer;
        transition: all .25s ease;
    }

        .upload-box:hover {
            border-color: #4f46e5;
            background: #f7f7ff;
        }

    .brand-create-logo {
        width: 180px;
        height: 180px;
        object-fit: cover;
        border-radius: 16px;
        border: 3px solid #e9ecef;
        box-shadow: 0 5px 20px rgba(0,0,0,.08);
    }

    .preview-text {
        margin-top: 15px;
        color: #6c757d;
        font-size: 14px;
    }

    .btn-create {
        min-width: 180px;
        height: 50px;
        border-radius: 12px;
        font-weight: 600;
        font-size: 16px;
    }

    .text-danger {
        font-size: 14px;
    }
</style>

<div class="page-container">
    <div class="brand-card">

        <h2 class="page-title">
            Create Brand
        </h2>

        <p class="page-subtitle">
            Add a new brand to your product catalog
        </p>

        <form method="post"
              enctype="multipart/form-data"
              asp-action="Create"
              asp-controller="Brand">

            <div asp-validation-summary="ModelOnly"
                 class="text-danger mb-3">
            </div>

            <div class="row">

                <div class="col-md-12 mb-4">

                    <label asp-for="BrandName"
                           class="form-label">
                    </label>

                    <input asp-for="BrandName"
                           class="form-control"
                           placeholder="Enter brand name" />

                    <span asp-validation-for="BrandName"
                          class="text-danger">
                    </span>

                </div>

                <div class="col-md-12 mb-4">

                    <label asp-for="BrandDescription"
                           class="form-label">
                    </label>

                    <textarea asp-for="BrandDescription"
                              class="form-control"
                              placeholder="Enter brand description">
                </textarea>

                    <span asp-validation-for="BrandDescription"
                          class="text-danger">
                    </span>

                </div>

                <div class="col-md-12">

                    <label class="form-label">
                        Brand Logo
                    </label>

                    <div class="upload-box"
                         onclick="document.getElementById('logoInput').click()">

                        <img id="logoPreview"
                             src="https://via.placeholder.com/180?text=Logo"
                             class="brand-create-logo" />

                        <div class="preview-text">
                            Click here to upload a logo image
                        </div>

                    </div>

                    <input asp-for="BrandLogo"
                           type="file"
                           id="logoInput"
                           accept="image/*"
                           hidden
                           onchange="previewLogo(this)" />

                    <span asp-validation-for="BrandLogo"
                          class="text-danger">
                    </span>

                </div>

            </div>

            <div class="text-end mt-4">

                <button type="submit"
                        class="btn btn-primary btn-create">

                    Create Brand

                </button>

            </div>

        </form>

    </div>


</div>
<script>
    window.previewLogo = function (input) {
        const file = input.files[0];
        if (!file) return;

        const reader = new FileReader();

        reader.onload = function (e) {
            document.getElementById("logoPreview").src = e.target.result;
        };

        reader.readAsDataURL(file);
    };
</script>
