@model PetCenterClient.DTOs.CreateBrandDTOs

<style>
    .logo-preview {
        width: 120px;
        height: 120px;
        object-fit: cover;
        border: 2px dashed #ccc;
        border-radius: 8px;
        cursor: pointer;
    }
</style>

<form method="post"
      enctype="multipart/form-data"
      asp-action="Create"
      asp-controller="Brand">

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="row">

        <!-- BRAND NAME -->
        <div class="col-md-12 mb-3">
            <label asp-for="BrandName" class="form-label"></label>
            <input asp-for="BrandName" class="form-control" />
            <span asp-validation-for="BrandName" class="text-danger"></span>
        </div>

        <!-- BRAND DESCRIPTION -->
        <div class="col-md-12 mb-3">
            <label asp-for="BrandDescription" class="form-label"></label>

            <textarea asp-for="BrandDescription"
                      class="form-control"
                      rows="3"
                      placeholder="Enter brand description"></textarea>

            <span asp-validation-for="BrandDescription"
                  class="text-danger"></span>
        </div>

        <!-- FILE INPUT -->
        <div class="col-md-12 mb-3">

            <label class="form-label">Brand Logo</label>

            <input type="file"
                   name="BrandLogo"
                   id="logoInput"
                   accept="image/*"
                   hidden
                   onchange="previewLogo(this)" />

        </div>

    </div>

    <!-- PREVIEW -->
    <div class="mt-3">

        <label class="fw-bold">Preview</label>

        <div class="mt-2">

            <img id="logoPreview"
                 src="https://via.placeholder.com/120"
                 class="logo-preview"
                 onclick="document.getElementById('logoInput').click()" />

        </div>

    </div>

    <button class="btn btn-primary mt-3">
        Create Brand
    </button>

</form>

<script>
    function previewLogo(input) {

        const file = input.files[0]

        if (!file) return

        const reader = new FileReader()

        reader.onload = function (e) {
            document.getElementById("logoPreview").src = e.target.result
        }

        reader.readAsDataURL(file)
    }
</script>