@model PetCenterClient.DTOs.CreateBrandDTOs

<style>

    .logo-preview {
        width: 120px;
        height: 120px;
        object-fit: cover;
        border: 2px dashed #ccc;
        border-radius: 8px;
    }

</style>

<form method="post"
      asp-action="Create"
      asp-controller="Brand">

    <!-- HIỂN THỊ LỖI MODEL -->
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="row">

        <!-- BRAND NAME -->
        <div class="col-md-12 mb-3">

            <label asp-for="BrandName" class="form-label"></label>

            <input asp-for="BrandName"
                   class="form-control" />

            <!-- HIỂN THỊ LỖI -->
            <span asp-validation-for="BrandName"
                  class="text-danger"></span>

        </div>


        <!-- LOGO URL -->
        <div class="col-md-12 mb-3">

            <label asp-for="BrandLogo" class="form-label"></label>

            <input asp-for="BrandLogo"
                   id="logoInput"
                   class="form-control"
                   placeholder="Enter logo image url" />

        </div>

    </div>


    <!-- PREVIEW -->
    <div class="mt-3">

        <label class="fw-bold">Preview</label>

        <div class="mt-2">

            <img id="logoPreview"
                 src="https://via.placeholder.com/120"
                 class="logo-preview" />

        </div>

    </div>


    <button class="btn btn-primary mt-3">
        Create Brand
    </button>

</form>


<script>

    // preview khi thay đổi url
    $("#logoInput").on("input", function () {

        const url = $(this).val()

        if (url) {
            $("#logoPreview").attr("src", url)
        } else {
            $("#logoPreview").attr("src", "https://via.placeholder.com/120")
        }

    })

</script>