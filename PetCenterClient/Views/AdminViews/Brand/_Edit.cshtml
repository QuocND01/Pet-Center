@model PetCenterClient.ViewModels.Brand.UpdateBrandViewModel

<style>

    .edit-card {
        background: #fff;
        border-radius: 18px;
        padding: 25px;
    }

    .page-title {
        font-size: 24px;
        font-weight: 700;
        color: #212529;
        margin-bottom: 5px;
    }

    .page-subtitle {
        color: #6c757d;
        margin-bottom: 25px;
    }

    .form-label {
        font-weight: 600;
        color: #343a40;
        margin-bottom: 8px;
    }

    .form-control {
        border-radius: 12px;
        min-height: 48px;
        border: 1px solid #dee2e6;
    }

        .form-control:focus {
            border-color: #4f46e5;
            box-shadow: 0 0 0 .2rem rgba(79,70,229,.15);
        }

    textarea.form-control {
        min-height: 120px;
        resize: vertical;
    }

    .logo-section {
        text-align: center;
        margin-top: 25px;
    }

    .logo-wrapper {
        position: relative;
        display: inline-block;
    }

    .logo-preview {
        width: 180px;
        height: 180px;
        object-fit: cover;
        border-radius: 18px;
        border: 3px solid #fff;
        box-shadow: 0 6px 25px rgba(0,0,0,.12);
        cursor: pointer;
        transition: .25s;
    }

        .logo-preview:hover {
            transform: scale(1.03);
        }

    .remove-btn {
        position: absolute;
        top: -8px;
        right: -8px;
        width: 30px;
        height: 30px;
        border-radius: 50%;
        padding: 0;
        font-size: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .upload-text {
        margin-top: 12px;
        color: #6c757d;
        font-size: 14px;
    }

    .btn-update {
        min-width: 140px;
        border-radius: 10px;
        font-weight: 600;
    }

    .btn-cancel {
        min-width: 140px;
        border-radius: 10px;
        font-weight: 600;
    }

</style>

<form asp-action="Edit"
      asp-controller="Brand"
      method="post"
      enctype="multipart/form-data">
    <input type="hidden" asp-for="BrandId" />
    <input type="hidden" asp-for="Status" />

    <div class="edit-card">

        <h3 class="page-title">
            Edit Brand
        </h3>

        <p class="page-subtitle">
            Update brand information and logo
        </p>

        <div asp-validation-summary="ModelOnly"
             class="text-danger mb-3">
        </div>

        <div class="row">

            <div class="col-md-12 mb-4">

                <label asp-for="BrandName"
                       class="form-label">
                </label>

                <input asp-for="BrandName"
                       class="form-control" />

                <span asp-validation-for="BrandName"
                      class="text-danger">
                </span>

            </div>

            <div class="col-md-12">

                <label asp-for="BrandDescription"
                       class="form-label">
                </label>

                <textarea asp-for="BrandDescription"
                          class="form-control"
                          placeholder="Enter brand description">
            </textarea>

                <span asp-validation-for="BrandDescription"
                      class="text-danger">
                </span>

            </div>

        </div>

        <div class="logo-section">

            <h5 class="mb-3">
                Brand Logo
            </h5>

            <div class="logo-wrapper">

                <img id="logoPreview"
                     src="@(string.IsNullOrEmpty(Model.ExistingBrandLogo)
                                         ? "https://via.placeholder.com/180?text=Brand"
                                         : Model.ExistingBrandLogo)"
                     class="logo-preview"
                     onclick="document.getElementById('logoInput').click()" />

                <button type="button"
                        class="btn btn-danger remove-btn"
                        onclick="removeLogo()">

                    <i class="bi bi-x-lg"></i>

                </button>

            </div>

            <div class="upload-text">
                Click the image to upload a new logo
            </div>

            <input asp-for="BrandLogo"
                   type="file"
                   id="logoInput"
                   accept="image/*"
                   hidden
                   onchange="previewLogo(this)" />

        </div>

        <div class="d-flex justify-content-end gap-2 mt-4">

            <button type="button"
                    class="btn btn-outline-secondary btn-cancel"
                    data-bs-dismiss="modal">

                Cancel

            </button>

            <button type="submit"
                    class="btn btn-warning btn-update">

                <i class="bi bi-pencil-square me-1"></i>
                Update

            </button>

        </div>

    </div>

</form>

<script>

    function previewLogo(input) {

        const file = input.files[0];

        if (!file)
            return;

        const reader = new FileReader();

        reader.onload = function (e) {

            document.getElementById("logoPreview").src =
                e.target.result;

        };

        reader.readAsDataURL(file);
    }

    function removeLogo() {

        document.getElementById("logoPreview").src =
            "https://via.placeholder.com/180?text=Brand";

        document.getElementById("logoInput").value = "";
    }

</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
