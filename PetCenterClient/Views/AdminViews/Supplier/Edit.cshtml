@model ReadSupplierDto
@using PetCenterClient.DTOs;
@{
    Layout = null; // Bắt buộc là null
}

<form id="editForm">
    @* ASP.NET Core Hidden Field *@
    <input type="hidden" asp-for="SupplierId" />

    <div class="mb-3">
        <label class="form-label">Name</label>
        <input class="form-control" asp-for="SupplierName" required />
    </div>

    <div class="mb-3">
        <label class="form-label">Email</label>
        <input type="email" class="form-control" asp-for="SupplierEmail" required />
    </div>

    <div class="mb-3">
        <label class="form-label">Phone</label>
        <input class="form-control" asp-for="SupplierPhoneNumber" />
    </div>

    <div class="mb-3">
        <label class="form-label">Address</label>
        <input class="form-control" asp-for="SupplierAddress" />
    </div>

    <div class="modal-footer px-0 pb-0">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
        <button type="submit" class="btn btn-success">Save Changes</button>
    </div>
</form>