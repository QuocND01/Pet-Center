@using PetCenterClient.DTOs
@model List<ReadSupplierDto>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@* Chèn thư viện (nếu Layout chưa có) *@
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>

<h2>Suppliers Management</h2>

<button class="btn btn-primary" id="btnCreate">Create Supplier</button>

<table class="table mt-3">
    <thead>
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Phone</th>
            <th>Address</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var s in Model)
        {
            <tr>
                <td>@s.SupplierName</td>
                <td>@s.SupplierEmail</td>
                <td>@s.SupplierPhoneNumber</td>
                <td>@s.SupplierAddress</td>
                <td>
                    <button class="btn btn-warning btn-edit" data-id="@s.SupplierId">Edit</button>
                    <button class="btn btn-danger btn-delete" data-id="@s.SupplierId" data-name="@s.SupplierName">Delete</button>
                </td>
            </tr>
        }
    </tbody>
</table>

<div class="modal fade" id="supplierModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalTitle">Supplier Information</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="modalBody">
            </div>
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        var myModal = new bootstrap.Modal(document.getElementById('supplierModal'));

        // 1. Mở Modal CREATE
        $("#btnCreate").click(function () {
            $("#modalTitle").text("Create New Supplier");
            $("#modalBody").load('/Suppliers/Create', function () {
                myModal.show();
            });
        });

        // 2. Mở Modal EDIT
            $(document).on("click", ".btn-edit", function () {
        var id = $(this).data("id");
        // Sử dụng URL tuyệt đối an toàn
        $("#modalBody").load('/Suppliers/Edit/' + id, function () {
            myModal.show();
        });
    });

        // 3. Mở Modal DELETE (Xác nhận xóa)
        $(document).on("click", ".btn-delete", function () {
            var id = $(this).data("id");
            var name = $(this).data("name");
            $("#modalTitle").text("Confirm Delete");
            $("#modalBody").html(`
                <p>Are you sure you want to delete supplier: <b>${name}</b>?</p>
                <div class="modal-footer px-0 pb-0">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-danger" id="confirmDeleteBtn" data-id="${id}">Delete</button>
                </div>
            `);
            myModal.show();
        });

        // 4. Xử lý SUBMIT (Dùng cho cả CreateForm và EditForm)
        $(document).on("submit", "#createForm, #editForm", function (e) {
            e.preventDefault();
            var form = $(this);
            var url = form.attr('id') === "createForm" ? '/Suppliers/Create' : '/Suppliers/Edit';

            $.ajax({
                url: url,
                type: 'POST',
                data: form.serialize(),
                    success: function (res) {

                if (res.success) {
                        location.reload();
                } else {
                        $("#modalBody").html(res);
                }

                },
                error: function () {
                    alert("Error saving data!");
                }
            });
        });

        // 5. Xử lý CLICK DELETE thực sự
        $(document).on("click", "#confirmDeleteBtn", function () {
            var id = $(this).data("id");
            $.post('/Suppliers/Delete/' + id, function () {
                location.reload();
            }).fail(function() {
                alert("Error deleting supplier!");
            });
        });
    });
</script>