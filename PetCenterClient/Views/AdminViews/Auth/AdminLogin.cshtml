@{
    Layout = null;
}
@model PetCenterClient.DTOs.LoginDto

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>PetCenter Admin Login</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            min-height: 100vh;
            display: flex;
            background: #0a1a0f;
            overflow: hidden;
        }

        /* Left panel */
        .left-panel {
            width: 55%;
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(145deg, #052e16 0%, #065f46 45%, #047857 100%);
            overflow: hidden;
        }

            .left-panel::before {
                content: '';
                position: absolute;
                width: 650px;
                height: 650px;
                border-radius: 50%;
                background: radial-gradient(circle, rgba(16,185,129,0.25) 0%, transparent 65%);
                top: -120px;
                left: -120px;
            }

            .left-panel::after {
                content: '';
                position: absolute;
                width: 450px;
                height: 450px;
                border-radius: 50%;
                background: radial-gradient(circle, rgba(52,211,153,0.18) 0%, transparent 65%);
                bottom: -60px;
                right: -60px;
            }

        .orb {
            position: absolute;
            width: 200px;
            height: 200px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(110,231,183,0.12) 0%, transparent 70%);
            top: 55%;
            left: 55%;
        }

        .left-content {
            position: relative;
            z-index: 1;
            text-align: center;
            padding: 40px;
        }

        .brand-icon {
            font-size: 64px;
            margin-bottom: 24px;
            display: block;
            filter: drop-shadow(0 8px 28px rgba(16,185,129,0.5));
        }

        .brand-name {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 38px;
            font-weight: 700;
            color: white;
            letter-spacing: -1.2px;
            margin-bottom: 12px;
        }

            .brand-name span {
                color: #6ee7b7;
            }

        .brand-sub {
            font-size: 14.5px;
            color: rgba(255,255,255,0.5);
            line-height: 1.7;
            max-width: 300px;
            margin: 0 auto 44px;
        }

        .feature-list {
            list-style: none;
            text-align: left;
            display: inline-block;
        }

            .feature-list li {
                display: flex;
                align-items: center;
                gap: 12px;
                color: rgba(255,255,255,0.65);
                font-size: 14px;
                margin-bottom: 14px;
            }

                .feature-list li i {
                    width: 32px;
                    height: 32px;
                    background: rgba(16,185,129,0.2);
                    border: 1px solid rgba(16,185,129,0.25);
                    border-radius: 9px;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    font-size: 14px;
                    color: #6ee7b7;
                    flex-shrink: 0;
                }

        /* Right panel */
        .right-panel {
            width: 45%;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #0a1a0f;
            padding: 48px 40px;
            position: relative;
        }

            .right-panel::before {
                content: '';
                position: absolute;
                width: 300px;
                height: 300px;
                border-radius: 50%;
                background: radial-gradient(circle, rgba(16,185,129,0.06) 0%, transparent 70%);
                top: -80px;
                right: -80px;
                pointer-events: none;
            }

        .form-box {
            width: 100%;
            max-width: 380px;
            position: relative;
            z-index: 1;
        }

        .form-header {
            margin-bottom: 36px;
        }

            .form-header h2 {
                font-family: 'Space Grotesk', sans-serif;
                font-size: 27px;
                font-weight: 700;
                color: white;
                margin-bottom: 6px;
                letter-spacing: -0.5px;
            }

            .form-header p {
                font-size: 14px;
                color: #4b6b55;
            }

        /* Role tabs */
        .role-tabs {
            display: flex;
            background: #112318;
            border: 1px solid #1a3a25;
            border-radius: 11px;
            padding: 4px;
            margin-bottom: 28px;
            gap: 4px;
        }

        .role-tab {
            flex: 1;
            padding: 9px;
            border: none;
            border-radius: 8px;
            background: transparent;
            color: #4b6b55;
            font-family: 'DM Sans', sans-serif;
            font-size: 13px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
        }

            .role-tab.active {
                background: linear-gradient(135deg, #059669, #10b981);
                color: white;
                box-shadow: 0 2px 12px rgba(16,185,129,0.35);
            }

        /* Fields */
        .field-group {
            margin-bottom: 18px;
        }

        .field-label {
            display: block;
            font-size: 11.5px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.7px;
            color: #4b6b55;
            margin-bottom: 8px;
        }

        .input-wrap {
            position: relative;
        }

            .input-wrap i.icon {
                position: absolute;
                left: 14px;
                top: 50%;
                transform: translateY(-50%);
                color: #2d5a3d;
                font-size: 15px;
                pointer-events: none;
            }

        .field-input {
            width: 100%;
            padding: 12px 14px 12px 42px;
            background: #112318;
            border: 1px solid #1a3a25;
            border-radius: 10px;
            font-family: 'DM Sans', sans-serif;
            font-size: 14px;
            color: #e2f5ea;
            outline: none;
            transition: all 0.2s;
        }

            .field-input::placeholder {
                color: #2d5a3d;
            }

            .field-input:focus {
                border-color: #10b981;
                box-shadow: 0 0 0 3px rgba(16,185,129,0.12);
            }

        .toggle-pw {
            position: absolute;
            right: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: #2d5a3d;
            cursor: pointer;
            font-size: 15px;
            transition: color 0.2s;
        }

            .toggle-pw:hover {
                color: #6ee7b7;
            }

        /* Error */
        .error-alert {
            display: flex;
            align-items: center;
            gap: 8px;
            background: rgba(239,68,68,0.08);
            border: 1px solid rgba(239,68,68,0.25);
            border-radius: 10px;
            padding: 12px 14px;
            color: #fca5a5;
            font-size: 13.5px;
            margin-bottom: 20px;
            animation: shake 0.4s ease;
        }

        @@keyframes shake {
            0%, 100% {
                transform: translateX(0)
            }

            25% {
                transform: translateX(-6px)
            }

            75% {
                transform: translateX(6px)
            }
        }

        /* Button */
        .btn-submit {
            width: 100%;
            padding: 13px;
            background: linear-gradient(135deg, #059669 0%, #10b981 60%, #34d399 100%);
            border: none;
            border-radius: 10px;
            font-family: 'DM Sans', sans-serif;
            font-size: 15px;
            font-weight: 600;
            color: white;
            cursor: pointer;
            transition: all 0.25s;
            margin-top: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            letter-spacing: 0.2px;
        }

            .btn-submit:hover {
                transform: translateY(-2px);
                box-shadow: 0 10px 28px rgba(16,185,129,0.4);
            }

            .btn-submit:active {
                transform: translateY(0);
            }

            .btn-submit:disabled {
                opacity: 0.6;
                cursor: not-allowed;
                transform: none;
                box-shadow: none;
            }

        /* Footer */
        .form-footer {
            text-align: center;
            margin-top: 28px;
            font-size: 13px;
            color: #2d5a3d;
        }

            .form-footer a {
                color: #10b981;
                text-decoration: none;
                font-weight: 500;
                transition: color 0.2s;
            }

                .form-footer a:hover {
                    color: #6ee7b7;
                }

        /* Divider */
        .divider {
            display: flex;
            align-items: center;
            gap: 12px;
            margin: 20px 0 0;
        }

            .divider::before, .divider::after {
                content: '';
                flex: 1;
                height: 1px;
                background: #1a3a25;
            }

            .divider span {
                font-size: 12px;
                color: #2d5a3d;
                white-space: nowrap;
            }

        /* Spinner */
        .spinner {
            width: 16px;
            height: 16px;
            border: 2px solid rgba(255,255,255,0.3);
            border-top-color: white;
            border-radius: 50%;
            animation: spin 0.7s linear infinite;
            display: none;
        }

        @@keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        @@media (max-width: 768px) {
            .left-panel {
                display: none;
            }

            .right-panel {
                width: 100%;
            }
        }
    </style>
</head>
<body>
    <!-- Left panel -->
    <div class="left-panel">
        <div class="orb"></div>
        <div class="left-content">
            <span class="brand-icon">🐾</span>
            <div class="brand-name">Pet<span>Center</span></div>
            <p class="brand-sub">Management portal for admins and staff to manage the platform efficiently.</p>
            <ul class="feature-list">
                <li><i class="bi bi-people-fill"></i> Manage customers & staff</li>
                <li><i class="bi bi-box-seam"></i> Products & inventory control</li>
                <li><i class="bi bi-receipt"></i> Order tracking & processing</li>
                <li><i class="bi bi-graph-up-arrow"></i> Analytics & reports</li>
            </ul>
        </div>
    </div>

    <!-- Right panel -->
    <div class="right-panel">
        <div class="form-box">
            <div class="form-header">
                <h2>Welcome back 👋</h2>
                <p>Sign in to access the admin dashboard</p>
            </div>

            <div class="role-tabs">
                <button type="button" class="role-tab active" id="tabAdmin">
                    <i class="bi bi-shield-fill"></i> Admin
                </button>
                <button type="button" class="role-tab" id="tabStaff">
                    <i class="bi bi-person-badge-fill"></i> Staff
                </button>
            </div>

            @if (ViewBag.Error != null)
            {
                <div class="error-alert">
                    <i class="bi bi-exclamation-circle-fill"></i>
                    @ViewBag.Error
                </div>
            }

            <form method="post" asp-action="AdminLogin" asp-controller="Auth" id="adminLoginForm">
                <input type="hidden" name="selectedRole" id="selectedRole" value="Admin" />

                <div class="field-group">
                    <label class="field-label">Email Address</label>
                    <div class="input-wrap">
                        <i class="bi bi-envelope icon"></i>
                        <input type="email" name="Email" class="field-input" placeholder="admin@petcenter.com" required />
                    </div>
                </div>

                <div class="field-group">
                    <label class="field-label">Password</label>
                    <div class="input-wrap">
                        <i class="bi bi-lock icon"></i>
                        <input type="password" name="Password" class="field-input" id="pwInput" placeholder="Enter your password" required />
                        <i class="bi bi-eye toggle-pw" id="togglePw"></i>
                    </div>
                </div>

                <button type="submit" class="btn-submit" id="submitBtn">
                    <span id="btnText"><i class="bi bi-box-arrow-in-right"></i> Sign In</span>
                    <div class="spinner" id="btnSpinner"></div>
                </button>
            </form>

            <div class="divider"><span>PetCenter © 2025</span></div>

            <div class="form-footer">
                <a asp-controller="Auth" asp-action="Login">← Back to Customer Login</a>
            </div>
        </div>
    </div>

    <script>
        document.getElementById('togglePw').addEventListener('click', function () {
            const input = document.getElementById('pwInput');
            const isText = input.type === 'text';
            input.type = isText ? 'password' : 'text';
            this.className = isText ? 'bi bi-eye toggle-pw' : 'bi bi-eye-slash toggle-pw';
        });

                document.getElementById('tabAdmin').addEventListener('click', function () {
            this.classList.add('active');
            document.getElementById('tabStaff').classList.remove('active');
            document.getElementById('selectedRole').value = 'Admin';
        });

        document.getElementById('tabStaff').addEventListener('click', function () {
            this.classList.add('active');
            document.getElementById('tabAdmin').classList.remove('active');
            document.getElementById('selectedRole').value = 'Staff';
        });

        document.getElementById('adminLoginForm').addEventListener('submit', function () {
            const btn = document.getElementById('submitBtn');
            document.getElementById('btnText').style.display = 'none';
            document.getElementById('btnSpinner').style.display = 'block';
            btn.disabled = true;
        });
    </script>
</body>
</html>