@model PetCenterClient.ViewModels.Product.CreateProductViewModel

<style>

    .page-card {
        background: #fff;
        border-radius: 18px;
        padding: 30px;
    }

    .page-title {
        font-size: 28px;
        font-weight: 700;
        margin-bottom: 5px;
    }

    .page-subtitle {
        color: #6c757d;
        margin-bottom: 25px;
    }

    .section-card {
        background: #f8f9fa;
        border-radius: 16px;
        padding: 20px;
        margin-bottom: 25px;
    }

    .section-title {
        font-size: 18px;
        font-weight: 700;
        margin-bottom: 18px;
    }

    .form-label {
        font-weight: 600;
    }

    .form-control,
    .form-select {
        min-height: 48px;
        border-radius: 12px;
    }

    textarea.form-control {
        min-height: 120px;
        resize: vertical;
    }

    .image-preview {
        width: 150px;
        height: 150px;
        object-fit: cover;
        border-radius: 16px;
        border: 3px solid #fff;
        box-shadow: 0 5px 20px rgba(0,0,0,.12);
        cursor: pointer;
        transition: .25s;
    }

        .image-preview:hover {
            transform: scale(1.03);
        }

    .image-item {
        position: relative;
    }

    .remove-image {
        position: absolute;
        top: -8px;
        right: -8px;
        width: 30px;
        height: 30px;
        border-radius: 50%;
        padding: 0;
    }

    .attribute-row {
        background: #fff;
        border: 1px solid #e9ecef;
        border-radius: 12px;
        padding: 12px;
        margin-bottom: 12px;
    }

    .btn-create {
        min-width: 180px;
        height: 50px;
        border-radius: 12px;
        font-weight: 600;
    }

    .add-image-btn {
        border-radius: 10px;
        font-weight: 600;
    }

</style>

<div class="page-card">


    <h2 class="page-title">
        Create Product
    </h2>

    <p class="page-subtitle">
        Add a new product to your catalog
    </p>

    <form method="post"
          enctype="multipart/form-data"
          asp-action="Create"
          asp-controller="Products">

        <div asp-validation-summary="ModelOnly"
             class="text-danger mb-3">
        </div>

        <div class="section-card">

            <div class="section-title">
                Basic Information
            </div>

            <div class="row">

                <div class="col-md-12 mb-3">

                    <label asp-for="ProductName"
                           class="form-label"></label>

                    <input asp-for="ProductName"
                           class="form-control" />

                    <span asp-validation-for="ProductName"
                          class="text-danger"></span>

                </div>

                <div class="col-md-12 mb-3">

                    <label asp-for="ProductDescription"
                           class="form-label"></label>

                    <textarea asp-for="ProductDescription"
                              class="form-control"></textarea>

                    <span asp-validation-for="ProductDescription"
                          class="text-danger"></span>

                </div>

                <div class="col-md-6">

                    <label asp-for="ProductPrice"
                           class="form-label"></label>

                    <input asp-for="ProductPrice"
                           type="number"
                           class="form-control" />

                    <span asp-validation-for="ProductPrice"
                          class="text-danger"></span>

                </div>

            </div>

        </div>

        <div class="section-card">

            <div class="section-title">
                Product Classification
            </div>

            <div class="row">

                <div class="col-md-6">

                    <label asp-for="BrandId"
                           class="form-label"></label>

                    <select asp-for="BrandId"
                            asp-items="@(ViewBag.Brands as SelectList)"
                            class="form-select">

                        <option value="">
                            -- Select Brand --
                        </option>

                    </select>

                    <span asp-validation-for="BrandId"
                          class="text-danger"></span>

                </div>

                <div class="col-md-6">

                    <label asp-for="CategoryId"
                           class="form-label"></label>

                    <select asp-for="CategoryId"
                            asp-items="@(ViewBag.Categories as SelectList)"
                            class="form-select">

                        <option value="">
                            -- Select Category --
                        </option>

                    </select>

                    <span asp-validation-for="CategoryId"
                          class="text-danger"></span>

                </div>

            </div>

        </div>

        <div class="section-card">

            <div class="section-title">
                Product Attributes
            </div>

            <div id="attributeList">

                @if (Model?.Attributes != null)
                {
                    for (int i = 0; i < Model.Attributes.Count; i++)
                    {
                        <div class="attribute-row">

                            <div class="row">

                                <div class="col-md-5">

                                    <input class="form-control"
                                           value="@Model.Attributes[i].AttributeName"
                                           readonly />

                                </div>

                                <div class="col-md-7">

                                    <input name="Attributes[@i].AttributeValue"
                                           value="@Model.Attributes[i].AttributeValue"
                                           class="form-control"
                                           placeholder="Enter value" />

                                    <input type="hidden"
                                           name="Attributes[@i].CategoryAttributeId"
                                           value="@Model.Attributes[i].CategoryAttributeId" />

                                </div>

                            </div>

                        </div>
                    }
                }

            </div>

        </div>

        <div class="section-card">

            <div class="section-title">
                Product Images
            </div>

            <div id="imageList"
                 class="d-flex flex-wrap gap-3">

                <div class="image-item">

                    <input type="file"
                           name="ImageFiles"
                           accept="image/*"
                           hidden
                           onchange="previewSelectedImage(this,'preview_0')" />

                    <img id="preview_0"
                         src="https://via.placeholder.com/150"
                         class="image-preview"
                         onclick="this.previousElementSibling.click()" />

                    <button type="button"
                            class="btn btn-danger remove-image"
                            onclick="removeImage(this)">

                        <i class="bi bi-x-lg"></i>

                    </button>

                </div>

            </div>

            <button type="button"
                    id="addImage"
                    class="btn btn-success add-image-btn mt-3">

                <i class="bi bi-plus-lg me-1"></i>
                Add Image

            </button>

        </div>

        <div class="text-end">

            <button type="submit"
                    class="btn btn-success btn-create">

                <i class="bi bi-check-circle me-1"></i>
                Create Product

            </button>

        </div>

    </form>


</div>


<script>



    let imageIndex = 1

    $(document).on("click", "#addImage", function () {

            const html = `
            <div class="image-item position-relative">

                <input type="file"
                       name="ImageFiles"
                       accept="image/*"
                       hidden
                       onchange="previewSelectedImage(this,'preview_${imageIndex}')"/>

                <img id="preview_${imageIndex}"
                     src="https://via.placeholder.com/120"
                     class="image-preview"
                     onclick="this.previousElementSibling.click()" />

                <button type="button"
                        class="btn btn-danger btn-sm remove-image"
                        onclick="removeImage(this)">
                    ✖
                </button>

            </div>
            `

            $("#imageList").append(html)

            imageIndex++

        })


        // LOAD CATEGORY ATTRIBUTES
    $(document).on("change","#CategoryId",function(){

            const categoryId = $(this).val()

            if (!categoryId) return

            $.get(`https://localhost:7004/api/Categories/${categoryId}/attributes`, function (data) {

                $("#attributeList").empty()

                let index = 0

                  data.forEach(attr => {

        const html = `
        <div class="row mb-2">

            <div class="col-md-5">
                <input class="form-control"
                       value="${attr.attributeName}"
                       readonly />
            </div>

            <div class="col-md-7">
                <input name="Attributes[${index}].AttributeValue"
                       class="form-control"
                       data-val="true"
                       data-val-required="Attribute value is required"
                       placeholder="Enter value"/>

                <span class="text-danger field-validation-valid"
                      data-valmsg-for="Attributes[${index}].AttributeValue"
                      data-valmsg-replace="true"></span>

                <input type="hidden"
                       name="Attributes[${index}].CategoryAttributeId"
                       value="${attr.categoryAttributeId}" />
            </div>

        </div>
        `

        $("#attributeList").append(html)

        index++
    })

    $.validator.unobtrusive.parse("#attributeList")
            })

        })

    // REMOVE IMAGE
    function removeImage(button){

        if($(".image-item").length <= 1){
            alert("Product must have at least 1 image")
            return
        }

        $(button).closest(".image-item").remove()

    }


    // PREVIEW IMAGE
    function previewSelectedImage(input, previewId){

        const file = input.files[0]

        if(!file) return

        const reader = new FileReader()

        reader.onload = function(e){

            document.getElementById(previewId).src = e.target.result

        }

        reader.readAsDataURL(file)

    }

</script>