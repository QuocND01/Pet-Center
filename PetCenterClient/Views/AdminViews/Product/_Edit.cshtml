@model PetCenterClient.ViewModels.Product.UpdateProductViewModel

<style>

    .product-update-logo {
        width: 120px;
        height: 120px;
        object-fit: contain;
        object-position: center;
        background: #fff;
        border-radius: 8px;
        border: 1px solid #ddd;
    }

    .image-wrapper {
        position: relative;
        display: inline-block;
    }

    .remove-btn {
        position: absolute;
        top: -6px;
        right: -6px;
        border-radius: 50%;
        width: 22px;
        height: 22px;
        padding: 0;
        font-size: 12px;
    }

</style>

<form asp-action="Edit"
      asp-controller="Products"
      method="post"
      enctype="multipart/form-data">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <input asp-for="ProductId" type="hidden" />

    <div class="row">

        <!-- NAME -->

        <div class="col-md-12 mb-3">
            <label class="form-label">Product Name</label>
            <input asp-for="ProductName" class="form-control" />
            <span asp-validation-for="ProductName" class="text-danger"></span>
        </div>

        <!-- DESCRIPTION -->

        <div class="col-md-12 mb-3">
            <label>Description</label>
            <textarea asp-for="ProductDescription"
                      class="form-control"></textarea>
            <span asp-validation-for="ProductDescription" class="text-danger"></span>
        </div>

        <!-- PRICE -->

        <div class="col-md-6 mb-3">
            <label>Price</label>
            <input asp-for="ProductPrice"
                   type="number"
                   class="form-control" />

            <span asp-validation-for="ProductPrice" class="text-danger"></span>
        </div>

        <!-- BRAND -->

        <div class="col-md-6 mb-3">
            <label>Brand</label>
            <input class="form-control"
                   value="@Model.BrandName"
                   readonly />
        </div>

        <!-- CATEGORY -->

        <div class="col-md-6 mb-3">
            <label>Category</label>
            <input class="form-control"
                   value="@Model.CategoryName"
                   readonly />
        </div>

    </div>
    <input asp-for="BrandId" type="hidden" />
    <input asp-for="CategoryId" type="hidden" />

    <!-- CURRENT IMAGES -->

    <div class="mt-3">

        <h6>Current Images</h6>

        <div class="d-flex flex-wrap gap-2">

            @if (Model.ExistingImages != null)
            {
                foreach (var img in Model.ExistingImages)
                {
                    <div class="image-wrapper">

                        <img src="@img" class="product-update-logo" />

                        <button type="button"
                                class="btn btn-danger btn-sm remove-btn"
                                onclick="removeOldImage(this,'@img')">
                            ✖
                        </button>

                        <input type="hidden"
                               name="ExistingImages"
                               value="@img" />

                    </div>
                }
            }

        </div>

    </div>


    <!-- ADD NEW IMAGE -->

    <div class="mt-3">

        <label>Add New Images</label>

        <input type="file"
               id="newImages"
               multiple
               accept="image/*"
               class="form-control" />

        <div id="previewNewImages"
             class="d-flex flex-wrap gap-2 mt-2">
        </div>

    </div>


    <!-- ATTRIBUTES -->
    @if (Model.Attributes != null && Model.Attributes.Any())
    {

        <div class="mt-4">

            <h6>Attributes</h6>

            @for (int i = 0; i < Model.Attributes.Count; i++)
            {

                <div class="row mb-2">
                    <div class="col-md-5">

                        <input class="form-control"
                               value="@Model.Attributes[i].AttributeName"
                               readonly />

                        <input asp-for="Attributes[i].AttributeName"
                               type="hidden" />

                    </div>
                    <div class="col-md-7">

                        <input asp-for="Attributes[i].AttributeValue"
                               class="form-control" />

                        <span asp-validation-for="Attributes[i].AttributeValue"
                              class="text-danger"></span>

                        <input asp-for="Attributes[i].CategoryAttributeId" type="hidden" />

                    </div>

                </div>

            }

        </div>

    }


    <!-- ACTION BUTTON -->

    <div class="d-flex justify-content-end gap-2 mt-4">

        <button type="button"
                class="btn btn-secondary"
                data-bs-dismiss="modal">

            Cancel

        </button>

        <button type="submit"
                class="btn btn-warning">

            <i class="bi bi-pencil-square"></i>
            Update

        </button>

    </div>

</form>
<script>

    // Submit form
    $("form").submit(function (e) {

        const activeOldImages =
            $("input[name='ExistingImages']:enabled").length;

        const newImages =
            $("#previewNewImages .image-wrapper").length;

        if (activeOldImages + newImages > 10) {
            e.preventDefault();
            alert("Maximum 10 images are allowed.");
            return;
        }

        let valid = true;

        $("input[name*='AttributeValue']").each(function () {

            if (!$(this).val().trim()) {
                valid = false;
                $(this).addClass("is-invalid");
            }
            else {
                $(this).removeClass("is-invalid");
            }

        });

        if (!valid) {
            e.preventDefault();
        }

    });


    // Add new images
    $("#newImages").change(function () {

        const activeOldImages =
            $("input[name='ExistingImages']:enabled").length;

        const newImages =
            $("#previewNewImages .image-wrapper").length;

        const files = this.files;

        if (activeOldImages + newImages + files.length > 10) {
            alert("Maximum 10 images are allowed.");
            $(this).val("");
            return;
        }

        for (let i = 0; i < files.length; i++) {

            const file = files[i];
            const reader = new FileReader();

            reader.onload = function (e) {

                const id = "img_" + Date.now() + "_" + i;

                const html = `
                <div class="image-wrapper" id="${id}">

                   <img src="${e.target.result}" class="product-update-logo"/>

                    <button type="button"
                            class="btn btn-danger btn-sm remove-btn"
                            onclick="removeNewImage('${id}')">
                        ✖
                    </button>

                    <input type="file"
                           name="ImageFiles"
                           hidden />

                </div>
                `;

                $("#previewNewImages").append(html);

                const dt = new DataTransfer();
                dt.items.add(file);

                $("#" + id + " input")[0].files = dt.files;
            };

            reader.readAsDataURL(file);
        }

        // Cho phép chọn tiếp
        $(this).val("");

    });


    // Remove old image
    function removeOldImage(btn) {

        const wrapper = $(btn).closest(".image-wrapper");

        wrapper.find("input[name='ExistingImages']").prop("disabled", true);

        wrapper.hide();

    }


    // Remove new image
    function removeNewImage(id) {

        $("#" + id).remove();

    }

</script>