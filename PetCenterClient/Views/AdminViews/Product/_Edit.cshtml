@model ProductAPI.DTOs.ReadProductDTO

<style>

    .image-preview {
        width: 120px;
        height: 120px;
        object-fit: cover;
        border-radius: 8px;
        border: 1px solid #ddd;
    }

</style>

<form asp-action="Edit"
      asp-controller="Products"
      method="post"
      enctype="multipart/form-data">

    <input type="hidden" name="ProductId" value="@Model.ProductId" />

    <div class="row">

        <!-- NAME -->

        <div class="col-md-12 mb-3">
            <label class="form-label">Product Name</label>
            <input name="ProductName"
                   class="form-control"
                   value="@Model.ProductName" />
        </div>

        <!-- DESCRIPTION -->

        <div class="col-md-12 mb-3">
            <label>Description</label>
            <textarea name="ProductDescription"
                      class="form-control">@Model.ProductDescription</textarea>
        </div>

        <!-- PRICE -->

        <div class="col-md-6 mb-3">
            <label>Price</label>
            <input type="number"
                   name="ProductPrice"
                   class="form-control"
                   value="@Model.ProductPrice" />
        </div>

        <!-- STOCK -->

        <div class="col-md-6 mb-3">
            <label>Stock</label>
            <input type="number"
                   name="StockQuantity"
                   class="form-control"
                   value="@Model.StockQuantity" />
        </div>

        <!-- BRAND -->

        <div class="col-md-6 mb-3">
            <label>Brand</label>
            <input class="form-control"
                   value="@Model.BrandName"
                   readonly />
        </div>

        <!-- CATEGORY -->

        <div class="col-md-6 mb-3">
            <label>Category</label>
            <input class="form-control"
                   value="@Model.CategoryName"
                   readonly />
        </div>

    </div>
    <input type="hidden" name="BrandId" value="@Model.BrandId" />
    <input type="hidden" name="CategoryId" value="@Model.CategoryId" />

    <!-- CURRENT IMAGES -->

    <div class="mt-3">

        <h6>Current Images</h6>

        <div class="d-flex flex-wrap gap-2">

            @if (Model.Images != null)
            {
                foreach (var img in Model.Images)
                {
                    <img src="@img" class="image-preview" />
                }
            }

        </div>

    </div>


    <!-- ADD NEW IMAGE -->

    <div class="mt-3">

        <label>Add New Images</label>

        <input type="file"
               name="ImageFiles"
               multiple
               accept="image/*"
               class="form-control" />

    </div>


    <!-- ATTRIBUTES -->
    @if (Model.Attributes != null && Model.Attributes.Any())
    {

        <div class="mt-4">

            <h6>Attributes</h6>

            @for (int i = 0; i < Model.Attributes.Count; i++)
            {

                <div class="row mb-2">

                    <div class="col-md-5">

                        <input class="form-control"
                               value="@Model.Attributes[i].AttributeName"
                               readonly />

                    </div>

                    <div class="col-md-7">

                        <input name="Attributes[@i].AttributeValue"
                               class="form-control"
                               value="@Model.Attributes[i].AttributeValue" />

                        <input type="hidden"
                               name="Attributes[@i].CategoryAttributeId"
                               value="@Model.Attributes[i].CategoryAttributeId" />

                    </div>

                </div>

            }

        </div>

    }


    <!-- ACTION BUTTON -->

    <div class="d-flex justify-content-end gap-2 mt-4">

        <button type="button"
                class="btn btn-secondary"
                data-bs-dismiss="modal">

            Cancel

        </button>

        <button type="submit"
                class="btn btn-warning">

            <i class="bi bi-pencil-square"></i>
            Update

        </button>

    </div>

</form>