@model PetCenterClient.DTOs.ReadProductDTO
@using PetCenterClient.Common

<style>
    .product-image {
        width: 100px;
        height: 100px;
        object-fit: cover;
        border-radius: 8px;
        border: 1px solid #ddd;
        margin-right: 8px;
    }
</style>

<form asp-action="ChangeStatusConfirmed"
      asp-controller="Products"
      method="post">

    @Html.AntiForgeryToken()

    <input type="hidden"
           name="id"
           value="@Model.ProductId" />

    <input type="hidden"
           name="status"
           value="@((int)ViewBag.Status)" />

    <div class="text-center">

        <h5 class="text-danger mb-3">
            Are you sure you want to update this product status?
        </h5>

        <h4 class="fw-bold">
            @Model.ProductName
        </h4>

    </div>

    <div class="d-flex justify-content-end gap-2 mt-3">

        <button type="button"
                class="btn btn-secondary"
                data-bs-dismiss="modal">
            Cancel
        </button>

        <button type="submit"
                class="btn btn-danger">

            <i class="bi bi-trash"></i>
            Confirm

        </button>

    </div>

</form>