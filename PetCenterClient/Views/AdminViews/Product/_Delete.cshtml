@model PetCenterClient.DTOs.ReadProductDTO

<style>

    .product-image {
        width: 100px;
        height: 100px;
        object-fit: cover;
        border-radius: 8px;
        border: 1px solid #ddd;
        margin-right: 8px;
    }

</style>

<form asp-action="Delete"
      asp-controller="Products"
      method="post">

    <input type="hidden" name="id" value="@Model.ProductId" />

    <div class="text-center">

        <h5 class="text-danger mb-3">
            Are you sure you want to delete this product?
        </h5>

        <h4 class="fw-bold">
            @Model.ProductName
        </h4>

    </div>

    <!-- Images -->

    <div class="d-flex justify-content-center flex-wrap mt-3">

        @if (Model.Images != null && Model.Images.Any())
        {
            foreach (var img in Model.Images)
            {
                <img src="@img" class="product-image" />
            }
        }

    </div>

    <!-- Info -->

    <div class="row mt-4">

        <div class="col-md-6">
            <strong>Price:</strong> @Model.ProductPrice
        </div>

        <div class="col-md-6">
            <strong>Stock:</strong> @Model.StockQuantity
        </div>

        <div class="col-md-6">
            <strong>Brand:</strong> @Model.BrandName
        </div>

        <div class="col-md-6">
            <strong>Category:</strong> @Model.CategoryName
        </div>

    </div>

    <div class="alert alert-warning mt-4 text-center">
        This action cannot be undone.
    </div>

    <div class="d-flex justify-content-end gap-2 mt-3">

        <button type="button"
                class="btn btn-secondary"
                data-bs-dismiss="modal">
            Cancel
        </button>

        <button type="submit"
                class="btn btn-danger">

            <i class="bi bi-trash"></i>
            Delete

        </button>

    </div>

</form>