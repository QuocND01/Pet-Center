@using PetCenterClient.DTOs
@model OdataResponse<ReadProductDTO>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Manage Products";
    var role = Context.Session.GetString("Role");
    bool isAdmin = role == "Admin";
}

<style>
    .pagination {
        margin-top: 20px;
        display: flex;
        gap: 6px;
    }

    .page-btn {
        padding: 6px 12px;
        background: #eee;
        border-radius: 6px;
        text-decoration: none;
    }

        .page-btn.active {
            background: #4f46e5;
            color: white;
        }

</style>

<link rel="stylesheet" href="~/css/AdminViews/BaseManageLayout.css" asp-append-version="true" />

<div class="page-wrapper">

    <!-- HEADER -->
    <div class="page-header">

        <div class="page-title-group">
            <h1>Product Management</h1>
            <p>Manage all products in system</p>
        </div>

        <div class="header-stat">
           <span class="num">@Model?.Count</span>
            <span class="label">Products</span>
        </div>

    </div>


    <!-- TOOLBAR -->
    <form asp-action="Indexadmin" asp-controller="Products" method="get" class="toolbar">

        <!-- Search -->
        <div class="search-wrap">
            <i class="bi bi-search"></i>

            <input type="text"
                   name="search"
                   value="@Context.Request.Query["search"]"
                   class="search-input"
                   placeholder="Search product name..." />
        </div>

        <!-- Sort -->
        <select name="sortBy" class="filter-btn">
            <option value="">Sort By</option>
            <option value="ProductName">Name</option>
            <option value="ProductPrice">Price</option>
            <option value="CreatedAt">Created</option>
        </select>

        <select name="sortOrder" class="filter-btn">
            <option value="asc">Asc</option>
            <option value="desc">Desc</option>
        </select>

        <!-- Price -->
        <input type="number"
               name="minPrice"
               value="@Context.Request.Query["minPrice"]"
               class="filter-input"
               placeholder="Min price" />

        <input type="number"
               name="maxPrice"
               value="@Context.Request.Query["maxPrice"]"
               class="filter-input"
               placeholder="Max price" />

        <!-- Date -->
        <input type="date"
               name="fromDate"
               value="@Context.Request.Query["fromDate"]"
               class="filter-input" />

        <input type="date"
               name="toDate"
               value="@Context.Request.Query["toDate"]"
               class="filter-input" />
        <!-- Buttons -->
        <button type="submit" class="filter-btn active">
            Apply
        </button>
        @if (isAdmin)
            {
                <button type="button"
                class="filter-btn"
                data-bs-toggle="modal"
                data-bs-target="#productModal"
                data-url="@Url.Action("Create", "Products")">

                    <i class="bi bi-plus"></i> Add
                </button>
            }
        </form>


    <!-- TABLE -->
    <div class="table-card">

        <table class="data-table">

            <thead>
                <tr>
                    <th>#</th>
                    <th>Product</th>
                    <th>Price</th>
                    <th>Stock</th>
                    <th>Brand</th>
                    <th>Category</th>
                    <th style="width:180px">Actions</th>
                </tr>
            </thead>

            <tbody>

                @if (Model?.Values != null && Model.Values.Any())
                {
                    int i = 1;

                    foreach (var p in Model.Values)
                    {
                        <tr>

                            <td class="row-num">@i</td>

                            <td>
                                <div class="customer-cell">

                                    <img src="@p.Images?.FirstOrDefault()"
                                         style="width:38px;height:38px;border-radius:8px;object-fit:cover" />

                                    <div class="customer-name">
                                        @p.ProductName
                                    </div>

                                </div>
                            </td>

                            <td>
                                @p.ProductPrice.ToString("N0") ₫
                            </td>

                            <td>
                                @p.StockQuantity
                            </td>

                            <td class="email-cell">
                                @p.BrandName
                            </td>

                            <td class="email-cell">
                                @p.CategoryName
                            </td>

                            <td>
                                @if (isAdmin){
                                <!-- VIEW -->
                                <button class="btn-detail"
                                        data-bs-toggle="modal"
                                        data-bs-target="#productModal"
                                        data-url="@Url.Action("Details", "Products", new { id = p.ProductId })">

                                    <i class="bi bi-eye"></i>
                                </button>

                                <!-- EDIT -->
                                <button class="btn-detail"
                                        data-bs-toggle="modal"
                                        data-bs-target="#productModal"
                                        data-url="@Url.Action("Edit", "Products", new { id = p.ProductId })">

                                    <i class="bi bi-pencil"></i>
                                </button>

                                <!-- DELETE -->
                                <button class="btn-toggle-status active"
                                        data-bs-toggle="modal"
                                        data-bs-target="#productModal"
                                        data-url="@Url.Action("Delete", "Products", new { id = p.ProductId })">

                                    <i class="bi bi-trash"></i>
                                </button>}

                            </td>

                        </tr>

                        i++;
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7">

                            <div class="empty-state">

                                <div class="empty-icon">
                                    <i class="bi bi-box"></i>
                                </div>

                                <h3>No products found</h3>
                                <p>Try adjusting filters</p>

                            </div>

                        </td>
                    </tr>
                }

            </tbody>

        </table>
        @{
            int currentPage = ViewBag.CurrentPage ?? 1;
            int totalPages = ViewBag.TotalPages ?? 1;
            var routeValues = new
            {
                search = Context.Request.Query["search"],
                minPrice = Context.Request.Query["minPrice"],
                maxPrice = Context.Request.Query["maxPrice"],
                sortBy = Context.Request.Query["sortBy"],
                sortOrder = Context.Request.Query["sortOrder"]
            };
        }
        <div class="pagination">

            <!-- Prev -->
            @if (currentPage > 1)
            {
                <a class="page-btn"
                   href="@Url.Action("Indexadmin", new { page = currentPage - 1 })">
                    Prev
                </a>
            }

            <!-- Numbers -->
           
            @for (int i = 1; i <= totalPages; i++)
            {
                <a class="page-btn @(i == currentPage ? "active" : "")"
                  href="@Url.Action("Indexadmin", new {
                    page = i,
                    search = routeValues.search,
                    minPrice = routeValues.minPrice,
                    maxPrice = routeValues.maxPrice,
                    sortBy = routeValues.sortBy,
                    sortOrder = routeValues.sortOrder
                })">
                    @i
                </a>
            }

            <!-- Next -->
            @if (currentPage < totalPages)
            {
                <a class="page-btn"
                   href="@Url.Action("Indexadmin", new { page = currentPage + 1 })">
                    Next
                </a>
            }

        </div>

    </div>

</div>


<!-- PRODUCT MODAL -->

<div class="modal fade" id="productModal" tabindex="-1" aria-hidden="true">

    <div class="modal-dialog modal-lg modal-dialog-centered">

        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Product</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body" id="productModalBody"></div>

        </div>

    </div>

</div>


<!-- Loading Overlay -->

<div id="pageLoadingOverlay"
     style="display:none;
            position:fixed;
            top:0;
            left:0;
            width:100%;
            height:100%;
            background: rgba(255,255,255,0.7);
            z-index:2000;
            justify-content:center;
            align-items:center;
            flex-direction:column;">

    <div class="spinner-border text-primary"
         role="status"
         style="width:3rem;height:3rem"></div>

    <p class="mt-2">Processing, Please wait...</p>

</div>


<!-- TOAST -->

<div class="position-fixed bottom-0 end-0 p-3" style="z-index:1100">

    <div id="liveToast"
         class="toast bg-success text-white"
         role="alert">

        <div class="toast-body"></div>

    </div>

</div>


@section Scripts {

    <script>

                // Load modal content

                    $(document).on("click", "[data-bs-target='#productModal']", function () {

                    var url = $(this).data("url");

                    $("#productModalBody").html("Loading...");

                    $("#productModalBody").load(url, function () {

                    var form = $("#productModalBody").find("form");

                    $.validator.unobtrusive.parse(form);

                });

                });



                // Submit form bằng AJAX

                $('#productModal').on('submit', 'form', function (e) {

                    e.preventDefault();

                    var form = $(this);

                    var formData = new FormData(form[0]);

                    $("#pageLoadingOverlay").css("display", "flex");

                    $.ajax({

                        url: form.attr('action'),

                        type: form.attr('method'),

                        data: formData,

                        contentType: false,

                        processData: false,

                 success: function (res) {

                    $("#pageLoadingOverlay").hide();

                    if (res.success) {

                        $('#productModal').modal('hide');

                        showToast("Success");

                        setTimeout(function () {
                            location.reload();
                        }, 800);

                    }
                    else {

                        $("#productModalBody").html(res);

                    }

                },
                error: function () {

                    $("#pageLoadingOverlay").hide();

                    showToast("Error");

                }

                    });

                });



                function showToast(message) {

                    $('#liveToast .toast-body').text(message);

                    var toast = new bootstrap.Toast(document.getElementById('liveToast'));

                    toast.show();

                }


               document.querySelector(".toolbar").addEventListener("submit", function () {

            this.querySelectorAll("input, select").forEach(el => {
                if (!el.value) {
                    el.removeAttribute("name");
                }
            });

        });
    </script>

}