@using PetCenterClient.Common
@using PetCenterClient.ViewModels.Brand
@using PetCenterClient.ViewModels.Category
@using PetCenterClient.ViewModels.Product
@model IEnumerable<ReadProductViewModel>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Manage Products";
    var role = Context.Session.GetString("Role");
    bool isAdmin = role == "Admin";
}

<style>
    .pagination {
        margin-top: 20px;
        display: flex;
        gap: 6px;
    }

    .page-btn {
        padding: 6px 12px;
        background: #eee;
        border-radius: 6px;
        text-decoration: none;
    }

        .page-btn.active {
            background: #4f46e5;
            color: white;
        }


  .filter-container {
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-bottom: 24px;
}

.toolbar-row {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: center;
}

.search-wrap,
.filter-select,
.filter-input {
    flex: 1;
    min-width: 180px;
}

.search-wrap {
    position: relative;
}

.search-wrap i {
    position: absolute;
    left: 12px;
    top: 50%;
    transform: translateY(-50%);
    color: #94a3b8;
}

.search-input,
.filter-select,
.filter-input {
    width: 100%;
    height: 44px;
    border: 1px solid #dbe2ea;
    border-radius: 10px;
    background: white;
    padding: 0 14px;
    transition: .2s;
}

.search-input {
    padding-left: 38px;
}

.search-input:focus,
.filter-select:focus,
.filter-input:focus {
    border-color: #4f46e5;
    outline: none;
    box-shadow: 0 0 0 3px rgba(79,70,229,.12);
}

/* Apply */
.btn-filter-apply {
    height: 44px;
    min-width: 120px;
    border: none;
    border-radius: 10px;
    background: #4f46e5;
    color: white;
    font-weight: 600;
    padding: 0 18px;
    transition: .2s;
}

.btn-filter-apply:hover {
    background: #4338ca;
}

/* Reset */
.btn-filter-reset {
    height: 44px;
    min-width: 120px;
    border-radius: 10px;
    background: #e5e7eb;
    color: #374151;
    text-decoration: none;
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: .2s;
}

.btn-filter-reset:hover {
    background: #d1d5db;
    color: #111827;
}

/* Add Product */
.btn-add-product {
    border: none;
    background: #16a34a;
    color: white;
    border-radius: 10px;
    padding: 11px 18px;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 8px;
    transition: .2s;
}

.btn-add-product:hover {
    background: #15803d;
}

@@media(max-width:768px) {

    .toolbar-row {
        flex-direction: column;
        align-items: stretch;
    }

    .search-wrap,
    .filter-select,
    .filter-input,
    .btn-filter-apply,
    .btn-filter-reset {
        width: 100%;
    }
}

/* Đồng bộ font toàn bộ filter */
.filter-container,
.filter-container input,
.filter-container select,
.filter-container button,
.filter-container a {
    font-family: inherit !important;
    font-size: 14px !important;
    font-weight: 500;
    line-height: 1.2;
}

/* Đồng bộ chiều cao */
.search-input,
.filter-select,
.filter-input,
.btn-filter-apply,
.btn-filter-reset {
    height: 44px;
    font-size: 14px !important;
    font-weight: 500;
}

/* Date picker thường bị lệch font */
.filter-input[type="date"] {
    font-family: inherit !important;
    font-size: 14px !important;
}

/* Select thường nhìn đậm hơn input */
.filter-select {
    appearance: none;
    -webkit-appearance: none;
    -moz-appearance: none;
    background-position: right 12px center;
    padding-right: 36px;
}

/* Apply */
.btn-filter-apply {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
}

/* Reset */
.btn-filter-reset {
    display: flex;
    align-items: center;
    justify-content: center;
}

.action-grid {
    display: grid;
    grid-template-columns: repeat(2, 40px);
    gap: 8px;
    justify-content: center;
}

/* ===== Prevent table overflow ===== */

.data-table {
    width: 100%;
    table-layout: fixed;
}

/* Các cột text dài */
.customer-name,
.email-cell {
    overflow: hidden;
    text-overflow: ellipsis;
}

/* Product column */
.data-table th:nth-child(2),
.data-table td:nth-child(2) {
    width: 320px;
}

/* Product name */
.customer-name {
    max-width: 240px;
    white-space: normal;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    overflow-wrap: break-word;
    line-height: 1.4;
}


/* Brand + Category */
.email-cell {
    max-width: 160px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

/* Date */
.data-table td:nth-child(7),
.data-table td:nth-child(8) {
    max-width: 120px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}

/* Image + name container */
.customer-cell {
    display: flex;
    align-items: center;
    gap: 12px;
    min-width: 0;
}

.customer-cell img {
    width:45px !important;
    height:45px !important;
    flex-shrink:0;
}

/* Header không bị xuống dòng */
.data-table th {
    white-space: nowrap;
}

/* Action không bị co */
.data-table td:last-child {
    width: 180px;
    white-space: nowrap;
}
</style>

<link rel="stylesheet" href="~/css/AdminViews/BaseManageLayout.css" asp-append-version="true" />

<div class="page-wrapper">

    <!-- HEADER -->
  <div class="page-header">

    <div class="page-title-group">
        <h1>Product Management</h1>
        <p>Manage all products in system</p>
    </div>

    <div class="d-flex align-items-center gap-3">

        <div class="header-stat">
             <span class="num">@ViewBag.TotalProducts</span>
            <span class="label">Products</span>
        </div>

        @if (isAdmin)
        {
            <button type="button"
                    class="btn-add-product"
                    data-bs-toggle="modal"
                    data-bs-target="#productModal"
                    data-url="@Url.Action("Create", "Products")">

                <i class="bi bi-plus-lg"></i>
                Add Product
            </button>
        }

    </div>

</div>


    <!-- TOOLBAR -->
   <form asp-action="IndexAdmin"
      asp-controller="Products"
      method="get"
      class="filter-container">

    <!-- Row 1 -->
    <div class="toolbar-row">

        <div class="search-wrap">
            <i class="bi bi-search"></i>
            <input type="text"
                   name="search"
                   value="@ViewBag.Search"
                   class="search-input"
                   placeholder="Search product..." />
        </div>

      <select name="status" class="filter-select">
    <option value="">All Status</option>

    <option value="1"
            selected="@(ViewBag.Status?.ToString() == "1")">
        Active
    </option>

    <option value="2"
            selected="@(ViewBag.Status?.ToString() == "2")">
        Inactive
    </option>
</select>

       <select name="categoryId" class="filter-select">
            <option value="">All Categories</option>

            @foreach (var item in (IEnumerable<ReadCategoryViewModel>)ViewBag.Categories)
            {
                if (ViewBag.CategoryId?.ToString() == item.CategoryId.ToString())
                {
                    <option value="@item.CategoryId" selected>
                        @item.CategoryName
                    </option>
                }
                else
                {
                    <option value="@item.CategoryId">
                        @item.CategoryName
                    </option>
                }
            }
        </select>

       <select name="brandId" class="filter-select">
            <option value="">All Brands</option>

            @foreach (var item in (IEnumerable<ReadBrandViewModel>)ViewBag.Brands)
            {
                if (ViewBag.BrandId?.ToString() == item.BrandId.ToString())
                {
                    <option value="@item.BrandId" selected>
                        @item.BrandName
                    </option>
                }
                else
                {
                    <option value="@item.BrandId">
                        @item.BrandName
                    </option>
                }
            }
        </select>

    </div>

    <!-- Row 2 -->
    <div class="toolbar-row">

        <select name="sortBy" class="filter-select">
            <option value="">Sort By</option>

            <option value="ProductName"
                    selected="@(ViewBag.SortBy == "ProductName")">
                Name
            </option>

            <option value="ProductPrice"
                    selected="@(ViewBag.SortBy == "ProductPrice")">
                Price
            </option>

            <option value="CreatedAt"
                    selected="@(ViewBag.SortBy == "CreatedAt")">
                Created Date
            </option>
        </select>

       <select name="sortOrder" class="filter-select">
            <option value="asc"
                    selected="@(ViewBag.SortOrder == "asc")">
                Ascending
            </option>

            <option value="desc"
                    selected="@(ViewBag.SortOrder == "desc")">
                Descending
            </option>
        </select>

        <input type="number"
               name="minPrice"
               value="@ViewBag.MinPrice"
               class="filter-input"
               placeholder="Min Price" />

        <input type="number"
               name="maxPrice"
               value="@ViewBag.MaxPrice"
               class="filter-input"
               placeholder="Max Price" />

        <input type="date"
               name="fromDate"
               value="@(ViewBag.FromDate != null ? ((DateTime)ViewBag.FromDate).ToString("yyyy-MM-dd") : "")"
               class="filter-input" />

        <input type="date"
               name="toDate"
               value="@(ViewBag.ToDate != null ? ((DateTime)ViewBag.ToDate).ToString("yyyy-MM-dd") : "")"
               class="filter-input" />

       <button type="submit" class="btn-filter-apply">
            <i class="bi bi-funnel"></i>
            Apply
        </button>

        <a asp-action="IndexAdmin"
           asp-controller="Products"
           class="btn-filter-reset">
            Reset
        </a>

    </div>

</form>


    <!-- TABLE -->
    <div class="table-card">

        <table class="data-table">

            <thead>
                <tr>
                    <th>#</th>
                    <th>Product</th>
                    <th>Price</th>
                    <th>Stock</th>
                    <th>Brand</th>
                    <th>Category</th>
                    <th>Added Date</th>
                    <th>Updated Date</th>
                    <th>Status</th>
                    <th style="width:180px">Actions</th>
                </tr>
            </thead>

            <tbody>

             @if (Model != null && Model.Any())
                {
                    int i = 1;

                    foreach (var p in Model)
                    {
                        <tr>

                            <td class="row-num">@i</td>

                            <td>
                                <div class="customer-cell">

                                    <img src="@p.Images?.FirstOrDefault()"
                                         style="width:38px;height:38px;border-radius:8px;object-fit:cover" />

                                    <div class="customer-name">
                                        @p.ProductName
                                    </div>

                                </div>
                            </td>

                            <td>
                                @p.ProductPrice.ToString("N0") ₫
                            </td>

                            <td>
                                @p.StockQuantity
                            </td>

                            <td class="email-cell">
                                @p.BrandName
                            </td>

                            <td class="email-cell">
                                @p.CategoryName
                            </td>

                            <td class="email-cell">
                                @p.AddedAt
                            </td>

                            <td class="email-cell">
                                @p.UpdateAt
                            </td>

                             <td class="email-cell">
                                @p.Status
                            </td>

                            <td>
                                     <div class="action-grid">
                                @if (isAdmin){
                                <!-- VIEW -->
                                <button class="btn-detail"
                                        data-bs-toggle="modal"
                                        data-bs-target="#productModal"
                                        data-url="@Url.Action("Details", "Products", new { id = p.ProductId })">

                                    <i class="bi bi-eye"></i>
                                </button>

                                <!-- EDIT -->
                                <button class="btn-detail"
                                        data-bs-toggle="modal"
                                        data-bs-target="#productModal"
                                        data-url="@Url.Action("Edit", "Products", new { id = p.ProductId })">

                                    <i class="bi bi-pencil"></i>
                                </button>

                                <!-- DELETE -->
                             <!-- Active / Inactive -->
                           <!-- Toggle Active / Inactive -->
                          <!-- Toggle Active / Inactive -->
                            <button class="btn-detail @(p.Status == Status.Active ? "text-warning" : "text-success")"
                                    data-bs-toggle="modal"
                                    data-bs-target="#productModal"
                                    data-url="@Url.Action("ChangeStatus", "Products", new {
                                        id = p.ProductId,
                                        status = p.Status == Status.Active
                                            ? Status.Inactive
                                            : Status.Active
                                    })">

                                @if (p.Status == Status.Active)
                                {
                                    <i class="bi bi-toggle-on text-success"></i>
                                }
                                else
                                {
                                   <i class="bi bi-toggle-off text-warning"></i>
                                }
                            </button>

                            <!-- Delete -->
                            <button class="btn-detail text-danger"
                                    data-bs-toggle="modal"
                                    data-bs-target="#productModal"
                                    data-url="@Url.Action("ChangeStatus", "Products", new {
                                        id = p.ProductId,
                                        status = Status.Deleted
                                    })">

                                <i class="bi bi-trash"></i>
                            </button>
                                }
                                   </div>
                            </td>

                        </tr>

                        i++;
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7">

                            <div class="empty-state">

                                <div class="empty-icon">
                                    <i class="bi bi-box"></i>
                                </div>

                                <h3>No products found</h3>
                                <p>Try adjusting filters</p>

                            </div>

                        </td>
                    </tr>
                }

            </tbody>

        </table>
        @{
            int currentPage = ViewBag.CurrentPage ?? 1;
            int totalPages = ViewBag.TotalPages ?? 1;
            var routeValues = new
            {
                 search = Context.Request.Query["search"],
                status = Context.Request.Query["status"],
                categoryId = Context.Request.Query["categoryId"],
                brandId = Context.Request.Query["brandId"],
                minPrice = Context.Request.Query["minPrice"],
                maxPrice = Context.Request.Query["maxPrice"],
                fromDate = Context.Request.Query["fromDate"],
                toDate = Context.Request.Query["toDate"],
                sortBy = Context.Request.Query["sortBy"],
                sortOrder = Context.Request.Query["sortOrder"]
            };
        }
        <div class="pagination">

            <!-- Prev -->
           <a class="page-btn"
   href="@Url.Action("IndexAdmin", new {
         page = currentPage - 1,
        search = routeValues.search,
        status = routeValues.status,
        categoryId = routeValues.categoryId,
        brandId = routeValues.brandId,
        minPrice = routeValues.minPrice,
        maxPrice = routeValues.maxPrice,
        fromDate = routeValues.fromDate,
        toDate = routeValues.toDate,
        sortBy = routeValues.sortBy,
        sortOrder = routeValues.sortOrder
   })">
    Prev
</a>

            <!-- Numbers -->
           
            @for (int i = 1; i <= totalPages; i++)
            {
                <a class="page-btn @(i == currentPage ? "active" : "")"
                  href="@Url.Action("IndexAdmin", new {
                    page = i,
                    search = routeValues.search,
                    status = routeValues.status,
                    categoryId = routeValues.categoryId,
                    brandId = routeValues.brandId,
                    minPrice = routeValues.minPrice,
                    maxPrice = routeValues.maxPrice,
                    fromDate = routeValues.fromDate,
                    toDate = routeValues.toDate,
                    sortBy = routeValues.sortBy,
                    sortOrder = routeValues.sortOrder
                })">
                    @i
                </a>
            }

            <!-- Next -->
            <a class="page-btn"
   href="@Url.Action("IndexAdmin", new {
        page = currentPage + 1,
            search = routeValues.search,
            status = routeValues.status,
            categoryId = routeValues.categoryId,
            brandId = routeValues.brandId,
            minPrice = routeValues.minPrice,
            maxPrice = routeValues.maxPrice,
            fromDate = routeValues.fromDate,
            toDate = routeValues.toDate,
            sortBy = routeValues.sortBy,
            sortOrder = routeValues.sortOrder
   })">
    Next
</a>

    </div>

</div>


<!-- PRODUCT MODAL -->

<div class="modal fade" id="productModal" tabindex="-1" aria-hidden="true">

    <div class="modal-dialog modal-lg modal-dialog-centered">

        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Product</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body" id="productModalBody"></div>

        </div>

    </div>

</div>


<!-- Loading Overlay -->

<div id="pageLoadingOverlay"
     style="display:none;
            position:fixed;
            top:0;
            left:0;
            width:100%;
            height:100%;
            background: rgba(255,255,255,0.7);
            z-index:2000;
            justify-content:center;
            align-items:center;
            flex-direction:column;">

    <div class="spinner-border text-primary"
         role="status"
         style="width:3rem;height:3rem"></div>

    <p class="mt-2">Processing, Please wait...</p>

</div>


<!-- TOAST -->

<div class="position-fixed bottom-0 end-0 p-3" style="z-index:1100">

    <div id="liveToast"
         class="toast bg-success text-white"
         role="alert">

        <div class="toast-body"></div>

    </div>

</div>

</div>


@section Scripts {

    <script>

                // Load modal content

                    $(document).on("click", "[data-bs-target='#productModal']", function () {

                    var url = $(this).data("url");

                    $("#productModalBody").html("Loading...");

                    $("#productModalBody").load(url, function () {

                    var form = $("#productModalBody").find("form");

                    $.validator.unobtrusive.parse(form);

                });

                });



                // Submit form bằng AJAX

                $('#productModal').on('submit', 'form', function (e) {

                    e.preventDefault();

                    var form = $(this);

                    var formData = new FormData(form[0]);

                    $("#pageLoadingOverlay").css("display", "flex");

                    $.ajax({

                        url: form.attr('action'),

                        type: form.attr('method'),

                        data: formData,

                        contentType: false,

                        processData: false,

                 success: function (res) {

                    $("#pageLoadingOverlay").hide();

                    if (res.success) {

                        $('#productModal').modal('hide');

                        showToast("Success");

                        setTimeout(function () {
                            location.reload();
                        }, 800);

                    }
                    else {

                        $("#productModalBody").html(res);

                    }

                },
                error: function (xhr) {

                    $("#pageLoadingOverlay").hide();

                    console.log(xhr.responseText);
                     showToast("Error");


                }

                    });

                });



                function showToast(message) {

                    $('#liveToast .toast-body').text(message);

                    var toast = new bootstrap.Toast(document.getElementById('liveToast'));

                    toast.show();

                }


              document.querySelector(".filter-container")?.addEventListener("submit", function () {

    this.querySelectorAll("input, select").forEach(el => {
        if (!el.value) {
            el.removeAttribute("name");
        }
    });

});
    </script>

}