@model List<PetCenterClient.DTOs.CustomerListDto>
@{
    ViewData["Title"] = "Manage Customers";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=Space+Grotesk:wght@400;500;600&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="~/css/AdminViews/ManageCustomer/manage-customer.css" asp-append-version="true" />

<div class="page-wrapper">
    <div class="page-header">
        <div class="page-title-group">
            <h1>Customer Management</h1>
            <p>View and manage all registered customers</p>
        </div>
        <div class="header-stat">
            <span class="num">@Model.Count</span>
            <span class="label">Total Customers</span>
        </div>
    </div>

    <div class="toolbar">
        <div class="search-wrap">
            <i class="bi bi-search"></i>
            <input type="text" class="search-input" id="searchInput" placeholder="Search by name or email…" />
        </div>
        <button class="filter-btn active" data-filter="all">All</button>
        <button class="filter-btn" data-filter="active">
            <span style="width:7px;height:7px;background:#10b981;border-radius:50%;display:inline-block"></span> Active
        </button>
        <button class="filter-btn" data-filter="inactive">
            <span style="width:7px;height:7px;background:#ef4444;border-radius:50%;display:inline-block"></span> Inactive
        </button>
    </div>

    <div class="table-card">
        <table class="data-table" id="customerTable">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Customer</th>
                    <th>Email</th>
                    <th>Status</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5">
                            <div class="empty-state">
                                <div class="empty-icon"><i class="bi bi-people"></i></div>
                                <h3>No customers found</h3>
                                <p>There are no registered customers yet.</p>
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    int i = 1;
                    foreach (var c in Model)
                    {
                        var initials = string.Join("", c.FullName.Split(' ').Take(2).Select(w => w.Length > 0 ? w[0].ToString().ToUpper() : ""));
                        <tr data-status="@(c.IsActive ? "active" : "inactive")">
                            <td><span class="row-num">@i</span></td>
                            <td>
                                <div class="customer-cell">
                                    <div class="avatar">@initials</div>
                                    <span class="customer-name">@c.FullName</span>
                                </div>
                            </td>
                            <td><span class="email-cell">@c.Email</span></td>
                            <td>
                                @if (c.IsActive)
                                {
                                    <span class="badge-status badge-active"><span class="badge-dot"></span> Active</span>
                                }
                                else
                                {
                                    <span class="badge-status badge-inactive"><span class="badge-dot"></span> Inactive</span>
                                }
                            </td>
                            <td>
                                <div style="display: flex; gap: 8px;">
                                    <a asp-controller="ManageCustomer" asp-action="Detail" asp-route-id="@c.CustomerId" class="btn-detail">
                                        <i class="bi bi-person-lines-fill"></i> View Detail
                                    </a>
                                    <button class="btn-toggle-status @(c.IsActive ? "active" : "inactive")"
                                            data-customer-id="@c.CustomerId"
                                            data-is-active="@(c.IsActive ? "true" : "false")">
                                        <i class="bi @(c.IsActive ? "bi-lock" : "bi-unlock")"></i>
                                        @(c.IsActive ? "Deactivate" : "Activate")
                                    </button>
                                </div>
                            </td>
                        </tr>
                        i++;
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        // ===== PAGE INITIALIZATION =====
        const searchInput = document.getElementById('searchInput');
        let debounceTimer;
        let originalTableHTML = null;

        // Lưu HTML gốc của table khi load trang
        document.addEventListener('DOMContentLoaded', function() {
            const tbody = document.querySelector('#customerTable tbody');
            originalTableHTML = tbody.innerHTML;
            attachStatusButtonListeners();
        });

        // ===== SEARCH EVENT LISTENER =====
        searchInput.addEventListener('input', function(e) {
            const query = e.target.value.trim();

            clearTimeout(debounceTimer);

            if (query.length === 0) {
                // Reset về HTML gốc
                const tbody = document.querySelector('#customerTable tbody');
                tbody.innerHTML = originalTableHTML;
                attachStatusButtonListeners();
                return;
            }

            debounceTimer = setTimeout(async () => {
                await performSearch(query);
            }, 300);
        });

        // ===== FILTER BUTTONS =====
        document.querySelectorAll('.filter-btn').forEach(btn => {
            btn.addEventListener('click', function() {
                document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
                this.classList.add('active');
                applyFilter(this.dataset.filter);
            });
        });

        // ===== PERFORM SEARCH =====
        async function performSearch(query) {
            try {
                const url = `/ManageCustomer/Search?query=${encodeURIComponent(query)}`;
                const response = await fetch(url);
                const result = await response.json();

                if (result.success && result.data && result.data.length > 0) {
                    updateTableWithResults(result.data);
                    const activeFilter = document.querySelector('.filter-btn.active')?.dataset.filter || 'all';
                    applyFilter(activeFilter);
                } else {
                    showEmptyState('No customers found', 'Try adjusting your search terms.');
                }
            } catch (error) {
                console.error('Search error:', error);
                showEmptyState('Search failed', 'Please try again.');
            }
        }

        // ===== UPDATE TABLE WITH RESULTS =====
        function updateTableWithResults(results) {
            const tbody = document.querySelector('#customerTable tbody');
            tbody.innerHTML = '';

            if (!results || results.length === 0) {
                showEmptyState('No customers found', 'Try adjusting your search terms.');
                return;
            }

            results.forEach((customer, index) => {
                const initials = getInitials(customer.fullName);
                const statusClass = customer.isActive ? 'active' : 'inactive';
                const statusText = customer.isActive ? 'Active' : 'Inactive';
                const statusBadgeClass = customer.isActive ? 'badge-active' : 'badge-inactive';
                const buttonText = customer.isActive ? 'Deactivate' : 'Activate';
                const iconClass = customer.isActive ? 'bi-lock' : 'bi-unlock';

                const row = document.createElement('tr');
                row.setAttribute('data-status', statusClass);
                row.innerHTML = `
                    <td><span class="row-num">${index + 1}</span></td>
                    <td>
                        <div class="customer-cell">
                            <div class="avatar">${initials}</div>
                            <span class="customer-name">${escapeHtml(customer.fullName)}</span>
                        </div>
                    </td>
                    <td><span class="email-cell">${escapeHtml(customer.email)}</span></td>
                    <td>
                        <span class="badge-status ${statusBadgeClass}">
                            <span class="badge-dot"></span> ${statusText}
                        </span>
                    </td>
                    <td>
                        <div style="display: flex; gap: 8px;">
                            <a href="/ManageCustomer/Detail/${customer.customerId}" class="btn-detail">
                                <i class="bi bi-person-lines-fill"></i> View Detail
                            </a>
                            <button class="btn-toggle-status ${statusClass}"
                                    data-customer-id="${customer.customerId}"
                                    data-is-active="${customer.isActive}">
                                <i class="bi ${iconClass}"></i>
                                ${buttonText}
                            </button>
                        </div>
                    </td>
                `;
                tbody.appendChild(row);
            });

            // ✅ Attach event listeners sau khi update table
            attachStatusButtonListeners();
        }

        // ===== SHOW EMPTY STATE =====
        function showEmptyState(title, message) {
            const tbody = document.querySelector('#customerTable tbody');
            tbody.innerHTML = `
                <tr>
                    <td colspan="5">
                        <div class="empty-state">
                            <div class="empty-icon"><i class="bi bi-search"></i></div>
                            <h3>${title}</h3>
                            <p>${message}</p>
                        </div>
                    </td>
                </tr>
            `;
        }

        // ===== APPLY FILTER =====
        function applyFilter(filter) {
            const rows = document.querySelectorAll('#customerTable tbody tr[data-status]');
            let visibleCount = 0;

            rows.forEach(row => {
                const matchFilter = filter === 'all' || row.dataset.status === filter;
                row.style.display = matchFilter ? '' : 'none';
                if (matchFilter) visibleCount++;
            });

            if (visibleCount === 0 && searchInput.value.trim() !== '') {
                showEmptyState('No matching customers', 'Try adjusting your filter or search terms.');
            }
        }

        // ===== GET INITIALS =====
        function getInitials(fullName) {
            if (!fullName) return '?';
            return fullName
                .split(' ')
                .slice(0, 2)
                .map(w => w && w.length > 0 ? w[0].toUpperCase() : '')
                .join('')
                .substring(0, 2);
        }

        // ===== ESCAPE HTML =====
        function escapeHtml(text) {
            if (!text) return '';
            const map = {
                '&': '&amp;',
                '<': '&lt;',
                '>': '&gt;',
                '"': '&quot;',
                "'": '&#039;'
            };
            return text.replace(/[&<>"']/g, m => map[m]);
        }

        // ===== ATTACH STATUS BUTTON LISTENERS =====
        function attachStatusButtonListeners() {
            document.querySelectorAll('.btn-toggle-status').forEach(btn => {
                btn.addEventListener('click', handleStatusToggle);
            });
        }

        // ===== HANDLE STATUS TOGGLE =====
        async function handleStatusToggle(e) {
            e.preventDefault();

            const btn = this;
            const customerId = btn.dataset.customerId;
            const currentStatus = btn.dataset.isActive === 'true';
            const newStatus = !currentStatus;
            const statusText = newStatus ? 'Activate' : 'Deactivate';

            // Confirm
            if (!confirm(`Are you sure you want to ${statusText} this customer?`)) {
                return;
            }

            try {
                btn.disabled = true;
                const originalHTML = btn.innerHTML;
                btn.innerHTML = '<i class="bi bi-hourglass-split"></i> Processing...';

                const response = await fetch(`/ManageCustomer/ChangeStatus/${customerId}`, {
                    method: 'PUT',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ isActive: newStatus })
                });

                const result = await response.json();

                if (result.success) {
                    alert(`Customer status changed to ${statusText} successfully!`);
                    location.reload();
                } else {
                    alert(result.message || 'Failed to change status');
                    btn.disabled = false;
                    btn.innerHTML = originalHTML;
                }
            } catch (error) {
                console.error('Error:', error);
                alert('An error occurred: ' + error.message);
                btn.disabled = false;
                btn.innerHTML = originalHTML;
            }
        }
    </script>
}