@model List<PetCenterClient.ViewModels.ManageCustomer.CustomerListViewModel>
@{
    ViewData["Title"] = "Manage Customers";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=Space+Grotesk:wght@400;500;600&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="~/css/AdminViews/ManageCustomer/manage-customer.css" asp-append-version="true" />

<div class="page-wrapper">
    <div class="page-header">
        <div class="page-title-group">
            <h1>Customer Management</h1>
            <p>View and manage all registered customers</p>
        </div>
        <div class="header-stat">
            <span class="num">@Model.Count</span>
            <span class="label">Total Customers</span>
        </div>
    </div>

    <div class="toolbar">
        <div class="search-wrap">
            <i class="bi bi-search"></i>
            <input type="text" class="search-input" id="searchInput" placeholder="Search by name or email…" />
        </div>
        <button class="filter-btn active" data-filter="all">All</button>
        <button class="filter-btn" data-filter="active">
            <span style="width:7px;height:7px;background:#10b981;border-radius:50%;display:inline-block"></span> Active
        </button>
        <button class="filter-btn" data-filter="inactive">
            <span style="width:7px;height:7px;background:#ef4444;border-radius:50%;display:inline-block"></span> Inactive
        </button>
    </div>

    <div class="table-card">
        <table class="data-table" id="customerTable">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Customer</th>
                    <th>Email</th>
                    <th>Status</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5">
                            <div class="empty-state">
                                <div class="empty-icon"><i class="bi bi-people"></i></div>
                                <h3>No customers found</h3>
                                <p>There are no registered customers yet.</p>
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    int i = 1;
                    foreach (var c in Model)
                    {
                        var initials = string.Join("", c.FullName.Split(' ').Take(2).Select(w => w.Length > 0 ? w[0].ToString().ToUpper() : ""));
                        <tr data-status="@(c.IsActive ? "active" : "inactive")">
                            <td><span class="row-num">@i</span></td>
                            <td>
                                <div class="customer-cell">
                                    <div class="avatar">@initials</div>
                                    <span class="customer-name">@c.FullName</span>
                                </div>
                            </td>
                            <td><span class="email-cell">@c.Email</span></td>
                            <td>
                                @if (c.IsActive)
                                {
                                    <span class="badge-status badge-active"><span class="badge-dot"></span> Active</span>
                                }
                                else
                                {
                                    <span class="badge-status badge-inactive"><span class="badge-dot"></span> Inactive</span>
                                }
                            </td>
                            <td>
                                <div style="display: flex; gap: 8px;">
                                    <button class="btn-detail js-view-customer" data-id="@c.CustomerId">
                                        <i class="bi bi-person-lines-fill"></i> View Detail
                                    </button>
                                    <button class="btn-toggle-status @(c.IsActive ? "active" : "inactive")"
                                            data-customer-id="@c.CustomerId"
                                            data-is-active="@(c.IsActive ? "true" : "false")">
                                        <i class="bi @(c.IsActive ? "bi-lock" : "bi-unlock")"></i>
                                        @(c.IsActive ? "Deactivate" : "Activate")
                                    </button>
                                </div>
                            </td>
                        </tr>
                        i++;
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<!-- ══ VIEW DETAIL MODAL ═════════════════════════════════════ -->
<div class="modal fade" id="viewCustomerModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-person-vcard"></i> Customer Detail
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="customerDetailBody">
                <div class="text-center py-4 text-muted">
                    <i class="bi bi-arrow-repeat" style="font-size:24px;display:block;
                       margin-bottom:8px;animation:spin 1s linear infinite"></i>
                    Loading...
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-cancel" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<style>
    /* Modal reuse styles từ manage-customer.css */
    #viewCustomerModal .detail-section-title {
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.7px;
        color: var(--text-muted);
        margin-bottom: 16px;
        margin-top: 4px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        #viewCustomerModal .detail-section-title::after {
            content: '';
            flex: 1;
            height: 1px;
            background: var(--border);
        }

    #viewCustomerModal .detail-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
        margin-bottom: 8px;
    }

    #viewCustomerModal .field-group {
        display: flex;
        flex-direction: column;
        gap: 5px;
    }

    #viewCustomerModal .field-label {
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.6px;
        color: var(--text-muted);
    }

    #viewCustomerModal .field-value {
        padding: 10px 13px;
        background: var(--surface-2);
        border: 1px solid var(--border);
        border-radius: 8px;
        font-size: 14px;
        font-weight: 500;
        color: var(--text-primary);
        min-height: 40px;
    }

    #viewCustomerModal .verified-chip {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        font-size: 11.5px;
        font-weight: 500;
        padding: 3px 9px;
        border-radius: 12px;
    }

    #viewCustomerModal .verified-yes {
        background: #d1fae5;
        color: #065f46;
    }

    #viewCustomerModal .verified-no {
        background: #fef3c7;
        color: #92400e;
    }

    #viewCustomerModal .btn-cancel {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 10px 18px;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 500;
        color: var(--text-secondary);
        background: var(--surface);
        border: 1px solid var(--border);
        cursor: pointer;
        transition: all 0.2s;
    }

        #viewCustomerModal .btn-cancel:hover {
            border-color: var(--text-secondary);
            color: var(--text-primary);
        }
    @@keyframes spin {
        from

    {
        transform: rotate(0deg);
    }

    to {
        transform: rotate(360deg);
    }

    }
    @@media (max-width: 600px) {
        #viewCustomerModal .detail-grid

    {
        grid-template-columns: 1fr;
    }

    }
</style>

@section Scripts {
    <script>
        // ===== PAGE INITIALIZATION =====
        const searchInput = document.getElementById('searchInput');
        let debounceTimer;
        let originalTableHTML = null;

        // Lưu HTML gốc của table khi load trang
        document.addEventListener('DOMContentLoaded', function() {
            const tbody = document.querySelector('#customerTable tbody');
            originalTableHTML = tbody.innerHTML;
            attachStatusButtonListeners();
            attachViewDetailListeners();
        });

        // ===== SEARCH EVENT LISTENER =====
        searchInput.addEventListener('input', function(e) {
            const query = e.target.value.trim();

            clearTimeout(debounceTimer);

            if (query.length === 0) {
                // Reset về HTML gốc
                const tbody = document.querySelector('#customerTable tbody');
                tbody.innerHTML = originalTableHTML;
                attachStatusButtonListeners();
                return;
            }

            debounceTimer = setTimeout(async () => {
                await performSearch(query);
            }, 300);
        });

        // ===== FILTER BUTTONS =====
        document.querySelectorAll('.filter-btn').forEach(btn => {
            btn.addEventListener('click', function() {
                document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
                this.classList.add('active');
                applyFilter(this.dataset.filter);
            });
        });

        // ===== PERFORM SEARCH =====
        async function performSearch(query) {
            try {
                const url = `/ManageCustomer/Search?query=${encodeURIComponent(query)}`;
                const response = await fetch(url);
                const result = await response.json();

                if (result.success && result.data && result.data.length > 0) {
                    updateTableWithResults(result.data);
                    const activeFilter = document.querySelector('.filter-btn.active')?.dataset.filter || 'all';
                    applyFilter(activeFilter);
                } else {
                    showEmptyState('No customers found', 'Try adjusting your search terms.');
                }
            } catch (error) {
                console.error('Search error:', error);
                showEmptyState('Search failed', 'Please try again.');
            }
        }

        // ===== UPDATE TABLE WITH RESULTS =====
        function updateTableWithResults(results) {
            const tbody = document.querySelector('#customerTable tbody');
            tbody.innerHTML = '';

            if (!results || results.length === 0) {
                showEmptyState('No customers found', 'Try adjusting your search terms.');
                return;
            }

            results.forEach((customer, index) => {
                const initials = getInitials(customer.fullName);
                const statusClass = customer.isActive ? 'active' : 'inactive';
                const statusText = customer.isActive ? 'Active' : 'Inactive';
                const statusBadgeClass = customer.isActive ? 'badge-active' : 'badge-inactive';
                const buttonText = customer.isActive ? 'Deactivate' : 'Activate';
                const iconClass = customer.isActive ? 'bi-lock' : 'bi-unlock';

                const row = document.createElement('tr');
                row.setAttribute('data-status', statusClass);
                row.innerHTML = `
                    <td><span class="row-num">${index + 1}</span></td>
                    <td>
                        <div class="customer-cell">
                            <div class="avatar">${initials}</div>
                            <span class="customer-name">${escapeHtml(customer.fullName)}</span>
                        </div>
                    </td>
                    <td><span class="email-cell">${escapeHtml(customer.email)}</span></td>
                    <td>
                        <span class="badge-status ${statusBadgeClass}">
                            <span class="badge-dot"></span> ${statusText}
                        </span>
                    </td>
                    <td>
                        <div style="display: flex; gap: 8px;">
                                    <button class="btn-detail js-view-customer" data-id="${customer.customerId}">
                                        <i class="bi bi-person-lines-fill"></i> View Detail
                                    </button>
                            <button class="btn-toggle-status ${statusClass}"
                                    data-customer-id="${customer.customerId}"
                                    data-is-active="${customer.isActive}">
                                <i class="bi ${iconClass}"></i>
                                ${buttonText}
                            </button>
                        </div>
                    </td>
                `;
                tbody.appendChild(row);
            });

            attachStatusButtonListeners();
            attachViewDetailListeners();
        }

        // ===== SHOW EMPTY STATE =====
        function showEmptyState(title, message) {
            const tbody = document.querySelector('#customerTable tbody');
            tbody.innerHTML = `
                <tr>
                    <td colspan="5">
                        <div class="empty-state">
                            <div class="empty-icon"><i class="bi bi-search"></i></div>
                            <h3>${title}</h3>
                            <p>${message}</p>
                        </div>
                    </td>
                </tr>
            `;
        }

        // ===== APPLY FILTER =====
        function applyFilter(filter) {
            const rows = document.querySelectorAll('#customerTable tbody tr[data-status]');
            let visibleCount = 0;

            rows.forEach(row => {
                const matchFilter = filter === 'all' || row.dataset.status === filter;
                row.style.display = matchFilter ? '' : 'none';
                if (matchFilter) visibleCount++;
            });

            if (visibleCount === 0 && searchInput.value.trim() !== '') {
                showEmptyState('No matching customers', 'Try adjusting your filter or search terms.');
            }
        }

        // ===== GET INITIALS =====
        function getInitials(fullName) {
            if (!fullName) return '?';
            return fullName
                .split(' ')
                .slice(0, 2)
                .map(w => w && w.length > 0 ? w[0].toUpperCase() : '')
                .join('')
                .substring(0, 2);
        }

        // ===== ESCAPE HTML =====
        function escapeHtml(text) {
            if (!text) return '';
            const map = {
                '&': '&amp;',
                '<': '&lt;',
                '>': '&gt;',
                '"': '&quot;',
                "'": '&#039;'
            };
            return text.replace(/[&<>"']/g, m => map[m]);
        }

        // ===== ATTACH STATUS BUTTON LISTENERS =====
        function attachStatusButtonListeners() {
            document.querySelectorAll('.btn-toggle-status').forEach(btn => {
                btn.addEventListener('click', handleStatusToggle);
            });
        }

        // ===== VIEW DETAIL MODAL =====
        function attachViewDetailListeners() {
            document.querySelectorAll('.js-view-customer').forEach(function(btn) {
                btn.addEventListener('click', async function() {
                    const id   = this.dataset.id;
                    const body = document.getElementById('customerDetailBody');

                    // Show loading spinner
                    body.innerHTML = `
                        <div class="text-center py-4 text-muted">
                            <i class="bi bi-arrow-repeat" style="font-size:24px;display:block;
                               margin-bottom:8px;animation:spin 1s linear infinite"></i>
                            Loading...
                        </div>`;

                    new bootstrap.Modal(document.getElementById('viewCustomerModal')).show();

                    try {
                        const res  = await fetch('/ManageCustomer/GetDetail?id=' + id);
                        const json = await res.json();

                        if (!json.success) {
                            body.innerHTML = '<p class="text-danger p-3">Failed to load customer.</p>';
                            return;
                        }

                        const d = json.data;

                        const initials = (d.fullName || '?')
                            .split(' ').slice(0, 2)
                            .map(w => w[0]?.toUpperCase() || '').join('');

                        const genderIcon  = d.gender?.toLowerCase() === 'male'   ? 'bi-gender-male'
                                          : d.gender?.toLowerCase() === 'female' ? 'bi-gender-female'
                                          : 'bi-gender-ambiguous';
                        const genderColor = d.gender?.toLowerCase() === 'male'   ? '#3b82f6'
                                          : d.gender?.toLowerCase() === 'female' ? '#ec4899'
                                          : '#8b5cf6';

                        function fmtDate(s) {
                            if (!s) return '—';
                            const dt = new Date(s);
                            return isNaN(dt) ? '—' : dt.toLocaleDateString('en-GB', {
                                day: '2-digit', month: 'short', year: 'numeric'
                            });
                        }

                        body.innerHTML = `
                            <!-- Avatar + tên -->
                            <div style="display:flex;align-items:center;gap:16px;
                                        padding:16px;background:var(--surface-2);
                                        border-radius:12px;margin-bottom:24px;
                                        border:1px solid var(--border)">
                                <div style="width:54px;height:54px;border-radius:50%;
                                            background:linear-gradient(135deg,#6366f1,#8b5cf6);
                                            display:flex;align-items:center;justify-content:center;
                                            font-size:20px;font-weight:700;color:#fff;flex-shrink:0">
                                    ${initials}
                                </div>
                                <div>
                                    <div style="font-size:16px;font-weight:600;color:var(--text-primary)">
                                        ${d.fullName || '—'}
                                    </div>
                                    <div style="font-size:13px;color:var(--text-muted);margin-top:2px">
                                        ${d.email || '—'}
                                    </div>
                                </div>
                                <div style="margin-left:auto">
                                    ${d.isActive
                                        ? '<span class="badge-status badge-active"><span class="badge-dot"></span> Active</span>'
                                        : '<span class="badge-status badge-inactive"><span class="badge-dot"></span> Inactive</span>'}
                                </div>
                            </div>

                            <!-- Personal Info -->
                            <div class="detail-section-title">
                                <i class="bi bi-person"></i> Personal Information
                            </div>
                            <div class="detail-grid" style="margin-bottom:24px">
                                <div class="field-group">
                                    <label class="field-label">Full Name</label>
                                    <div class="field-value">${d.fullName || '—'}</div>
                                </div>
                                <div class="field-group">
                                    <label class="field-label">Phone Number</label>
                                    <div class="field-value">${d.phoneNumber || '—'}</div>
                                </div>
                                <div class="field-group">
                                    <label class="field-label">Date of Birth</label>
                                    <div class="field-value">${fmtDate(d.birthDay)}</div>
                                </div>
                                <div class="field-group">
                                    <label class="field-label">Gender</label>
                                    <div class="field-value">
                                        <i class="bi ${genderIcon}" style="color:${genderColor}"></i>
                                        ${d.gender || '—'}
                                    </div>
                                </div>
                            </div>

                            <!-- Account Info -->
                            <div class="detail-section-title">
                                <i class="bi bi-shield-check"></i> Account Information
                            </div>
                            <div class="detail-grid">
                                <div class="field-group" style="grid-column:1/-1">
                                    <label class="field-label">Address</label>
                                    <div class="field-value">${d.address || '—'}</div>
                                </div>
                                <div class="field-group">
                                    <label class="field-label">Email Verified</label>
                                    <div class="field-value">
                                        ${d.isVerified
                                            ? '<span class="verified-chip verified-yes"><i class="bi bi-patch-check-fill"></i> Verified</span>'
                                            : '<span class="verified-chip verified-no"><i class="bi bi-exclamation-circle"></i> Unverified</span>'}
                                    </div>
                                </div>
                                <div class="field-group">
                                    <label class="field-label">Member Since</label>
                                    <div class="field-value">${fmtDate(d.createdAt)}</div>
                                </div>
                            </div>`;

                    } catch(err) {
                        body.innerHTML = `<p class="text-danger p-3">Error: ${err.message}</p>`;
                    }
                });
            });
        }

        // ===== HANDLE STATUS TOGGLE =====
        async function handleStatusToggle(e) {
            e.preventDefault();

            const btn = this;
            const customerId = btn.dataset.customerId;
            const currentStatus = btn.dataset.isActive === 'true';
            const newStatus = !currentStatus;
            const statusText = newStatus ? 'Activate' : 'Deactivate';

            // Confirm
            if (!confirm(`Are you sure you want to ${statusText} this customer?`)) {
                return;
            }

            try {
                btn.disabled = true;
                const originalHTML = btn.innerHTML;
                btn.innerHTML = '<i class="bi bi-hourglass-split"></i> Processing...';

                const response = await fetch(`/ManageCustomer/ChangeStatus/${customerId}`, {
                    method: 'PUT',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ isActive: newStatus })
                });

                const result = await response.json();

                if (result.success) {
                    alert(`Customer status changed to ${statusText} successfully!`);
                    location.reload();
                } else {
                    alert(result.message || 'Failed to change status');
                    btn.disabled = false;
                    btn.innerHTML = originalHTML;
                }
            } catch (error) {
                console.error('Error:', error);
                alert('An error occurred: ' + error.message);
                btn.disabled = false;
                btn.innerHTML = originalHTML;
            }
        }
    </script>
}