@using PetCenterClient.ViewModels
@model DashboardMetricsViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Analytics Dashboard";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold m-0"><i class="bi bi-graph-up-arrow text-success"></i> Business Analytics</h3>
        <span class="text-muted">Current Month Overview</span>
    </div>

    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card shadow-sm border-0 border-start border-success border-4 h-100">
                <div class="card-body">
                    <h6 class="text-muted fw-bold text-uppercase">Revenue</h6>
                    <h3 class="fw-bold mb-0 text-success">@Model.TotalRevenue.ToString("N0") đ</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm border-0 border-start border-primary border-4 h-100">
                <div class="card-body">
                    <h6 class="text-muted fw-bold text-uppercase">Orders</h6>
                    <h3 class="fw-bold mb-0">@Model.TotalOrders</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm border-0 border-start border-warning border-4 h-100">
                <div class="card-body">
                    <h6 class="text-muted fw-bold text-uppercase">Appointments</h6>
                    <h3 class="fw-bold mb-0">@Model.TotalAppointments</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm border-0 border-start border-info border-4 h-100">
                <div class="card-body">
                    <h6 class="text-muted fw-bold text-uppercase">Total Customers</h6>
                    <h3 class="fw-bold mb-0">@Model.TotalCustomers</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8 mb-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white border-bottom py-3">
                    <h6 class="m-0 fw-bold">Revenue Last 6 Months</h6>
                </div>
                <div class="card-body">
                    <canvas id="revenueChart" height="100"></canvas>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white border-bottom py-3">
                    <h6 class="m-0 fw-bold"><i class="bi bi-star-fill text-warning"></i> Top Selling Products</h6>
                </div>
                <ul class="list-group list-group-flush">
                    @if (Model.TopProducts != null && Model.TopProducts.Any())
                    {
                        var rank = 1;
                        foreach (var item in Model.TopProducts)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center py-3">
                                <div class="text-truncate" style="max-width: 70%;">
                                    <span class="badge bg-secondary me-2">#@rank</span> @item.ProductName
                                </div>
                                <span class="badge bg-success rounded-pill">@item.TotalSold sold</span>
                            </li>
                            rank++;
                        }
                    }
                    else
                    {
                        <li class="list-group-item text-center text-muted py-4">No data available</li>
                    }
                </ul>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    document.addEventListener("DOMContentLoaded", function () {
    // Biến cục bộ C# sang mảng JS xịn xò
    const chartLabels = @Json.Serialize(Model.RevenueChart.Select(x => x.Month));
    const chartData = @Json.Serialize(Model.RevenueChart.Select(x => x.Revenue));

    const ctx = document.getElementById('revenueChart').getContext('2d');

    new Chart(ctx, {
    type: 'line',
    data: {
    labels: chartLabels,
    datasets: [{
    label: 'Revenue (VND)',
    data: chartData,
    borderColor: '#2ecc71',
    backgroundColor: 'rgba(46, 204, 113, 0.2)',
    borderWidth: 2,
    fill: true,
    tension: 0.4, // Đường cong mượt
    pointBackgroundColor: '#27ae60',
    pointRadius: 4
    }]
    },
    options: {
    responsive: true,
    plugins: {
    legend: { display: false }
    },
    scales: {
    y: {
    beginAtZero: true,
    ticks: {
    callback: function(value) {
    if(value >= 1000000) return (value / 1000000) + 'M';
    if(value >= 1000) return (value / 1000) + 'K';
    return value;
    }
    }
    }
    }
    }
    });
    });
</script>