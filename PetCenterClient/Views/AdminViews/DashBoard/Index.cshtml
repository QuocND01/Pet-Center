@model PetCenterClient.DTOs.DashboardStatsDto

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Statistics Center";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0"><i class="bi bi-graph-up-arrow"></i> Revenue Report</h2>

    <form asp-action="Index" method="get" class="d-flex align-items-center bg-white p-2 rounded shadow-sm border">
        <label class="fw-bold me-2 text-muted mb-0"><i class="fas fa-calendar-alt me-1"></i> Select Year:</label>
        <select name="year" class="form-select form-select-sm w-auto fw-bold text-primary border-primary" onchange="this.form.submit()">
            @for (int i = DateTime.Now.Year; i >= 2024; i--)
            {
                if (ViewBag.SelectedYear == i)
                {
                    <option value="@i" selected>@i</option>
                }
                else
                {
                    <option value="@i">@i</option>
                }
            }
        </select>
    </form>
</div>

<div class="row mb-4">
    <div class="col-md-4">
        <div class="card text-white bg-success shadow-sm">
            <div class="card-body">
                <h5 class="card-title">Total Revenue</h5>
                <h3 class="fw-bold">@Model.TotalRevenue.ToString("N0") VND</h3>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white bg-primary shadow-sm">
            <div class="card-body">
                <h5 class="card-title">Total Orders</h5>
                <h3 class="fw-bold">@Model.TotalOrders</h3>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white bg-warning shadow-sm text-dark">
            <div class="card-body">
                <h5 class="card-title">Pending Orders</h5>
                <h3 class="fw-bold">@Model.PendingOrders</h3>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header bg-white fw-bold">
        Revenue Chart for @ViewBag.SelectedYear
    </div>
    <div class="card-body">
        <canvas id="revenueChart" height="100"></canvas>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Lấy dữ liệu từ Model
            const labels = @Html.Raw(Json.Serialize(Model.RevenueByMonth.Select(x => "Month " + x.Month)));
            const dataValues = @Html.Raw(Json.Serialize(Model.RevenueByMonth.Select(x => x.Revenue)));

            const ctx = document.getElementById('revenueChart').getContext('2d');
            new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Revenue',
                        data: dataValues,
                        backgroundColor: 'rgba(46, 204, 113, 0.7)',
                        borderColor: '#27ae60',
                        borderWidth: 1,
                        borderRadius: 5
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        tooltip: {
                            callbacks: {
                                // Format tiền tệ khi hover vào cột
                                label: function(context) {
                                    let label = context.dataset.label || '';
                                    if (label) {
                                        label += ': ';
                                    }
                                    if (context.parsed.y !== null) {
                                        label += context.parsed.y.toLocaleString('vi-VN') + ' VND';
                                    }
                                    return label;
                                }
                            }
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: {
                                // Format tiền tệ cho trục Y (hiển thị 1.000.000 VND thay vì 1000000)
                                callback: function(value, index, values) {
                                    if (value >= 1000000) {
                                        return (value / 1000000).toLocaleString('vi-VN') + 'M VND'; // Rút gọn thành chữ M (Triệu) cho gọn
                                    }
                                    return value.toLocaleString('vi-VN') + ' VND';
                                }
                            }
                        }
                    }
                }
            });
        });
    </script>
}