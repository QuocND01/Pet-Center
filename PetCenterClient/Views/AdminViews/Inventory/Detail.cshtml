@using PetCenterClient.ViewModels.Inventory
@model InventoryDetailViewModel

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=Space+Grotesk:wght@400;500;600&display=swap" rel="stylesheet" />
<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />

<link rel="stylesheet"
      href="~/css/AdminViews/ManageInventory/inventory_detail.css"
      asp-append-version="true" />

<div class="page-wrapper">

    <div class="page-header">

        <div class="page-title-group">

            <h1>Inventory Detail</h1>

            <p>Monitor inventory status and batches.</p>

        </div>

        <a asp-action="Index" class="btn-back">

            <i class="bi bi-arrow-left"></i>

            Back

        </a>

    </div>


    <div class="product-card">

        <img src="@Model.ProductImage"
             class="product-image" />

        <div class="product-content">

            <h2>@Model.ProductName</h2>

            <div class="product-meta">

                <span>SKU : @Model.SKU</span>

                <span>Brand : @Model.Brand</span>

                <span>Category : @Model.Category</span>

            </div>

            <div class="last-update">

                Last Updated :
                @Model.LastUpdated.ToString("dd/MM/yyyy HH:mm")

            </div>

        </div>

    </div>


    <div class="summary-grid">

        <div class="summary-card success">

            <span>Available</span>

            <strong>@Model.QuantityAvailable</strong>

        </div>

        <div class="summary-card warning">

            <span>Reserved</span>

            <strong>@Model.QuantityReserved</strong>

        </div>

        <div class="summary-card danger">

            <span>Damaged</span>

            <strong>@Model.QuantityDamaged</strong>

        </div>

    </div>


    <div class="table-card">

        <div class="table-header">

            <h3>

                <i class="bi bi-box-seam"></i>

                Batch Information

            </h3>

        </div>

        <table class="data-table">

            <thead>

                <tr>

                    <th>Batch</th>

                    <th>MFG</th>

                    <th>EXP</th>

                    <th>Imported</th>

                    <th>Sold</th>

                    <th>Stock Left</th>

                    <th>Status</th>

                </tr>

            </thead>

            <tbody>

                @foreach (var batch in Model.Batches)
                {
                    <tr>

                        <td>@batch.BatchCode</td>

                        <td>@batch.ManufacturingDate?.ToString("dd/MM/yyyy")</td>

                        <td>@batch.ExpiryDate?.ToString("dd/MM/yyyy")</td>

                        <td>@batch.Quantity</td>

                        <td>@batch.QuantitySold</td>

                        <td>@batch.StockLeft</td>

                        <td>

                            @{
                                var css = batch.BatchStatus switch
                                {
                                    BatchStatus.Active => "badge-active",
                                    BatchStatus.Expired => "badge-danger",
                                    BatchStatus.Quarantine => "badge-warning",
                                    BatchStatus.Exhausted => "badge-secondary",
                                    _ => "badge-secondary"
                                };
                            }

                            <span class="badge-status @css">

                                @batch.BatchStatus

                            </span>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>


    <div class="table-card">

        <div class="table-header">

            <h3>

                <i class="bi bi-clock-history"></i>

                Inventory Transactions

            </h3>

        </div>

        <table class="data-table">

            <thead>

                <tr>

                    <th>Date</th>

                    <th>Type</th>

                    <th>Change</th>

                    <th>Before</th>

                    <th>After</th>

                    <th>Reference</th>

                    <th>Note</th>

                </tr>

            </thead>


            @* Transaction *@
            <tbody>

                @foreach (var t in Model.Transactions)
                {

                    <tr>

                        <td>@t.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>

                        <td>@t.TransactionType</td>

                        <td>@t.QuantityChange</td>

                        <td>@t.QuantityBefore</td>

                        <td>@t.QuantityAfter</td>

                        <td>@t.TransactionType</td>

                        <td>@t.Note</td>

                    </tr>

                }

            </tbody>

        </table>

    </div>

</div>