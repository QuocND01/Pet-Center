@using PetCenterClient.ViewModels.Inventory
@model InventoryListResponseViewModel

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    var categories = ViewBag.CategoryList as IEnumerable<SelectListItem>;
    var brands = ViewBag.BrandList as IEnumerable<SelectListItem>;

    string keyword = ViewBag.Keyword ?? "";
    Guid? categoryId = ViewBag.CategoryId;
    Guid? brandId = ViewBag.BrandId;
    bool? lowStock = ViewBag.LowStock;
    bool? outOfStock = ViewBag.OutOfStock;
}

<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=Space+Grotesk:wght@400;500;600&display=swap" rel="stylesheet" />
<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

<link rel="stylesheet"
      href="~/css/AdminViews/ManageInventory/inventory_index.css"
      asp-append-version="true" />

<div class="page-wrapper">

    <div class="page-header">

        <div class="page-title-group">
            <h1>Inventory Management</h1>
            <p>Manage warehouse inventory and stock availability.</p>
        </div>

    </div>


    <form asp-action="Index" method="get">

        <div class="filter-card">

            <div class="filter-grid">

                <div class="filter-item">

                    <label>Keyword</label>

                    <input type="text"
                           class="form-control"
                           name="keyword"
                           value="@keyword"
                           placeholder="Search product..." />

                </div>

                <div class="filter-item">

                    <label>Category</label>

                    <select name="categoryId"
                            class="form-select">

                        <option value="">All Categories</option>

                        @foreach (var c in categories ?? Enumerable.Empty<SelectListItem>())
                        {
                            <option value="@c.Value"
                                    selected="@(categoryId?.ToString() == c.Value)">
                                @c.Text
                            </option>
                        }

                    </select>

                </div>


                <div class="filter-item">

                    <label>Brand</label>

                    <select name="brandId"
                            class="form-select">

                        <option value="">All Brands</option>

                        @foreach (var b in brands ?? Enumerable.Empty<SelectListItem>())
                        {
                            <option value="@b.Value"
                                    selected="@(brandId?.ToString() == b.Value)">
                                @b.Text
                            </option>
                        }

                    </select>

                </div>


                <div class="filter-item">

                    <label>Stock Status</label>

                    <select name="status"
                            class="form-select">

                        <option value="">All</option>

                        <option value="low"
                                selected="@(lowStock == true)">
                            Low Stock
                        </option>

                        <option value="out"
                                selected="@(outOfStock == true)">
                            Out Of Stock
                        </option>

                    </select>

                </div>

            </div>


            <div class="filter-actions">

                <button class="btn-search"
                        type="submit">

                    <i class="bi bi-search"></i>

                    Search

                </button>

                <a asp-action="Index"
                   class="btn-reset">

                    <i class="bi bi-arrow-clockwise"></i>

                    Reset

                </a>

            </div>

        </div>

    </form>



    <div class="table-card">

        <div class="table-header">

            <h3>

                <i class="bi bi-box-seam"></i>

                Inventory

            </h3>

        </div>

        <table class="data-table">

            <thead>

                <tr>

                    <th>Product</th>

                    <th>SKU</th>

                    <th>Available</th>

                    <th>Reserved</th>

                    <th>Damaged</th>

                    <th>Updated</th>

                    <th></th>

                </tr>

            </thead>

            <tbody>

                @foreach (var item in Model.Items)
                {

                    <tr>

                        <td>

                            <div class="product-info">

                                <img src="@item.ProductImage"
                                     class="product-image" />

                                <div>

                                    <div class="product-name">

                                        @item.ProductName

                                    </div>

                                    <div class="product-meta">

                                        <span>@item.Brand</span>

                                        <span>@item.Category</span>

                                    </div>

                                </div>

                            </div>

                        </td>

                        <td>

                            @item.SKU

                        </td>

                        <td>

                            <span class="stock-badge available">

                                @item.QuantityAvailable

                            </span>

                        </td>

                        <td>

                            <span class="stock-badge reserved">

                                @item.QuantityReserved

                            </span>

                        </td>

                        <td>

                            <span class="stock-badge damaged">

                                @item.QuantityDamaged

                            </span>

                        </td>

                        <td>

                            @item.LastUpdated.ToString("dd/MM/yyyy HH:mm")

                        </td>

                        <td>

                            <a asp-action="Details"
                               asp-route-id="@item.InventoryId"
                               class="btn-view">

                                <i class="bi bi-eye"></i>

                                View

                            </a>

                        </td>

                    </tr>

                }

            </tbody>

        </table>

        <div class="table-pagination">

            <div class="pagination-info">

                Showing

                @(((Model.Page - 1) * Model.PageSize) + 1)

                -

                @(Math.Min(Model.Page * Model.PageSize, Model.TotalRecords))

                of

                @Model.TotalRecords

            </div>

            <div class="pagination-controls">

                <a class="page-btn"
                   asp-route-page="@(Model.Page - 1)"
                   asp-route-pageSize="@Model.PageSize">

                    <i class="bi bi-chevron-left"></i>

                </a>

                <span id="pageInfo">

                    @Model.Page / @Model.TotalPages

                </span>

                <a class="page-btn"
                   asp-route-page="@(Model.Page + 1)"
                   asp-route-pageSize="@Model.PageSize">

                    <i class="bi bi-chevron-right"></i>

                </a>

            </div>

        </div>

    </div>

</div>