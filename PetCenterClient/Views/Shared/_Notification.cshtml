

@if (TempData["Success"] != null)
{
    <script>
        toastr.success('@Html.Raw(TempData["Success"])');
    </script>
}

@if (TempData["Error"] != null)
{
    <script>
        toastr.error('@Html.Raw(TempData["Error"])');
    </script>
}

@if (TempData["Warning"] != null)
{
    <script>
        toastr.warning('@Html.Raw(TempData["Warning"])');
    </script>
}

@if (TempData["Info"] != null)
{
    <script>
        toastr.info('@Html.Raw(TempData["Info"])');
    </script>
}
@* ==HTML==

@await Html.PartialAsync("_Notification")


