<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PetCenter</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <style>
        :root {
            --green: #22c55e;
            --green-dark: #16a34a;
            --border: #e5e7eb;
            --bg: #f8fafc;
            --text: #1e293b;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            background: var(--bg);
            font-family: "Segoe UI", sans-serif;
        }

        /* ===============================
                   GLOBAL HEADER
                ===============================*/

        .top-header {
            position: sticky;
            top: 0;
            z-index: 1000;
            background: white;
            border-bottom: 1px solid var(--border);
            height: 70px;
        }

        .top-header-inner {
            max-width: 1400px;
            margin: auto;
            height: 70px;
            padding: 0 24px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .logo {
            text-decoration: none;
            color: var(--green-dark);
            font-size: 28px;
            font-weight: 800;
        }

        .main-nav {
            display: flex;
            gap: 12px;
        }

            .main-nav a {
                text-decoration: none;
                color: #475569;
                padding: 10px 18px;
                border-radius: 999px;
                font-weight: 700;
                transition: .2s;
            }

                .main-nav a:hover {
                    background: #dcfce7;
                    color: var(--green-dark);
                }

        .auth-nav {
            display: flex;
            gap: 10px;
        }

        .auth-btn {
            text-decoration: none;
            padding: 10px 18px;
            border-radius: 999px;
            font-weight: 700;
        }

        .login-btn {
            border: 1px solid #cbd5e1;
            color: #334155;
            background: white;
        }

        .logout-btn {
            background: var(--green);
            color: white;
        }

        /* ===============================
                   PAGE MENU
                ===============================*/

        .module-nav {
            background: white;
            border-bottom: 1px solid var(--border);
        }

        .module-nav-inner {
            max-width: 1400px;
            margin: auto;
            padding: 12px 24px;
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }

            .module-nav-inner a {
                text-decoration: none;
                padding: 8px 16px;
                border-radius: 999px;
                background: #f1f5f9;
                color: #334155;
                font-weight: 600;
            }

                .module-nav-inner a:hover {
                    background: #dcfce7;
                    color: var(--green-dark);
                }

        /* ===============================
                   CONTENT
                ===============================*/
        .page-content {
            width: 100%;
            max-width: 1600px;
            margin: 0 auto;
        }

        /* =========================
           FOOTER
        ========================= */

        .footer {
            background: #0f172a;
            color: #cbd5e1;
            padding: 80px 0 30px;
            margin-top: 100px;
        }

        .footer-container {
            max-width: 1400px;
            margin: auto;
            padding: 0 40px;
            display: grid;
            grid-template-columns: 2fr 1fr 1fr 1.2fr;
            gap: 50px;
        }

        .footer-section h3 {
            color: white;
            font-size: 2rem;
            font-weight: 800;
            margin-bottom: 20px;
        }

        .footer-section h4 {
            color: white;
            font-size: 1.15rem;
            font-weight: 700;
            margin-bottom: 20px;
        }

        .footer-section p {
            line-height: 1.8;
            margin-bottom: 10px;
            color: #94a3b8;
        }

        .footer-section ul {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .footer-section li {
            margin-bottom: 12px;
            color: #94a3b8;
        }

        .footer-section a {
            text-decoration: none;
            color: #94a3b8;
            transition: .3s;
        }

            .footer-section a:hover {
                color: #22c55e;
                padding-left: 4px;
            }

        .footer-bottom {
            margin-top: 60px;
            padding-top: 25px;
            border-top: 1px solid rgba(255,255,255,.08);
            text-align: center;
        }

            .footer-bottom p {
                margin: 0;
                color: #64748b;
                font-size: .95rem;
            }

        .admin-btn {
            background: #0f172a;
            color: white;
        }

            .admin-btn:hover {
                background: #1e293b;
                color: white;
            }

        .user-name {
            display: flex;
            align-items: center;
            font-weight: 700;
            color: #334155;
            margin-right: 10px;
        }
    </style>
</head>
<body>

    <!-- HEADER -->
    <header class="top-header">
        <div class="top-header-inner">

            <a asp-controller="Home"
               asp-action="Index"
               class="logo">
                🐾 PetCenter
            </a>

            <nav class="main-nav">

                <a asp-controller="Home"
                   asp-action="Index">
                    Home Page
                </a>

                <a asp-controller="Products"
                   asp-action="Index">
                    Product Page
                </a>

                <a asp-controller="Services"
                   asp-action="Index">
                    Service Page
                </a>

            </nav>

            <div class="auth-nav">

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <span class="user-name">
                        👋 @User.Identity.Name
                    </span>
                    <a asp-controller="Auth"
                       asp-action="Logout"
                       class="auth-btn logout-btn">
                        Logout
                    </a>
                }
                else
                {
                    <a asp-controller="Auth"
                       asp-action="Login"
                       class="auth-btn login-btn">
                        Login
                    </a>

                    <!-- tạm thời để login admin -->
                    <a asp-controller="Auth" asp-action="AdminLogin" class="pc-admin-link" id="adminBtn" title="Admin Panel">
                        ⚙ Admin
                    </a>
                }

            </div>

        </div>
    </header>

    <!-- PAGE SPECIFIC MENU -->
    @RenderSection("ModuleNav", required: false)

    <!-- CONTENT -->
    <main class="page-content">
        @RenderBody()
    </main>

    <!-- FOOTER -->
    <footer class="footer">
        <div class="footer-container">

            <div class="footer-section">
                <h3>🐾 PetCenter</h3>
                <p>One Platform For Every Pet Care Need</p>
                <p>
                    Connecting pet owners with trusted veterinary care,
                    grooming, boarding, and AI-powered health assistance.
                </p>
            </div>

            <div class="footer-section">
                <h4>Services</h4>
                <ul>
                    <li>Veterinary Appointments</li>
                    <li>Pet Grooming</li>
                    <li>Vaccination</li>
                    <li>Pet Boarding</li>
                    <li>AI Disease Identification</li>
                </ul>
            </div>

            <div class="footer-section">
                <h4>Quick Links</h4>
                <ul>
                    <li><a href="#">Home</a></li>
                    <li><a href="#">Services</a></li>
                    <li><a href="#">Appointments</a></li>
                    <li><a href="#">About Us</a></li>
                    <li><a href="#">Contact</a></li>
                </ul>
            </div>

            <div class="footer-section">
                <h4>Contact Us</h4>
                <p>📍 Can Tho, Vietnam</p>
                <p>📞 +84 123 456 789</p>
                <p>✉ support@petcenter.com</p>
                <p>🕒 Mon - Sun: 8:00 AM - 8:00 PM</p>
            </div>

        </div>

        <div class="footer-bottom">
            <p>© 2026 PetCenter. All Rights Reserved.</p>
        </div>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
