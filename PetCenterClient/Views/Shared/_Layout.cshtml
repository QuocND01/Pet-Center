<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PetCenter</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    @* _Notification *@
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        :root {
            --green: #22c55e;
            --green-dark: #16a34a;
            --border: #e5e7eb;
            --bg: #f8fafc;
            --text: #1e293b;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            background: var(--bg);
            font-family: "Segoe UI", sans-serif;
        }

        /* ===============================
                   GLOBAL HEADER
                ===============================*/

        .top-header {
            position: sticky;
            top: 0;
            z-index: 1000;
            background: #fff;
            border-bottom: 1px solid var(--border);
        }

        .top-header-inner {
            max-width: 1400px;
            margin: auto;
            height: 70px;
            padding: 0 24px;
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .logo {
            text-decoration: none;
            color: var(--green-dark);
            font-size: 26px;
            font-weight: 800;
            white-space: nowrap;
        }

        /* primary navigation */
        .main-nav {
            display: flex;
            gap: 8px;
        }

            .main-nav a {
                text-decoration: none;
                color: #475569;
                padding: 9px 18px;
                border-radius: 999px;
                font-weight: 700;
                transition: .2s;
            }

                .main-nav a:hover {
                    background: #dcfce7;
                    color: var(--green-dark);
                }

        .auth-nav {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-left: auto;
        }

        .auth-btn {
            text-decoration: none;
            padding: 9px 18px;
            border-radius: 999px;
            font-weight: 700;
            transition: .2s;
        }

        .login-btn {
            border: 1px solid #cbd5e1;
            color: #334155;
            background: #fff;
        }

            .login-btn:hover {
                background: #f1f5f9;
            }

        .logout-btn {
            background: var(--green);
            color: #fff;
        }

        /* hamburger (mobile only) */
        .nav-toggle {
            display: none;
            align-items: center;
            justify-content: center;
            width: 42px;
            height: 42px;
            font-size: 20px;
            border: 1px solid var(--border);
            background: #fff;
            border-radius: 10px;
            color: #334155;
            cursor: pointer;
        }

        /* user dropdown */
        .user-menu {
            position: relative;
        }

        .user-trigger {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 6px 12px 6px 6px;
            border: 1px solid var(--border);
            background: #fff;
            border-radius: 999px;
            cursor: pointer;
            transition: .2s;
        }

            .user-trigger:hover {
                background: #f1f5f9;
            }

        .user-avatar {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--green), var(--green-dark));
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 800;
            flex-shrink: 0;
        }

        .user-trigger .name {
            font-weight: 700;
            color: #334155;
            max-width: 150px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .user-trigger .caret {
            color: #94a3b8;
            font-size: 12px;
        }

        .user-dropdown {
            position: absolute;
            right: 0;
            top: calc(100% + 10px);
            min-width: 230px;
            background: #fff;
            border: 1px solid var(--border);
            border-radius: 14px;
            box-shadow: 0 14px 40px rgba(0,0,0,.14);
            padding: 8px;
            opacity: 0;
            visibility: hidden;
            transform: translateY(-8px);
            transition: opacity .18s ease, transform .18s ease, visibility .18s;
        }

        .user-menu.open .user-dropdown {
            opacity: 1;
            visibility: visible;
            transform: translateY(0);
        }

        .user-dropdown a {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 11px 12px;
            border-radius: 10px;
            text-decoration: none;
            color: #334155;
            font-weight: 600;
            font-size: 14px;
        }

            .user-dropdown a:hover {
                background: #dcfce7;
                color: var(--green-dark);
            }

        .user-dropdown .ic {
            font-size: 16px;
            width: 20px;
            text-align: center;
        }

        /* cart count badge inside the Cart dropdown item */
        .cart-badge {
            margin-left: auto;
            background: var(--green);
            color: #fff;
            font-size: 11px;
            font-weight: 800;
            min-width: 20px;
            height: 20px;
            padding: 0 6px;
            border-radius: 999px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            line-height: 1;
        }

        .dropdown-divider {
            height: 1px;
            background: var(--border);
            margin: 6px;
        }

        .logout-item {
            color: #dc2626 !important;
        }

            .logout-item:hover {
                background: #fee2e2 !important;
                color: #dc2626 !important;
            }

        @@media (max-width: 768px) {
            .nav-toggle {
                display: inline-flex;
            }

            .main-nav {
                position: absolute;
                top: 70px;
                left: 0;
                right: 0;
                flex-direction: column;
                background: #fff;
                border-bottom: 1px solid var(--border);
                padding: 12px 16px;
                gap: 6px;
                display: none;
                box-shadow: 0 10px 28px rgba(0,0,0,.08);
            }

                .main-nav.open {
                    display: flex;
                }

            .user-trigger .name {
                display: none;
            }

            .logo {
                font-size: 22px;
            }
        }

        /* ===============================
                   PAGE MENU
                ===============================*/

        .module-nav {
            background: white;
            border-bottom: 1px solid var(--border);
        }

        .module-nav-inner {
            max-width: 1400px;
            margin: auto;
            padding: 12px 24px;
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }

            .module-nav-inner a {
                text-decoration: none;
                padding: 8px 16px;
                border-radius: 999px;
                background: #f1f5f9;
                color: #334155;
                font-weight: 600;
            }

                .module-nav-inner a:hover {
                    background: #dcfce7;
                    color: var(--green-dark);
                }

        /* ===============================
                   CONTENT
                ===============================*/
        .page-content {
            width: 100%;
            max-width: 1600px;
            margin: 0 auto;
        }

        /* =========================
           FOOTER
        ========================= */

        .footer {
            background: #0f172a;
            color: #cbd5e1;
            padding: 80px 0 30px;
            margin-top: 100px;
        }

        .footer-container {
            max-width: 1400px;
            margin: auto;
            padding: 0 40px;
            display: grid;
            grid-template-columns: 2fr 1fr 1fr 1.2fr;
            gap: 50px;
        }

        .footer-section h3 {
            color: white;
            font-size: 2rem;
            font-weight: 800;
            margin-bottom: 20px;
        }

        .footer-section h4 {
            color: white;
            font-size: 1.15rem;
            font-weight: 700;
            margin-bottom: 20px;
        }

        .footer-section p {
            line-height: 1.8;
            margin-bottom: 10px;
            color: #94a3b8;
        }

        .footer-section ul {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .footer-section li {
            margin-bottom: 12px;
            color: #94a3b8;
        }

        .footer-section a {
            text-decoration: none;
            color: #94a3b8;
            transition: .3s;
        }

            .footer-section a:hover {
                color: #22c55e;
                padding-left: 4px;
            }

        .footer-bottom {
            margin-top: 60px;
            padding-top: 25px;
            border-top: 1px solid rgba(255,255,255,.08);
            text-align: center;
        }

            .footer-bottom p {
                margin: 0;
                color: #64748b;
                font-size: .95rem;
            }

        .admin-btn {
            background: #0f172a;
            color: white;
        }

            .admin-btn:hover {
                background: #1e293b;
                color: white;
            }

        .user-name {
            display: flex;
            align-items: center;
            font-weight: 700;
            color: #334155;
            margin-right: 10px;
        }
    </style>
</head>
<body>

    <!-- HEADER -->
    <header class="top-header">
        <div class="top-header-inner">

            @{
                // Login state is tracked via Session (the client has no auth middleware,
                // so User.Identity is never authenticated). Customers are not linked to roles.
                var custToken = Context.Session.GetString("JWT");
                var custName = Context.Session.GetString("FullName")
                               ?? Context.Session.GetString("Name");
                var custInitial = string.IsNullOrWhiteSpace(custName)
                    ? "U" : custName.Trim()[0].ToString().ToUpper();
            }

            <a asp-controller="Home" asp-action="Index" class="logo">🐾 PetCenter</a>

            <button class="nav-toggle" id="navToggle" type="button" aria-label="Toggle menu">☰</button>

            <nav class="main-nav" id="mainNav">
                <a asp-controller="Home" asp-action="Index">Home</a>
                <a asp-controller="Products" asp-action="Index">Products</a>
                <a asp-controller="Service" asp-action="Index">Services</a>
            </nav>

            <div class="auth-nav">
                @if (!string.IsNullOrEmpty(custToken))
                {
                    <div class="user-menu" id="userMenu">
                        <button class="user-trigger" id="userTrigger" type="button">
                            <span class="user-avatar">@custInitial</span>
                            <span class="name">@custName</span>
                            <span class="caret">▾</span>
                        </button>
                        <div class="user-dropdown">
                            <a asp-controller="Customer" asp-action="Profile">
                                <i class="bi bi-person-circle me-2"></i> Profile
                            </a>

                            <a asp-controller="Pets" asp-action="Index">
                                <i class="bi bi-heart me-2"></i> My Pets
                            </a>

                            <a asp-controller="Appointment" asp-action="MyAppointments">
                                <i class="bi bi-calendar2-check me-2"></i> My Appointments
                            </a>

                            <a asp-controller="Orders" asp-action="History">
                                <i class="bi bi-box-seam me-2"></i> My Orders
                            </a>

                            <a asp-controller="MedicalRecord" asp-action="CustomerIndex">
                                <i class="bi bi-file-medical me-2"></i> Medical Records
                            </a>

                            <a asp-controller="Cart" asp-action="Index">
                                <i class="bi bi-cart3 me-2"></i>
                                Cart
                                <span class="cart-badge" id="cartBadge" style="display:none">0</span>
                            </a>

                            <a asp-controller="Addresses" asp-action="Index">
                                <i class="bi bi-geo-alt me-2"></i> Address
                            </a>

                            <div class="dropdown-divider"></div>

                            <a asp-controller="Auth" asp-action="Logout" class="logout-item">
                                <i class="bi bi-box-arrow-right me-2"></i> Logout
                            </a>
                        </div>
                    </div>
                }
                else
                {
                    <a asp-controller="Auth" asp-action="Login" class="auth-btn login-btn">Login</a>
                    <a asp-controller="Auth" asp-action="AdminLogin" class="auth-btn admin-btn" id="adminBtn" title="Admin Panel">⚙ Admin</a>
                }
            </div>

        </div>
    </header>

    <!-- PAGE SPECIFIC MENU -->
    @RenderSection("ModuleNav", required: false)

    <!-- CONTENT -->
    <main class="page-content">
        @RenderBody()
    </main>

    <!-- FOOTER -->
    <footer class="footer">
        <div class="footer-container">

            <div class="footer-section">
                <h3>🐾 PetCenter</h3>
                <p>One Platform For Every Pet Care Need</p>
                <p>
                    Connecting pet owners with trusted veterinary care,
                    grooming, boarding, and AI-powered health assistance.
                </p>
            </div>

            <div class="footer-section">
                <h4>Services</h4>
                <ul>
                    <li>Veterinary Appointments</li>
                    <li>Pet Grooming</li>
                    <li>Vaccination</li>
                    <li>Pet Boarding</li>
                    <li>AI Disease Identification</li>
                </ul>
            </div>

            <div class="footer-section">
                <h4>Quick Links</h4>
                <ul>
                    <li><a href="#">Home</a></li>
                    <li><a href="#">Services</a></li>
                    <li><a href="#">Appointments</a></li>
                    <li><a href="#">About Us</a></li>
                    <li><a href="#">Contact</a></li>
                </ul>
            </div>

            <div class="footer-section">
                <h4>Contact Us</h4>
                <p>📍 Can Tho, Vietnam</p>
                <p>📞 +84 123 456 789</p>
                <p>✉ support@petcenter.com</p>
                <p>🕒 Mon - Sun: 8:00 AM - 8:00 PM</p>
            </div>

        </div>

        <div class="footer-bottom">
            <p>© 2026 PetCenter. All Rights Reserved.</p>
        </div>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // Header: user dropdown + mobile nav toggle (vanilla, no dependency)
        (function () {
            var menu = document.getElementById('userMenu');
            var trigger = document.getElementById('userTrigger');
            if (menu && trigger) {
                trigger.addEventListener('click', function (e) {
                    e.stopPropagation();
                    menu.classList.toggle('open');
                });
                var dd = menu.querySelector('.user-dropdown');
                if (dd) dd.addEventListener('click', function (e) { e.stopPropagation(); });
                document.addEventListener('click', function () { menu.classList.remove('open'); });
            }

            var navToggle = document.getElementById('navToggle');
            var mainNav = document.getElementById('mainNav');
            if (navToggle && mainNav) {
                navToggle.addEventListener('click', function (e) {
                    e.stopPropagation();
                    mainNav.classList.toggle('open');
                });
            }

            // cart count badge — exposed globally so add-to-cart / remove can refresh it live
            window.refreshCartBadge = function () {
                var badge = document.getElementById('cartBadge');
                if (!badge) return;
                fetch('/Cart/Count')
                    .then(function (r) { return r.json(); })
                    .then(function (d) {
                        var n = (d && d.count) ? d.count : 0;
                        if (n > 0) { badge.textContent = n; badge.style.display = 'inline-flex'; }
                        else { badge.style.display = 'none'; }
                    })
                    .catch(function () { });
            };
            if (menu) window.refreshCartBadge();
        })();
    </script>

    <script src="~/js/order-feedback.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

    @* ── PetCenter Chatbot Widget ────────────────────────────────────────── *@
    <script>
        window.__RASA_URL    = 'http://localhost:5005';
        window.__API_URL     = 'https://localhost:7004';
        window.__JWT         = '@(custToken ?? "")';
        window.__CUSTOMER_ID = '@(Context.Session.GetString("CustomerId") ?? "")';
    </script>
    <script src="~/js/chatbot.js" asp-append-version="true"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script src="~/js/signalr-client.js"></script>

    <script>
        // Lấy Token từ Session Razor và truyền vào JS
        var userToken = '@Context.Session.GetString("JWT")';
        if (userToken) {
        startSignalR(userToken);
        }
    </script>
    @* ── KHU VỰC NÚT STAFF CHAT (ĐỘC LẬP & NẰM BÊN TRÁI) ── *@
    @if (Context.Session.GetString("Role") == "Customer")
    {
        <style>
            /* 1. Nút chat Nhân viên (Nằm góc trái) */
            .staff-chat-btn {
            position: fixed;
            bottom: 30px; /* Trả về 30px vì giờ đã ở bên trái, không vướng Rasa */
            left: 30px; /* Chuyển sang góc trái */
            width: 60px;
            height: 60px;
            background-color: #2ecc71;
            color: white;
            border: none;
            border-radius: 50%;
            box-shadow: 0 4px 15px rgba(46,204,113,0.4);
            z-index: 9999;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: 0.3s;
            }

            .staff-chat-btn:hover {
            transform: scale(1.1);
            }

            /* 2. Khung popup Live Chat với Nhân viên */
            .staff-chat-popup {
            position: fixed;
            bottom: 100px;
            left: 30px; /* Chuyển popup sang góc trái theo nút */
            width: 360px;
            z-index: 9999;
            background: white;
            border-radius: 15px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.2);
            display: none;
            flex-direction: column;
            overflow: hidden;
            transform: translateY(20px);
            opacity: 0;
            transition: all 0.3s ease;
            }

            .staff-chat-popup.show {
            display: flex;
            transform: translateY(0);
            opacity: 1;
            }
        </style>

        <!-- Nút Trực Tiếp Mở Chat Nhân Viên (Sử dụng SVG trực tiếp để đảm bảo luôn hiện icon) -->
        <button id="staffChatBtn" class="staff-chat-btn" onclick="toggleStaffChatPopup()">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor" viewBox="0 0 16 16">
                <path d="M16 8c0 3.866-3.582 7-8 7a9.06 9.06 0 0 1-2.347-.306c-2.016.289-4.004.81-4.004.81s-.474-.294-.474-.81c0-.521.144-1.46.36-2.285C.566 11.233 0 9.68 0 8c0-3.866 3.582-7 8-7s8 3.134 8 7zM5 8a1 1 0 1 0-2 0 1 1 0 0 0 2 0zm4 0a1 1 0 1 0-2 0 1 1 0 0 0 2 0zm3 1a1 1 0 1 0 0-2 1 1 0 0 0 0 2z" />
            </svg>
        </button>

        <!-- Khung chat với Nhân viên -->
        <div id="staffChatPopup" class="staff-chat-popup">
            <div class="bg-success text-white py-3 px-3 d-flex justify-content-between align-items-center">
                <h6 class="m-0 fw-bold">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="me-2" viewBox="0 0 16 16">
                        <path d="M8 1a5 5 0 0 0-5 5v1h1a1 1 0 0 1 1 1v3a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V6a6 6 0 1 1 12 0v6a2.5 2.5 0 0 1-2.5 2.5H9.366a1 1 0 0 1-.866.5h-1a1 1 0 1 1 0-2h1a1 1 0 0 1 .866.5H11.5A1.5 1.5 0 0 0 13 12h-1a1 1 0 0 1-1-1V8a1 1 0 0 1 1-1h1V6a5 5 0 0 0-5-5z" />
                    </svg>
                    PetCenter Support
                </h6>
                <button class="btn-close btn-close-white" onclick="toggleStaffChatPopup()"></button>
            </div>

            <div class="bg-light p-3" id="staffChatBox" style="height: 380px; overflow-y: auto;">
                <div class="text-center text-muted mt-5" id="staffChatIntro">
                    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" fill="currentColor" class="mb-2" viewBox="0 0 16 16">
                        <path d="M8 15c4.418 0 8-3.134 8-7s-3.582-7-8-7-8 3.134-8 7c0 1.76.743 3.37 1.97 4.6-.097 1.016-.417 2.13-.771 2.966-.079.186.074.394.273.362 2.256-.37 3.597-.938 4.18-1.234A9.06 9.06 0 0 0 8 15z" />
                    </svg>
                    <p class="small mt-2">Gửi tin nhắn và nhân viên của chúng tôi sẽ hỗ trợ bạn ngay lập tức.</p>
                </div>
            </div>

            <div class="bg-white border-top p-2">
                <div class="input-group">
                    <input type="text" id="staffTxtMsg" class="form-control rounded-pill bg-light border-0 px-3" placeholder="Nhập tin nhắn..." onkeypress="handleStaffEnter(event)">
                    <button class="btn btn-success rounded-pill ms-2 px-3" onclick="sendStaffMsg()">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M15.964.686a.5.5 0 0 0-.65-.65L.767 5.855H.766l-.452.18a.5.5 0 0 0-.082.887l.41.26.001.002 4.995 3.178 3.178 4.995.002.002.26.41a.5.5 0 0 0 .886-.083l6-15Zm-1.833 1.89L6.637 10.07l-.215-.338a.5.5 0 0 0-.154-.154l-.338-.215 7.494-7.494 1.178-.471-.47 1.178Z" />
                        </svg>
                    </button>
                </div>
            </div>
        </div>

        <script>
            let isStaffHistoryLoaded = false;
            let staffConn = null;

            function toggleStaffChatPopup() {
            const popup = document.getElementById("staffChatPopup");

            if (popup.classList.contains("show")) {
            popup.classList.remove("show");
            setTimeout(() => popup.style.display = "none", 300);
            } else {
            popup.style.display = "flex";
            setTimeout(() => popup.classList.add("show"), 10);

            if (!isStaffHistoryLoaded) {
            initStaffChatSignalR();
            loadStaffHistory();
            isStaffHistoryLoaded = true;
            }
            }
            }

            function initStaffChatSignalR() {
            staffConn = new signalR.HubConnectionBuilder()
            .withUrl(window.__API_URL + "/appHub", { accessTokenFactory: () => window.__JWT })
            .withAutomaticReconnect()
            .build();

            staffConn.on("ReceiveMessage", (senderId, msg, time) => appendStaffMessage(senderId, msg, time));
            staffConn.on("ReceiveSystemMessage", (msg) => {
            document.getElementById("staffChatBox").innerHTML += `<div class="text-center text-warning small my-2 fw-bold">${msg}</div>`;
            });

            staffConn.start().catch(err => console.error("SignalR Chat Error:", err));
            }

            function loadStaffHistory() {
            fetch(window.__API_URL + "/api/chat/my-history", {
            headers: { 'Authorization': 'Bearer ' + window.__JWT }
            })
            .then(r => r.json())
            .then(msgs => {
            if(msgs.length > 0) document.getElementById("staffChatIntro").style.display = "none";
            msgs.forEach(m => appendStaffMessage(m.senderId, m.content, m.createdAt));
            })
            .catch(err => console.error("Lỗi load lịch sử:", err));
            }

            function appendStaffMessage(senderId, message, timestampString = null) {
            const chatBox = document.getElementById("staffChatBox");
            document.getElementById("staffChatIntro").style.display = "none";

            const isMe = String(senderId).toLowerCase() === String(window.__CUSTOMER_ID).toLowerCase();
            const dateObj = timestampString ? new Date(timestampString) : new Date();
            const timeText = dateObj.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });

            const borderRadius = isMe ? "15px 15px 4px 15px" : "15px 15px 15px 4px";
            const bgColor = isMe ? "linear-gradient(135deg, #2ecc71, #27ae60)" : "#ffffff";
            const textColor = isMe ? "#ffffff" : "#333333";
            const shadow = isMe ? "0 4px 10px rgba(46, 204, 113, 0.2)" : "0 2px 8px rgba(0,0,0,0.08)";

            chatBox.innerHTML += `
            <div class="d-flex ${isMe ? 'justify-content-end' : 'justify-content-start'} mb-3">
            <div style="max-width: 85%;">
            <div class="p-2 px-3" style="background: ${bgColor}; color: ${textColor}; border-radius: ${borderRadius}; box-shadow: ${shadow}; display: inline-block;">
            <span style="font-size: 13.5px; line-height: 1.4;">${message}</span>
            </div>
            <div class="text-muted mt-1 ${isMe ? 'text-end' : 'text-start'}" style="font-size: 10px;">${timeText}</div>
            </div>
            </div>`;
            chatBox.scrollTop = chatBox.scrollHeight;
            }

            function sendStaffMsg() {
            const input = document.getElementById("staffTxtMsg");
            if (!input.value.trim() || !staffConn) return;

            staffConn.invoke("SendMessageToSupport", input.value.trim());
            input.value = '';
            }

            function handleStaffEnter(e) { if (e.key === 'Enter') sendStaffMsg(); }
        </script>
    }
</body>
</html>