<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PetCenter</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    @* _Notification *@
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <style>
        :root {
            --green: #22c55e;
            --green-dark: #16a34a;
            --border: #e5e7eb;
            --bg: #f8fafc;
            --text: #1e293b;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            background: var(--bg);
            font-family: "Segoe UI", sans-serif;
        }

        /* ===============================
                   GLOBAL HEADER
                ===============================*/

        .top-header {
            position: sticky;
            top: 0;
            z-index: 1000;
            background: #fff;
            border-bottom: 1px solid var(--border);
        }

        .top-header-inner {
            max-width: 1400px;
            margin: auto;
            height: 70px;
            padding: 0 24px;
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .logo {
            text-decoration: none;
            color: var(--green-dark);
            font-size: 26px;
            font-weight: 800;
            white-space: nowrap;
        }

        /* primary navigation */
        .main-nav {
            display: flex;
            gap: 8px;
        }

            .main-nav a {
                text-decoration: none;
                color: #475569;
                padding: 9px 18px;
                border-radius: 999px;
                font-weight: 700;
                transition: .2s;
            }

                .main-nav a:hover {
                    background: #dcfce7;
                    color: var(--green-dark);
                }

        .auth-nav {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-left: auto;
        }

        .auth-btn {
            text-decoration: none;
            padding: 9px 18px;
            border-radius: 999px;
            font-weight: 700;
            transition: .2s;
        }

        .login-btn {
            border: 1px solid #cbd5e1;
            color: #334155;
            background: #fff;
        }

            .login-btn:hover {
                background: #f1f5f9;
            }

        .logout-btn {
            background: var(--green);
            color: #fff;
        }

        /* hamburger (mobile only) */
        .nav-toggle {
            display: none;
            align-items: center;
            justify-content: center;
            width: 42px;
            height: 42px;
            font-size: 20px;
            border: 1px solid var(--border);
            background: #fff;
            border-radius: 10px;
            color: #334155;
            cursor: pointer;
        }

        /* user dropdown */
        .user-menu {
            position: relative;
        }

        .user-trigger {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 6px 12px 6px 6px;
            border: 1px solid var(--border);
            background: #fff;
            border-radius: 999px;
            cursor: pointer;
            transition: .2s;
        }

            .user-trigger:hover {
                background: #f1f5f9;
            }

        .user-avatar {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--green), var(--green-dark));
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 800;
            flex-shrink: 0;
        }

        .user-trigger .name {
            font-weight: 700;
            color: #334155;
            max-width: 150px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .user-trigger .caret {
            color: #94a3b8;
            font-size: 12px;
        }

        .user-dropdown {
            position: absolute;
            right: 0;
            top: calc(100% + 10px);
            min-width: 230px;
            background: #fff;
            border: 1px solid var(--border);
            border-radius: 14px;
            box-shadow: 0 14px 40px rgba(0,0,0,.14);
            padding: 8px;
            opacity: 0;
            visibility: hidden;
            transform: translateY(-8px);
            transition: opacity .18s ease, transform .18s ease, visibility .18s;
        }

        .user-menu.open .user-dropdown {
            opacity: 1;
            visibility: visible;
            transform: translateY(0);
        }

        .user-dropdown a {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 11px 12px;
            border-radius: 10px;
            text-decoration: none;
            color: #334155;
            font-weight: 600;
            font-size: 14px;
        }

            .user-dropdown a:hover {
                background: #dcfce7;
                color: var(--green-dark);
            }

        .user-dropdown .ic {
            font-size: 16px;
            width: 20px;
            text-align: center;
        }

        /* cart count badge inside the Cart dropdown item */
        .cart-badge {
            margin-left: auto;
            background: var(--green);
            color: #fff;
            font-size: 11px;
            font-weight: 800;
            min-width: 20px;
            height: 20px;
            padding: 0 6px;
            border-radius: 999px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            line-height: 1;
        }

        .dropdown-divider {
            height: 1px;
            background: var(--border);
            margin: 6px;
        }

        .logout-item {
            color: #dc2626 !important;
        }

            .logout-item:hover {
                background: #fee2e2 !important;
                color: #dc2626 !important;
            }

        @@media (max-width: 768px) {
            .nav-toggle {
                display: inline-flex;
            }

            .main-nav {
                position: absolute;
                top: 70px;
                left: 0;
                right: 0;
                flex-direction: column;
                background: #fff;
                border-bottom: 1px solid var(--border);
                padding: 12px 16px;
                gap: 6px;
                display: none;
                box-shadow: 0 10px 28px rgba(0,0,0,.08);
            }

                .main-nav.open {
                    display: flex;
                }

            .user-trigger .name {
                display: none;
            }

            .logo {
                font-size: 22px;
            }
        }

        /* ===============================
                   PAGE MENU
                ===============================*/

        .module-nav {
            background: white;
            border-bottom: 1px solid var(--border);
        }

        .module-nav-inner {
            max-width: 1400px;
            margin: auto;
            padding: 12px 24px;
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }

            .module-nav-inner a {
                text-decoration: none;
                padding: 8px 16px;
                border-radius: 999px;
                background: #f1f5f9;
                color: #334155;
                font-weight: 600;
            }

                .module-nav-inner a:hover {
                    background: #dcfce7;
                    color: var(--green-dark);
                }

        /* ===============================
                   CONTENT
                ===============================*/
        .page-content {
            width: 100%;
            max-width: 1600px;
            margin: 0 auto;
        }

        /* =========================
           FOOTER
        ========================= */

        .footer {
            background: #0f172a;
            color: #cbd5e1;
            padding: 80px 0 30px;
            margin-top: 100px;
        }

        .footer-container {
            max-width: 1400px;
            margin: auto;
            padding: 0 40px;
            display: grid;
            grid-template-columns: 2fr 1fr 1fr 1.2fr;
            gap: 50px;
        }

        .footer-section h3 {
            color: white;
            font-size: 2rem;
            font-weight: 800;
            margin-bottom: 20px;
        }

        .footer-section h4 {
            color: white;
            font-size: 1.15rem;
            font-weight: 700;
            margin-bottom: 20px;
        }

        .footer-section p {
            line-height: 1.8;
            margin-bottom: 10px;
            color: #94a3b8;
        }

        .footer-section ul {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .footer-section li {
            margin-bottom: 12px;
            color: #94a3b8;
        }

        .footer-section a {
            text-decoration: none;
            color: #94a3b8;
            transition: .3s;
        }

            .footer-section a:hover {
                color: #22c55e;
                padding-left: 4px;
            }

        .footer-bottom {
            margin-top: 60px;
            padding-top: 25px;
            border-top: 1px solid rgba(255,255,255,.08);
            text-align: center;
        }

            .footer-bottom p {
                margin: 0;
                color: #64748b;
                font-size: .95rem;
            }

        .admin-btn {
            background: #0f172a;
            color: white;
        }

            .admin-btn:hover {
                background: #1e293b;
                color: white;
            }

        .user-name {
            display: flex;
            align-items: center;
            font-weight: 700;
            color: #334155;
            margin-right: 10px;
        }
    </style>
</head>
<body>

    <!-- HEADER -->
    <header class="top-header">
        <div class="top-header-inner">

            @{
                // Login state is tracked via Session (the client has no auth middleware,
                // so User.Identity is never authenticated). Customers are not linked to roles.
                var custToken = Context.Session.GetString("JWT");
                var custName = Context.Session.GetString("FullName")
                               ?? Context.Session.GetString("Name");
                var custInitial = string.IsNullOrWhiteSpace(custName)
                    ? "U" : custName.Trim()[0].ToString().ToUpper();
            }

            <a asp-controller="Home" asp-action="Index" class="logo">🐾 PetCenter</a>

            <button class="nav-toggle" id="navToggle" type="button" aria-label="Toggle menu">☰</button>

            <nav class="main-nav" id="mainNav">
                <a asp-controller="Home" asp-action="Index">Home Page</a>
                <a asp-controller="Products" asp-action="Index">Product Page</a>
                <a asp-controller="Service" asp-action="Index">Service Page</a>
            </nav>

            <div class="auth-nav">
                @if (!string.IsNullOrEmpty(custToken))
                {
                    <div class="user-menu" id="userMenu">
                        <button class="user-trigger" id="userTrigger" type="button">
                            <span class="user-avatar">@custInitial</span>
                            <span class="name">@custName</span>
                            <span class="caret">▾</span>
                        </button>
                        <div class="user-dropdown">
                            <a asp-controller="Customer" asp-action="Profile"><span class="ic">👤</span> Profile</a>
                            <a asp-controller="Orders" asp-action="History"><span class="ic">📦</span> My Orders</a>
                            <a asp-controller="MedicalRecord" asp-action="CustomerIndex"><span class="ic">🏥</span> Medical Records</a>
                            <a asp-controller="Cart" asp-action="Index"><span class="ic">🛒</span> Cart <span class="cart-badge" id="cartBadge" style="display:none">0</span></a>
                            <a asp-controller="Addresses" asp-action="Index"><span class="ic">📍</span> Address Book</a>
                            <div class="dropdown-divider"></div>
                            <a asp-controller="Auth" asp-action="Logout" class="logout-item"><span class="ic">🚪</span> Logout</a>
                        </div>
                    </div>
                }
                else
                {
                    <a asp-controller="Auth" asp-action="Login" class="auth-btn login-btn">Login</a>
                    <a asp-controller="Auth" asp-action="AdminLogin" class="auth-btn admin-btn" id="adminBtn" title="Admin Panel">⚙ Admin</a>
                }
            </div>

        </div>
    </header>

    <!-- PAGE SPECIFIC MENU -->
    @RenderSection("ModuleNav", required: false)

    <!-- CONTENT -->
    <main class="page-content">
        @RenderBody()
    </main>

    <!-- FOOTER -->
    <footer class="footer">
        <div class="footer-container">

            <div class="footer-section">
                <h3>🐾 PetCenter</h3>
                <p>One Platform For Every Pet Care Need</p>
                <p>
                    Connecting pet owners with trusted veterinary care,
                    grooming, boarding, and AI-powered health assistance.
                </p>
            </div>

            <div class="footer-section">
                <h4>Services</h4>
                <ul>
                    <li>Veterinary Appointments</li>
                    <li>Pet Grooming</li>
                    <li>Vaccination</li>
                    <li>Pet Boarding</li>
                    <li>AI Disease Identification</li>
                </ul>
            </div>

            <div class="footer-section">
                <h4>Quick Links</h4>
                <ul>
                    <li><a href="#">Home</a></li>
                    <li><a href="#">Services</a></li>
                    <li><a href="#">Appointments</a></li>
                    <li><a href="#">About Us</a></li>
                    <li><a href="#">Contact</a></li>
                </ul>
            </div>

            <div class="footer-section">
                <h4>Contact Us</h4>
                <p>📍 Can Tho, Vietnam</p>
                <p>📞 +84 123 456 789</p>
                <p>✉ support@petcenter.com</p>
                <p>🕒 Mon - Sun: 8:00 AM - 8:00 PM</p>
            </div>

        </div>

        <div class="footer-bottom">
            <p>© 2026 PetCenter. All Rights Reserved.</p>
        </div>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // Header: user dropdown + mobile nav toggle (vanilla, no dependency)
        (function () {
            var menu = document.getElementById('userMenu');
            var trigger = document.getElementById('userTrigger');
            if (menu && trigger) {
                trigger.addEventListener('click', function (e) {
                    e.stopPropagation();
                    menu.classList.toggle('open');
                });
                var dd = menu.querySelector('.user-dropdown');
                if (dd) dd.addEventListener('click', function (e) { e.stopPropagation(); });
                document.addEventListener('click', function () { menu.classList.remove('open'); });
            }

            var navToggle = document.getElementById('navToggle');
            var mainNav = document.getElementById('mainNav');
            if (navToggle && mainNav) {
                navToggle.addEventListener('click', function (e) {
                    e.stopPropagation();
                    mainNav.classList.toggle('open');
                });
            }

            // cart count badge — exposed globally so add-to-cart / remove can refresh it live
            window.refreshCartBadge = function () {
                var badge = document.getElementById('cartBadge');
                if (!badge) return;
                fetch('/Cart/Count')
                    .then(function (r) { return r.json(); })
                    .then(function (d) {
                        var n = (d && d.count) ? d.count : 0;
                        if (n > 0) { badge.textContent = n; badge.style.display = 'inline-flex'; }
                        else { badge.style.display = 'none'; }
                    })
                    .catch(function () { });
            };
            if (menu) window.refreshCartBadge();
        })();
    </script>

    <script src="~/js/order-feedback.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

    @* ── PetCenter Chatbot Widget ────────────────────────────────────────── *@
    <script>
        window.__RASA_URL    = 'http://localhost:5005';
        window.__API_URL     = 'https://localhost:7004';
        window.__JWT         = '@(custToken ?? "")';
        window.__CUSTOMER_ID = '@(Context.Session.GetString("CustomerId") ?? "")';
    </script>
    <script src="~/js/chatbot.js" asp-append-version="true"></script>

</body>
</html>
