@model PetCenterClient.ViewModels.Appointment.AppointmentDetailViewModel

@{
    ViewData["Title"] = "Appointment Detail";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

<div class="appointment-detail-wrapper py-5" data-bs-theme="light">
    <div class="container">

        <!-- BACK BUTTON -->
        <div class="mb-4">
            <a href="@Url.Action("MyAppointments", "Appointment")" class="text-decoration-none text-muted small fw-bold">
                <i class="fas fa-chevron-left me-2"></i>Back to List
            </a>
        </div>

        <div class="row g-4">
            <!-- LEFT COLUMN: DETAILS & SERVICES -->
            <div class="col-lg-8">
                <div class="bg-white p-4 rounded-4 shadow-sm border mb-4">

                    <!-- BLOCK HEADER -->
                    <div class="d-flex justify-content-between align-items-start border-bottom pb-3 mb-4">
                        <div>
                            <span class="text-muted xsmall-text d-block">APPOINTMENT ID: @Model.AppointmentId.ToString().ToUpper().Substring(0, 8)</span>
                            <h4 class="fw-bold text-dark m-0 mt-1">Appointment Information</h4>
                        </div>
                        <div>
                            @switch (Model.Status)
                            {
                                case 1:
                                    <span class="badge badge-lg bg-warning text-dark rounded-pill fw-bold px-3 py-2"><i class="far fa-clock me-1"></i>Pending</span>
                                    break;
                                case 2:
                                    <span class="badge badge-lg bg-info text-white rounded-pill fw-bold px-3 py-2"><i class="fas fa-calendar-check me-1"></i>Confirmed</span>
                                    break;
                                case 3:
                                    <span class="badge badge-lg bg-primary text-white rounded-pill fw-bold px-3 py-2"><i class="fas fa-spinner fa-spin me-1"></i>In Progress</span>
                                    break;
                                case 4:
                                    <span class="badge badge-lg bg-success text-white rounded-pill fw-bold px-3 py-2"><i class="fas fa-check-circle me-1"></i>Completed</span>
                                    break;
                                case 0:
                                    <span class="badge badge-lg bg-danger text-white rounded-pill fw-bold px-3 py-2"><i class="fas fa-times-circle me-1"></i>Cancelled</span>
                                    break;
                                default:
                                    <span class="badge badge-lg bg-secondary text-white rounded-pill fw-bold px-3 py-2">Unknown</span>
                                    break;
                            }
                        </div>
                    </div>

                    <!-- PROFILE PET & VET SIDE-BY-SIDE -->
                    <div class="row g-3 mb-4">
                        <div class="col-sm-6">
                            <div class="profile-mini-card p-3 rounded-3 border d-flex align-items-center gap-3">
                                <img src="@(string.IsNullOrEmpty(Model.PetAvatar) ? "https://placehold.co/60x60?text=Pet" : Model.PetAvatar)" class="rounded-circle border" alt="@Model.PetName" style="width: 50px; height: 50px; object-fit: cover;" />
                                <div>
                                    <span class="text-muted small d-block">Pet Patient</span>
                                    <strong class="text-dark fs-6">@Model.PetName</strong>
                                </div>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="profile-mini-card p-3 rounded-3 border d-flex align-items-center gap-3">
                                <img src="@(string.IsNullOrEmpty(Model.VetAvatar) ? "https://placehold.co/60x60?text=Vet" : Model.VetAvatar)" class="rounded-circle border" alt="@Model.VetName" style="width: 50px; height: 50px; object-fit: cover;" />
                                <div>
                                    <span class="text-muted small d-block">Veterinary Doctor</span>
                                    <strong class="text-dark fs-6">Dr. @Model.VetName</strong>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- CLINICAL SNAPSHOT SUB-BLOCK -->
                    @if (Model.Snapshot != null)
                    {
                        <div class="row g-3 mb-4 bg-light p-3 rounded-3 mx-1 small border">
                            <div class="col-6 col-sm-3">Species: <strong>@Model.Snapshot.Species</strong></div>
                            <div class="col-6 col-sm-3">Breed: <strong>@Model.Snapshot.Breed</strong></div>
                            <div class="col-6 col-sm-3">Gender: <strong>@Model.Snapshot.Gender</strong></div>
                            <div class="col-6 col-sm-3">Weight: <strong>@Model.Snapshot.Weight kg</strong></div>
                        </div>
                    }

                    <!-- SCHEDULED TIME -->
                    <div class="time-block p-3 rounded-3 mb-4 d-flex flex-wrap gap-4 border">
                        <div>
                            <span class="text-muted small d-block"><i class="far fa-calendar-alt text-success me-1"></i> Start Time</span>
                            <strong class="text-dark">@Model.AppointmentStart.ToString("dd/MM/yyyy 'at' HH:mm")</strong>
                        </div>
                        <div class="border-start ps-4 display-desktop-only"></div>
                        <div>
                            <span class="text-muted small d-block"><i class="far fa-clock text-success me-1"></i> Estimated End</span>
                            <strong class="text-dark">@Model.AppointmentEnd.ToString("dd/MM/yyyy 'at' HH:mm")</strong>
                        </div>
                    </div>

                    <!-- CUSTOMER NOTE -->
                    @if (!string.IsNullOrEmpty(Model.Note))
                    {
                        <div class="mb-4">
                            <label class="fw-bold text-secondary small mb-1"><i class="far fa-comment-dots me-1"></i> Your Notes:</label>
                            <div class="p-3 bg-light rounded-3 text-muted small italic">"@Model.Note"</div>
                        </div>
                    }

                    <!-- SELECTED SERVICES TABLE -->
                    <div class="services-list-section mt-4">
                        <h5 class="fw-bold text-dark mb-3"><i class="fas fa-concierge-bell text-success me-2"></i>Selected Services</h5>
                        <div class="table-responsive">
                            <table class="table table-hover align-middle custom-modern-table">
                                <thead class="table-light">
                                    <tr>
                                        <th>Service Name</th>
                                        <th class="text-center">Duration</th>
                                        <th class="text-end">Price</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var srv in Model.AppointmentServices)
                                    {
                                        <tr>
                                            <td>
                                                <div class="fw-bold text-dark">@srv.ServiceName</div>
                                                @if (srv.CompleteAt.HasValue)
                                                {
                                                    <span class="xsmall-text text-success"><i class="fas fa-check me-1"></i> Completed at: @srv.CompleteAt.Value.ToString("HH:mm")</span>
                                                }
                                            </td>
                                            <td class="text-center text-muted small">@srv.Duration mins</td>
                                            <td class="text-end fw-bold text-dark">@srv.Price.ToString("N0") đ</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                </div>

                <!-- CLINICAL RESULTS & USER REVIEW SECTION (SEPARATED & UPDATEABLE - ONLY SHOW IF COMPLETED - STATUS = 4) -->
                @if (Model.Status == 4)
                {
                    <div class="bg-white p-4 rounded-4 shadow-sm border mb-4">
                        <div class="d-flex justify-content-between align-items-center mb-3 border-bottom pb-2">
                            <h5 class="fw-bold text-dark m-0"><i class="fas fa-star text-warning me-2"></i>Your Appointment Review</h5>
                            @if (Model.Snapshot != null && Model.Snapshot.Rating > 0)
                            {
                                <button type="button" class="btn btn-sm btn-outline-success rounded-pill px-3 fw-bold" onclick="toggleReviewForm()">
                                    <i class="fas fa-edit me-1"></i>Edit Review
                                </button>
                            }
                        </div>

                        @if (Model.Snapshot != null && Model.Snapshot.Rating > 0)
                        {
                            <!-- DISPLAY EXISTING REVIEW LAYOUT -->
                            <div id="existingReviewContainer" class="review-display-box">
                                <div class="mb-2 text-warning fs-5">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <i class="@(i <= Model.Snapshot.Rating ? "fas" : "far") fa-star"></i>
                                    }
                                    <span class="text-dark small ms-2">(@Model.Snapshot.Rating / 5.0)</span>
                                </div>
                                <div class="p-3 bg-light rounded-3 text-muted small italic border-start border-success border-3">
                                    " @Model.Snapshot.Feedback "
                                </div>
                            </div>
                        }

                        <!-- EDITABLE / SUBMIT FORM BLOCK (CALLS SAMES SUBMITREVIEW ACTION) -->
                        <div id="reviewFormContainer" style="@(Model.Snapshot != null && Model.Snapshot.Rating > 0 ? "display: none;" : "")" class="mt-2">
                            <form asp-action="SubmitReview" method="post">
                                <input type="hidden" name="AppointmentId" value="@Model.AppointmentId" />

                                <div class="mb-3">
                                    <label class="form-label small text-muted mb-1 fw-bold">Select satisfaction level:</label>
                                    <div class="rating-stars-input text-warning fs-4">
                                        <input type="radio" name="Rating" value="5" id="star5" @(Model.Snapshot?.Rating == 5 || Model.Snapshot?.Rating == 0 ? "checked" : "") class="d-none" /><label for="star5" class="star-label"><i class="fas fa-star"></i></label>
                                        <input type="radio" name="Rating" value="4" id="star4" @(Model.Snapshot?.Rating == 4 ? "checked" : "") class="d-none" /><label for="star4" class="star-label"><i class="fas fa-star"></i></label>
                                        <input type="radio" name="Rating" value="3" id="star3" @(Model.Snapshot?.Rating == 3 ? "checked" : "") class="d-none" /><label for="star3" class="star-label"><i class="fas fa-star"></i></label>
                                        <input type="radio" name="Rating" value="2" id="star2" @(Model.Snapshot?.Rating == 2 ? "checked" : "") class="d-none" /><label for="star2" class="star-label"><i class="fas fa-star"></i></label>
                                        <input type="radio" name="Rating" value="1" id="star1" @(Model.Snapshot?.Rating == 1 ? "checked" : "") class="d-none" /><label for="star1" class="star-label"><i class="fas fa-star"></i></label>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label small text-muted mb-1 fw-bold">Your Feedback Comments:</label>
                                    <textarea name="Feedback" class="form-control form-control-sm rounded-3 px-3 py-2" rows="3" required placeholder="Share your experience about the doctor and service here...">@(Model.Snapshot?.Feedback ?? "")</textarea>
                                </div>
                                <div class="d-flex gap-2">
                                    <button type="submit" class="btn btn-modern-success font-weight-bold px-4 py-2 shadow-sm">Submit Review</button>
                                    @if (Model.Snapshot != null && Model.Snapshot.Rating > 0)
                                    {
                                        <button type="button" class="btn btn-outline-secondary font-weight-bold px-4 py-2 rounded-3" onclick="toggleReviewForm()">Cancel</button>
                                    }
                                </div>
                            </form>
                        </div>
                    </div>
                }
            </div>

            <!-- RIGHT COLUMN: INVOICE SUMMARY & ACTIONS -->
            <div class="col-lg-4">
                <div class="bg-white p-4 rounded-4 shadow-sm border sticky-top">
                    <h5 class="fw-bold text-dark pb-3 mb-3 border-bottom"><i class="fas fa-receipt text-success me-2"></i>Invoice Summary</h5>

                    <div class="d-flex justify-content-between align-items-center mb-2 small">
                        <span class="text-muted">Customer:</span>
                        <strong class="text-dark">@Model.CustomerName</strong>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mb-4 small">
                        <span class="text-muted">Total Services:</span>
                        <strong class="text-dark">@Model.AppointmentServices.Count</strong>
                    </div>

                    <div class="p-3 rounded-3 bg-light-green-box border-green-dash mb-4">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="fw-bold text-secondary">Total Amount</span>
                            <span class="fs-4 fw-black text-success">@Model.Total.ToString("N0") đ</span>
                        </div>
                    </div>

                    <!-- CANCEL BUTTON TRIGGER MODAL -->
                    @if (Model.Status == 1 || Model.Status == 2)
                    {
                        <button type="button" class="btn btn-outline-danger w-100 fw-bold py-2 rounded-3" data-bs-toggle="modal" data-bs-target="#cancelConfirmModal">
                            <i class="far fa-calendar-times me-2"></i>Cancel Appointment
                        </button>
                    }
                    else if (Model.Status == 0)
                    {
                        <div class="alert alert-secondary small text-center rounded-3 m-0 py-2">
                            <i class="fas fa-ban me-1"></i> This appointment was cancelled
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-success small text-center rounded-3 m-0 py-2">
                            <i class="fas fa-lock me-1"></i> Appointment profile is locked
                        </div>
                    }
                </div>
            </div>
        </div>

    </div>
</div>

<!-- MODERN CANCEL CONFIRMATION MODAL -->
<div class="modal fade" id="cancelConfirmModal" tabindex="-1" aria-labelledby="cancelModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-confirm">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-0 flex-column text-center pt-4">
                <div class="icon-box-danger text-danger mb-3">
                    <i class="fas fa-exclamation-triangle fa-3x animate-pulse"></i>
                </div>
                <h4 class="modal-title fw-bold text-dark w-100" id="cancelModalLabel">Are you sure?</h4>
            </div>
            <div class="modal-body text-center text-muted px-4 py-2">
                <p class="m-0 small">Do you really want to cancel this appointment? This action cannot be undone and your slot will be released immediately.</p>
            </div>
            <div class="modal-footer border-0 d-flex justify-content-center gap-2 pb-4 pt-3">
                <button type="button" class="btn btn-modern-secondary px-4 rounded-3 fw-bold" data-bs-dismiss="modal">Keep Appointment</button>
                <form asp-action="Cancel" method="post" class="d-inline">
                    <input type="hidden" name="id" value="@Model.AppointmentId" />
                    <button type="submit" class="btn btn-modern-danger px-4 rounded-3 fw-bold">Yes, Cancel It</button>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    :root {
        --primary-green: #10b981;
        --primary-green-hover: #059669;
        --light-green-bg: #f0fdf4;
        --accent-light-green: #d1fae5;
        --dark-theme: #1f2937;
        --text-muted: #6b7280;
        --border-color: #e5e7eb;
        --white: #ffffff;
        --bg-main: #f9fafb;
    }

    .profile-mini-card {
        background-color: var(--white);
        border-color: var(--border-color) !important;
    }

        .profile-mini-card img {
            width: 50px;
            height: 50px;
            object-fit: cover;
        }

    .time-block {
        background-color: var(--bg-main);
        border-color: var(--border-color) !important;
    }

    .custom-modern-table th {
        font-weight: 700;
        font-size: 13px;
        color: var(--dark-theme);
        padding: 12px;
    }

    .custom-modern-table td {
        padding: 14px 12px;
        border-bottom: 1px solid var(--border-color);
    }

    .bg-light-green-box {
        background-color: var(--light-green-bg);
    }

    .border-green-dash {
        border: 1px dashed var(--primary-green);
    }

    .btn-modern-success {
        background-color: var(--primary-green);
        color: var(--white);
        border: none;
        border-radius: 8px;
        transition: all 0.2s ease;
    }

        .btn-modern-success:hover {
            background-color: var(--primary-green-hover);
            color: var(--white);
        }

    .rating-stars-input {
        display: flex;
        flex-direction: row-reverse;
        justify-content: flex-end;
        gap: 4px;
    }

    .star-label {
        cursor: pointer;
        color: #e5e7eb;
        transition: color 0.15s ease;
    }

    .rating-stars-input input:checked ~ label,
    .rating-stars-input label:hover,
    .rating-stars-input label:hover ~ label {
        color: #f59e0b;
    }

    .xsmall-text {
        font-size: 11px;
    }

    .italic {
        font-style: italic;
    }

    .fw-black {
        font-weight: 900;
    }

    @Html.Raw("@") media (max-width: 576px) {
        .display-desktop-only {
            display: none !important;
        }
    }

    /* ĐỒNG BỘ STICKY-TOP CHO SIDEBAR */
    .col-lg-4 > .sticky-top {
        top: 90px !important;
        z-index: 10 !important;
    }

    /* GIAO DIỆN MODAL CONFIRM CHUYÊN NGHIỆP */
    .modal-confirm {
        max-width: 380px;
    }

    .icon-box-danger {
        width: 80px;
        height: 80px;
        background-color: #fef2f2;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto;
    }

    .btn-modern-secondary {
        background-color: #f3f4f6;
        color: #4b5563;
        border: none;
        padding: 10px 18px;
        transition: all 0.2s;
    }

        .btn-modern-secondary:hover {
            background-color: #e5e7eb;
            color: #1f2937;
        }

    .btn-modern-danger {
        background-color: #ef4444;
        color: #ffffff;
        border: none;
        padding: 10px 18px;
        transition: all 0.2s;
    }

        .btn-modern-danger:hover {
            background-color: #dc2626;
            box-shadow: 0 4px 12px rgba(239, 68, 68, 0.25);
        }

    .animate-pulse {
        animation: pulse 2s infinite linear;
    }

    @Html.Raw("@") keyframes pulse {
        0% {
            transform: scale(1);
        }

        50% {
            transform: scale(1.08);
        }

        100% {
            transform: scale(1);
        }
    }
</style>

<!-- TOGGLE DISCOVERY LOGIC FOR EDITING REVIEW -->
<script>
    function toggleReviewForm() {
        const formContainer = document.getElementById("reviewFormContainer");
        const displayContainer = document.getElementById("existingReviewContainer");

        if (formContainer && displayContainer) {
            if (formContainer.style.display === "none") {
                formContainer.style.display = "block";
                displayContainer.style.display = "none";
            } else {
                formContainer.style.display = "none";
                displayContainer.style.display = "block";
            }
        }
    }
</script>