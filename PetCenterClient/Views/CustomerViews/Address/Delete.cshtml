@model AddressResponseDTO

<div class="container mt-4">
    <div class="alert alert-danger">
        <h4>⚠️ Cảnh báo xóa!</h4>
        <p>Bạn có chắc chắn muốn xóa địa chỉ: <strong>@Model.AddressDetails</strong> không?</p>
    </div>

    <div>
        <form asp-action="Delete">
            <input type="hidden" asp-for="AddressId" />
            <button type="submit" class="btn btn-danger">Xác nhận xóa vĩnh viễn</button>
            <a asp-action="Index" class="btn btn-secondary">Hủy bỏ</a>
        </form>
    </div>
</div>