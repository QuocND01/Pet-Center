@model PetCenterClient.DTOs.CreateFeedbackDTO

<div class="container mt-4" style="max-width:600px">

    <h3>Write Your Feedback</h3>

    <form asp-controller="Feedback" asp-action="Create" method="post">

        <input type="hidden" name="ProductId" value="@Model.ProductId" />
        <input type="hidden" asp-for="CustomerId" />

        <div class="mb-3">
            <label>Rating</label>
            <select asp-for="Rating" class="form-control">
                <option value="1">⭐ 1</option>
                <option value="2">⭐⭐ 2</option>
                <option value="3">⭐⭐⭐ 3</option>
                <option value="4">⭐⭐⭐⭐ 4</option>
                <option value="5">⭐⭐⭐⭐⭐ 5</option>
            </select>
        </div>

        <div class="mb-3">
            <label>Your Comment</label>
            <textarea asp-for="Comment" class="form-control" rows="4"></textarea>
        </div>

        <button class="btn btn-primary">Submit Feedback</button>
    </form>

</div>