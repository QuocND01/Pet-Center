@using PetCenterClient.DTOs
@model IEnumerable<ReadOrderListViewModel>

@{
    // Giả sử layout cho phía ngoài trang chủ/khách hàng là _Layout.cshtml
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "My Order History";
}

<div class="container py-5">
    <div class="row mb-4">
        <div class="col">
            <h2 class="fw-bold" style="font-family: 'Segoe UI', sans-serif;">My Order History</h2>
            <p class="text-muted">Track, manage and view your recent purchases.</p>
        </div>
    </div>

    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-body p-0 table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Order ID</th>
                        <th>Date</th>
                        <th>Total Amount</th>
                        <th>Payment</th>
                        <th>Status</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody id="customerOrdersTableBody">
                    @Html.Partial("~/Views/CustomerViews/Order/_TableBody.cshtml", Model)
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="orderModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title fw-bold">Order Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="orderModalBody"></div>
        </div>
    </div>
</div>

<script>
    // 1. Gọi API để Load View Details bằng Fetch API (Thuần JS)
    document.addEventListener("click", function (e) {
        var btnView = e.target.closest("[data-bs-target='#orderModal']");
        if (btnView) {
            var url = btnView.getAttribute("data-url");
            var modalBody = document.getElementById("orderModalBody");

            modalBody.innerHTML = "<div class='text-center my-4'><div class='spinner-border text-primary'></div><p class='mt-2'>Loading...</p></div>";

            fetch(url)
                .then(response => response.text())
                .then(html => {
                    modalBody.innerHTML = html;
                    // innerHTML does not execute <script> tags by design,
                    // so any script returned by the partial view (e.g. order-feedback.js
                    // initialization) must be manually re-created and re-appended to run
                    runInlineScripts(modalBody);
                })
                .catch(err => {
                    modalBody.innerHTML = "<div class='text-center text-danger'>Failed to load details.</div>";
                });
        }
    });

    // Re-execute any <script> tags that were injected via innerHTML,
    // since the browser intentionally ignores them otherwise
    function runInlineScripts(container) {
        var oldScripts = container.querySelectorAll("script");
        oldScripts.forEach(function (oldScript) {
            var newScript = document.createElement("script");
            if (oldScript.src) {
                newScript.src = oldScript.src;
            } else {
                newScript.textContent = oldScript.textContent;
            }
            Array.from(oldScript.attributes).forEach(function (attr) {
                newScript.setAttribute(attr.name, attr.value);
            });
            oldScript.parentNode.replaceChild(newScript, oldScript);
        });
    }

    // 2. Xử lý Hủy đơn cho Customer bằng Fetch API (Thuần JS)
    document.addEventListener("click", function (e) {
        var btnCancel = e.target.closest(".btn-cancel-customer");
        if (btnCancel) {
            var orderId = btnCancel.getAttribute("data-id");

            if (confirm("Are you sure you want to cancel this order?")) {
                fetch('@Url.Action("Cancel", "Orders")', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded'
                    },
                    body: 'id=' + encodeURIComponent(orderId)
                })
                .then(response => response.json())
                .then(res => {
                    if (res.success) {
                        toastr.success("Your order has been cancelled successfully.");
                        refreshCustomerHistory();
                    } else {
                        alert("Notice: " + res.message);
                    }
                })
                .catch(err => {
                    alert("An error occurred while cancelling your order.");
                });
            }
        }
    });

    function refreshCustomerHistory() {
        var url = '@Url.Action("HistoryPartial", "Orders")';
        fetch(url)
            .then(r => r.text())
            .then(html => {
                document.getElementById('customerOrdersTableBody').innerHTML = html;
            })
            .catch(() => console.warn('Failed to refresh customer orders'));
    }

    // Listen for SignalR events dispatched to window
    window.addEventListener('order:created', function (e) { refreshCustomerHistory(); });
    window.addEventListener('order:updated', function (e) { refreshCustomerHistory(); });
</script>