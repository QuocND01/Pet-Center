@{
    ViewData["Title"] = "Change Password";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

<style>
    .cp-page {
        min-height: calc(100vh - 56px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px 16px;
        background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
        margin: -16px -15px -16px;
    }

    .cp-wrapper {
        width: 100%;
        max-width: 460px;
        animation: cpFadeUp 0.5s ease-out both;
    }

    @@keyframes cpFadeUp {
        from {
            opacity: 0;
            transform: translateY(24px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .cp-back {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        color: #7f8c8d;
        text-decoration: none;
        font-size: 13px;
        font-weight: 600;
        margin-bottom: 20px;
        transition: color 0.2s, gap 0.2s;
    }

        .cp-back:hover {
            color: #2c3e50;
            gap: 10px;
            text-decoration: none;
        }

    .cp-card {
        background: white;
        border-radius: 20px;
        box-shadow: 0 12px 48px rgba(0,0,0,0.10);
        overflow: hidden;
    }

    .cp-header {
        background: linear-gradient(135deg, #2ecc71 0%, #27ae60 100%);
        padding: 36px 32px 28px;
        text-align: center;
        color: white;
        position: relative;
        overflow: hidden;
    }

        .cp-header::before,
        .cp-header::after {
            content: '';
            position: absolute;
            border-radius: 50%;
            background: rgba(255,255,255,0.08);
        }

        .cp-header::before {
            width: 180px;
            height: 180px;
            top: -60px;
            right: -50px;
        }

        .cp-header::after {
            width: 120px;
            height: 120px;
            bottom: -40px;
            left: -30px;
        }

    .cp-icon {
        width: 72px;
        height: 72px;
        background: rgba(255,255,255,0.18);
        border: 2.5px solid rgba(255,255,255,0.55);
        border-radius: 50%;
        margin: 0 auto 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 30px;
        position: relative;
        z-index: 1;
    }

    .cp-header h2 {
        font-size: 21px;
        font-weight: 700;
        margin-bottom: 5px;
        position: relative;
        z-index: 1;
    }

    .cp-header p {
        font-size: 12.5px;
        opacity: 0.82;
        position: relative;
        z-index: 1;
    }

    .cp-body {
        padding: 32px;
    }

    .cp-alert {
        display: none;
        align-items: center;
        gap: 9px;
        padding: 12px 14px;
        border-radius: 10px;
        font-size: 13px;
        font-weight: 500;
        margin-bottom: 22px;
        animation: cpSlideDown 0.3s ease-out;
    }

        .cp-alert.show {
            display: flex;
        }

        .cp-alert.success {
            background: rgba(39,174,96,0.1);
            color: #1e8449;
            border: 1px solid rgba(39,174,96,0.28);
        }

        .cp-alert.error {
            background: rgba(231,76,60,0.08);
            color: #c0392b;
            border: 1px solid rgba(231,76,60,0.25);
        }

    @@keyframes cpSlideDown {
        from {
            opacity: 0;
            transform: translateY(-6px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .cp-group {
        margin-bottom: 20px;
    }

        .cp-group label {
            display: block;
            font-size: 13px;
            font-weight: 600;
            color: #2c3e50;
            margin-bottom: 7px;
        }

    .cp-input-wrap {
        position: relative;
    }

        .cp-input-wrap input {
            width: 100%;
            padding: 11px 44px 11px 14px;
            border: 2px solid #ecf0f1;
            border-radius: 10px;
            font-size: 14px;
            font-family: inherit;
            color: #2c3e50;
            background: #fafafa;
            transition: border-color 0.25s, box-shadow 0.25s, background 0.25s;
            outline: none;
        }

            .cp-input-wrap input:focus {
                border-color: #2ecc71;
                background: white;
                box-shadow: 0 0 0 3.5px rgba(46,204,113,0.12);
            }

            .cp-input-wrap input.is-error {
                border-color: #e74c3c;
                background: #fff8f8;
            }

                .cp-input-wrap input.is-error:focus {
                    box-shadow: 0 0 0 3px rgba(231,76,60,0.12);
                }

    .cp-eye {
        position: absolute;
        right: 13px;
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        cursor: pointer;
        color: #b0bec5;
        font-size: 15px;
        padding: 0;
        transition: color 0.2s;
    }

        .cp-eye:hover {
            color: #2ecc71;
        }

    .cp-field-err {
        font-size: 11.5px;
        color: #e74c3c;
        margin-top: 5px;
        display: none;
    }

        .cp-field-err.show {
            display: block;
        }

    .cp-strength-bar {
        height: 4px;
        border-radius: 4px;
        background: #ecf0f1;
        margin-top: 9px;
        overflow: hidden;
    }

    .cp-strength-fill {
        height: 100%;
        border-radius: 4px;
        transition: width 0.35s ease, background 0.35s ease;
        width: 0%;
    }

    .cp-strength-label {
        font-size: 11px;
        font-weight: 700;
        margin-top: 4px;
        min-height: 16px;
    }

    .cp-submit {
        width: 100%;
        padding: 13px;
        background: linear-gradient(135deg, #2ecc71 0%, #27ae60 100%);
        color: white;
        border: none;
        border-radius: 10px;
        font-size: 14.5px;
        font-weight: 700;
        cursor: pointer;
        margin-top: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        transition: transform 0.2s, box-shadow 0.2s, opacity 0.2s;
        letter-spacing: 0.3px;
    }

        .cp-submit:hover:not(:disabled) {
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(46,204,113,0.38);
        }

        .cp-submit:active:not(:disabled) {
            transform: translateY(0);
        }

        .cp-submit:disabled {
            opacity: 0.65;
            cursor: not-allowed;
        }

    .cp-spinner {
        width: 17px;
        height: 17px;
        border: 2.5px solid rgba(255,255,255,0.35);
        border-top-color: white;
        border-radius: 50%;
        animation: cpSpin 0.7s linear infinite;
        display: none;
    }

    @@keyframes cpSpin {
        to {
            transform: rotate(360deg);
        }
    }

    .cp-hint {
        text-align: center;
        font-size: 12px;
        color: #aab0b8;
        margin-top: 18px;
    }

    @@media (max-width: 500px) {
        .cp-body {
            padding: 24px 20px;
        }

        .cp-header {
            padding: 28px 20px 22px;
        }
    }
</style>

<div class="cp-page">
    <div class="cp-wrapper">

        <a href="@Url.Action("Profile", "Customer")" class="cp-back">
            <i class="fas fa-arrow-left"></i> Back to Profile
        </a>

        <div class="cp-card">
            <div class="cp-header">
                <div class="cp-icon">🔒</div>
                <h2>Change Password</h2>
                <p>Enter your current password and choose a new one</p>
            </div>

            <div class="cp-body">
                <div class="cp-alert success" id="cpSuccess">
                    <i class="fas fa-check-circle"></i>
                    <span id="cpSuccessMsg"></span>
                </div>
                <div class="cp-alert error" id="cpError">
                    <i class="fas fa-exclamation-circle"></i>
                    <span id="cpErrorMsg"></span>
                </div>

                <form id="cpForm" novalidate>
                    <div class="cp-group">
                        <label for="cpCurrent">Current Password</label>
                        <div class="cp-input-wrap">
                            <input type="password" id="cpCurrent" placeholder="Enter your current password" autocomplete="current-password" />
                            <button type="button" class="cp-eye" data-target="cpCurrent">
                                <i class="fas fa-eye"></i>
                            </button>
                        </div>
                        <p class="cp-field-err" id="err-cpCurrent"></p>
                    </div>

                    <div class="cp-group">
                        <label for="cpNew">New Password</label>
                        <div class="cp-input-wrap">
                            <input type="password" id="cpNew" placeholder="At least 6 characters" autocomplete="new-password" />
                            <button type="button" class="cp-eye" data-target="cpNew">
                                <i class="fas fa-eye"></i>
                            </button>
                        </div>
                        <div class="cp-strength-bar"><div class="cp-strength-fill" id="cpStrengthFill"></div></div>
                        <p class="cp-strength-label" id="cpStrengthLabel"></p>
                        <p class="cp-field-err" id="err-cpNew"></p>
                    </div>

                    <div class="cp-group">
                        <label for="cpConfirm">Confirm New Password</label>
                        <div class="cp-input-wrap">
                            <input type="password" id="cpConfirm" placeholder="Re-enter your new password" autocomplete="new-password" />
                            <button type="button" class="cp-eye" data-target="cpConfirm">
                                <i class="fas fa-eye"></i>
                            </button>
                        </div>
                        <p class="cp-field-err" id="err-cpConfirm"></p>
                    </div>

                    <button type="submit" class="cp-submit" id="cpSubmitBtn">
                        <div class="cp-spinner" id="cpSpinner"></div>
                        <i class="fas fa-shield-alt" id="cpSaveIcon"></i>
                        <span id="cpBtnText">Change Password</span>
                    </button>
                </form>

                <p class="cp-hint">Your session will remain active after changing password.</p>
            </div>
        </div>

    </div>
</div>

<script>
    // Fix background full width
    document.querySelector('.container').style.cssText =
        'max-width:100%;padding:0;margin:0';

    // Toggle show/hide password
    document.querySelectorAll('.cp-eye').forEach(btn => {
        btn.addEventListener('click', () => {
            const input = document.getElementById(btn.dataset.target);
            const icon  = btn.querySelector('i');
            const show  = input.type === 'password';
            input.type     = show ? 'text' : 'password';
            icon.className = show ? 'fas fa-eye-slash' : 'fas fa-eye';
        });
    });

    // Strength meter
    document.getElementById('cpNew').addEventListener('input', function () {
        const v = this.value;
        let s = 0;
        if (v.length >= 6)  s++;
        if (v.length >= 10) s++;
        if (/[A-Z]/.test(v) && /[a-z]/.test(v)) s++;
        if (/\d/.test(v))   s++;
        if (/[^A-Za-z0-9]/.test(v)) s++;

        const levels = [
            { pct: '0%',   color: 'transparent', label: '',        labelColor: '' },
            { pct: '25%',  color: '#e74c3c',      label: 'Weak',   labelColor: '#e74c3c' },
            { pct: '50%',  color: '#f39c12',      label: 'Fair',   labelColor: '#f39c12' },
            { pct: '75%',  color: '#3498db',      label: 'Good',   labelColor: '#3498db' },
            { pct: '100%', color: '#2ecc71',      label: 'Strong', labelColor: '#2ecc71' },
        ];
        const lvl = levels[Math.min(s, 4)];
        const fill  = document.getElementById('cpStrengthFill');
        const label = document.getElementById('cpStrengthLabel');
        fill.style.width      = v ? lvl.pct   : '0%';
        fill.style.background = v ? lvl.color : 'transparent';
        label.textContent     = v ? lvl.label : '';
        label.style.color     = lvl.labelColor;
    });

    // Helpers
    function fieldErr(id, msg) {
        const el = document.getElementById('err-' + id);
        el.textContent = msg;
        el.classList.add('show');
        document.getElementById(id).classList.add('is-error');
    }
    function clearAll() {
        ['cpCurrent','cpNew','cpConfirm'].forEach(id => {
            document.getElementById('err-' + id).classList.remove('show');
            document.getElementById(id).classList.remove('is-error');
        });
        document.getElementById('cpSuccess').classList.remove('show');
        document.getElementById('cpError').classList.remove('show');
    }
    function showBanner(type, msg) {
        const el  = document.getElementById(type === 'success' ? 'cpSuccess' : 'cpError');
        const txt = document.getElementById(type === 'success' ? 'cpSuccessMsg' : 'cpErrorMsg');
        txt.textContent = msg;
        el.classList.add('show');
        if (type === 'error') setTimeout(() => el.classList.remove('show'), 6000);
    }
    function setLoading(on) {
        document.getElementById('cpSpinner').style.display  = on ? 'block' : 'none';
        document.getElementById('cpSaveIcon').style.display = on ? 'none'  : 'inline';
        document.getElementById('cpBtnText').textContent    = on ? 'Saving...' : 'Change Password';
        document.getElementById('cpSubmitBtn').disabled     = on;
    }

    // Validate password rule giống Register
    function validateNewPassword(val) {
        const errors = [];
        if (val.length < 6)        errors.push('At least 6 characters');
        if (!/[A-Z]/.test(val[0])) errors.push('First character must be uppercase');
        if (!/@@/.test(val))        errors.push('Must contain @@');
        if (!/[0-9]/.test(val))    errors.push('Must contain at least 1 number');
        if (/\s/.test(val))        errors.push('No spaces allowed');
        return errors;
    }

    // Realtime validate khi gõ mật khẩu mới
    document.getElementById('cpNew').addEventListener('input', function () {
        const val = this.value;
        const errEl = document.getElementById('err-cpNew');
        this.classList.remove('is-error');
        errEl.classList.remove('show');
        if (!val) return;
        const errors = validateNewPassword(val);
        if (errors.length > 0) {
            errEl.textContent = errors.join('  |  ');
            errEl.classList.add('show');
            this.classList.add('is-error');
        }
    });

    function validate(cur, nw, conf) {
        let ok = true;
        if (!cur) {
            fieldErr('cpCurrent', 'Current password is required.');
            ok = false;
        }
        if (!nw) {
            fieldErr('cpNew', 'New password is required.');
            ok = false;
        } else {
            const errors = validateNewPassword(nw);
            if (errors.length > 0) {
                fieldErr('cpNew', errors.join('  |  '));
                ok = false;
            }
        }
        if (!conf) {
            fieldErr('cpConfirm', 'Please confirm your new password.');
            ok = false;
        } else if (nw !== conf) {
            fieldErr('cpConfirm', 'Passwords do not match.');
            ok = false;
        }
        return ok;
    }

    // Submit
    document.getElementById('cpForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        clearAll();

        const cur  = document.getElementById('cpCurrent').value.trim();
        const nw   = document.getElementById('cpNew').value.trim();
        const conf = document.getElementById('cpConfirm').value.trim();

        if (!validate(cur, nw, conf)) return;

        setLoading(true);
        try {
            const res = await fetch('@Url.Action("ChangePassword", "Customer")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    currentPassword:    cur,
                    newPassword:        nw,
                    confirmNewPassword: conf
                })
            });
            const data = await res.json();

            if (data.success) {
                showBanner('success', data.message || 'Password changed successfully!');
                document.getElementById('cpForm').reset();
                document.getElementById('cpStrengthFill').style.width = '0%';
                document.getElementById('cpStrengthLabel').textContent = '';
                setTimeout(() => {
                    window.location.href = '@Url.Action("Profile", "Customer")';
                }, 2000);
            } else {
                if (data.message?.toLowerCase().includes('current password')) {
                    fieldErr('cpCurrent', data.message);
                } else {
                    showBanner('error', data.message || 'Failed to change password.');
                }
            }
        } catch {
            showBanner('error', 'Network error. Please try again.');
        } finally {
            setLoading(false);
        }
    });

    // Clear error on retype (trừ cpNew tự handle ở trên)
    ['cpCurrent', 'cpConfirm'].forEach(id => {
        document.getElementById(id).addEventListener('input', () => {
            document.getElementById('err-' + id).classList.remove('show');
            document.getElementById(id).classList.remove('is-error');
        });
    });
</script>