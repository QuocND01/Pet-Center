@model PetCenterClient.DTOs.VerifyEmailDto
@{
	Layout = null;
}

<!DOCTYPE html>
<html>
<head>

	<meta name="viewport" content="width=device-width, initial-scale=1">

	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">

	<style>

		body {
			height: 100vh;
			display: flex;
			justify-content: center;
			align-items: center;
			background: linear-gradient(135deg,#2ecc71,#27ae60);
			font-family: Segoe UI;
		}

		.verify-card {
			width: 420px;
			background: white;
			padding: 40px;
			border-radius: 15px;
			box-shadow: 0 10px 40px rgba(0,0,0,0.2);
		}

		.title {
			font-size: 26px;
			font-weight: 700;
			text-align: center;
			color: #2ecc71;
			margin-bottom: 20px;
		}

		.logo {
			font-size: 40px;
			text-align: center;
			margin-bottom: 10px;
		}

		.error {
			color: red;
			text-align: center;
			margin-bottom: 10px;
		}

		.otp-input {
			width: 50px;
			height: 50px;
			font-size: 22px;
			text-align: center;
			border-radius: 10px;
			border: 1px solid #ccc;
		}

		.btn-verify {
			height: 45px;
			border-radius: 10px;
			background: #2ecc71;
			border: none;
			font-weight: 600;
		}

	</style>

</head>

<body>

	<div class="verify-card">

		<div class="logo">📧</div>

		<div class="title">Email Verification</div>

		@if (ViewBag.Error != null)
		{
			<div class="error">@ViewBag.Error</div>
		}

		<form method="post">

			<input type="hidden" name="Email" value="@Model.Email" />

			<div class="d-flex justify-content-between mb-3">

				<input class="otp-input" maxlength="1" inputmode="numeric">
				<input class="otp-input" maxlength="1" inputmode="numeric">
				<input class="otp-input" maxlength="1" inputmode="numeric">
				<input class="otp-input" maxlength="1" inputmode="numeric">
				<input class="otp-input" maxlength="1" inputmode="numeric">
				<input class="otp-input" maxlength="1" inputmode="numeric">

			</div>

			<input type="hidden" name="Code" id="Code">

			<button class="btn btn-verify w-100" id="verifyBtn" disabled>Verify</button>

		</form>

		<form method="post" action="/Auth/Resend" class="mt-3">

			<input type="hidden" name="email" value="@Model.Email" />

			<button id="resendBtn" class="btn btn-secondary w-100">
				Resend Code
			</button>

			<div id="countdown" class="text-center mt-2"></div>

		</form>

	</div>

	<script>

		const inputs = document.querySelectorAll(".otp-input");
		const hiddenCode = document.getElementById("Code");
		const verifyBtn = document.getElementById("verifyBtn");

		inputs[0].focus();

		inputs.forEach((input,index)=>{

		input.addEventListener("input",()=>{

		input.value = input.value.replace(/[^0-9]/g,'');

		if(input.value && index < inputs.length-1){
		inputs[index+1].focus();
		}

		updateCode();

		});

		input.addEventListener("keydown",(e)=>{

		if(e.key === "Backspace" && input.value === "" && index>0){
		inputs[index-1].focus();
		}

		});

		});

		function updateCode(){

		let code="";

		inputs.forEach(i=> code += i.value);

		hiddenCode.value = code;

		verifyBtn.disabled = code.length !== 6;

		}

		// paste OTP
		document.addEventListener("paste",function(e){

		const paste = (e.clipboardData || window.clipboardData).getData('text');

		if(paste.length === 6 && /^\d+$/.test(paste)){

		inputs.forEach((input,index)=>{
		input.value = paste[index];
		});

		updateCode();

		}

		});

		// resend countdown
		let seconds = 45;

		const btn = document.getElementById("resendBtn");
		const text = document.getElementById("countdown");

		btn.disabled = true;

		const timer = setInterval(()=>{

		seconds--;

		text.innerHTML = "Resend code in " + seconds + "s";

		if(seconds <= 0){

		clearInterval(timer);

		btn.disabled = false;

		text.innerHTML = "You can resend code now";

		}

		},1000);

	</script>

</body>
</html>