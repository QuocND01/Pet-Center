@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>

    <meta name="viewport" content="width=device-width, initial-scale=1">

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">

    <style>

        body{
        height:100vh;
        display:flex;
        justify-content:center;
        align-items:center;
        background:linear-gradient(135deg,#2ecc71,#27ae60);
        font-family:Segoe UI;
        }

        .login-card{

        width:420px;
        background:white;
        padding:40px;
        border-radius:15px;
        box-shadow:0 10px 40px rgba(0,0,0,0.2);

        }

        .login-title{

        font-size:28px;
        font-weight:700;
        text-align:center;
        color:#2ecc71;
        margin-bottom:30px;

        }

        .form-control{

        height:45px;
        border-radius:10px;

        }

        .btn-login{

        height:45px;
        border-radius:10px;
        background:#2ecc71;
        border:none;
        font-weight:600;

        }

        .btn-login:hover{

        background:#27ae60;

        }

        .logo{

        font-size:40px;
        text-align:center;
        margin-bottom:10px;

        }

        .error{

        color:red;
        text-align:center;
        margin-bottom:10px;

        }

    </style>

</head>

<body>

    <div class="login-card">

        <div class="logo">🐶</div>

        <div class="login-title">
            PetCenter Login
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="error">@ViewBag.Error</div>
        }

        <form method="post">

            <div class="mb-3">

                <input type="email"
                       name="Email"
                       class="form-control"
                       placeholder="Email"
                       required />

            </div>

            <div class="mb-3">

                <input type="password"
                       name="Password"
                       class="form-control"
                       placeholder="Password"
                       required />

            </div>

            <button type="submit"
                    class="btn btn-login w-100">

                Login

            </button>

        </form>

    </div>

</body>
</html>