@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Forgot Password — PetCenter</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        :root {
            --green: #2ecc71;
            --green-dark: #27ae60;
            --green-soft: #f0fdf4;
            --text: #1e2d3d;
            --muted: #64748b;
            --border: #e2e8f0;
            --error: #ef4444;
            --radius: 14px;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #f1f5f9;
            position: relative;
            overflow: hidden;
        }

            body::before, body::after {
                content: '';
                position: fixed;
                border-radius: 50%;
                filter: blur(80px);
                opacity: .25;
                pointer-events: none;
            }

            body::before {
                width: 520px;
                height: 520px;
                background: var(--green);
                top: -160px;
                left: -120px;
            }

            body::after {
                width: 400px;
                height: 400px;
                background: #3b82f6;
                bottom: -100px;
                right: -80px;
            }

        .card {
            position: relative;
            background: #fff;
            width: 100%;
            max-width: 460px;
            border-radius: 24px;
            padding: 48px 44px 44px;
            box-shadow: 0 8px 40px rgba(0,0,0,.10), 0 1px 3px rgba(0,0,0,.06);
            animation: slideUp .45s cubic-bezier(.22,1,.36,1) both;
        }

        @@keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(28px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .icon-wrap {
            width: 68px;
            height: 68px;
            background: var(--green-soft);
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 34px;
            margin-bottom: 24px;
        }

        h1 {
            font-size: 26px;
            font-weight: 800;
            color: var(--text);
            letter-spacing: -.6px;
            margin-bottom: 8px;
        }

        .subtitle {
            font-size: 14px;
            color: var(--muted);
            line-height: 1.6;
            margin-bottom: 32px;
        }

        label {
            display: block;
            font-size: 13px;
            font-weight: 600;
            color: var(--text);
            margin-bottom: 6px;
        }

        .input-wrap {
            position: relative;
            margin-bottom: 20px;
        }

            .input-wrap svg {
                position: absolute;
                left: 15px;
                top: 50%;
                transform: translateY(-50%);
                color: #94a3b8;
                pointer-events: none;
            }

        input[type="email"] {
            width: 100%;
            height: 50px;
            padding: 0 16px 0 44px;
            border: 1.5px solid var(--border);
            border-radius: var(--radius);
            font-size: 15px;
            font-family: inherit;
            color: var(--text);
            background: #f8fafc;
            outline: none;
            transition: border .2s,box-shadow .2s,background .2s;
        }

            input[type="email"]:focus {
                border-color: var(--green);
                background: #fff;
                box-shadow: 0 0 0 4px rgba(46,204,113,.12);
            }

            input[type="email"].error-input {
                border-color: var(--error);
                box-shadow: 0 0 0 4px rgba(239,68,68,.10);
            }

        .btn {
            width: 100%;
            height: 52px;
            border: none;
            border-radius: var(--radius);
            background: linear-gradient(135deg,var(--green),var(--green-dark));
            color: #fff;
            font-size: 15px;
            font-weight: 700;
            font-family: inherit;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            box-shadow: 0 4px 16px rgba(46,204,113,.35);
            transition: opacity .2s,transform .15s,box-shadow .2s;
        }

            .btn:hover:not(:disabled) {
                opacity: .92;
                transform: translateY(-1px);
                box-shadow: 0 8px 24px rgba(46,204,113,.45);
            }

            .btn:active:not(:disabled) {
                transform: translateY(0);
            }

            .btn:disabled {
                opacity: .65;
                cursor: not-allowed;
            }

        .spinner {
            width: 18px;
            height: 18px;
            border: 2.5px solid rgba(255,255,255,.4);
            border-top-color: #fff;
            border-radius: 50%;
            animation: spin .7s linear infinite;
            display: none;
        }

        @@keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        .alert {
            display: none;
            border-radius: var(--radius);
            padding: 14px 16px;
            font-size: 13.5px;
            line-height: 1.5;
            margin-bottom: 20px;
        }

        .alert-error {
            background: #fef2f2;
            color: #b91c1c;
            border: 1px solid #fecaca;
        }

        .success-state {
            display: none;
            text-align: center;
            animation: slideUp .4s cubic-bezier(.22,1,.36,1) both;
        }

        .success-icon {
            width: 76px;
            height: 76px;
            background: var(--green-soft);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
            font-size: 38px;
        }

        .success-state h2 {
            font-size: 22px;
            font-weight: 800;
            color: var(--text);
            margin-bottom: 10px;
        }

        .success-state p {
            font-size: 14px;
            color: var(--muted);
            line-height: 1.6;
            margin-bottom: 28px;
        }

        .back-link {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            margin-top: 24px;
            font-size: 13.5px;
            color: var(--muted);
            text-decoration: none;
            font-weight: 500;
            transition: color .2s;
        }

            .back-link:hover {
                color: var(--green);
            }

        .security-note {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            background: var(--green-soft);
            border: 1px solid #bbf7d0;
            border-radius: 10px;
            padding: 12px 14px;
            margin-top: 20px;
        }

            .security-note span:first-child {
                font-size: 16px;
                flex-shrink: 0;
                margin-top: 1px;
            }

            .security-note p {
                font-size: 12.5px;
                color: #166534;
                line-height: 1.5;
                margin: 0;
            }
    </style>
</head>
<body>
    <div class="card">

        <div id="formState">
            <div class="icon-wrap">🔑</div>
            <h1>Forgot password?</h1>
            <p class="subtitle">
                No worries! Enter your registered email and we'll send you
                a link to reset your password.
            </p>

            <div class="alert alert-error" id="alertError"></div>

            <label for="emailInput">Email address</label>
            <div class="input-wrap">
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                    <polyline points="22,6 12,12 2,6" />
                </svg>
                <input type="email" id="emailInput" placeholder="you@example.com" autocomplete="email" />
            </div>

            <button class="btn" id="submitBtn" onclick="handleSubmit()">
                <span class="spinner" id="spinner"></span>
                <span id="btnText">Send Reset Link</span>
            </button>

            <div class="security-note">
                <span>🔒</span>
                <p>For your security, reset links expire after <strong>15 minutes</strong> and can only be used once.</p>
            </div>

            <a href="/Auth/Login" class="back-link">
                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                    <polyline points="15 18 9 12 15 6" />
                </svg>
                Back to Login
            </a>
        </div>

        <div class="success-state" id="successState">
            <div class="success-icon">✉️</div>
            <h2>Check your inbox</h2>
            <p>We've sent a password reset link to<br><strong id="sentEmail"></strong></p>
            <p style="margin-bottom:0;">
                Didn't receive the email? Check your spam folder, or
                <a href="/Auth/ForgotPassword" style="color:var(--green);font-weight:600;text-decoration:none;">try a different email</a>.
            </p>
            <a href="/Auth/Login" class="back-link" style="margin-top:28px;">
                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                    <polyline points="15 18 9 12 15 6" />
                </svg>
                Back to Login
            </a>
        </div>

    </div>

    <script>
        const emailInput = document.getElementById('emailInput');
        const spinner    = document.getElementById('spinner');
        const btnText    = document.getElementById('btnText');
        const submitBtn  = document.getElementById('submitBtn');
        const alertError = document.getElementById('alertError');

        emailInput.addEventListener('keydown', e => { if (e.key === 'Enter') handleSubmit(); });

        function showError(msg) {
            alertError.textContent = msg;
            alertError.style.display = 'block';
            emailInput.classList.add('error-input');
        }

        function hideError() {
            alertError.style.display = 'none';
            emailInput.classList.remove('error-input');
        }

        function setLoading(on) {
            submitBtn.disabled = on;
            spinner.style.display = on ? 'block' : 'none';
            btnText.textContent = on ? 'Sending...' : 'Send Reset Link';
        }

        async function handleSubmit() {
            hideError();
            const email = emailInput.value.trim();

            if (!email) { showError('Please enter your email address.'); return; }

            const emailRegex = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;
            if (!emailRegex.test(email)) { showError('Please enter a valid email address.'); return; }

            setLoading(true);
            try {
                const res  = await fetch('/Auth/ForgotPassword', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: `email=${encodeURIComponent(email)}`
                });
                const data = await res.json();

                if (data.success) {
                    document.getElementById('formState').style.display = 'none';
                    document.getElementById('sentEmail').textContent = email;
                    document.getElementById('successState').style.display = 'block';
                } else {
                    showError(data.message || 'Something went wrong. Please try again.');
                }
            } catch {
                showError('Network error. Please check your connection and try again.');
            } finally {
                setLoading(false);
            }
        }
    </script>
</body>
</html>