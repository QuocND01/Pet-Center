@model PetCenterClient.DTOs.RegisterDto
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
    <style>
        body {
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            background: linear-gradient(135deg,#2ecc71,#27ae60);
            font-family: Segoe UI;
        }

        .register-card {
            width: 450px;
            background: white;
            padding: 40px;
            border-radius: 15px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.2);
        }

        .title {
            font-size: 28px;
            font-weight: 700;
            text-align: center;
            color: #2ecc71;
            margin-bottom: 30px;
        }

        .form-control {
            height: 45px;
            border-radius: 10px;
        }

        .btn-register {
            height: 45px;
            border-radius: 10px;
            background: #2ecc71;
            border: none;
            font-weight: 600;
        }

            .btn-register:hover {
                background: #27ae60;
            }

        .logo {
            font-size: 40px;
            text-align: center;
            margin-bottom: 10px;
        }

        .error {
            color: red;
            text-align: center;
            margin-bottom: 10px;
        }

        .password-match-error {
            color: red;
            font-size: 14px;
            display: none;
        }

        .password-match-success {
            color: green;
            font-size: 14px;
            display: none;
        }
    </style>
</head>
<body>
    <div class="register-card">
        <div class="logo">🐶</div>
        <div class="title">Create Account</div>
        @if (ViewBag.Error != null)
        {
            <div class="error">@ViewBag.Error</div>
        }
        <form method="post" id="registerForm">
            <!-- Thêm id vào các input trong form -->
            <input id="fullName" name="FullName" class="form-control mb-3" placeholder="Full Name" required />
            <input type="email" id="email" name="Email" class="form-control mb-3" placeholder="Email" required />
            <input id="phoneNumber" name="PhoneNumber" pattern="[0-9]{10}"
                   class="form-control mb-3" placeholder="Phone Number" required />
            <input type="password" id="password" name="Password" class="form-control mb-2" placeholder="Password" required />
            <div id="passwordStrength" style="font-size:14px;margin-bottom:10px;"></div>
            <input type="password" id="confirmPassword" class="form-control mb-2" placeholder="Confirm Password" required />
            <div id="passwordMatch" class="password-match-error">Passwords do not match</div>
            <div id="passwordMatchSuccess" class="password-match-success">Passwords match</div>
            <input type="date" id="birthDay" name="BirthDay" class="form-control mb-3" />
            <select id="gender" name="Gender" class="form-control mb-3" required>
                <option value="">-- Select Gender --</option>
                <option value="Male">Male</option>
                <option value="Female">Female</option>
                <option value="Other">Other</option>
            </select>
            <button type="submit" class="btn btn-register w-100" id="registerBtn">Register</button>
        </form>
        <div class="text-center mt-3">
            Already have an account?
            <a href="/Auth/Login" style="color:#2ecc71;font-weight:600;">Login</a>
        </div>
    </div>
    <script>
    const passwordInput   = document.getElementById("password");
    const confirmPassword = document.getElementById("confirmPassword");
    const strength        = document.getElementById("passwordStrength");
    const passwordMatch   = document.getElementById("passwordMatch");
    const passwordMatchSuccess = document.getElementById("passwordMatchSuccess");
    const registerBtn     = document.getElementById("registerBtn");
    const registerForm    = document.getElementById("registerForm");

    // ============================================================
    // FULL NAME
    // ============================================================
    const fullNameInput = document.getElementById("fullName");
    const fullNameMsg   = document.createElement("div");
    fullNameMsg.style.cssText = "font-size:13px;margin-top:-10px;margin-bottom:10px;display:none;";
    fullNameInput.insertAdjacentElement("afterend", fullNameMsg);

    function validateFullName(val) {
        const trimmed = val.trim();
        if (trimmed.length < 2)                         return "Full name must be at least 2 characters";
        if (!/^[a-zA-ZÀ-ỹ\s]+$/.test(trimmed))         return "Full name must contain letters only";
        if (trimmed.split(/\s+/).length < 2)            return "Please enter your full name (first and last name)";
        return "";
    }

    fullNameInput.addEventListener("input", function () {
        const err = validateFullName(this.value);
        fullNameMsg.innerHTML    = err ? "❌ " + err : "✓ Looks good";
        fullNameMsg.style.color  = err ? "red" : "green";
        fullNameMsg.style.display = "block";
    });
    fullNameInput.addEventListener("blur", () => { fullNameMsg.style.display = "none"; });

    // ============================================================
    // EMAIL
    // ============================================================
    const emailInput = document.getElementById("email");
    const emailMsg   = document.createElement("div");
    emailMsg.style.cssText = "font-size:13px;margin-top:-10px;margin-bottom:10px;display:none;";
    emailInput.insertAdjacentElement("afterend", emailMsg);

    function validateEmail(val) {
        if (!val)                                              return "Email is required";
        if (!/^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(val))         return "Invalid email format";
        return "";
    }

    emailInput.addEventListener("input", function () {
        const err = validateEmail(this.value);
        emailMsg.innerHTML    = err ? "❌ " + err : "✓ Valid email";
        emailMsg.style.color  = err ? "red" : "green";
        emailMsg.style.display = "block";
    });
    emailInput.addEventListener("blur", () => { emailMsg.style.display = "none"; });

    // ============================================================
    // PHONE
    // ============================================================
    const phoneInput = document.getElementById("phoneNumber");
    const phoneMsg   = document.createElement("div");
    phoneMsg.style.cssText = "font-size:13px;margin-top:-10px;margin-bottom:10px;display:none;";
    phoneInput.insertAdjacentElement("afterend", phoneMsg);

    function validatePhone(val) {
        if (!val)                          return "Phone number is required";
        if (!/^0[0-9]{9}$/.test(val))     return "Must start with 0 and be exactly 10 digits";
        return "";
    }

    phoneInput.addEventListener("input", function () {
        const err = validatePhone(this.value);
        phoneMsg.innerHTML    = err ? "❌ " + err : "✓ Valid phone number";
        phoneMsg.style.color  = err ? "red" : "green";
        phoneMsg.style.display = "block";
    });
    phoneInput.addEventListener("blur", () => { phoneMsg.style.display = "none"; });

    // ============================================================
    // BIRTHDAY
    // ============================================================
    const birthdayInput = document.getElementById("birthDay");
    const birthdayMsg   = document.createElement("div");
    birthdayMsg.style.cssText = "font-size:13px;margin-top:-10px;margin-bottom:10px;display:none;";
    birthdayInput.insertAdjacentElement("afterend", birthdayMsg);

    const today      = new Date();
    const minAgeDate = new Date();
    minAgeDate.setFullYear(minAgeDate.getFullYear() - 16);
    birthdayInput.max = today.toISOString().split("T")[0];

    function validateBirthday(val) {
        if (!val) return "";
        const birth = new Date(val);
        if (birth > today)      return "Birthday cannot be in the future";
        if (birth > minAgeDate) return "You must be at least 16 years old to register";
        return "";
    }

    birthdayInput.addEventListener("change", function () {
        const err = validateBirthday(this.value);
        if (this.value) {
            birthdayMsg.innerHTML    = err ? "❌ " + err : "✓ Valid date of birth";
            birthdayMsg.style.color  = err ? "red" : "green";
            birthdayMsg.style.display = "block";
        } else {
            birthdayMsg.style.display = "none";
        }
    });
    birthdayInput.addEventListener("blur", () => { birthdayMsg.style.display = "none"; });

    // ============================================================
    // PASSWORD
    // ============================================================
    function validatePassword(val) {
        const errors = [];
        if (val.length < 6)             errors.push("At least 6 characters");
        if (!/[A-Z]/.test(val[0]))      errors.push("First character must be uppercase");
        if (!/@@/.test(val))             errors.push("Must contain @@");
        if (!/[0-9]/.test(val))         errors.push("Must contain at least 1 number");
        if (/\s/.test(val))             errors.push("No spaces allowed");
        return errors;
    }

    function showStrength() {
        const val = passwordInput.value;
        if (!val) { strength.innerHTML = ""; return; }
        const errors = validatePassword(val);
        strength.innerHTML = errors.length === 0
            ? "✓ Strong password"
            : "❌ " + errors.join(" &nbsp;|&nbsp; ❌ ");
        strength.style.color = errors.length === 0 ? "green" : "red";
    }

    passwordInput.addEventListener("input", showStrength);
    passwordInput.addEventListener("focus", function () { if (passwordInput.value) showStrength(); });
    passwordInput.addEventListener("blur",  () => { strength.innerHTML = ""; });

    // ============================================================
    // CONFIRM PASSWORD
    // ============================================================
    function showMatch() {
        if (!confirmPassword.value) {
            passwordMatch.style.display        = "none";
            passwordMatchSuccess.style.display = "none";
            return;
        }
        const match = passwordInput.value === confirmPassword.value;
        passwordMatch.style.display        = match ? "none"  : "block";
        passwordMatchSuccess.style.display = match ? "block" : "none";
        registerBtn.disabled = !match;
    }

    confirmPassword.addEventListener("input", showMatch);
    confirmPassword.addEventListener("focus", function () { if (confirmPassword.value) showMatch(); });
    confirmPassword.addEventListener("blur",  () => {
        passwordMatch.style.display        = "none";
        passwordMatchSuccess.style.display = "none";
    });

    // ============================================================
    // ERROR BANNER
    // ============================================================
    const errorDiv = document.querySelector(".error") || (() => {
        const d = document.createElement("div");
        d.className = "error";
        d.style.display = "none";
        registerForm.insertAdjacentElement("beforebegin", d);
        return d;
    })();

    function showError(msg) {
        errorDiv.textContent = msg;
        errorDiv.style.display = "block";
        errorDiv.style.color = "red";
        errorDiv.style.textAlign = "center";
        errorDiv.style.marginBottom = "10px";
        errorDiv.scrollIntoView({ behavior: "smooth", block: "center" });
    }

    function hideError() {
        errorDiv.style.display = "none";
        errorDiv.textContent = "";
    }

    // ============================================================
    // SUBMIT — AJAX, giữ nguyên data khi lỗi
    // ============================================================
    registerForm.addEventListener("submit", async function (e) {
        e.preventDefault();
        hideError();

        const fullName   = fullNameInput.value.trim();
        const email      = emailInput.value.trim();
        const phone      = phoneInput.value.trim();
        const password   = passwordInput.value;
        const confirm    = confirmPassword.value;
        const birthday   = birthdayInput.value;
        const gender     = document.getElementById("gender").value;

        // Client-side validate
        const allErrors = [];
        const nameErr = validateFullName(fullName);
        if (nameErr)   allErrors.push("Full Name: " + nameErr);

        const emailErr = validateEmail(email);
        if (emailErr)  allErrors.push("Email: " + emailErr);

        const phoneErr = validatePhone(phone);
        if (phoneErr)  allErrors.push("Phone: " + phoneErr);

        const bdErr = validateBirthday(birthday);
        if (bdErr)     allErrors.push("Birthday: " + bdErr);

        const passErrors = validatePassword(password);
        if (passErrors.length > 0) allErrors.push("Password: " + passErrors.join(", "));

        if (password !== confirm) allErrors.push("Passwords do not match");
        if (!gender)              allErrors.push("Please select a gender");

        if (allErrors.length > 0) {
            showError(allErrors.join(" | "));
            return;
        }

        // Disable button
        registerBtn.disabled     = true;
        registerBtn.textContent  = "Registering...";

        try {
            const formData = new FormData(registerForm);
            const response = await fetch(registerForm.action || window.location.href, {
                method: "POST",
                headers: { "RequestVerificationToken": document.querySelector('input[name="__RequestVerificationToken"]')?.value || "" },
                body: formData
            });

            const result = await response.json();

            if (result.success) {
                window.location.href = result.redirectUrl;
            } else {
                // Hiện lỗi nhưng GIỮ NGUYÊN data người dùng đã nhập
                showError(result.message || "Registration failed. Please try again.");
                registerBtn.disabled    = false;
                registerBtn.textContent = "Register";
            }
        } catch (err) {
            showError("An error occurred. Please try again.");
            registerBtn.disabled    = false;
            registerBtn.textContent = "Register";
        }
    });
</script>
</body>
</html>