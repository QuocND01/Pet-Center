@{
    Layout = null;
    bool tokenValid = ViewBag.TokenValid == true;
    string email = ViewBag.Email ?? "";
    string token = ViewBag.Token ?? "";
    string tokenErr = ViewBag.TokenError ?? "This reset link is invalid or has expired.";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Reset Password — PetCenter</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --green:      #2ecc71;
            --green-dark: #27ae60;
            --green-soft: #f0fdf4;
            --text:       #1e2d3d;
            --muted:      #64748b;
            --border:     #e2e8f0;
            --error:      #ef4444;
            --radius:     14px;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            min-height: 100vh;
            display: flex; align-items: center; justify-content: center;
            background: #f1f5f9;
            position: relative; overflow: hidden;
        }

        body::before, body::after {
            content: ''; position: fixed; border-radius: 50%;
            filter: blur(80px); opacity: .25; pointer-events: none;
        }
        body::before { width:520px;height:520px;background:var(--green);top:-160px;left:-120px; }
        body::after  { width:400px;height:400px;background:#8b5cf6;bottom:-100px;right:-80px; }

        .card {
            position: relative; background: #fff;
            width: 100%; max-width: 480px;
            border-radius: 24px; padding: 48px 44px 44px;
            box-shadow: 0 8px 40px rgba(0,0,0,.10), 0 1px 3px rgba(0,0,0,.06);
            animation: slideUp .45s cubic-bezier(.22,1,.36,1) both;
        }

        @@keyframes slideUp {
            from { opacity:0; transform:translateY(28px); }
            to   { opacity:1; transform:translateY(0); }
        }

        .icon-wrap {
            width:68px;height:68px;border-radius:20px;
            display:flex;align-items:center;justify-content:center;
            font-size:34px;margin-bottom:24px;
        }
        .icon-valid   { background:var(--green-soft); }
        .icon-invalid { background:#fef2f2; }

        h1 { font-size:26px;font-weight:800;color:var(--text);letter-spacing:-.6px;margin-bottom:8px; }
        .subtitle { font-size:14px;color:var(--muted);line-height:1.6;margin-bottom:32px; }

        label { display:block;font-size:13px;font-weight:600;color:var(--text);margin-bottom:6px; }
        .field { margin-bottom:20px; }

        .input-wrap { position:relative; }
        .input-wrap svg.icon-left {
            position:absolute;left:15px;top:50%;transform:translateY(-50%);
            color:#94a3b8;pointer-events:none;
        }

        input[type="password"],
        input[type="text"].pw-field {
            width: 100%;
            height: 50px;
            padding: 0 48px 0 44px;
            border: 1.5px solid var(--border);
            border-radius: var(--radius);
            font-size: 15px;
            font-family: inherit;
            color: var(--text);
            background: #f8fafc;
            outline: none;
            transition: border .2s,box-shadow .2s,background .2s;
        }

            input[type="password"]:focus,
            input[type="text"].pw-field:focus {
                border-color: var(--green);
                background: #fff;
                box-shadow: 0 0 0 4px rgba(46,204,113,.12);
            }

            input[type="password"].error-input,
            input[type="text"].pw-field.error-input {
                border-color: var(--error);
                box-shadow: 0 0 0 4px rgba(239,68,68,.10);
            }

        .toggle-pw {
            position:absolute;right:14px;top:50%;transform:translateY(-50%);
            background:none;border:none;cursor:pointer;color:#94a3b8;
            padding:4px;display:flex;transition:color .2s;
        }
        .toggle-pw:hover { color:var(--text); }

        .strength-bar-wrap { display:flex;gap:4px;margin-top:8px; }
        .strength-seg { flex:1;height:4px;border-radius:4px;background:#e2e8f0;transition:background .3s; }
        .strength-label { font-size:11.5px;color:var(--muted);margin-top:5px;text-align:right; }

        .match-hint { font-size:12px;margin-top:6px; }
        .match-ok  { color:var(--green); }
        .match-bad { color:var(--error); }

        .btn {
            width:100%;height:52px;border:none;border-radius:var(--radius);
            background:linear-gradient(135deg,var(--green),var(--green-dark));
            color:#fff;font-size:15px;font-weight:700;font-family:inherit;cursor:pointer;
            display:flex;align-items:center;justify-content:center;gap:8px;
            box-shadow:0 4px 16px rgba(46,204,113,.35);
            transition:opacity .2s,transform .15s,box-shadow .2s;
        }
        .btn:hover:not(:disabled) { opacity:.92;transform:translateY(-1px);box-shadow:0 8px 24px rgba(46,204,113,.45); }
        .btn:active:not(:disabled) { transform:translateY(0); }
        .btn:disabled { opacity:.65;cursor:not-allowed; }

        .spinner {
            width:18px;height:18px;
            border:2.5px solid rgba(255,255,255,.4);border-top-color:#fff;
            border-radius:50%;animation:spin .7s linear infinite;display:none;
        }
        @@keyframes spin { to { transform:rotate(360deg); } }

        .alert { display:none;border-radius:var(--radius);padding:14px 16px;font-size:13.5px;line-height:1.5;margin-bottom:20px; }
        .alert-error { background:#fef2f2;color:#b91c1c;border:1px solid #fecaca; }

        .success-state {
            display:none;text-align:center;
            animation:slideUp .4s cubic-bezier(.22,1,.36,1) both;
        }
        .success-icon {
            width:76px;height:76px;background:var(--green-soft);border-radius:50%;
            display:flex;align-items:center;justify-content:center;
            margin:0 auto 20px;font-size:38px;
        }
        .success-state h2 { font-size:22px;font-weight:800;color:var(--text);margin-bottom:10px; }
        .success-state p { font-size:14px;color:var(--muted);line-height:1.6;margin-bottom:28px; }

        .back-link {
            display:flex;align-items:center;justify-content:center;gap:6px;
            margin-top:20px;font-size:13.5px;color:var(--muted);
            text-decoration:none;font-weight:500;transition:color .2s;
        }
        .back-link:hover { color:var(--green); }

        .req-list { margin-top:8px;display:flex;flex-direction:column;gap:4px; }
        .req-item { display:flex;align-items:center;gap:6px;font-size:12px;color:#94a3b8;transition:color .2s; }
        .req-item.ok { color:var(--green); }
        .req-item .dot { width:6px;height:6px;border-radius:50%;background:currentColor;flex-shrink:0; }
    </style>
</head>
<body>
<div class="card">

        @if (!tokenValid)
        {
        <div style="text-align:center;">
            <div class="icon-wrap icon-invalid" style="margin:0 auto 24px;">⚠️</div>
            <h1>Link Expired</h1>
            <p class="subtitle">@tokenErr</p>
            <p class="subtitle" style="margin-bottom:28px;">
                Reset links are valid for <strong>15 minutes</strong>.
                Please request a new one to continue.
            </p>
            <a href="/Auth/ForgotPassword">
                <button class="btn" style="margin-bottom:12px;">Request New Reset Link</button>
            </a>
            <a href="/Auth/Login" class="back-link">
                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                    <polyline points="15 18 9 12 15 6"/>
                </svg>
                Back to Login
            </a>
        </div>
        }
        else
        {
        <div id="formState">
            <div class="icon-wrap icon-valid">🔐</div>
            <h1>Create new password</h1>
            <p class="subtitle">
                Your new password must be at least 8 characters and different from your previous one.
            </p>

            <div class="alert alert-error" id="alertError"></div>

            <div class="field">
                <label>New Password</label>
                <div class="input-wrap">
                    <svg class="icon-left" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                        <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                    </svg>
                        <input type="password" id="newPassword" class="pw-field" placeholder="Enter new password" oninput="evalStrength()" />
                    <button type="button" class="toggle-pw" onclick="togglePw('newPassword', this)">
                        <svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                            <circle cx="12" cy="12" r="3"/>
                        </svg>
                    </button>
                </div>
                <div class="strength-bar-wrap">
                    <div class="strength-seg" id="s1"></div>
                    <div class="strength-seg" id="s2"></div>
                    <div class="strength-seg" id="s3"></div>
                    <div class="strength-seg" id="s4"></div>
                </div>
                <div class="strength-label" id="strengthLabel">Enter a password</div>
                <div class="req-list">
    <div class="req-item" id="req-len"><span class="dot"></span>At least 6 characters</div>
    <div class="req-item" id="req-upper"><span class="dot"></span>Must start with uppercase letter</div>
    <div class="req-item" id="req-lower"><span class="dot"></span>Must contain @@</div>
    <div class="req-item" id="req-num"><span class="dot"></span>Must contain a number</div>
</div>
            </div>

            <div class="field">
                <label>Confirm Password</label>
                <div class="input-wrap">
                    <svg class="icon-left" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M9 12l2 2 4-4"/>
                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                        <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                    </svg>
                        <input type="password" id="confirmPassword" class="pw-field" placeholder="Re-enter password" oninput="checkMatch()" />
                    <button type="button" class="toggle-pw" onclick="togglePw('confirmPassword', this)">
                        <svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                            <circle cx="12" cy="12" r="3"/>
                        </svg>
                    </button>
                </div>
                <div class="match-hint" id="matchHint"></div>
            </div>

            <button class="btn" id="submitBtn" onclick="handleReset()">
                <span class="spinner" id="spinner"></span>
                <span id="btnText">Reset Password</span>
            </button>

            <a href="/Auth/Login" class="back-link" style="margin-top:20px;">
                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                    <polyline points="15 18 9 12 15 6"/>
                </svg>
                Back to Login
            </a>
        </div>

        <div class="success-state" id="successState">
            <div class="success-icon">✅</div>
            <h2>Password Reset!</h2>
            <p>Your password has been updated successfully.<br>You can now login with your new password.</p>
            <a href="/Auth/Login"><button class="btn">Go to Login</button></a>
        </div>
        }

</div>

    @if (tokenValid)
    {
    <script>
        const RESET_EMAIL = '@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(email))';
        const RESET_TOKEN = '@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(token))';

        function togglePw(inputId, btn) {
            const inp = document.getElementById(inputId);
            const isText = inp.type === 'text';
            inp.type = isText ? 'password' : 'text';
            btn.querySelector('svg').innerHTML = isText
                ? '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>'
                : '<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/>';
        }

        function evalStrength() {
    const pw = document.getElementById('newPassword').value;
    const colors = ['#ef4444','#f97316','#eab308','#22c55e'];
    const labels = ['Weak','Fair','Good','Strong'];

    let score = 0;
    if (pw.length >= 6)      score++;
    if (/^[A-Z]/.test(pw))   score++;
    if (/@@/.test(pw))         score++;
    if (/[0-9]/.test(pw))    score++;

    ['s1','s2','s3','s4'].forEach((id, i) => {
        document.getElementById(id).style.background = i < score ? colors[score-1] : '#e2e8f0';
    });
    const lbl = document.getElementById('strengthLabel');
    lbl.textContent = pw.length === 0 ? 'Enter a password' : (labels[score-1] || 'Weak');
    lbl.style.color = pw.length === 0 ? '#94a3b8' : colors[score-1];

    document.getElementById('req-len').classList.toggle('ok',   pw.length >= 6);
    document.getElementById('req-upper').classList.toggle('ok', /^[A-Z]/.test(pw));
    document.getElementById('req-lower').classList.toggle('ok', /@@/.test(pw));
    document.getElementById('req-num').classList.toggle('ok',   /[0-9]/.test(pw));
    checkMatch();
}

        function checkMatch() {
            const pw  = document.getElementById('newPassword').value;
            const cpw = document.getElementById('confirmPassword').value;
            const hint = document.getElementById('matchHint');
            const inp  = document.getElementById('confirmPassword');
            if (!cpw) { hint.textContent = ''; inp.classList.remove('error-input'); return; }
            if (pw === cpw) {
                hint.textContent = '✓ Passwords match';
                hint.className = 'match-hint match-ok';
                inp.classList.remove('error-input');
            } else {
                hint.textContent = '✗ Passwords do not match';
                hint.className = 'match-hint match-bad';
                inp.classList.add('error-input');
            }
        }

        function showError(msg) {
            const el = document.getElementById('alertError');
            el.textContent = msg; el.style.display = 'block';
            el.scrollIntoView({ behavior:'smooth', block:'center' });
        }
        function hideError() { document.getElementById('alertError').style.display = 'none'; }

        function setLoading(on) {
            document.getElementById('submitBtn').disabled = on;
            document.getElementById('spinner').style.display = on ? 'block' : 'none';
            document.getElementById('btnText').textContent = on ? 'Resetting...' : 'Reset Password';
        }

        async function handleReset() {
            hideError();
            const pw  = document.getElementById('newPassword').value;
            const cpw = document.getElementById('confirmPassword').value;

            if (!pw)               { showError('Please enter a new password.'); return; }
if (pw.length < 6)     { showError('Password must be at least 6 characters.'); return; }
if (!/^[A-Z]/.test(pw)){ showError('Password must start with an uppercase letter.'); return; }
if (!/@@/.test(pw))     { showError('Password must contain @@.'); return; }
if (!/[0-9]/.test(pw)) { showError('Password must contain at least one number.'); return; }
if (/\s/.test(pw))     { showError('Password must not contain spaces.'); return; }
if (pw !== cpw)        { showError('Passwords do not match.'); return; }

            setLoading(true);
            try {
                const res = await fetch('/Auth/ResetPassword', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: new URLSearchParams({
                        Token:           RESET_TOKEN,
                        Email:           RESET_EMAIL,
                        NewPassword:     pw,
                        ConfirmPassword: cpw
                    })
                });
                const data = await res.json();
                if (data.success) {
                    document.getElementById('formState').style.display = 'none';
                    document.getElementById('successState').style.display = 'block';
                } else {
                    showError(data.message || 'Failed to reset password. Please try again.');
                }
            } catch {
                showError('Network error. Please check your connection and try again.');
            } finally {
                setLoading(false);
            }
        }
    </script>
    }
</body>
</html>