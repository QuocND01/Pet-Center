@using PetCenterClient.DTOs
@model ReadProductDTO

@{
    ViewData["Title"] = Model.ProductName;
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&family=Fraunces:ital,opsz,wght@0,9..144,700;0,9..144,900;1,9..144,700&display=swap" rel="stylesheet">

<style>
    :root {
        --g0: #f0fdf4;
        --g1: #dcfce7;
        --g3: #2ecc71;
        --g4: #27ae60;
        --g5: #166534;
        --ink: #0f1f0f;
        --ink2: #374151;
        --muted: #6b7280;
        --border: #e5e7eb;
        --surface: #fff;
        --radius: 16px;
        --font: 'Nunito',sans-serif;
        --font-head: 'Fraunces',Georgia,serif;
    }

    .pg {
        font-family: var(--font);
        color: var(--ink);
        max-width: 1000px;
        margin: 0 auto;
        padding: 32px 16px;
    }

    .breadcrumb {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 24px;
        font-size: 13px;
        color: var(--muted);
    }

        .breadcrumb a {
            color: var(--muted);
            text-decoration: none;
            font-weight: 700;
        }

            .breadcrumb a:hover {
                color: var(--g4);
            }

        .breadcrumb span {
            color: var(--border);
        }

    .product-layout {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 40px;
        align-items: start;
    }

    @@media(max-width:700px) {
        .product-layout {
            grid-template-columns: 1fr;
            gap: 24px;
        }
    }

    .img-main {
        aspect-ratio: 1;
        border-radius: var(--radius);
        overflow: hidden;
        background: var(--g0);
        border: 1.5px solid var(--border);
        margin-bottom: 12px;
    }

        .img-main img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform .4s;
            cursor: zoom-in;
        }

            .img-main img:hover {
                transform: scale(1.05);
            }

        .img-main .no-img {
            width: 100%;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 72px;
        }

    .img-thumbs {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

    .thumb {
        width: 64px;
        height: 64px;
        border-radius: 10px;
        object-fit: cover;
        border: 2px solid var(--border);
        cursor: pointer;
        transition: all .2s;
    }

        .thumb:hover, .thumb.active {
            border-color: var(--g3);
        }

    .info-tags {
        display: flex;
        gap: 8px;
        margin-bottom: 14px;
        flex-wrap: wrap;
    }

    .tag {
        font-size: 11px;
        font-weight: 800;
        padding: 4px 12px;
        border-radius: 100px;
        letter-spacing: .04em;
    }

    .tag-cat {
        background: var(--g1);
        color: var(--g5);
    }

    .tag-brand {
        background: #eff6ff;
        color: #1d4ed8;
    }

    .tag-in {
        background: var(--g1);
        color: var(--g5);
    }

    .tag-out {
        background: #fee2e2;
        color: #991b1b;
    }

    .product-name {
        font-family: var(--font-head);
        font-size: clamp(22px,4vw,32px);
        font-weight: 900;
        line-height: 1.2;
        color: var(--ink);
        margin-bottom: 10px;
    }

    .product-price {
        font-family: var(--font-head);
        font-size: 32px;
        font-weight: 900;
        color: var(--g4);
        margin-bottom: 16px;
    }

    .product-desc {
        font-size: 14px;
        color: var(--muted);
        line-height: 1.7;
        margin-bottom: 20px;
    }

    .specs-title {
        font-size: 13px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: .06em;
        color: var(--muted);
        margin-bottom: 10px;
    }

    .specs-table {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 24px;
    }

        .specs-table tr {
            border-bottom: 1px solid var(--border);
        }

            .specs-table tr:last-child {
                border-bottom: none;
            }

        .specs-table td {
            padding: 9px 0;
            font-size: 13px;
        }

            .specs-table td:first-child {
                color: var(--muted);
                font-weight: 700;
                width: 45%;
            }

            .specs-table td:last-child {
                color: var(--ink);
                font-weight: 800;
            }

    .cart-row {
        display: flex;
        gap: 10px;
        align-items: center;
    }

    .qty-wrap {
        display: flex;
        align-items: center;
        border: 1.5px solid var(--border);
        border-radius: 100px;
        overflow: hidden;
    }

    .qty-btn {
        width: 36px;
        height: 40px;
        border: none;
        background: #f9fafb;
        cursor: pointer;
        font-size: 18px;
        font-weight: 700;
        color: var(--ink2);
        transition: background .15s;
    }

        .qty-btn:hover {
            background: var(--g1);
        }

    .qty-input {
        width: 52px;
        height: 40px;
        border: none;
        border-left: 1.5px solid var(--border);
        border-right: 1.5px solid var(--border);
        text-align: center;
        font-family: var(--font);
        font-size: 15px;
        font-weight: 800;
        color: var(--ink);
        outline: none;
    }

    .btn-cart {
        flex: 1;
        background: var(--g3);
        color: #fff;
        border: none;
        border-radius: 100px;
        font-family: var(--font);
        font-weight: 800;
        font-size: 15px;
        height: 44px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        box-shadow: 0 4px 16px rgba(46,204,113,.35);
        transition: all .2s;
    }

        .btn-cart:hover:not(:disabled) {
            background: var(--g4);
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(46,204,113,.45);
        }

        .btn-cart:disabled {
            opacity: .6;
            cursor: not-allowed;
            transform: none;
        }

    .stock-note {
        font-size: 12px;
        color: var(--muted);
        font-weight: 700;
        margin-top: 8px;
    }

    /* ── TOAST ── */
    .pc-toast-container {
        position: fixed;
        top: 80px;
        right: 24px;
        z-index: 999999;
        display: flex;
        flex-direction: column;
        gap: 10px;
        pointer-events: none;
        max-width: 320px;
    }

    .pc-toast {
        pointer-events: auto;
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 14px 18px;
        border-radius: 14px;
        font-family: var(--font);
        font-size: 14px;
        font-weight: 800;
        color: #fff;
        box-shadow: 0 8px 32px rgba(0,0,0,.2);
        opacity: 1;
        transform: translateX(0);
        transition: opacity .35s ease, transform .35s ease;
    }

        .pc-toast.ok {
            background: var(--g4);
        }

        .pc-toast.err {
            background: #e74c3c;
        }

        .pc-toast.fade-out {
            opacity: 0;
            transform: translateX(30px);
        }

    .pc-toast-icon {
        font-size: 18px;
        flex-shrink: 0;
    }

    @@keyframes toastIn {
        from {
            opacity: 0;
            transform: translateX(40px);
        }

        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    .pc-toast {
        animation: toastIn .3s cubic-bezier(.22,1,.36,1) both;
    }

    /* spinner */
    .btn-spin {
        width: 16px;
        height: 16px;
        flex-shrink: 0;
        border: 2.5px solid rgba(255,255,255,.35);
        border-top-color: #fff;
        border-radius: 50%;
        display: inline-block;
        animation: spinR .7s linear infinite;
    }

    @@keyframes spinR {
        to {
            transform: rotate(360deg);
        }
    }
</style>

<div class="pg">
    <div class="breadcrumb">
        <a asp-controller="Products" asp-action="Index">🏠 Home</a>
        <span>/</span>
        <span>@Model.ProductName</span>
    </div>

    <div class="product-layout">
        <!-- Images -->
        <div>
            <div class="img-main" id="mainImgWrap">
                @if (Model.Images?.Any() == true)
                {
                    <img id="mainImg" src="@Model.Images.First()" alt="@Model.ProductName"
                         onerror="this.parentElement.innerHTML='<div class=\'no-img\'>🐾</div>'" />
                }
                else
                {
                    <div class="no-img">🐾</div>
                }
            </div>
            @if (Model.Images?.Count > 1)
            {
                <div class="img-thumbs">
                    @foreach (var img in Model.Images)
                    {
                        <img src="@img" class="thumb" onclick="setImg(this)"
                             onerror="this.style.display='none'" />
                    }
                </div>
            }
        </div>

        <!-- Info -->
        <div>
            <div class="info-tags">
                @if (!string.IsNullOrEmpty(Model.CategoryName))
                {
                    <span class="tag tag-cat">@Model.CategoryName</span>
                }
                @if (!string.IsNullOrEmpty(Model.BrandName))
                {
                    <span class="tag tag-brand">@Model.BrandName</span>
                }
                @if (Model.StockQuantity > 0)
                {
                    <span class="tag tag-in">✓ @Model.StockQuantity items available</span>
                }
                else
                {

                    <span class="tag tag-out">Out of stock</span>
                }
            </div>

            <h1 class="product-name">@Model.ProductName</h1>
            <div class="product-price">@Model.ProductPrice.ToString("N0")₫</div>

            @if (!string.IsNullOrEmpty(Model.ProductDescription))
            {
                <p class="product-desc">@Model.ProductDescription</p>
            }

            @if (Model.Attributes?.Any() == true)
            {
                <div class="specs-title">Technical Specifications</div>
                <table class="specs-table">
                    @foreach (var attr in Model.Attributes)
                    {
                        <tr>
                            <td>@attr.AttributeName</td>
                            <td>@attr.AttributeValue</td>
                        </tr>
                    }
                </table>
            }

            @if (Model.StockQuantity > 0)
            {
                <div class="cart-row">
                    <div class="qty-wrap">
                        <button class="qty-btn" type="button" onclick="stepQty(-1)">−</button>
                        <input type="number" id="qtyInput" class="qty-input"
                               value="1" min="1" max="@Model.StockQuantity" />
                        <button class="qty-btn" type="button" onclick="stepQty(1)">+</button>
                    </div>
                    <button id="btnCart" class="btn-cart" onclick="addToCart()">
                        🛒 Add to Cart
                    </button>
                </div>
                <div class="stock-note">@Model.StockQuantity items remaining in stock</div>
            }
            else
            {
                <button class="btn-cart" disabled>Out of stock</button>
            }
        </div>
    </div>
</div>

<script>
    // ── Tạo toast container trực tiếp vào <body> để tránh bị stacking context ẩn ──
    var _toastBox = document.createElement('div');
    _toastBox.className = 'pc-toast-container';
    document.body.appendChild(_toastBox);

    function showToast(msg, type) {
        var el = document.createElement('div');
        el.className = 'pc-toast ' + (type === 'err' ? 'err' : 'ok');
        el.innerHTML =
            '<span class="pc-toast-icon">' + (type === 'err' ? '✕' : '✓') + '</span>' +
            '<span>' + msg + '</span>';
        _toastBox.appendChild(el);

        setTimeout(function () {
            el.classList.add('fade-out');
            setTimeout(function () { el.remove(); }, 380);
        }, 3200);
    }

    function setImg(el) {
        var m = document.getElementById('mainImg');
        if (m) m.src = el.src;
        document.querySelectorAll('.thumb').forEach(function(t) { t.classList.remove('active'); });
        el.classList.add('active');
    }

    function stepQty(d) {
        var inp = document.getElementById('qtyInput');
        inp.value = Math.max(1, Math.min(parseInt(inp.max) || 9999, (parseInt(inp.value) || 1) + d));
    }

    var PRODUCT_ID = '@Model.ProductId';
    var URL_CART   = '@Url.Action("AddToCart", "Cart")';
    var URL_LOGIN  = '@Url.Action("Login", "Auth")';

    async function addToCart() {
        var inp = document.getElementById('qtyInput');
        var btn = document.getElementById('btnCart');
        var qty = parseInt(inp.value) || 1;
        var max = parseInt(inp.max)   || 9999;

        if (qty < 1)   { showToast('Quantity must be at least 1.', 'err'); return; }
        if (qty > max) { showToast('Exceeds available stock (' + max + ').', 'err'); return; }

        btn.disabled = true;
        btn.innerHTML = '<span class="btn-spin"></span> Adding...';

        try {
            var res  = await fetch(URL_CART, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ productId: PRODUCT_ID, quantity: qty })
            });
            var data = await res.json();

            if (data.success) {
                showToast(data.message || 'Added to cart successfully!', 'ok');
            } else {
                var msg = data.message || 'Failed to add to cart.';
                showToast(msg, 'err');
                if (msg.toLowerCase().includes('login')) {
                    setTimeout(function () { window.location.href = URL_LOGIN; }, 1600);
                }
            }
        } catch (e) {
            showToast('Network error. Please try again.', 'err');
        } finally {
            btn.disabled = false;
            btn.innerHTML = '🛒 Add to Cart';
        }
    }
</script>

<hr style="margin:40px 0;" />

@* <h3>Customer Feedback</h3>

@if (ViewBag.Feedbacks != null)
{
    foreach (var item in ViewBag.Feedbacks)
    {
        <div class="border p-2 mb-2">
            <b>User: @item.CustomerId</b> ⭐ @item.Rating
            <p>@item.Comment</p>
            <small>@item.CreatedDate</small>

            @if (item.Reply != null)
            {
                <div class="bg-light p-2 mt-2">
                    <b>Shop reply:</b>
                    <p>@item.Reply</p>
                </div>
            }
        </div>
    }
}