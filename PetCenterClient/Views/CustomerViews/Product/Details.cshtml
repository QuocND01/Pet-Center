
@using PetCenterClient.ViewModels.Product
@model ReadProductViewModel

@{
    ViewData["Title"] = Model.ProductName;
}

@if (TempData["Error"] != null)
{
    <div style="color:red; font-weight:bold;">
        @TempData["Error"]
    </div>
}

@if (TempData["Success"] != null)
{
    <div style="color:green; font-weight:bold;">
        @TempData["Success"]
    </div>
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&family=Fraunces:ital,opsz,wght@0,9..144,700;0,9..144,900;1,9..144,700&display=swap" rel="stylesheet">

<style>
    :root {
        --g0: #f0fdf4;
        --g1: #dcfce7;
        --g3: #2ecc71;
        --g4: #27ae60;
        --g5: #166534;
        --ink: #0f1f0f;
        --ink2: #374151;
        --muted: #6b7280;
        --border: #e5e7eb;
        --surface: #fff;
        --radius: 16px;
        --font: 'Nunito',sans-serif;
        --font-head: 'Fraunces',Georgia,serif;
    }

    .pg {
        font-family: var(--font);
        color: var(--ink);
        max-width: 1000px;
        margin: 0 auto;
        padding: 32px 16px;
    }

    .breadcrumb {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 24px;
        font-size: 13px;
        color: var(--muted);
    }

        .breadcrumb a {
            color: var(--muted);
            text-decoration: none;
            font-weight: 700;
        }

            .breadcrumb a:hover {
                color: var(--g4);
            }

        .breadcrumb span {
            color: var(--border);
        }

    .product-layout {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 40px;
        align-items: start;
    }

    @@media(max-width:700px) {
        .product-layout {
            grid-template-columns: 1fr;
            gap: 24px;
        }
    }

    .img-main {
        aspect-ratio: 1;
        border-radius: var(--radius);
        overflow: hidden;
        background: var(--g0);
        border: 1.5px solid var(--border);
        margin-bottom: 12px;
    }

        .img-main img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform .4s;
            cursor: zoom-in;
        }

            .img-main img:hover {
                transform: scale(1.05);
            }

        .img-main .no-img {
            width: 100%;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 72px;
        }

    .img-thumbs {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

    .thumb {
        width: 64px;
        height: 64px;
        border-radius: 10px;
        object-fit: cover;
        border: 2px solid var(--border);
        cursor: pointer;
        transition: all .2s;
    }

        .thumb:hover, .thumb.active {
            border-color: var(--g3);
        }

    .info-tags {
        display: grid;
        grid-template-columns: repeat(3, auto);
        gap: 8px;
        justify-content: start;
        align-items: start;
    }

    .tag {
        display: inline-block;
        max-width: 180px;
        font-size: 11px;
        font-weight: 800;
        padding: 4px 12px;
        border-radius: 100px;
        letter-spacing: .04em;
        white-space: normal;
        overflow-wrap: anywhere;
        word-break: break-word;
    }

    .tag-cat {
        background: var(--g1);
        color: var(--g5);
    }

    .tag-brand {
        background: #eff6ff;
        color: #1d4ed8;
    }

    .tag-in {
        background: var(--g1);
        color: var(--g5);
    }

    .tag-out {
        background: #fee2e2;
        color: #991b1b;
    }

    .product-name {
        font-family: var(--font-head);
        font-size: clamp(22px,4vw,32px);
        font-weight: 900;
        line-height: 1.2;
        color: var(--ink);
        margin-bottom: 10px;
    }

    .product-price {
        font-family: var(--font-head);
        font-size: 32px;
        font-weight: 900;
        color: var(--g4);
        margin-bottom: 16px;
    }

    .product-desc {
        font-size: 14px;
        color: var(--muted);
        line-height: 1.7;
        margin-bottom: 20px;
    }

    .specs-title {
        font-size: 13px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: .06em;
        color: var(--muted);
        margin-bottom: 10px;
    }

    .specs-table {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 24px;
    }

        .specs-table tr {
            border-bottom: 1px solid var(--border);
        }

            .specs-table tr:last-child {
                border-bottom: none;
            }

        .specs-table td {
            padding: 9px 0;
            font-size: 13px;
        }

            .specs-table td:first-child {
                color: var(--muted);
                font-weight: 700;
                width: 45%;
            }

            .specs-table td:last-child {
                color: var(--ink);
                font-weight: 800;
            }

    .cart-row {
        display: flex;
        gap: 10px;
        align-items: center;
    }

    .qty-wrap {
        display: flex;
        align-items: center;
        border: 1.5px solid var(--border);
        border-radius: 100px;
        overflow: hidden;
    }

    .qty-btn {
        width: 36px;
        height: 40px;
        border: none;
        background: #f9fafb;
        cursor: pointer;
        font-size: 18px;
        font-weight: 700;
        color: var(--ink2);
        transition: background .15s;
    }

        .qty-btn:hover {
            background: var(--g1);
        }

    .qty-input {
        width: 52px;
        height: 40px;
        border: none;
        border-left: 1.5px solid var(--border);
        border-right: 1.5px solid var(--border);
        text-align: center;
        font-family: var(--font);
        font-size: 15px;
        font-weight: 800;
        color: var(--ink);
        outline: none;
    }

    .btn-cart {
        flex: 1;
        background: var(--g3);
        color: #fff;
        border: none;
        border-radius: 100px;
        font-family: var(--font);
        font-weight: 800;
        font-size: 15px;
        height: 44px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        box-shadow: 0 4px 16px rgba(46,204,113,.35);
        transition: all .2s;
    }

        .btn-cart:hover:not(:disabled) {
            background: var(--g4);
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(46,204,113,.45);
        }

        .btn-cart:disabled {
            opacity: .6;
            cursor: not-allowed;
            transform: none;
        }

    .stock-note {
        font-size: 12px;
        color: var(--muted);
        font-weight: 700;
        margin-top: 8px;
    }

    /* ── TOAST ── */
    .pc-toast-container {
        position: fixed;
        top: 80px;
        right: 24px;
        z-index: 999999;
        display: flex;
        flex-direction: column;
        gap: 10px;
        pointer-events: none;
        max-width: 320px;
    }

    .pc-toast {
        pointer-events: auto;
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 14px 18px;
        border-radius: 14px;
        font-family: var(--font);
        font-size: 14px;
        font-weight: 800;
        color: #fff;
        box-shadow: 0 8px 32px rgba(0,0,0,.2);
        opacity: 1;
        transform: translateX(0);
        transition: opacity .35s ease, transform .35s ease;
    }

        .pc-toast.ok {
            background: var(--g4);
        }

        .pc-toast.err {
            background: #e74c3c;
        }

        .pc-toast.fade-out {
            opacity: 0;
            transform: translateX(30px);
        }

    .pc-toast-icon {
        font-size: 18px;
        flex-shrink: 0;
    }

    @@keyframes toastIn {
        from {
            opacity: 0;
            transform: translateX(40px);
        }

        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    .pc-toast {
        animation: toastIn .3s cubic-bezier(.22,1,.36,1) both;
    }

    /* spinner */
    .btn-spin {
        width: 16px;
        height: 16px;
        flex-shrink: 0;
        border: 2.5px solid rgba(255,255,255,.35);
        border-top-color: #fff;
        border-radius: 50%;
        display: inline-block;
        animation: spinR .7s linear infinite;
    }

    @@keyframes spinR {
        to {
            transform: rotate(360deg);
        }
    }

    .product-name,
    .product-desc,
    .tag,
    .specs-table td,
    .stock-note {
        white-space: normal;
        overflow-wrap: anywhere;
        word-break: break-word;
    }

        .specs-table td:first-child,
        .specs-table td:last-child {
            white-space: normal;
            overflow-wrap: anywhere;
            word-break: break-word;
        }
</style>

<div class="pg">
    <div class="breadcrumb">
        <a asp-controller="Products" asp-action="Index">🏠 Home</a>
        <span>/</span>
        <span>@Model.ProductName</span>
    </div>

    <div class="product-layout">
        <!-- Images -->
        <div>
            <div class="img-main" id="mainImgWrap">
                @if (Model.Images?.Any() == true)
                {
                    <img id="mainImg" src="@Model.Images.First()" alt="@Model.ProductName"
                         onerror="this.parentElement.innerHTML='<div class=\'no-img\'>🐾</div>'" />
                }
                else
                {
                    <div class="no-img">🐾</div>
                }
            </div>
            @if (Model.Images?.Count > 1)
            {
                <div class="img-thumbs">
                    @foreach (var img in Model.Images)
                    {
                        <img src="@img" class="thumb" onclick="setImg(this)"
                             onerror="this.style.display='none'" />
                    }
                </div>
            }
        </div>

        <!-- Info -->
        <div>
            <div class="info-tags">
                @if (!string.IsNullOrEmpty(Model.CategoryName))
                {
                    <span class="tag tag-cat">@Model.CategoryName</span>
                }
                @if (!string.IsNullOrEmpty(Model.BrandName))
                {
                    <span class="tag tag-brand">@Model.BrandName</span>
                }
                @if (Model.StockQuantity > 0)
                {
                    <span class="tag tag-in">✓ @Model.StockQuantity items available</span>
                }
                else
                {

                    <span class="tag tag-out">Out of stock</span>
                }
            </div>

            <h1 class="product-name">@Model.ProductName</h1>
            <div class="product-price">@Model.ProductPrice.ToString("N0")₫</div>

            @if (!string.IsNullOrEmpty(Model.ProductDescription))
            {
                <p class="product-desc">@Model.ProductDescription</p>
            }

            @if (Model.Attributes?.Any() == true)
            {
                <div class="specs-title">Technical Specifications</div>
                <table class="specs-table">
                    @foreach (var attr in Model.Attributes)
                    {
                        <tr>
                            <td>@attr.AttributeName</td>
                            <td>@attr.AttributeValue</td>
                        </tr>
                    }
                </table>
            }

            @if (Model.StockQuantity > 0)
            {
                <div class="cart-row">
                    <div class="qty-wrap">
                        <button class="qty-btn" type="button" onclick="stepQty(-1)">−</button>
                        <input type="number" id="qtyInput" class="qty-input"
                               value="1" min="1" max="@Model.StockQuantity" />
                        <button class="qty-btn" type="button" onclick="stepQty(1)">+</button>
                    </div>
                    <button id="btnCart" class="btn-cart" onclick="addToCart()">
                        🛒 Add to Cart
                    </button>
                </div>
            }
            else
            {
                <button class="btn-cart" disabled>Out of stock</button>
            }
        </div>
    </div>
</div>

<script>
    // ── Tạo toast container trực tiếp vào <body> để tránh bị stacking context ẩn ──
    var _toastBox = document.createElement('div');
    _toastBox.className = 'pc-toast-container';
    document.body.appendChild(_toastBox);

    function showToast(msg, type) {
        var el = document.createElement('div');
        el.className = 'pc-toast ' + (type === 'err' ? 'err' : 'ok');
        el.innerHTML =
            '<span class="pc-toast-icon">' + (type === 'err' ? '✕' : '✓') + '</span>' +
            '<span>' + msg + '</span>';
        _toastBox.appendChild(el);

        setTimeout(function () {
            el.classList.add('fade-out');
            setTimeout(function () { el.remove(); }, 380);
        }, 3200);
    }

    function setImg(el) {
        var m = document.getElementById('mainImg');
        if (m) m.src = el.src;
        document.querySelectorAll('.thumb').forEach(function(t) { t.classList.remove('active'); });
        el.classList.add('active');
    }

    function stepQty(d) {
        var inp = document.getElementById('qtyInput');
        inp.value = Math.max(1, Math.min(parseInt(inp.max) || 9999, (parseInt(inp.value) || 1) + d));
    }

    var PRODUCT_ID = '@Model.ProductId';
    var URL_CART   = '@Url.Action("AddToCart", "Cart")';
    var URL_LOGIN  = '@Url.Action("Login", "Auth")';

    async function addToCart() {
        var inp = document.getElementById('qtyInput');
        var btn = document.getElementById('btnCart');
        var qty = parseInt(inp.value) || 1;
        var max = parseInt(inp.max)   || 9999;

        if (qty < 1)   { showToast('Quantity must be at least 1.', 'err'); return; }
        if (qty > max) { showToast('Exceeds available stock (' + max + ').', 'err'); return; }

        btn.disabled = true;
        btn.innerHTML = '<span class="btn-spin"></span> Adding...';

        try {
            var res  = await fetch(URL_CART, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ productId: PRODUCT_ID, quantity: qty })
            });
            var data = await res.json();

            if (data.success) {
                showToast(data.message || 'Added to cart successfully!', 'ok');
                if (window.refreshCartBadge) window.refreshCartBadge();
            } else {
                var msg = data.message || 'Failed to add to cart.';
                showToast(msg, 'err');
                if (msg.toLowerCase().includes('login')) {
                    setTimeout(function () { window.location.href = URL_LOGIN; }, 1600);
                }
            }
        } catch (e) {
            showToast('Network error. Please try again.', 'err');
        } finally {
            btn.disabled = false;
            btn.innerHTML = '🛒 Add to Cart';
        }
    }
</script>


<hr style="margin: 48px 0 0 0; border: none; border-top: 2px solid var(--border);" />

<!-- ═══════════════════════════════════════════════════
     CUSTOMER FEEDBACK SECTION
════════════════════════════════════════════════════ -->
<style>
    /* ── Section wrapper ── */
    .fb-section {
        max-width: 1000px;
        margin: 0 auto;
        padding: 40px 16px 64px;
        font-family: var(--font);
    }

    .fb-section-title {
        font-family: var(--font-head);
        font-size: 26px;
        font-weight: 900;
        color: var(--ink);
        margin-bottom: 32px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .fb-section-title span.fb-count-badge {
            font-family: var(--font);
            font-size: 13px;
            font-weight: 800;
            background: var(--g1);
            color: var(--g5);
            padding: 4px 12px;
            border-radius: 100px;
        }

    /* ── Summary box ── */
    .fb-summary {
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 32px;
        align-items: center;
        background: var(--g0);
        border: 1.5px solid var(--g1);
        border-radius: var(--radius);
        padding: 28px 32px;
        margin-bottom: 36px;
    }

    @@media(max-width: 600px) {
        .fb-summary {
            grid-template-columns: 1fr;
            gap: 20px;
            padding: 20px;
        }
    }

    .fb-avg-block {
        text-align: center;
        min-width: 120px;
    }

    .fb-avg-number {
        font-family: var(--font-head);
        font-size: 64px;
        font-weight: 900;
        color: var(--g4);
        line-height: 1;
    }

    .fb-avg-stars {
        display: flex;
        justify-content: center;
        gap: 3px;
        margin: 8px 0 6px;
    }

    .fb-avg-stars .star {
        font-size: 20px;
    }

    .fb-avg-total {
        font-size: 12px;
        font-weight: 700;
        color: var(--muted);
    }

    /* ── Bar chart ── */
    .fb-bars {
        display: flex;
        flex-direction: column;
        gap: 8px;
        width: 100%;
    }

    .fb-bar-row {
        display: grid;
        grid-template-columns: 60px 1fr 40px;
        align-items: center;
        gap: 10px;
    }

    .fb-bar-label {
        font-size: 12px;
        font-weight: 800;
        color: var(--ink2);
        text-align: right;
        white-space: nowrap;
    }

    .fb-bar-label .star-sm {
        color: #f59e0b;
    }

    .fb-bar-track {
        height: 10px;
        background: var(--border);
        border-radius: 100px;
        overflow: hidden;
    }

    .fb-bar-fill {
        height: 100%;
        background: linear-gradient(90deg, #2ecc71, #27ae60);
        border-radius: 100px;
        transition: width .6s cubic-bezier(.22,1,.36,1);
    }

    .fb-bar-pct {
        font-size: 11px;
        font-weight: 800;
        color: var(--muted);
        text-align: right;
    }

    /* ── Empty state ── */
    .fb-empty {
        text-align: center;
        padding: 56px 24px;
        color: var(--muted);
        background: var(--g0);
        border: 1.5px dashed var(--border);
        border-radius: var(--radius);
    }

    .fb-empty-icon {
        font-size: 52px;
        margin-bottom: 12px;
    }

    .fb-empty-text {
        font-size: 15px;
        font-weight: 700;
    }

    .fb-empty-sub {
        font-size: 13px;
        margin-top: 6px;
        color: #9ca3af;
    }

    /* ── Feedback list ── */
    .fb-list {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .fb-card {
        background: var(--surface);
        border: 1.5px solid var(--border);
        border-radius: var(--radius);
        padding: 20px 24px;
        transition: box-shadow .2s;
        overflow-wrap: break-word;
        word-break: break-word;
    }

    .fb-card:hover {
        box-shadow: 0 4px 20px rgba(0,0,0,.07);
     }

    .fb-card-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 10px;
        flex-wrap: wrap;
    }

    .fb-avatar {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--g3), #27ae60);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 16px;
        font-weight: 900;
        color: #fff;
        flex-shrink: 0;
    }

    .fb-meta {
        flex: 1;
    }

    .fb-meta-name {
        font-size: 14px;
        font-weight: 800;
        color: var(--ink);
        overflow-wrap: break-word;
        word-break: break-word;
    }

    .fb-meta-date {
        font-size: 11px;
        color: var(--muted);
        font-weight: 600;
        margin-top: 2px;
    }

    .fb-stars {
        display: flex;
        gap: 2px;
    }

    .fb-stars .star {
        font-size: 15px;
    }

    .fb-comment {
        font-size: 14px;
        color: var(--ink2);
        line-height: 1.7;
        margin-bottom: 0;
        white-space: pre-wrap; 
        overflow-wrap: break-word; 
        word-break: break-word;
        max-width: 100%;
    }

    /* ── Shop reply ── */
    .fb-reply-text {
        font-size: 13px;
        color: var(--ink2);
        line-height: 1.6;
        white-space: pre-wrap; 
        overflow-wrap: break-word;
        word-break: break-word;
        max-width: 100%;
    }

    .fb-reply-header {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 6px;
    }

    .fb-reply-badge {
        font-size: 11px;
        font-weight: 800;
        background: var(--g3);
        color: #fff;
        padding: 2px 10px;
        border-radius: 100px;
        letter-spacing: .04em;
    }

    .fb-reply-date {
        font-size: 11px;
        color: var(--muted);
        font-weight: 600;
    }

    .fb-reply-text {
        font-size: 13px;
        color: var(--ink2);
        line-height: 1.6;
    }

    .fb-reply {
        margin-top: 14px;
        background: var(--g0);
        border-left: 3px solid var(--g3);
        border-radius: 0 10px 10px 0;
        padding: 12px 16px;
        overflow-wrap: break-word;
        word-break: break-word; 
    }

    /* ── Updated badge ── */
    .fb-updated-badge {
        font-size: 10px;
        font-weight: 700;
        color: var(--muted);
        background: #f3f4f6;
        padding: 2px 8px;
        border-radius: 100px;
        margin-left: auto;
    }

    /* ── Feedback media (images + videos) ── */
    .fb-media-list {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin-top: 14px;
    }

    .fb-media-item {
        width: 96px;
        height: 96px;
        border-radius: 10px;
        overflow: hidden;
        border: 1.5px solid var(--border);
        background: #f9fafb;
        cursor: pointer;
        position: relative;
        flex-shrink: 0;
    }

    .fb-media-item img,
    .fb-media-item video {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
    }

    .fb-media-video-badge {
        position: absolute;
        bottom: 4px;
        right: 4px;
        background: rgba(0,0,0,.6);
        color: #fff;
        font-size: 11px;
        padding: 1px 6px;
        border-radius: 100px;
        font-weight: 800;
    }

    /* ── Media Lightbox ── */
    .fb-lightbox-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,.9);
        z-index: 99999;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .fb-lightbox-overlay.fb-lightbox-entering {
            animation: fbLightboxFade .2s ease;
        }

    @@keyframes fbLightboxFade {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    .fb-lightbox-content {
        max-width: 90vw;
        max-height: 85vh;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 1;
        transition: opacity .15s ease;
    }

        .fb-lightbox-content.fb-lightbox-fading {
            opacity: 0;
        }

    .fb-lightbox-content {
        max-width: 90vw;
        max-height: 85vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .fb-lightbox-content img,
        .fb-lightbox-content video {
            max-width: 90vw;
            max-height: 85vh;
            border-radius: 12px;
            object-fit: contain;
        }

    .fb-lightbox-close {
        position: absolute;
        top: 20px;
        right: 24px;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: rgba(255,255,255,.15);
        border: none;
        color: #fff;
        font-size: 22px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background .2s;
    }

        .fb-lightbox-close:hover {
            background: rgba(255,255,255,.28);
        }

    .fb-lightbox-nav {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background: rgba(255,255,255,.15);
        border: none;
        color: #fff;
        font-size: 22px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background .2s;
    }

        .fb-lightbox-nav:hover {
            background: rgba(255,255,255,.28);
        }

    .fb-lightbox-prev {
        left: 20px;
    }

    .fb-lightbox-next {
        right: 20px;
    }

    .fb-lightbox-counter {
        position: absolute;
        bottom: 22px;
        left: 50%;
        transform: translateX(-50%);
        background: rgba(255,255,255,.15);
        color: #fff;
        font-size: 13px;
        font-weight: 700;
        padding: 6px 16px;
        border-radius: 100px;
    }

    /* ── Load more ── */
    .fb-card.fb-hidden {
        display: none;
    }

    .fb-loadmore-wrap {
        display: flex;
        justify-content: center;
        margin-top: 20px;
    }

    .btn-loadmore {
        background: var(--surface);
        color: var(--g4);
        border: 1.5px solid var(--g3);
        border-radius: 100px;
        font-family: var(--font);
        font-weight: 800;
        font-size: 14px;
        padding: 10px 28px;
        cursor: pointer;
        transition: all .2s;
    }

    .btn-loadmore:hover {
        background: var(--g1);
    }
</style>

<div class="fb-section">
    <h2 class="fb-section-title">
        ⭐ Customer Reviews
        @if (ViewBag.TotalCount != null && ViewBag.TotalCount > 0)
        {
            <span class="fb-count-badge">@ViewBag.TotalCount reviews</span>
        }
    </h2>

    @if (ViewBag.TotalCount != null && ViewBag.TotalCount > 0)
    {
        <!-- Summary -->
        <div class="fb-summary">
            <!-- Average score -->
            <div class="fb-avg-block">
                <div class="fb-avg-number">@ViewBag.AvgRating</div>
                <div class="fb-avg-stars">
                    @for (int s = 1; s <= 5; s++)
                    {
                        double avg = (double)ViewBag.AvgRating;
                        if (s <= Math.Floor(avg))
                        {
                            <span class="star" style="color:#f59e0b;">★</span>
                        }
                        else if (s - avg < 1 && s - avg > 0)
                        {
                            <span class="star" style="color:#f59e0b; opacity:.45;">★</span>
                        }
                        else
                        {
                            <span class="star" style="color:#e5e7eb;">★</span>
                        }
                    }
                </div>
                <div class="fb-avg-total">out of 5 · @ViewBag.TotalCount reviews</div>
            </div>

            <!-- Bar chart -->
            <div class="fb-bars">
                @{
                    var ratingCounts = ViewBag.RatingCounts as Dictionary<int, int>;
                    int total = (int)ViewBag.TotalCount;
                }
                @for (int star = 5; star >= 1; star--)
                {
                    int count = ratingCounts != null && ratingCounts.ContainsKey(star)
                    ? ratingCounts[star] : 0;
                    double pct = total > 0 ? Math.Round((double)count / total * 100, 0) : 0;

                    <div class="fb-bar-row">
                        <div class="fb-bar-label">
                            @star <span class="star-sm">★</span>
                        </div>
                        <div class="fb-bar-track">
                            <div class="fb-bar-fill" style="width: @pct%"></div>
                        </div>
                        <div class="fb-bar-pct">@pct%</div>
                    </div>
                }
            </div>
        </div>

        <!-- Feedback list -->
        <div class="fb-list">
            @{
                int fbInitialShow = 5;
                int fbIndex = 0;
            }
            @foreach (var item in ViewBag.Feedbacks)
            {
                int rating = item.Rating ?? 0;
                bool isHiddenInitially = fbIndex >= fbInitialShow;
                fbIndex++;

                string displayName = !string.IsNullOrEmpty(item.CustomerName)
                ? item.CustomerName
                : "Anonymous";

                string initials = displayName != "Anonymous" && displayName.Length > 0
                ? string.Join("", displayName.Split(' ')
                .Where(w => w.Length > 0)
                .Take(2)
                .Select(w => w[0].ToString().ToUpper()))
                : "?";

                string createdDateStr = item.CreatedDate != null
                ? ((DateTime)item.CreatedDate).ToString("dd/MM/yyyy HH:mm")
                : "";

                <div class="fb-card @(isHiddenInitially ? "fb-hidden" : "")" data-fb-index="@(fbIndex - 1)">
                    <div class="fb-card-header">
                        <!-- Avatar -->
                        <div class="fb-avatar">@initials</div>

                        <!-- Meta -->
                        <div class="fb-meta">
                            <div class="fb-meta-name">@displayName</div>
                            <div class="fb-meta-date">@createdDateStr</div>
                        </div>

                        <!-- Stars -->
                        <div class="fb-stars">
                            @for (int s = 1; s <= 5; s++)
                            {
                                <span class="star" style="color: @(s <= rating ? "#f59e0b" : "#e5e7eb")">★</span>
                            }
                        </div>

                        <!-- Updated badge -->
                        @if (item.UpdatedAt != null)
                        {
                            <span class="fb-updated-badge">Edited</span>
                        }
                    </div>

                    <!-- Comment -->
                    @if (!string.IsNullOrEmpty(item.Comment))
                    {
                        <p class="fb-comment">@item.Comment</p>
                    }
                    else
                    {
                        <p class="fb-comment" style="color:#9ca3af; font-style:italic;">
                            No comment left.
                        </p>
                    }

                    <!-- Media files (images + videos uploaded with the feedback) -->
                    @if (item.MediaFiles != null && item.MediaFiles.Count > 0)
                    {
                        var mediaFilesEnumerable = (IEnumerable<dynamic>)item.MediaFiles;
                        var mediaGroupJson = System.Text.Json.JsonSerializer.Serialize(
                        mediaFilesEnumerable.Select(m => new { url = (string)m.MediaUrl, type = (string)m.MediaType })
                        );

                        <div class="fb-media-list" data-media-group='@mediaGroupJson'>
                            @for (int mIdx = 0; mIdx < item.MediaFiles.Count; mIdx++)
                            {
                                var media = item.MediaFiles[mIdx];
                                <div class="fb-media-item" onclick="openFbLightbox(this.closest('.fb-media-list'), @mIdx)">
                                    @if (media.MediaType == "video")
                                    {
                                        <video src="@media.MediaUrl" muted></video>
                                        <span class="fb-media-video-badge">▶ Video</span>
                                    }
                                    else
                                    {
                                        <img src="@media.MediaUrl" alt="Feedback image"
                                             onerror="this.parentElement.style.display='none'" />
                                    }
                                </div>
                            }
                        </div>
                    }

                    <!-- Shop reply -->
                    @if (!string.IsNullOrEmpty(item.Reply))
                    {
                        <div class="fb-reply">
                            <div class="fb-reply-header">
                                <span class="fb-reply-badge">🏪 Shop Reply</span>
                                @if (item.ReplyDate != null)
                                {
                                    <span class="fb-reply-date">
                                        @(((DateTime)item.ReplyDate).ToString("dd/MM/yyyy HH:mm"))
                                    </span>
                                }
                            </div>
                            <div class="fb-reply-text">@item.Reply</div>
                        </div>
                    }
                </div>
            }
        </div>

        @if ((int)ViewBag.TotalCount > 5)
        {
            <div class="fb-loadmore-wrap">
                <button id="btnLoadMoreFb" class="btn-loadmore" onclick="loadMoreFeedback()">
                    Load More Reviews (<span id="fbRemainCount"></span> remaining)
                </button>
            </div>
        }
    }
    else
    {
        <!-- Empty state -->
        <div class="fb-empty">
            <div class="fb-empty-icon">🐾</div>
            <div class="fb-empty-text">No reviews yet</div>
            <div class="fb-empty-sub">Be the first to share your experience with this product!</div>
        </div>
    }
</div>

    <script>
    var FB_BATCH_SIZE = 5;
    var fbShownCount = 5;
    var fbTotalCards = document.querySelectorAll('.fb-card').length;

    function updateRemainText() {
        var remaining = fbTotalCards - fbShownCount;
        var span = document.getElementById('fbRemainCount');
        var btn = document.getElementById('btnLoadMoreFb');
        if (!btn) return;

        if (remaining <= 0) {
            btn.style.display = 'none';
            return;
        }

        if (span) span.textContent = remaining;
    }

    function loadMoreFeedback() {
        var hiddenCards = document.querySelectorAll('.fb-card.fb-hidden');
        var batch = Array.prototype.slice.call(hiddenCards, 0, FB_BATCH_SIZE);

        batch.forEach(function (card) {
            card.classList.remove('fb-hidden');
        });

        fbShownCount += batch.length;
        updateRemainText();
    }

    let fbLightboxMedia = [];
    let fbLightboxIndex = 0;

    function openFbLightbox(groupEl, startIndex) {
        if (!groupEl) return;
        try {
            fbLightboxMedia = JSON.parse(groupEl.getAttribute('data-media-group')) || [];
        } catch (e) {
            fbLightboxMedia = [];
        }
        if (fbLightboxMedia.length === 0) return;

        fbLightboxIndex = startIndex;
        buildFbLightboxShell();
        document.addEventListener('keydown', handleFbLightboxKeydown);
    }

    function buildFbLightboxShell() {
        document.getElementById('fbLightboxOverlay')?.remove();

        const showNav = fbLightboxMedia.length > 1;

        document.body.insertAdjacentHTML('beforeend', `
            <div id="fbLightboxOverlay" class="fb-lightbox-overlay fb-lightbox-entering" onclick="closeFbLightboxOnOverlay(event)">
                <button class="fb-lightbox-close" onclick="closeFbLightbox()">✕</button>
                ${showNav ? `<button class="fb-lightbox-nav fb-lightbox-prev" onclick="fbLightboxStep(-1, event)">‹</button>` : ''}
                <div class="fb-lightbox-content" id="fbLightboxContent"></div>
                ${showNav ? `<button class="fb-lightbox-nav fb-lightbox-next" onclick="fbLightboxStep(1, event)">›</button>` : ''}
                ${showNav ? `<div class="fb-lightbox-counter" id="fbLightboxCounter"></div>` : ''}
            </div>`);

        renderFbLightboxMedia(false);
    }

    function renderFbLightboxMedia(animate) {
        const contentEl = document.getElementById('fbLightboxContent');
        const counterEl = document.getElementById('fbLightboxCounter');
        if (!contentEl) return;

        const media = fbLightboxMedia[fbLightboxIndex];
        if (!media) return;

        const mediaEl = media.type === 'video'
            ? `<video src="${media.url}" controls autoplay></video>`
            : `<img src="${media.url}" alt="Feedback media">`;

        if (!animate) {
            contentEl.innerHTML = mediaEl;
            if (counterEl) counterEl.textContent = `${fbLightboxIndex + 1} / ${fbLightboxMedia.length}`;
            return;
        }

        contentEl.classList.add('fb-lightbox-fading');
        setTimeout(() => {
            contentEl.innerHTML = mediaEl;
            if (counterEl) counterEl.textContent = `${fbLightboxIndex + 1} / ${fbLightboxMedia.length}`;
            contentEl.classList.remove('fb-lightbox-fading');
        }, 150);
    }

    function fbLightboxStep(direction, event) {
        if (event) event.stopPropagation();
        fbLightboxIndex = (fbLightboxIndex + direction + fbLightboxMedia.length) % fbLightboxMedia.length;
        renderFbLightboxMedia(true);
    }

    function closeFbLightbox() {
        document.getElementById('fbLightboxOverlay')?.remove();
        document.removeEventListener('keydown', handleFbLightboxKeydown);
    }

    function closeFbLightboxOnOverlay(event) {
        if (event.target.id === 'fbLightboxOverlay') closeFbLightbox();
    }

    function handleFbLightboxKeydown(e) {
        if (e.key === 'Escape') closeFbLightbox();
        else if (e.key === 'ArrowLeft') fbLightboxStep(-1);
        else if (e.key === 'ArrowRight') fbLightboxStep(1);
    }

    document.addEventListener('DOMContentLoaded', updateRemainText);
    </script>