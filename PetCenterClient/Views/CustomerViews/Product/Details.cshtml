@using PetCenterClient.DTOs
@model ReadProductDTO
@{
    ViewData["Title"] = "Product Details";
}
<link rel="stylesheet" href="~/css/UserViews/Product/Details.css" />
<style>
    .main-image img {
        width: 100%;
        max-height: 420px;
        object-fit: cover;
    }

    .thumb-image {
        width: 80px;
        height: 80px;
        object-fit: cover;
        border-radius: 6px;
        border: 2px solid #eee;
        cursor: pointer;
        transition: 0.2s;
    }

        .thumb-image:hover {
            border-color: #0d6efd;
        }

    /* Toast notification */
    .toast-container {
        position: fixed;
        top: 20px;
        right: 20px;
        z-index: 9999;
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .toast-msg {
        padding: 14px 20px;
        border-radius: 10px;
        color: white;
        font-size: 14px;
        font-weight: 500;
        min-width: 260px;
        box-shadow: 0 4px 16px rgba(0,0,0,0.15);
        display: flex;
        align-items: center;
        gap: 10px;
        animation: slideInRight 0.3s ease;
    }

        .toast-msg.success {
            background: #27ae60;
        }

        .toast-msg.error {
            background: #e74c3c;
        }

    @@keyframes slideInRight {
        from {
            opacity: 0;
            transform: translateX(40px);
        }

        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    #btnAddToCart:disabled {
        opacity: 0.7;
        cursor: not-allowed;
    }
</style>

<!-- Toast container -->
<div class="toast-container" id="toastContainer"></div>

<div class="container mt-4">
    <div class="row">
        <!-- PRODUCT IMAGES -->
        <div class="col-md-5">
            <div class="main-image mb-3">
                <img id="mainProductImage"
                     src="@Model.Images?.FirstOrDefault()"
                     class="img-fluid rounded shadow" />
            </div>
            <div class="d-flex gap-2 flex-wrap">
                @if (Model.Images != null)
                {
                    foreach (var img in Model.Images)
                    {
                        <img src="@img"
                             class="thumb-image"
                             onclick="changeImage('@img')" />
                    }
                }
            </div>
        </div>

        <!-- PRODUCT INFO -->
        <div class="col-md-7">
            <h2 class="fw-bold">@Model.ProductName</h2>
            <div class="text-muted mb-2">
                Brand: <strong>@Model.BrandName</strong>
            </div>
            <div class="text-muted mb-3">
                Category: <strong>@Model.CategoryName</strong>
            </div>
            <h3 class="text-danger fw-bold">
                @Model.ProductPrice.ToString("N0") ₫
            </h3>
            <div class="mb-3">
                @if (Model.StockQuantity > 0)
                {
                    <span class="badge bg-success fs-6">
                        In Stock (@Model.StockQuantity)
                    </span>
                }
                else
                {
                    <span class="badge bg-danger fs-6">
                        Out Of Stock
                    </span>
                }
            </div>
            <p class="mt-3">@Model.ProductDescription</p>

            <!-- ATTRIBUTES -->
            @if (Model.Attributes != null && Model.Attributes.Any())
            {
                <h5 class="mt-4">Product Specifications</h5>
                <table class="table table-bordered">
                    <tbody>
                        @foreach (var attr in Model.Attributes)
                        {
                            <tr>
                                <td style="width:200px">@attr.AttributeName</td>
                                <td>@attr.AttributeValue</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }

            <!-- ACTIONS -->
            <div class="mt-4 d-flex gap-2 align-items-center">
                <input type="number"
                       id="qtyInput"
                       value="1"
                       min="1"
                       max="@Model.StockQuantity"
                       class="form-control w-25"
                       @(Model.StockQuantity <= 0 ? "disabled" : "") />
                <button id="btnAddToCart"
                        class="btn btn-primary"
                        onclick="addToCart()"
                        @(Model.StockQuantity <= 0 ? "disabled" : "")>
                    <i class="bi bi-cart"></i>
                    Add To Cart
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    function changeImage(src) {
        document.getElementById("mainProductImage").src = src;
    }

    // ========================
    // TOAST NOTIFICATION
    // ========================
    function showToast(message, type = 'success') {
        const container = document.getElementById('toastContainer');
        const icon = type === 'success' ? '✓' : '✕';
        const toast = document.createElement('div');
        toast.className = `toast-msg ${type}`;
        toast.innerHTML = `<span>${icon}</span><span>${message}</span>`;
        container.appendChild(toast);
        setTimeout(() => {
            toast.style.opacity = '0';
            toast.style.transition = 'opacity 0.4s';
            setTimeout(() => toast.remove(), 400);
        }, 3000);
    }

    // ========================
    // ADD TO CART
    // ========================
    async function addToCart() {
        const qtyInput = document.getElementById('qtyInput');
        const btn = document.getElementById('btnAddToCart');
        const quantity = parseInt(qtyInput.value);
        const maxQty = parseInt(qtyInput.max);
        const productId = '@Model.ProductId';

        // Validate quantity
        if (isNaN(quantity) || quantity < 1) {
            showToast('Please enter a valid quantity.', 'error');
            return;
        }
        if (quantity > maxQty) {
            showToast(`Cannot exceed available stock (${maxQty}).`, 'error');
            qtyInput.value = maxQty;
            return;
        }

        // Disable button to prevent double-click
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Adding...';

        try {
            const res = await fetch('@Url.Action("AddToCart", "Cart")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    productId: productId,
                    quantity: quantity
                })
            });

            const data = await res.json();

            if (data.success) {
                showToast(data.message || 'Added to cart successfully!', 'success');
            } else {
                // Nếu chưa đăng nhập, redirect sang trang login
                if (res.status === 401 || (data.message && data.message.toLowerCase().includes('login'))) {
                    showToast('Please login to add items to cart.', 'error');
                    setTimeout(() => window.location.href = '@Url.Action("Login", "Auth")', 1500);
                } else {
                    showToast(data.message || 'Failed to add to cart.', 'error');
                }
            }
        } catch {
            showToast('An error occurred. Please try again.', 'error');
        } finally {
            btn.disabled = @(Model.StockQuantity <= 0 ? "true" : "false");
            btn.innerHTML = '<i class="bi bi-cart"></i> Add To Cart';
        }
    }
</script>
