@using PetCenterClient.DTOs
@model OdataResponse<ReadProductDTO>

@{
    ViewData["Title"] = "Products";

    var hotProducts = ViewBag.HotProducts as List<ReadProductDTO>;
    var newProducts = ViewBag.NewProducts as List<ReadProductDTO>;
}

<link rel="stylesheet" href="~/css/UserViews/Home/HomePage.css" />

<div class="container mt-4">

    <!-- HERO BANNER -->
    <div class="hero-banner mb-5">

        <img src="https://res.cloudinary.com/dbjdxy4p6/image/upload/v1773461154/Water2_lsvuv0.png"
             class="hero-img" />
        <div class="hero-content">
            <h1>Pet Center Shop</h1>
            <p>Best products for your lovely pets</p>

            <a asp-controller="Products"
               asp-action="Index"
               class="btn btn-primary">
                Shop Now
            </a>
        </div>

    </div>


    <!-- HOT PRODUCTS -->
    @if (hotProducts != null && hotProducts.Any())
    {
        <section class="mb-5">

            <div class="d-flex justify-content-between align-items-center mb-3">
                <h3 class="fw-bold">
                    🔥 Hot Products
                </h3>
            </div>

            <div class="product-grid">

                @foreach (var item in hotProducts)
                {
                    <a asp-controller="Products"
                       asp-action="DetailsForcustomer"
                       asp-route-id="@item.ProductId"
                       class="text-decoration-none text-dark">

                        <div class="product-card">

                            <div class="product-image">
                                <img src="@item.Images?.FirstOrDefault()" />
                            </div>

                            <div class="product-info">

                                <h5 class="product-title">
                                    @item.ProductName
                                </h5>

                                <span class="product-price">
                                    @item.ProductPrice.ToString("N0") ₫
                                </span>

                            </div>

                        </div>

                    </a>
                }

            </div>

        </section>
    }


    <!-- NEW PRODUCTS -->
    @if (newProducts != null && newProducts.Any())
    {
        <section class="mb-5">

            <div class="d-flex justify-content-between align-items-center mb-3">
                <h3 class="fw-bold">
                    🆕 New Products
                </h3>
            </div>

            <div class="product-grid">

                @foreach (var item in newProducts)
                {
                    <a asp-controller="Products"
                       asp-action="DetailsForcustomer"
                       asp-route-id="@item.ProductId"
                       class="text-decoration-none text-dark">

                        <div class="product-card">

                            <div class="product-image">
                                <img src="@item.Images?.FirstOrDefault()" />
                            </div>

                            <div class="product-info">

                                <h5 class="product-title">
                                    @item.ProductName
                                </h5>

                                <span class="product-price">
                                    @item.ProductPrice.ToString("N0") ₫
                                </span>

                            </div>

                        </div>

                    </a>
                }

            </div>

        </section>
    }


    <!-- FILTER -->
    <section class="mb-4">

    <h3 class="fw-bold mb-3">All Products</h3>

    <form asp-action="Index" method="get" class="row g-2 mb-3">

        <!-- Search -->
        <div class="col-md-3">
            <input type="text"
                   name="search"
                   value="@Context.Request.Query["search"]"
                   class="form-control"
                   placeholder="Search product..." />
        </div>

        <!-- Sort -->
        <div class="col-md-2">
            <select name="sortBy" class="form-control">
                <option value="">Sort By</option>
                <option value="Name">Name</option>
                <option value="Price">Price</option>
                <option value="date">Created Date</option>
            </select>
        </div>

        <div class="col-md-2">
            <select name="sortOrder" class="form-control">
                <option value="asc">Asc</option>
                <option value="desc">Desc</option>
            </select>
        </div>

        <!-- Price -->
        <div class="col-md-2">
            <input type="number"
                   name="minPrice"
                   value="@Context.Request.Query["minPrice"]"
                   class="form-control"
                   placeholder="Min price" />
        </div>

        <div class="col-md-2">
            <input type="number"
                   name="maxPrice"
                   value="@Context.Request.Query["maxPrice"]"
                   class="form-control"
                   placeholder="Max price" />
        </div>

        <!-- DATE FILTER -->
        <div class="col-md-2">
            <input type="date"
                   name="fromDate"
                   value="@Context.Request.Query["fromDate"]"
                   class="form-control"
                   placeholder="From date" />
        </div>

        <div class="col-md-2">
            <input type="date"
                   name="toDate"
                   value="@Context.Request.Query["toDate"]"
                   class="form-control"
                   placeholder="To date" />
        </div>

        <!-- Button -->
        <div class="col-md-1">
            <button class="btn btn-primary w-100">
                Filter
            </button>
        </div>

    </form>

</section>


    <!-- ALL PRODUCTS GRID -->
    @if (Model?.Values != null && Model.Values.Any())
    {
        <div class="product-grid">

            @foreach (var item in Model.Values)
            {
                <a asp-controller="Products"
                   asp-action="DetailsForcustomer"
                   asp-route-id="@item.ProductId"
                   class="text-decoration-none text-dark">

                    <div class="product-card">

                        <div class="product-image">
                            <img src="@item.Images?.FirstOrDefault()" />
                        </div>

                        <div class="product-info">

                            <h5 class="product-title">
                                @item.ProductName
                            </h5>

                            <p class="text-muted small">
                                @item.ProductDescription
                            </p>

                            <div class="product-meta">

                                <span class="product-price">
                                    @item.ProductPrice.ToString("N0") ₫
                                </span>

                                @if (item.StockQuantity > 0)
                                {
                                    <span class="badge bg-success">In Stock</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Out</span>
                                }

                            </div>

                            <div class="product-extra mt-2 small text-muted">
                                <div>Brand: @item.BrandName</div>
                                <div>Category: @item.CategoryName</div>
                            </div>

                        </div>

                    </div>

                </a>
            }

        </div>
    }

</div>

<script>
    document.querySelector("form").addEventListener("submit", function () {

        this.querySelectorAll("input, select").forEach(el => {
            if (!el.value) {
                el.removeAttribute("name");
            }
        });

    });
</script>