
@{
    ViewData["Title"] = "Pet Support Center";
    Layout = "_Layout";
}

<link rel="stylesheet"
      href="~/css/UserViews/Home/Home.css"
      asp-append-version="true" />

<section class="hero-slider">

    <div class="slide active">
        <img src="https://res.cloudinary.com/dbjdxy4p6/image/upload/v1781690348/professional_promotional_banner_for_a_luxury_pet_service_center._keep_t0shlu.png" />
    </div>

    <div class="slide">
        <img src="https://res.cloudinary.com/dbjdxy4p6/image/upload/v1781690348/translate_all_remaining_vietnamese_text_in_the_three_promotional_boxes_at_the_ckegbt.png" />
    </div>

    <div class="slide">
        <img src="https://res.cloudinary.com/dbjdxy4p6/image/upload/v1781690348/a_high_energy_vibrant_promotional_sales_banner_for_a_premium_pet_store_1920x720_qrpwar.png" />
    </div>

</section>
<!-- HERO -->

<section class="hero-section">

    <div class="hero-overlay"></div>

    <div class="hero-container">

        <div class="hero-left">

            <span class="hero-tag">
                🐾 PET SUPPORT CENTER SYSTEM
            </span>

            <h1>
                One Platform For Every Pet Care Need
            </h1>

            <p>
                A comprehensive pet care ecosystem that integrates veterinary
                services, grooming appointments, e-commerce, medical record
                management, inventory control, customer support and AI-powered
                disease identification into a single centralized platform.
            </p>

      

        </div>

        <div class="hero-right">

            <div class="dashboard-preview">

                <div class="dashboard-card">
                    <span>📅</span>
                    <h3>Appointments</h3>
                    <p>Online booking & scheduling</p>
                </div>

                <div class="dashboard-card">
                    <span>🏥</span>
                    <h3>Medical Records</h3>
                    <p>Digital healthcare management</p>
                </div>

                <div class="dashboard-card">
                    <span>🛒</span>
                    <h3>E-Commerce</h3>
                    <p>Products & order management</p>
                </div>

                <div class="dashboard-card">
                    <span>🤖</span>
                    <h3>AI Support</h3>
                    <p>Disease identification system</p>
                </div>

            </div>

        </div>

    </div>

</section>

<!-- STATS -->

<section class="stats-section">

    <div class="stats-container">

        <div class="stat-item">
            <h2>9+</h2>
            <span>Core Modules</span>
        </div>

        <div class="stat-item">
            <h2>AI</h2>
            <span>Disease Identification</span>
        </div>

        <div class="stat-item">
            <h2>24/7</h2>
            <span>Customer Support</span>
        </div>

        <div class="stat-item">
            <h2>1</h2>
            <span>Integrated Platform</span>
        </div>

    </div>

</section>

<!-- PROBLEMS -->

<section class="problem-section">

    <div class="section-heading">

        <span>Challenges</span>

        <h2>Why Was This System Developed?</h2>

        <p>
            Pet ownership has become increasingly popular in Vietnam.
            However, pet-related services remain fragmented and disconnected.
        </p>

    </div>

    <div class="timeline">

        <div class="timeline-item">
            <div class="timeline-number">01</div>

            <div class="timeline-content">
                <h3>Manual Appointment Process</h3>

                <p>
                    Grooming and veterinary appointments are often managed
                    through phone calls and messages, causing scheduling
                    conflicts and long waiting times.
                </p>
            </div>
        </div>

        <div class="timeline-item">
            <div class="timeline-number">02</div>

            <div class="timeline-content">
                <h3>Fragmented Services</h3>

                <p>
                    Customers must use multiple systems to purchase products,
                    book services, manage pets and access medical records.
                </p>
            </div>
        </div>

        <div class="timeline-item">
            <div class="timeline-number">03</div>

            <div class="timeline-content">
                <h3>Inefficient Store Management</h3>

                <p>
                    Inventory, appointments, customers and reports are often
                    managed manually, reducing operational efficiency.
                </p>
            </div>
        </div>

    </div>

</section>

<!-- SOLUTION -->

<section class="solution-section">

    <div class="solution-container">

        <div class="solution-left">

            <span>Solution</span>

            <h2>
                Comprehensive Pet Support Ecosystem
            </h2>

            <p>
                The Pet Support Center System centralizes all pet-related
                operations into one platform, helping customers receive
                better services while enabling businesses to manage
                operations more effectively.
            </p>

        </div>

        <div class="solution-right">

            <div class="solution-box">Appointment Management</div>
            <div class="solution-box">Medical Records</div>
            <div class="solution-box">Inventory Control</div>
            <div class="solution-box">E-Commerce</div>
            <div class="solution-box">Communication</div>
            <div class="solution-box">AI Support</div>

        </div>

    </div>

</section>


<!-- FEATURES -->

<section class="modules-section">

    <div class="section-heading">

        <span>Features</span>

        <h2>Core Functional Modules</h2>

    </div>

    <div class="modules-grid">

        <div class="module-card">🔐 User & Authentication</div>
        <div class="module-card">📅 Appointment Management</div>
        <div class="module-card">🐶 Pet Profile Management</div>
        <div class="module-card">🏥 Medical Records</div>
        <div class="module-card">🛒 E-Commerce Platform</div>
        <div class="module-card">📦 Inventory Management</div>
        <div class="module-card">👨‍⚕️ Veterinarian Profiles</div>
        <div class="module-card">💬 Real-Time Communication</div>
        <div class="module-card">🤖 AI Integration</div>

    </div>

</section>

<section class="promo-banner">

    <div class="promo-left">

        <span class="promo-tag">
            🤖 AI Technology
        </span>

        <h2>AI Pet Health Assistant</h2>

        <p>
            Upload pet images and symptoms to receive
            preliminary AI-powered disease analysis
            and personalized recommendations.
        </p>

        <div class="promo-actions">
            <a href="#" class="promo-btn">
                Try AI Analysis
            </a>

            <a href="#" class="promo-btn-outline">
                Learn More
            </a>
        </div>

    </div>

    <div class="promo-right">
        <img src="https://res.cloudinary.com/dbjdxy4p6/image/upload/v1781429052/banner4_ndvea2.png" />
    </div>

</section>

<!-- AI -->

<section class="ai-showcase">

    <div class="ai-content">

        <span>AI Powered Feature</span>

        <h2>AI-Based Disease Identification</h2>

        <p>
            Customers can upload images and provide symptoms to receive
            AI-assisted disease analysis and preliminary health evaluations
            before booking professional veterinary consultations.
        </p>

        <div class="ai-flow">

            <div>📸 Upload Image</div>
            <div>🔍 Analyze Symptoms</div>
            <div>🧠 AI Evaluation</div>
            <div>🏥 Veterinary Appointment</div>

        </div>

    </div>

</section>

<!-- CUSTOMER JOURNEY -->

<section class="journey-section">

    <div class="section-heading">

        <span>Workflow</span>

        <h2>Customer Journey</h2>

    </div>

    <div class="journey-flow">

        <div>Create Account</div>
        <div>Create Pet Profile</div>
        <div>Book Appointment</div>
        <div>Receive Treatment</div>
        <div>Purchase Products</div>

    </div>

</section>

<!-- CTA -->

<section class="cta-section">

    <div class="cta-content">

        <h2>
            Pet Care, Healthcare, Shopping & AI Support
            In One Integrated Platform
        </h2>

        <p>
            The Pet Support Center System provides a centralized ecosystem
            for pet owners, pet stores and veterinary clinics.
        </p>

    </div>

</section>




<script>
    const slides = document.querySelectorAll(".slide");

    let current = 0;

    setInterval(() => {

        slides[current].classList.remove("active");

        current++;

        if(current >= slides.length)
            current = 0;

        slides[current].classList.add("active");

    }, 4000);
</script>

