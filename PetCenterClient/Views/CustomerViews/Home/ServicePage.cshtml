    </div>

    <div class="service-marquee">
        <div class="marquee-track">

            <span>🐶 Veterinary Care</span>
            <span>✂️ Grooming</span>
            <span>🩺 Health Check</span>
            <span>💚 Pet Wellness</span>

            <span>🐶 Veterinary Care</span>
            <span>✂️ Grooming</span>
            <span>🩺 Health Check</span>
            <span>💚 Pet Wellness</span>

        </div>
    </div>

   

    <div class="stats">

        <div class="stat">
            <h3>@Model.Count</h3>
            <p>Services</p>
        </div>

        <div class="stat">
            <h3>500+</h3>
