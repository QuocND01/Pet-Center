<br>
    <div class="search-box">

        <div class="search-card">

            <form asp-action="Index"
                  asp-controller="Service"
                  method="get">

                <div class="search-row">

                    <input type="text"
                           name="search"
                           value="@currentSearch"
                           class="search-input"
                           placeholder="Search services..." />

                    <select name="serviceType"
                            class="search-select">

                        <option value="">
                            All Categories
                        </option>

                        <option value="1">
                            Veterinary
                        </option>

                        <option value="2">
                            Grooming
                        </option>

                        <option value="3">
                            Boarding
                        </option>

                        <option value="4">
                            Training
                        </option>

                    </select>

                    <button class="search-btn">
                        Search
                    </button>

                </div>

            </form>

        </div>

    </div>

    <br>

    @if (Model?.Values != null && Model.Values.Any())
    {
        <div id="services"
             class="services-grid">

            @foreach (var item in Model.Values)
            {
                var img =
                item.ImageFiles?.FirstOrDefault();

                <a asp-action="DetailsForcustomer"
                   asp-controller="Service"
                   asp-route-id="@item.ServiceId"
                   class="service-card">

                    <div class="service-image">

                        <img src="@(img ?? "/images/no-image.jpg")">

                        <span class="service-badge">
                            @GetTypeName(item.ServiceType)
                        </span>

                    </div>

                    <div class="service-content">

                        <div class="service-name">
                            @item.ServiceName
                        </div>

                        <div class="service-desc">
                            @item.ServiceDescription
                        </div>

                        <div class="service-meta">

                            <div class="meta">
                                ⏱ @item.Duration min
                            </div>

                            <div class="meta">
                                ⭐ Premium
                            </div>

                        </div>

                        <div class="service-footer">

                            <div class="price">
                                @item.Price.ToString("N0")₫
                            </div>

