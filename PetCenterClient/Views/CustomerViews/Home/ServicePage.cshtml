@using PetCenterClient.ViewModels.Common
@using static PetCenterClient.ViewModels.Service.ServiceViewModel
@model OdataResponse<ReadServiceViewModelForCustomer>

@{
    ViewData["Title"] = "Pet Services";

    var currentSearch = Context.Request.Query["search"].ToString();
    var currentType = Context.Request.Query["serviceType"].ToString();

    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap');

    :root {
        --primary: #2ecc71;
        --primary-dark: #27ae60;
        --primary-light: #d1fae5;
        --accent: #4f46e5;
        --bg: #f0f7f4;
        --card: #ffffff;
        --text: #0f172a;
        --muted: #64748b;
        --border: #e2e8f0;
        --shadow-sm: 0 2px 8px rgba(0,0,0,.06);
        --shadow: 0 8px 28px rgba(0,0,0,.08);
        --shadow-hover: 0 20px 50px rgba(46,204,113,.2);
        --radius: 20px;
    }


    /* ── WRAPPER ── */
    .sp-wrap {
        width: 100%;
        max-width: 1600px;
        margin: 0 auto;
        padding: 0 24px 40px;
        box-sizing: border-box;
    }

    /* ── HERO ── */
    .sp-hero {
        position: relative;
        height: 480px;
        border-radius: 28px;
        overflow: hidden;
        margin: 28px 0 50px;
    }

    .sp-hero img {
        width: 100%; height: 100%;
        object-fit: cover;
        transition: transform 8s ease;
    }

    .sp-hero:hover img { transform: scale(1.04); }

    .sp-hero-overlay {
        position: absolute; inset: 0;
        background: linear-gradient(100deg, rgba(10,20,15,.75) 0%, rgba(10,20,15,.3) 60%, transparent 100%);
    }

    .sp-hero-body {
        position: absolute;
        top: 50%; left: 64px;
        transform: translateY(-50%);
        color: #fff;
        max-width: 620px;
    }

    .sp-hero-label {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: rgba(46,204,113,.25);
        border: 1px solid rgba(46,204,113,.45);
        backdrop-filter: blur(10px);
        color: #6ee7a0;
        font-size: 13px;
        font-weight: 700;
        letter-spacing: .06em;
        text-transform: uppercase;
        padding: 7px 16px;
        border-radius: 999px;
        margin-bottom: 20px;
    }

    .sp-hero-body h1 {
        font-size: clamp(36px, 5vw, 58px);
        font-weight: 900;
        line-height: 1.1;
        margin: 0 0 16px;
        display: -webkit-box;
        -webkit-box-orient: vertical;
        -webkit-line-clamp: 2;
        overflow: hidden;
        overflow-wrap: anywhere;
    }

    .sp-hero-body p {
        font-size: 18px;
        opacity: .88;
        margin-bottom: 30px;
        line-height: 1.65;
        display: -webkit-box;
        -webkit-box-orient: vertical;
        -webkit-line-clamp: 3;
        overflow: hidden;
        overflow-wrap: anywhere;
    }

    .sp-card-name,
    .sp-card-desc,
    .sp-tag
 {
        word-break: break-word;
        overflow-wrap: anywhere;
    }

    .sp-hero-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: var(--primary);
        color: #fff;
        padding: 14px 30px;
        border-radius: 999px;
        font-weight: 800;
        font-size: 15px;
        text-decoration: none;
        transition: .25s;
        box-shadow: 0 6px 20px rgba(46,204,113,.4);
    }

    .sp-hero-btn:hover {
        background: var(--primary-dark);
        transform: translateY(-2px);
    }

    /* ── MARQUEE ── */
    .sp-marquee {
        overflow: hidden;
        background: #fff;
        border-radius: 14px;
        padding: 14px 0;
        margin-bottom: 50px;
        border: 1px solid var(--border);
    }

    .sp-marquee-track {
        display: flex;
        gap: 56px;
        width: max-content;
        animation: marqueeScroll 28s linear infinite;
    }

    .sp-marquee-track span {
        font-size: 14px;
        font-weight: 700;
        color: var(--primary-dark);
        white-space: nowrap;
    }

    .sp-marquee-track span em {
        color: var(--muted);
        font-style: normal;
        font-weight: 500;
    }

    @@keyframes marqueeScroll {
        from { transform: translateX(0); }
        to   { transform: translateX(-50%); }
    }

    /* ── STATS ── */
    .sp-stats {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-bottom: 60px;
    }

    .sp-stat {
        background: #fff;
        border-radius: var(--radius);
        padding: 28px 20px;
        text-align: center;
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--border);
        transition: .25s;
    }

    .sp-stat:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow);
    }

    .sp-stat-icon {
        font-size: 32px;
        margin-bottom: 10px;
        display: block;
    }

    .sp-stat h3 {
        font-size: 38px;
        font-weight: 900;
        color: var(--primary-dark);
        line-height: 1;
        margin: 0 0 6px;
    }

    .sp-stat p {
        color: var(--muted);
        font-size: 14px;
        font-weight: 600;
        margin: 0;
    }

    /* ── SECTION HEADER ── */
    .sp-section-head {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        margin-bottom: 28px;
    }

    .sp-section-head h2 {
        font-size: 30px;
        font-weight: 900;
        margin: 0;
    }

    .sp-section-head h2 span {
        color: var(--primary-dark);
    }

    /* ── SEARCH / FILTER ── */
    .sp-filter {
        background: #fff;
        border-radius: var(--radius);
        padding: 18px 22px;
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--border);
        margin-bottom: 32px;
    }

    .sp-filter form {
        display: flex;
        gap: 12px;
        align-items: center;
    }

    .sp-filter input,
    .sp-filter select {
        flex: 1;
        border: 1.5px solid var(--border);
        padding: 12px 16px;
        border-radius: 12px;
        font-size: 14px;
        font-family: 'Inter', sans-serif;
        background: #f8fafc;
        color: var(--text);
        transition: border-color .2s;
        outline: none;
    }

    .sp-filter input:focus,
    .sp-filter select:focus {
        border-color: var(--primary);
        background: #fff;
    }

    .sp-filter button {
        padding: 12px 26px;
        background: var(--primary);
        color: #fff;
        border: none;
        border-radius: 12px;
        font-weight: 800;
        font-size: 14px;
        cursor: pointer;
        font-family: 'Inter', sans-serif;
        transition: .2s;
        white-space: nowrap;
    }

    .sp-filter button:hover { background: var(--primary-dark); }

    /* ── GRID ── */
    .sp-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
        gap: 26px;
    }

    /* ── SERVICE CARD ── */
    .sp-card {
        background: #fff;
        border-radius: 22px;
        overflow: hidden;
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--border);
        text-decoration: none;
        color: inherit;
        display: flex;
        flex-direction: column;
        transition: .3s cubic-bezier(.25,.8,.25,1);
    }

    .sp-card:hover {
        transform: translateY(-8px);
        box-shadow: var(--shadow-hover);
        border-color: rgba(46,204,113,.3);
    }

    .sp-card-img {
        position: relative;
        height: 240px;
        overflow: hidden;
        flex-shrink: 0;
    }

    .sp-card-img img {
        width: 100%; height: 100%;
        object-fit: cover;
        transition: transform .5s ease;
    }

    .sp-card:hover .sp-card-img img { transform: scale(1.07); }

    .sp-card-badge {
        position: absolute;
        top: 14px; left: 14px;
        background: rgba(255,255,255,.94);
        backdrop-filter: blur(8px);
        color: var(--primary-dark);
        font-size: 11px;
        font-weight: 800;
        padding: 5px 12px;
        border-radius: 999px;
        letter-spacing: .04em;
        text-transform: uppercase;
        box-shadow: 0 2px 8px rgba(0,0,0,.1);
    }

    .sp-card-body {
        padding: 22px 24px;
        display: flex;
        flex-direction: column;
        flex: 1;
    }

    .sp-card-name {
        font-size: 20px;
        font-weight: 800;
        margin: 0 0 8px;
        line-height: 1.3;
        display: -webkit-box;
        -webkit-box-orient: vertical;
        -webkit-line-clamp: 2;
        overflow: hidden;
        overflow-wrap: anywhere;
        word-break: break-word;
    }

    .sp-card-desc {
        color: var(--muted);
        font-size: 14px;
        line-height: 1.7;
        flex: 1;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
        overflow-wrap: anywhere;
        word-break: break-word;
    }

    .sp-card-tags {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        margin-top: 14px;
    }

    .sp-tag {
        background: #f0fdf4;
        color: #15803d;
        border: 1px solid #bbf7d0;
        padding: 5px 12px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 700;
        display: inline-block;
        max-width: 140px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .sp-card-foot {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 16px;
        padding-top: 16px;
        border-top: 1px solid #f1f5f9;
    }

    .sp-price {
        font-size: 26px;
        font-weight: 900;
        color: var(--primary-dark);
    }

    .sp-price small {
        font-size: 14px;
        font-weight: 600;
        color: var(--muted);
    }

    .sp-book-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: var(--primary);
        color: #fff;
        padding: 10px 20px;
        border-radius: 999px;
        font-size: 13px;
        font-weight: 800;
        transition: .2s;
        box-shadow: 0 3px 12px rgba(46,204,113,.3);
    }

    .sp-card:hover .sp-book-btn {
        background: var(--primary-dark);
        transform: scale(1.04);
    }

    /* ── EMPTY ── */
    .sp-empty {
        text-align: center;
        padding: 100px 20px;
        color: var(--muted);
    }

    .sp-empty-icon { font-size: 64px; margin-bottom: 16px; }

    .sp-empty h3 {
        font-size: 26px;
        font-weight: 800;
        color: var(--text);
        margin: 0 0 8px;
    }

    /* ── PAGINATION ── */
    .sp-pager {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 8px;
        margin-top: 50px;
    }

    .sp-page-btn {
        width: 42px; height: 42px;
        border-radius: 12px;
        display: flex;
        justify-content: center;
        align-items: center;
        text-decoration: none;
        background: #fff;
        color: var(--text);
        font-weight: 700;
        font-size: 14px;
        border: 1.5px solid var(--border);
        box-shadow: var(--shadow-sm);
        transition: .2s;
    }

    .sp-page-btn:hover {
        border-color: var(--primary);
        color: var(--primary-dark);
    }

    .sp-page-btn.active {
        background: var(--primary);
        color: #fff;
        border-color: var(--primary);
        box-shadow: 0 4px 14px rgba(46,204,113,.35);
    }

    .sp-page-btn.disabled {
        opacity: .4;
        pointer-events: none;
    }

    /* ── AI BANNER ── */
    .sp-ai {
        margin-top: 70px;
        padding: 52px 60px;
        border-radius: 28px;
        background: linear-gradient(135deg, #312e81 0%, #1e40af 50%, #1d4ed8 100%);
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 40px;
        color: #fff;
        position: relative;
        overflow: hidden;
    }

    .sp-ai::before {
        content: '';
        position: absolute;
        width: 380px; height: 380px;
        border-radius: 50%;
        background: rgba(255,255,255,.06);
        right: -100px; top: -150px;
        pointer-events: none;
    }

    .sp-ai::after {
        content: '';
        position: absolute;
        width: 200px; height: 200px;
        border-radius: 50%;
        background: rgba(255,255,255,.04);
        left: 40%; bottom: -80px;
        pointer-events: none;
    }

    .sp-ai-body { max-width: 600px; position: relative; z-index: 2; }

    .sp-ai-tag {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: rgba(255,255,255,.15);
        border: 1px solid rgba(255,255,255,.25);
        padding: 7px 16px;
        border-radius: 999px;
        font-size: 13px;
        font-weight: 700;
        margin-bottom: 18px;
        letter-spacing: .04em;
    }

    .sp-ai-body h2 {
        font-size: clamp(26px, 3vw, 40px);
        font-weight: 900;
        margin: 0 0 14px;
        line-height: 1.2;
    }

    .sp-ai-body p {
        font-size: 16px;
        opacity: .9;
        line-height: 1.75;
        margin-bottom: 24px;
    }

    .sp-ai-chips {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-bottom: 28px;
    }

    .sp-ai-chips span {
        background: rgba(255,255,255,.12);
        border: 1px solid rgba(255,255,255,.2);
        padding: 7px 14px;
        border-radius: 999px;
        font-size: 13px;
        font-weight: 600;
    }

    .sp-ai-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: #fff;
        color: #1d4ed8;
        padding: 14px 28px;
        border-radius: 999px;
        font-weight: 800;
        font-size: 15px;
        text-decoration: none;
        transition: .25s;
        box-shadow: 0 6px 20px rgba(0,0,0,.15);
    }

    .sp-ai-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 28px rgba(0,0,0,.2);
    }

    .sp-ai-visual {
        font-size: 120px;
        position: relative;
        z-index: 2;
        flex-shrink: 0;
        filter: drop-shadow(0 10px 30px rgba(0,0,0,.3));
        animation: aiFloat 3.5s ease-in-out infinite;
    }


    @@keyframes aiFloat {
        0%, 100% { transform: translateY(0); }
        50%       { transform: translateY(-12px); }
    }

    /* ── PROMO STRIP ── */
    .sp-promo {
        margin: 60px 0;
        padding: 40px 52px;
        background: linear-gradient(135deg, #2ecc71, #16a34a);
        border-radius: 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 30px;
        color: #fff;
        position: relative;
        overflow: hidden;
    }

    .sp-promo::before {
        content: '';
        position: absolute;
        width: 360px; height: 360px;
        border-radius: 50%;
        background: rgba(255,255,255,.08);
        right: -80px; top: -160px;
        pointer-events: none;
    }

    .sp-promo-text { position: relative; z-index: 1; }

    .sp-promo-text h3 {
        font-size: 28px;
        font-weight: 900;
        margin: 0 0 6px;
    }

    .sp-promo-text p {
        margin: 0;
        font-size: 16px;
        opacity: .9;
    }

    .sp-promo-btn {
        position: relative; z-index: 1;
        flex-shrink: 0;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: #fff;
        color: #16a34a;
        padding: 14px 28px;
        border-radius: 999px;
        font-weight: 800;
        font-size: 15px;
        text-decoration: none;
        transition: .25s;
        box-shadow: 0 6px 20px rgba(0,0,0,.12);
    }

    .sp-promo-btn:hover { transform: translateY(-2px); }

    /* ── RESPONSIVE ── */
    @@media (max-width: 900px) {
        .sp-hero { height: 360px; }
        .sp-hero-body { left: 32px; }
        .sp-stats { grid-template-columns: repeat(2, 1fr); }
        .sp-ai { flex-direction: column; padding: 36px 28px; text-align: center; }
        .sp-ai-chips { justify-content: center; }
        .sp-ai-visual { font-size: 80px; }
        .sp-promo { flex-direction: column; text-align: center; padding: 32px 24px; }
    }

    @@media (max-width: 600px) {
        .sp-hero { height: 280px; }
        .sp-hero-body { left: 20px; max-width: calc(100% - 40px); }
        .sp-grid { grid-template-columns: 1fr; }
        .sp-filter form { flex-direction: column; }
        .sp-filter button { width: 100%; }
        .sp-section-head { flex-direction: column; align-items: flex-start; gap: 8px; }
    }

    .sp-clear-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 12px 22px;
        border-radius: 12px;
        background: #fff;
        border: 1.5px solid var(--border);
        color: var(--text);
        text-decoration: none;
        font-weight: 700;
        white-space: nowrap;
        transition: .2s;
    }

        .sp-clear-btn:hover {
            background: #f8fafc;
            border-color: var(--primary);
            color: var(--primary-dark);
        }

    .sp-ai-image {
        flex: 0 0 450px;
        display: flex;
        justify-content: center;
        align-items: center;
        position: relative;
        z-index: 2;
    }

        .sp-ai-image img {
            width: 100%;
            max-width: 450px;
            height: 450px;
            object-fit: cover;
            border-radius: 24px;
            border: 4px solid rgba(255,255,255,.18);
            box-shadow: 0 18px 40px rgba(0,0,0,.22);
            transition: .3s ease;
        }

            .sp-ai-image img:hover {
                transform: scale(1.03);
            }
</style>

<div class="sp-wrap">


    <section class="sp-hero">
        <img src="https://res.cloudinary.com/dbjdxy4p6/image/upload/v1781687991/a_professional_high_quality_wide_banner_for_a_premium_veterinary_clinic._the_wy49m3.png" alt="PetCenter Premium Services">
        <div class="sp-hero-overlay"></div>
        <div class="sp-hero-body">
            <div class="sp-hero-label">🐾 PetCenter</div>
            <h1>Premium Pet Care, Tailored for Your Companion</h1>
            <p>Trusted veterinary, grooming, boarding and training services delivered by certified experts.</p>
            <a href="#services" class="sp-hero-btn">Browse Services ↓</a>
        </div>
    </section>

    <div class="sp-marquee">
        <div class="sp-marquee-track">
            <span>🐶 Veterinary Care</span>
            <span>✂️ Grooming &amp; Spa</span>
            <span>🩺 Health Check-up</span>
            <span>💊 Vaccination</span>
            <span>🤖 AI Skin Detection</span>
            <span>💚 Wellness Plans</span>

            <span>🐶 Veterinary Care</span>
            <span>✂️ Grooming &amp; Spa</span>
            <span>🩺 Health Check-up</span>
            <span>💊 Vaccination</span>
            <span>🤖 AI Skin Detection</span>
            <span>💚 Wellness Plans</span>
        </div>
    </div>


    <div class="sp-stats">
        <div class="sp-stat">
            <span class="sp-stat-icon">🗂️</span>
            <h3>@Model.Count</h3>
            <p>Total Services</p>
        </div>
        <div class="sp-stat">
            <span class="sp-stat-icon">🤖</span>
            <h3>AI Diagnosis</h3>
            <p>Skin Disease Detection</p>
        </div>
        <div class="sp-stat">
            <span class="sp-stat-icon">🕐</span>
            <h3>24/7</h3>
            <p>Support Available</p>
        </div>
        <div class="sp-stat">
            <span class="sp-stat-icon">🩺</span>
            <h3>Professional Care</h3>
            <p>Comprehensive Pet Healthcare</p>
        </div>
    </div>


    <div class="sp-promo">

        <div class="sp-promo-text">

            <h3>🐾 Not Sure Which Service Your Pet Needs?</h3>

            <p>
                Explore our professional veterinary, grooming and wellness
                services to find the best care for your beloved companion.
            </p>

        </div>

        <a asp-controller="Appointment"
           asp-action="Create"
           class="sp-promo-btn">

            Book Appointment →

        </a>

    </div>

    <section id="services">
    <div class="sp-section-head">
        <h2>Our <span>Services</span></h2>
    </div>


    <div class="sp-filter">
            <form asp-action="Index" asp-controller="Service" method="get" id="filterForm">
            <input type="text"
                   name="search"
                   value="@currentSearch"
                   placeholder="🔍  Search services by name..." />

            <select name="serviceType">
                <option value="">All Categories</option>
                <option value="1" selected="@(currentType == "1")">🩺 Veterinary</option>
                <option value="2" selected="@(currentType == "2")">✂️ Grooming</option>
            </select>

            <button type="submit">Search</button>

                <a asp-action="Index"
                   asp-controller="Service"
                   class="sp-clear-btn"
                   id="btnReset">
                    ✕ Clear Filters
                </a>
        </form>
    </div>
    </section>

    @if (Model?.Values != null && Model.Values.Any())
    {
        <div class="sp-grid">
            @foreach (var item in Model.Values)
            {
                var img = item.ImageFiles?.FirstOrDefault();

                <a asp-action="DetailsForcustomer"
                   asp-controller="Service"
                   asp-route-id="@item.ServiceId"
                   class="sp-card">

                    <div class="sp-card-img">
                        <img src="@(img ?? "/images/no-image.jpg")">
                        <span class="sp-card-badge">@GetTypeName(item.ServiceType)</span>
                    </div>

                    <div class="sp-card-body">
                        <div class="sp-card-name">@item.ServiceName</div>
                        <div class="sp-card-desc">@item.ServiceDescription</div>

                        <div class="sp-card-tags">
                            <span class="sp-tag">⏱ @item.Duration min</span>
                            <span class="sp-tag">⭐ Premium</span>
                        </div>

                        <div class="sp-card-foot">
                            <div class="sp-price">
                                @item.Price.ToString("N0")₫
                                <small>/ session</small>
                            </div>
                            <span class="sp-book-btn">Book Now →</span>
                        </div>
                    </div>

                </a>
            }
        </div>

        @if (totalPages > 1)
        {
            <nav class="sp-pager">
                @if (currentPage > 1)
                {
                    <a href="?search=@currentSearch&serviceType=@currentType&page=@(currentPage - 1)"
                       class="sp-page-btn">‹</a>
                }
                else
                {
                    <span class="sp-page-btn disabled">‹</span>
                }

                @for (int p = 1; p <= totalPages; p++)
                {
                    <a href="?search=@currentSearch&serviceType=@currentType&page=@p"
                       class="sp-page-btn @(p == currentPage ? "active" : "")">@p</a>
                }

                @if (currentPage < totalPages)
                {
                    <a href="?search=@currentSearch&serviceType=@currentType&page=@(currentPage + 1)"
                       class="sp-page-btn">›</a>
                }
                else
                {
                    <span class="sp-page-btn disabled">›</span>
                }
            </nav>
        }
    }
    else
    {
        <div class="sp-empty">
            <div class="sp-empty-icon">🐾</div>
            <h3>No Services Found</h3>
            <p>Try a different keyword or category.</p>
        </div>
    }
    <div class="sp-ai">
        <div class="sp-ai-body">
            <div class="sp-ai-tag">🤖 AI-Powered Feature</div>
            <h2>Detect Your Pet's Skin Disease with AI</h2>
            <p>
                Upload a clear photo of your pet's skin and our AI model will analyze it within seconds —
                giving you a preliminary diagnosis to help decide if a vet visit is needed.
            </p>
            <div class="sp-ai-chips">
                <span>📸 Photo Upload</span>
                <span>⚡ Instant Results</span>
                <span>🐶 Dogs &amp; Cats</span>
                <span>🩺 Vet Recommendation</span>
            </div>
            <a asp-controller="AIClassify" asp-action="ClassifyAI" class="sp-ai-btn">
                Try AI Detection →
            </a>
        </div>
        <div class="sp-ai-image">
            <img src="https://res.cloudinary.com/dbjdxy4p6/image/upload/v1783502172/ringworm_x3cb5x.jpg"
                 alt="AI Pet Skin Disease Detection">
        </div>
        <div class="sp-ai-visual">🤖</div>
    </div>

</div>

@functions {
    string GetTypeName(int type)
    {
        return type switch
        {
            1 => "Veterinary",
            2 => "Grooming",
            _ => "Service"
        };
    }
}

<script>
    document.querySelectorAll('a[href="#services"]').forEach(el => {
        el.addEventListener('click', e => {
            e.preventDefault();
            document.getElementById('services')
                    ?.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
    });

        const form = document.getElementById("filterForm");

    if (form) {
        form.addEventListener("submit", function () {
            sessionStorage.setItem("serviceScroll", window.scrollY);
        });
    }

    window.addEventListener("load", function () {
        const scroll = sessionStorage.getItem("serviceScroll");

        if (scroll !== null) {
            window.scrollTo({
                top: parseInt(scroll),
                behavior: "instant"
            });

            sessionStorage.removeItem("serviceScroll");
        }
    });

    const btnReset = document.getElementById("btnReset");

    if (btnReset) {
        btnReset.addEventListener("click", function () {
            sessionStorage.setItem("serviceScroll", window.scrollY);
        });
    }
</script>