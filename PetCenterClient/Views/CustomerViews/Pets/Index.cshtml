@using PetCenterClient.ViewModels
@model IEnumerable<ReadPetListViewModel>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "My Pets";
}

<style>
    .pet-card {
        border-radius: 20px;
        border: 1px solid var(--border);
        background: #fff;
        overflow: hidden;
        transition: .2s;
    }

        .pet-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 30px rgba(0,0,0,0.08);
            border-color: var(--green);
        }

    .pet-avatar-wrapper {
        width: 100%;
        aspect-ratio: 1;
        overflow: hidden;
        background: #f1f5f9;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
    }

    .pet-avatar {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .pet-emoji {
        font-size: 60px;
    }

    .pet-info {
        padding: 20px;
    }

    .pet-tag {
        background: #dcfce7;
        color: var(--green-dark);
        padding: 4px 10px;
        border-radius: 8px;
        font-size: 12px;
        font-weight: 700;
    }

    /* Nút xóa góc phải ảnh */
    .btn-delete-pet {
        position: absolute;
        top: 10px;
        right: 10px;
        background: rgba(255,255,255,0.9);
        border: none;
        border-radius: 50%;
        width: 32px;
        height: 32px;
        color: #dc2626;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        cursor: pointer;
        transition: 0.2s;
    }

        .btn-delete-pet:hover {
            background: #dc2626;
            color: white;
        }
</style>

<div class="container py-5">
    <div class="row align-items-center mb-4 g-3">
        <div class="col-md-5">
            <h2 class="fw-bold m-0" style="font-family: 'Segoe UI', sans-serif;">My Pets 🐾</h2>
        </div>
        <div class="col-md-5">
            <form method="get" action="/Pets/Index" class="d-flex gap-2">
                <input type="text" name="search" class="form-control rounded-pill px-4" placeholder="Search breed or species..." value="@ViewBag.SearchKeyword" />
                <button type="submit" class="btn btn-dark rounded-pill px-4">Search</button>
            </form>
        </div>
        <div class="col-md-2 text-md-end">
            <button class="btn btn-primary rounded-pill w-100" style="background:#2ecc71; border:none;" onclick="openMutateModal(null)">+ Add Pet</button>
        </div>
    </div>

    <div class="row g-4">
        @if (Model != null && Model.Any())
        {
            foreach (var pet in Model)
            {
                <div class="col-6 col-md-4 col-lg-3">
                    <div class="pet-card">
                        <div class="pet-avatar-wrapper">
                            @if (!string.IsNullOrEmpty(pet.PetAvatar))
                            {
                                <img src="@pet.PetAvatar" class="pet-avatar" alt="@pet.Breed" />
                            }
                            else
                            {
                                <span class="pet-emoji">@(pet.Species.ToLower() == "cat" ? "🐱" : "🐶")</span>
                            }
                            <button class="btn-delete-pet" onclick="deletePet('@pet.PetId')" title="Remove Pet"><i class="bi bi-trash"></i></button>
                        </div>
                        <div class="pet-info text-center">
                            <h5 class="fw-bold mb-1">@pet.PetName</h5>
                            <div class="text-muted mb-1">@pet.Breed</div>
                            <div class="d-flex justify-content-center gap-2 mb-3">
                                <span class="pet-tag">@pet.Gender</span>
                                <span class="pet-tag" style="background:#f1f5f9; color:#475569;">@pet.Age</span>
                            </div>
                            <div class="d-flex gap-2">
                                <button class="btn btn-light w-50 btn-view-pet" data-id="@pet.PetId"><i class="bi bi-eye"></i> View</button>
                                <button class="btn btn-outline-dark w-50" onclick="openMutateModal('@pet.PetId')"><i class="bi bi-pencil"></i> Edit</button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5 text-muted">
                <i class="bi bi-search fs-1 d-block mb-3"></i>
                <h5>No pets found!</h5>
            </div>
        }
    </div>
</div>

<div class="modal fade" id="petDetailModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius: 20px; overflow: hidden; border:none;">
            <div class="modal-body p-0" id="petModalBody"></div>
        </div>
    </div>
</div>

<div class="modal fade" id="mutatePetModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius: 20px; border:none; box-shadow: 0 10px 40px rgba(0,0,0,0.1);">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold" id="mutateModalTitle">Add New Pet</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <input type="hidden" id="mutPetId" />
                <div class="row g-3">

                    <div class="col-12">
                        <label class="form-label text-muted fw-bold" style="font-size: 13px;">PET AVATAR</label>
                        <input type="file" id="mutImage" class="form-control bg-light border-0" accept="image/*">
                    </div>

                    <div class="col-6">
                        <label class="form-label text-muted fw-bold" style="font-size: 13px;">SPECIES</label>
                        <select id="mutSpecies" class="form-select bg-light border-0">
                            <option value="Dog">Dog 🐶</option>
                            <option value="Cat">Cat 🐱</option>
                        </select>
                    </div>
                    <div class="col-6">
                        <label class="form-label text-muted fw-bold" style="font-size: 13px;">GENDER</label>
                        <select id="mutGender" class="form-select bg-light border-0">
                            <option value="Male">Male</option>
                            <option value="Female">Female</option>
                        </select>
                    </div>
                    <div class="col-12">
                        <label class="form-label text-muted fw-bold" style="font-size: 13px;">PET NAME</label>
                        <input type="text" id="mutPetName" class="form-control bg-light border-0" placeholder="e.g. Fluffy, Bobo...">
                    </div>
                    <div class="col-12">
                        <label class="form-label text-muted fw-bold" style="font-size: 13px;">BREED</label>
                        <input type="text" id="mutBreed" class="form-control bg-light border-0" placeholder="e.g. Poodle, British Shorthair...">
                    </div>
                    <div class="col-6">
                        <label class="form-label text-muted fw-bold" style="font-size: 13px;">BIRTHDAY</label>
                        <input type="date" id="mutDob" class="form-control bg-light border-0">
                    </div>
                    <div class="col-6">
                        <label class="form-label text-muted fw-bold" style="font-size: 13px;">WEIGHT (kg)</label>
                        <input type="number" step="0.1" id="mutWeight" class="form-control bg-light border-0" placeholder="e.g. 5.5">
                    </div>
                    <div class="col-12">
                        <label class="form-label text-muted fw-bold" style="font-size: 13px;">MEDICAL NOTES (Optional)</label>
                        <textarea id="mutNote" class="form-control bg-light border-0" rows="2" placeholder="Allergies, habits..."></textarea>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-success rounded-pill px-4" onclick="savePet()">Save Pet 🐾</button>
            </div>
        </div>
    </div>
</div>

<script>
    // Shared helper to populate modal inputs for pet mutate forms
    function populatePetModal(data, prefix) {
        // prefix: 'mut' for customer modal, 'vMut' for vet/admin modal
        const v = (obj, camel, pascal) => (obj && obj[camel] !== undefined ? obj[camel] : (obj && pascal && obj[pascal] !== undefined ? obj[pascal] : undefined));
        const set = (id, value) => { const el = document.getElementById(id); if (el) el.value = value ?? ''; };

        set(prefix + 'PetName', v(data, 'petName', 'PetName') || '');
        set(prefix + 'Species', v(data, 'species', 'Species') || (prefix === 'mut' ? 'Dog' : 'Dog'));
        set(prefix + 'Breed', v(data, 'breed', 'Breed') || '');
        set(prefix + 'Gender', v(data, 'gender', 'Gender') || 'Male');

        const dobVal = v(data, 'dateOfBirth', 'DateOfBirth');
        if (dobVal) {
            const dt = new Date(dobVal);
            if (!isNaN(dt)) {
                const month = (dt.getMonth() + 1).toString().padStart(2, '0');
                const day = dt.getDate().toString().padStart(2, '0');
                set(prefix + 'Dob', dt.getFullYear() + '-' + month + '-' + day);
            } else {
                set(prefix + 'Dob', '');
            }
        } else {
            set(prefix + 'Dob', '');
        }

        set(prefix + 'Weight', (v(data, 'weight', 'Weight') ?? ''));
        set(prefix + 'Note', (v(data, 'note', 'Note') ?? ''));
        // File inputs cannot be set programmatically for security reasons; leave cleared
    }

    document.addEventListener("click", function (e) {
        var btnView = e.target.closest(".btn-view-pet");
        if (btnView) {
            var petId = btnView.getAttribute("data-id");
            var modalBody = document.getElementById("petModalBody");
            var modal = new bootstrap.Modal(document.getElementById('petDetailModal'));
            modalBody.innerHTML = "<div class='text-center py-5'><div class='spinner-border text-success'></div></div>";
            modal.show();
            fetch('/Pets/Details/' + petId)
                .then(r => r.text())
                .then(html => modalBody.innerHTML = html);
        }
    });

    function deletePet(id) {
        if (confirm("Are you sure you want to remove this pet?")) {
            fetch('/Pets/Delete/' + id, { method: 'POST' })
            .then(r => r.json())
            .then(d => {
                if (d.success) location.reload();
                else alert("Failed to delete.");
            });
        }
    }

    var mutateModal;
    function openMutateModal(id) {
        if (!mutateModal) mutateModal = new bootstrap.Modal(document.getElementById('mutatePetModal'));
        document.getElementById('mutPetId').value = id || '';
        document.getElementById('mutateModalTitle').innerText = id ? 'Edit Pet Profile' : 'Add New Pet';

        // Reset file input
        document.getElementById('mutImage').value = '';

        if (!id) {
            document.getElementById('mutSpecies').value = 'Dog';
            document.getElementById('mutGender').value = 'Male';
            document.getElementById('mutPetName').value = '';
            document.getElementById('mutBreed').value = '';
            document.getElementById('mutDob').value = '';
            document.getElementById('mutWeight').value = '';
            document.getElementById('mutNote').value = '';
        }
        // If editing, fetch existing pet data and prefill inputs
        if (id) {
            fetch('/Pets/GetJson/' + id)
                .then(r => {
                    if (!r.ok) throw new Error('Failed to load pet');
                    return r.json();
                })
                .then(data => {
                    populatePetModal(data, 'mut');
                })
                .catch(err => console.log('[openMutateModal] fetch pet error', err))
                .finally(() => mutateModal.show());
        } else {
            mutateModal.show();
        }
    }

    function savePet() {
        var id = document.getElementById('mutPetId').value;
        var petName = document.getElementById('mutPetName').value;
        if(!petName) return alert("Pet name is required!");
        if(!document.getElementById('mutBreed').value) return alert("Breed is required!");

        // Dùng FormData thay vì JSON
        var formData = new FormData();
        formData.append('Species', document.getElementById('mutSpecies').value);
        formData.append('Gender', document.getElementById('mutGender').value);
        formData.append('Breed', document.getElementById('mutBreed').value);
        formData.append('PetName', petName);

        var dob = document.getElementById('mutDob').value;
        if(dob) formData.append('DateOfBirth', dob);

        var weight = document.getElementById('mutWeight').value;
        if(weight) formData.append('Weight', weight);

        var note = document.getElementById('mutNote').value;
        if(note) formData.append('Note', note);

        // Nạp file ảnh nếu có
        var fileInput = document.getElementById('mutImage');
        if (fileInput.files.length > 0) {
            formData.append('ImageFile', fileInput.files[0]);
        }

        var url = id ? '/Pets/Update/' + id : '/Pets/Add';

        fetch(url, {
            method: 'POST',
            body: formData // Không set header Content-Type, trình duyệt tự xử lý boundary
        })
        .then(r => r.json())
        .then(d => {
            if (d.success) location.reload();
            else alert("Failed to save.");
        });
    }
</script>