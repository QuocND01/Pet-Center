@using PetCenterClient.DTOs
@model ReadPetDetailViewModel

<div class="position-relative">
    <div style="height: 180px; background: linear-gradient(135deg, #dcfce7, #86efac); display:flex; align-items:center; justify-content:center;">
        @if (!string.IsNullOrEmpty(Model.PetAvatar))
        {
            <img src="@Model.PetAvatar" style="width: 100%; height: 100%; object-fit: cover;" />
        }
        else
        {
            <span style="font-size: 80px;">@(Model.Species.ToLower() == "cat" ? "🐈" : "🐕")</span>
        }
    </div>

    <button type="button" class="btn-close position-absolute top-0 end-0 m-3 bg-white" data-bs-dismiss="modal" style="border-radius: 50%; opacity: 0.8;"></button>

    <div class="p-4 bg-white">
        <h3 class="fw-bold mb-1">@Model.Breed</h3>
        <p class="text-muted fw-semibold mb-3">@Model.Species • @Model.Gender</p>

        <div class="row g-3 mb-4">
            <div class="col-6">
                <div class="p-3 rounded-3" style="background: #f8fafc; border: 1px solid #e2e8f0;">
                    <small class="text-muted d-block fw-bold mb-1">BIRTHDAY</small>
                    <span class="fw-semibold">@(Model.DateOfBirth?.ToString("MMM dd, yyyy") ?? "N/A")</span>
                    <small class="d-block text-success fw-bold">@Model.Age</small>
                </div>
            </div>
            <div class="col-6">
                <div class="p-3 rounded-3" style="background: #f8fafc; border: 1px solid #e2e8f0;">
                    <small class="text-muted d-block fw-bold mb-1">WEIGHT</small>
                    <span class="fw-semibold fs-5">@(Model.Weight?.ToString("0.0") ?? "--") <small class="text-muted fs-6">kg</small></span>
                </div>
            </div>
        </div>

        <div>
            <small class="text-muted fw-bold d-block mb-1">SPECIAL NOTES</small>
            <p class="mb-0" style="color: #334155; line-height: 1.6;">
                @(string.IsNullOrEmpty(Model.Note) ? "No special notes recorded." : Model.Note)
            </p>
        </div>
    </div>
</div>