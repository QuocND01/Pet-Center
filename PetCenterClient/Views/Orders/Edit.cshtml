@model PetCenterClient.DTOs.OrderRequestDTO

<div class="container mt-4">
    <h4>🛠️ Cập nhật đơn hàng</h4>
    <hr />
    <div class="row">
        <div class="col-md-6">
            <form asp-action="Edit">
                <input type="hidden" name="id" value="@ViewContext.RouteData.Values["id"]" />

                <div class="mb-3">
                    <label class="form-label">Địa chỉ nhận hàng</label>
                    <select asp-for="AddressId" class="form-select" asp-items="ViewBag.AddressList"></select>
                </div>

                <div class="mb-3">
                    <label class="form-label">Trạng thái đơn hàng</label>
                    <select asp-for="Status" class="form-select">
                        <option value="1">Chờ xử lý</option>
                        <option value="2">Đang giao</option>
                        <option value="3">Hoàn thành</option>
                        <option value="0">Đã hủy</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label">Tổng số tiền</label>
                    <input asp-for="TotalAmount" class="form-control" />
                </div>

                <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
                <a asp-action="Index" class="btn btn-secondary">Hủy</a>
            </form>
        </div>
    </div>
</div>