@model PetCenterClient.DTOs.OrderResponseDTO
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

@{
    ViewData["Title"] = "Cancel Order";

    // AUTO SWITCH LAYOUT (Đồng bộ với các trang khác)
    var role = HttpContextAccessor.HttpContext?.Session.GetString("Role");
    var isStaffOrAdmin = (role == "Staff" || role == "Admin");
    Layout = isStaffOrAdmin ? "~/Views/Shared/_AdminLayout.cshtml" : "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="alert alert-danger shadow-sm">
        <h4>⚠️ Confirm Order Cancellation</h4>
        @* Using string.Format for safe handling of DateTime and DateTime? *@
        <p>Are you sure you want to cancel the order placed on <strong>@string.Format("{0:dd/MM/yyyy}", Model.OrderDate)</strong> with a total amount of <strong>@Model.TotalAmount.ToString("N0") VND</strong>?</p>
    </div>

    <form asp-action="Delete" method="post">
        @Html.AntiForgeryToken()
        @* EXTREMELY IMPORTANT: Name must be "id" to match the Controller parameter *@
        <input type="hidden" name="id" value="@Model.OrderId" />

        <button type="submit" class="btn btn-danger px-4">Confirm Cancellation</button>
        <a asp-action="Index" class="btn btn-secondary px-4">Back</a>
    </form>
</div>