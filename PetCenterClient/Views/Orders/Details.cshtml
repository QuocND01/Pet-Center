@model OrderResponseDTO
@using PetCenterClient.DTOs
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

@{
    ViewData["Title"] = "Order Details";
    var details = ViewBag.OrderDetails as List<OrderDetailVM> ?? new List<OrderDetailVM>();

    // Đã sửa lại dùng Session để đồng bộ với toàn hệ thống
    var role = HttpContextAccessor.HttpContext?.Session.GetString("Role");
    var isStaffOrAdmin = (role == "Staff" || role == "Admin");

    // AUTO SWITCH LAYOUT
    Layout = isStaffOrAdmin ? "~/Views/Shared/_AdminLayout.cshtml" : "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Orders</a></li>
            <li class="breadcrumb-item active">Details #@Model.OrderId.ToString().Substring(0, 8)</li>
        </ol>
    </nav>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center py-3">
            <h5 class="mb-0"><i class="fas fa-box-open me-2"></i>Order ID: @Model.OrderId</h5>
            <span class="badge bg-light text-primary fs-6">Status: @Model.Status</span>
        </div>

        <div class="card-body">
            <div class="row mb-4">
                <div class="col-md-6">
                    <h6 class="text-muted text-uppercase fw-bold border-bottom pb-2">Shipping Information</h6>
                    <p class="mb-1"><strong>Order Date:</strong> @string.Format("{0:dd/MM/yyyy HH:mm}", Model.OrderDate)</p>
                    <p class="mb-1"><strong>Address:</strong> @(Model.AddressSnapshot ?? "Not updated")</p>
                    <p class="mb-1"><strong>Delivered At:</strong> @(Model.DeliveredDate?.ToString("dd/MM/yyyy") ?? "Pending...")</p>
                </div>
                <div class="col-md-6 text-md-end">
                    <h6 class="text-muted text-uppercase fw-bold border-bottom pb-2">Payment</h6>
                    <p class="fs-4 fw-bold text-danger">Total: @Model.TotalAmount.ToString("N0") VND</p>
                    @if (Model.DiscountAmount > 0)
                    {
                        <small class="text-muted">Discount: -@Model.DiscountAmount?.ToString("N0") VND</small>
                    }
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 80px;">Image</th>
                            <th>Product</th>
                            <th class="text-center">Price</th>
                            <th class="text-center">Qty</th>
                            <th class="text-end">Subtotal</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in details)
                        {
                            <tr>
                                <td>
                                    <img src="@item.ImageUrl" class="rounded border shadow-sm"
                                         style="width: 60px; height: 60px; object-fit: cover;"
                                         onerror="this.src='/no-image.png'" />
                                </td>
                                <td><strong>@item.ProductName</strong><br /><small class="text-muted">ID: @item.ProductId</small></td>
                                <td class="text-center">@item.UnitPrice.ToString("N0")</td>
                                <td class="text-center">x @item.Quantity</td>
                                <td class="text-end fw-bold">@item.SubTotal.ToString("N0") VND</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card-footer bg-white py-3 d-flex justify-content-between">
            <a asp-action="Index" class="btn btn-outline-secondary px-4">
                <i class="fas fa-chevron-left me-1"></i>Back
            </a>
            <div class="d-flex gap-2">
                <button type="button" class="btn btn-info text-white px-4" onclick="window.print()">
                    <i class="fas fa-print me-1"></i>Print Invoice
                </button>

                @if (isStaffOrAdmin)
                {
                    <a asp-action="Edit" asp-route-id="@Model.OrderId" class="btn btn-warning">Update</a>
                }

                @if (Model.Status == 1)
                {
                    <a asp-action="Delete" asp-route-id="@Model.OrderId" class="btn btn-danger">Cancel Order</a>
                }
            </div>
        </div>
    </div>
</div>

<style>
    @@media print {
        .btn, nav, .breadcrumb, form {
            display: none !important;
        }

        .card {
            border: none !important;
            box-shadow: none !important;
        }

        .card-header {
            background-color: white !important;
            color: black !important;
            border-bottom: 2px solid #000 !important;
        }
    }
</style>