@model IEnumerable<PetCenterClient.DTOs.OrderResponseDTO>
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

@{
    ViewData["Title"] = "Order List";
    var role = HttpContextAccessor.HttpContext?.Session.GetString("Role");
    var isStaffOrAdmin = (role == "Staff" || role == "Admin");

    // AUTO SWITCH LAYOUT
    Layout = isStaffOrAdmin ? "~/Views/Shared/_AdminLayout.cshtml" : "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>📦 Order Management</h2>
        @if (role == "Customer")
        {
            <a asp-action="Create" class="btn btn-primary">➕ Place New Order</a>
        }
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm mb-4 border-0">
        <div class="card-body bg-light rounded">
            <form asp-action="Index" method="get" class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label fw-bold text-muted small">Search Order ID</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="fas fa-search text-muted"></i></span>
                        <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Enter order ID..." />
                    </div>
                </div>

                <div class="col-md-3">
                    <label class="form-label fw-bold text-muted small">Status</label>
                    <select name="status" class="form-select">
                        <option value="">-- All Statuses --</option>
                        <option value="1" selected="@(ViewBag.Status == 1 ? "selected" : null)">Pending</option>
                        <option value="2" selected="@(ViewBag.Status == 2 ? "selected" : null)">Approved</option>
                        <option value="3" selected="@(ViewBag.Status == 3 ? "selected" : null)">Delivering</option>
                        <option value="4" selected="@(ViewBag.Status == 4 ? "selected" : null)">Completed</option>
                        <option value="0" selected="@(ViewBag.Status == 0 ? "selected" : null)">Canceled</option>
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label fw-bold text-muted small">From Date</label>
                    <input type="date" name="fromDate" value="@ViewBag.FromDate" class="form-control" />
                </div>

                <div class="col-md-2">
                    <label class="form-label fw-bold text-muted small">To Date</label>
                    <input type="date" name="toDate" value="@ViewBag.ToDate" class="form-control" />
                </div>

                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100 mb-2">Filter</button>
                    <a asp-action="Index" class="btn btn-outline-secondary w-100">Clear</a>
                </div>
            </form>
        </div>
    </div>

    <div class="table-responsive shadow-sm">
        <table class="table table-hover border">
            <thead class="table-dark text-center">
                <tr>
                    <th class="text-start">Order Date</th>
                    <th>Total Amount</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="4" class="text-center py-4 text-muted">No matching orders found.</td>
                    </tr>
                }
                @foreach (var item in Model)
                {
                    <tr class="align-middle text-center">
                        <td class="text-start">@string.Format("{0:dd/MM/yyyy HH:mm}", item.OrderDate)</td>
                        <td class="text-success fw-bold">@item.TotalAmount.ToString("N0") VND</td>
                        <td>
                            @switch (item.Status)
                            {
                                case 1:
                                    <span class="badge bg-warning text-dark">Pending</span>
                                    break;
                                case 2:
                                    <span class="badge bg-info text-white">Approved</span>
                                    break;
                                case 3:
                                    <span class="badge bg-primary">Delivering</span>
                                    break;
                                case 4:
                                    <span class="badge bg-success">Completed</span>
                                    break;
                                case 0:
                                    <span class="badge bg-danger">Canceled</span>
                                    break;
                                default:
                                    <span class="badge bg-secondary">Unknown</span>
                                    break;
                            }
                        </td>
                        <td>
                            <div class="btn-group">
                                <a asp-action="Details" asp-route-id="@item.OrderId" class="btn btn-sm btn-info text-white">Details</a>

                                @if (isStaffOrAdmin)
                                {
                                    <a asp-action="Edit" asp-route-id="@item.OrderId" class="btn btn-sm btn-warning">Edit</a>
                                }

                                @if (item.Status == 1)
                                {
                                    <a asp-action="Delete" asp-route-id="@item.OrderId" class="btn btn-sm btn-danger ms-1">Cancel</a>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>