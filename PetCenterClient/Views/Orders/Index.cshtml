@model IEnumerable<PetCenterClient.DTOs.OrderResponseDTO>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>📦 Quản lý Đơn hàng</h2>
        <a asp-action="Create" class="btn btn-primary">➕ Đặt hàng mới</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <table class="table table-striped border">
        <thead class="table-dark">
            <tr>
                <th>Ngày đặt</th>
                <th>Tổng tiền</th>
                <th>Trạng thái</th>
                <th class="text-center">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.OrderDate?.ToString("dd/MM/yyyy HH:mm")</td>
                    <td class="text-success fw-bold">@item.TotalAmount.ToString("N0") VNĐ</td>
                    <td>
                        <span class="badge @(item.Status == 1 ? "bg-warning" : "bg-success")">
                            @(item.Status == 1 ? "Chờ xử lý" : "Đã xử lý")
                        </span>
                    </td>
                    <td class="text-center">
                        <a asp-action="Details" asp-route-id="@item.OrderId" class="btn btn-sm btn-info">Chi tiết</a>
                        <a asp-action="Edit" asp-route-id="@item.OrderId" class="btn btn-sm btn-warning">Sửa</a>
                        <a asp-action="Delete" asp-route-id="@item.OrderId" class="btn btn-sm btn-danger">Hủy</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>