@model IEnumerable<PetCenterClient.DTOs.OrderResponseDTO>
@using System.Security.Claims

@{
    ViewData["Title"] = "Danh sách đơn hàng";
    // Kiểm tra Role Staff để ẩn/hiện nút Sửa
    var isStaff = User.IsInRole("Staff");
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>📦 Quản lý Đơn hàng</h2>
        @if (!isStaff)
        {
            <a asp-action="Create" class="btn btn-primary">➕ Đặt hàng mới</a>
        }
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="table-responsive shadow-sm">
        <table class="table table-hover border">
            <thead class="table-dark text-center">
                <tr>
                    <th class="text-start">Ngày đặt</th>
                    <th>Tổng tiền</th>
                    <th>Trạng thái</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr class="align-middle">
                        <td>@string.Format("{0:dd/MM/yyyy HH:mm}", item.OrderDate)</td>
                        <td class="text-success fw-bold text-center">@item.TotalAmount.ToString("N0") VNĐ</td>
                        <td class="text-center">
                            <span class="badge @(item.Status == 1 ? "bg-warning" : "bg-success")">
                                @(item.Status == 1 ? "Chờ xử lý" : "Đã xử lý")
                            </span>
                        </td>
                        <td class="text-center">
                            <div class="btn-group">
                                <a asp-action="Details" asp-route-id="@item.OrderId" class="btn btn-sm btn-info text-white">Chi tiết</a>

                                @if (isStaff)
                                {
                                    <a asp-action="Edit" asp-route-id="@item.OrderId" class="btn btn-sm btn-warning">Sửa</a>
                                }

                                @if (item.Status == 1)
                                {
                                    @* Dẫn sang trang xác nhận Delete.cshtml *@
                                    <a asp-action="Delete" asp-route-id="@item.OrderId" class="btn btn-sm btn-danger ms-1">Hủy</a>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>